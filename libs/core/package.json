{
  "name": "@agent/core",
  "version": "1.0.0",
  "private": true,
  "description": "Core utilities and wrappers for Gemini Skills.",
  "main": "skill-wrapper.cjs",
  "types": "skill-wrapper.d.cts",
  "exports": {
    ".": {
      "types": "./skill-wrapper.d.cts",
      "default": "./skill-wrapper.cjs"
    },
    "./validators": {
      "types": "./validators.d.cts",
      "default": "./validators.cjs"
    },
    "./fs-utils": {
      "types": "./fs-utils.d.ts",
      "default": "./fs-utils.cjs"
    },
    "./cli-utils": {
      "types": "./cli-utils.d.ts",
      "default": "./cli-utils.cjs"
    },
    "./secure-io": {
      "types": "./secure-io.d.ts",
      "default": "./secure-io.cjs"
    },
    "./classifier": {
      "types": "./classifier.d.ts",
      "default": "./classifier.cjs"
    },
    "./path-resolver": {
      "types": "./path-resolver.d.ts",
      "default": "./path-resolver.cjs"
    },
    "./tier-guard": {
      "types": "./tier-guard.d.ts",
      "default": "./tier-guard.cjs"
    },
    "./network": {
      "types": "./network.d.ts",
      "default": "./network.cjs"
    },
    "./core": {
      "types": "./core.d.ts",
      "default": "./core.cjs"
    },
    "./logger": "./logger.cjs",
    "./metrics": "./metrics.cjs",
    "./error-codes": "./error-codes.cjs",
    "./validate": "./validate.cjs",
    "./orchestrator": "./orchestrator.cjs",
    "./ledger": "./ledger.cjs",
    "./secret-guard": "./secret-guard.cjs",
    "./test-utils": "./test-utils.cjs",
    "./pulse-guard": "./pulse-guard.cjs",
    "./finance": "./finance.cjs",
    "./excel-utils": {
      "types": "./excel-utils.d.ts",
      "default": "./excel-utils.cjs"
    },
    "./pptx-utils": {
      "types": "./pptx-utils.d.ts",
      "default": "./pptx-utils.cjs"
    },
    "./shared-business-types": {
      "types": "./shared-business-types.ts",
      "default": "./shared-business-types.ts"
    }
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "yargs": "^18.0.0",
    "axios": "^1.13.4",
    "js-yaml": "^4.1.1",
    "marked": "^12.0.0",
    "jsdom": "^24.0.0",
    "adm-zip": "^0.5.12",
    "pptxgenjs": "^4.0.1",
    "exceljs": "^4.4.0"
  }
}
