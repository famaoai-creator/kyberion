{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Calendar Action ADF",
  "type": "object",
  "required": ["op"],
  "properties": {
    "op": { "enum": ["list_calendars", "list_events", "create_event"] },
    "params": {
      "type": "object",
      "properties": {
        "calendar_names": { "type": "array", "items": { "type": "string" }, "description": "Optional list of calendar names to target" },
        "start_date": { "type": "string", "format": "date-time" },
        "end_date": { "type": "string", "format": "date-time" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}
