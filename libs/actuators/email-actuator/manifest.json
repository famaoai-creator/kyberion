{
  "actuator_id": "email-actuator",
  "version": "1.1.0",
  "description": "Adapter-based email composition and sending with selectable macOS Mail.app (JXA) and SMTP backends",
  "contract_schema": "libs/actuators/email-actuator/schemas/email-action.schema.json",
  "resilience_tier": "adaptive_retry",
  "recovery_policy": {
    "fallback_strategy": "draft_only",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 1000,
      "maxDelayMs": 8000,
      "factor": 2,
      "jitter": true
    },
    "retryable_categories": ["network", "timeout", "resource_unavailable"]
  },
  "capabilities": [
    {
      "op": "create_draft",
      "description": "Creates an email draft through the selected backend (Mail.app supports drafts)",
      "platforms": ["darwin"]
    },
    {
      "op": "send",
      "description": "Composes and sends email through the selected or automatically resolved backend",
      "platforms": ["darwin", "linux"]
    },
    {
      "op": "send_from_file",
      "description": "Reads email body from a markdown/text file and sends it through the selected backend",
      "platforms": ["darwin", "linux"]
    }
  ],
  "env_vars": {
    "KYBERION_EMAIL_FROM": "Sender address (e.g. 'ichimura@sbisecsol.com')",
    "KYBERION_SMTP_HOST": "SMTP host (activates SMTP mode, e.g. 'smtp.gmail.com')",
    "KYBERION_SMTP_PORT": "SMTP port (default 587)",
    "KYBERION_SMTP_USER": "SMTP username",
    "KYBERION_SMTP_PASS": "SMTP password or app token"
  }
}
