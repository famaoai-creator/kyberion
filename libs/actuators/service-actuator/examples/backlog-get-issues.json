{
  "_comment": "Backlog課題一覧取得 — service:preset を使う最小パターン。curlの代替として使用できる。",
  "_setup": "事前に `secret:set` で backlog_api_key をOSキーチェーンに登録すること。一度登録すれば以降不要。",
  "pipeline": [
    {
      "id": "register_secret",
      "_note": "初回のみ実行。以降はこのステップを削除してよい。",
      "op": "secret:set",
      "params": {
        "key": "backlog_api_key",
        "value": "YOUR_API_KEY_HERE"
      }
    },
    {
      "id": "fetch_issues",
      "op": "service:preset",
      "params": {
        "service": "backlog",
        "operation": "get_issues",
        "vars": {
          "space": "YOUR_SPACE_NAME"
        },
        "query": {
          "projectId[]": [12345],
          "statusId[]": [1, 2],
          "count": 50,
          "order": "desc"
        }
      },
      "output": "issues"
    },
    {
      "id": "log_result",
      "op": "system:log",
      "params": {
        "message": "取得件数: {{issues.length}}"
      }
    }
  ]
}
