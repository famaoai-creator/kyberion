{
  "actuator_id": "system-actuator",
  "version": "1.2.0",
  "description": "OS-level control, diagnostics, and short-lived local execution",
  "contract_schema": "schemas/system-pipeline.schema.json",
  "resilience_tier": "adaptive_retry",
  "recovery_policy": {
    "fallback_strategy": "os_action_retry",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 250,
      "maxDelayMs": 2000,
      "factor": 2,
      "jitter": true
    },
    "retryable_categories": ["network", "timeout", "resource_unavailable"]
  },
  "capabilities": [
    { "op": "pipeline", "schema_ref": "schemas/system-pipeline.schema.json", "platforms": ["darwin", "linux", "win32"] },
    { "op": "reconcile", "platforms": ["darwin", "linux", "win32"] },
    { "op": "computer_interaction", "schema_ref": "schemas/computer-interaction.schema.json", "platforms": ["darwin", "linux", "win32"] }
  ]
}
