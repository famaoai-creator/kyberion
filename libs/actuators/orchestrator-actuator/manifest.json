{
  "actuator_id": "orchestrator-actuator",
  "version": "1.0.0",
  "description": "Mission/control-plane transformation and execution-plan orchestration actuator",
  "contract_schema": "schemas/orchestrator-pipeline.schema.json",
  "resilience_tier": "adaptive_retry",
  "recovery_policy": {
    "fallback_strategy": "pipeline_retry",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 500,
      "maxDelayMs": 10000,
      "factor": 2,
      "jitter": true
    },
    "retryable_categories": ["network", "timeout", "resource_unavailable"]
  },
  "capabilities": [
    { "op": "pipeline", "schema_ref": "schemas/orchestrator-pipeline.schema.json", "platforms": ["darwin", "linux", "win32"] },
    { "op": "reconcile", "platforms": ["darwin", "linux", "win32"] }
  ]
}
