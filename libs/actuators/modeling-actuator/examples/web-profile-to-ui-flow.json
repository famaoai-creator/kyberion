{
  "action": "pipeline",
  "context": {
    "context_path": "active/shared/tmp/modeling/web-profile-to-ui-flow.context.json"
  },
  "steps": [
    {
      "type": "capture",
      "op": "read_json",
      "params": {
        "path": "knowledge/product/orchestration/web-app-profiles/example-web-login-guarded.json",
        "export_as": "web_profile"
      }
    },
    {
      "type": "transform",
      "op": "web_profile_to_ui_flow_adf",
      "params": {
        "from": "web_profile",
        "export_as": "ui_flow_adf"
      }
    },
    {
      "type": "apply",
      "op": "write_file",
      "params": {
        "from": "ui_flow_adf",
        "path": "active/shared/tmp/modeling/example-web-ui-flow-adf.json"
      }
    },
    {
      "type": "transform",
      "op": "ui_flow_to_test_inventory",
      "params": {
        "from": "ui_flow_adf",
        "export_as": "test_case_inventory"
      }
    },
    {
      "type": "apply",
      "op": "write_file",
      "params": {
        "from": "test_case_inventory",
        "path": "active/shared/tmp/modeling/example-web-test-inventory.json"
      }
    }
  ]
}
