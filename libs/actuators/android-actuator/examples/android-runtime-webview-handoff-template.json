{
  "action": "pipeline",
  "context": {
    "context_path": "active/shared/tmp/android/android-runtime-webview-handoff-template.context.json"
  },
  "steps": [
    {
      "type": "capture",
      "op": "read_json",
      "params": {
        "path": "knowledge/product/orchestration/mobile-app-profiles/example-mobile-login-passkey.json",
        "export_as": "app_profile",
        "validate_as": "mobile-app-profile"
      }
    },
    {
      "type": "capture",
      "op": "adb_health_check",
      "params": {
        "export_as": "android_health"
      }
    },
    {
      "type": "capture",
      "op": "capture_foreground_activity",
      "params": {
        "export_as": "foreground_activity"
      }
    },
    {
      "type": "capture",
      "op": "capture_runtime_session_handoff",
      "params": {
        "app_profile_from": "app_profile",
        "path": "active/shared/tmp/android/android-runtime-webview-handoff.json",
        "export_as": "runtime_session_handoff"
      }
    }
  ]
}
