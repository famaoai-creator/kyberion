{
  "action": "pipeline",
  "options": {
    "timeout_ms": 15000
  },
  "context": {
    "context_path": "active/shared/tmp/android/android-login-passkey-flow-template.context.json"
  },
  "steps": [
    {
      "type": "capture",
      "op": "read_json",
      "params": {
        "path": "knowledge/product/orchestration/mobile-app-profiles/example-mobile-login-passkey.json",
        "export_as": "app_profile",
        "validate_as": "mobile-app-profile"
      }
    },
    {
      "type": "capture",
      "op": "adb_health_check",
      "params": {
        "export_as": "android_health"
      }
    },
    {
      "type": "apply",
      "op": "launch_app",
      "params": {
        "component": "{{app_profile.launch.component}}"
      }
    },
    {
      "type": "apply",
      "op": "wait_for_ui_node",
      "params": {
        "resource_id": "email",
        "class_name": "EditText",
        "timeout_ms": 10000,
        "interval_ms": 1000,
        "export_as": "waited_email_field"
      }
    },
    {
      "type": "apply",
      "op": "fill_login_form",
      "params": {
        "app_profile_from": "app_profile",
        "email": "operator@example.com",
        "password": "S3curePasskeyReady",
        "submit": true,
        "export_as": "login_form_plan"
      }
    },
    {
      "type": "apply",
      "op": "wait_for_ui_node",
      "params": {
        "resource_id": "passkey",
        "class_name": "Button",
        "clickable": true,
        "timeout_ms": 8000,
        "interval_ms": 1000,
        "export_as": "waited_passkey_node"
      }
    },
    {
      "type": "apply",
      "op": "authenticate_with_passkey",
      "params": {
        "app_profile_from": "app_profile",
        "export_as": "passkey_auth_plan"
      }
    },
    {
      "type": "apply",
      "op": "capture_screen",
      "params": {
        "path": "active/shared/tmp/android/android-login-passkey-flow-template.png"
      }
    }
  ]
}
