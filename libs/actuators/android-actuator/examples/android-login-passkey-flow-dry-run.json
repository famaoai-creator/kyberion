{
  "action": "pipeline",
  "context": {
    "context_path": "active/shared/tmp/android/android-login-passkey-flow-dry-run.context.json"
  },
  "steps": [
    {
      "type": "capture",
      "op": "read_json",
      "params": {
        "path": "knowledge/product/orchestration/mobile-app-profiles/example-mobile-login-passkey.json",
        "export_as": "app_profile",
        "validate_as": "mobile-app-profile"
      }
    },
    {
      "type": "capture",
      "op": "read_text_file",
      "params": {
        "path": "libs/actuators/android-actuator/examples/assets/mock-ui-tree.xml",
        "export_as": "last_ui_tree"
      }
    },
    {
      "type": "transform",
      "op": "summarize_ui_tree",
      "params": {
        "from": "last_ui_tree",
        "export_as": "login_screen_summary"
      }
    },
    {
      "type": "apply",
      "op": "fill_login_form",
      "params": {
        "from": "last_ui_tree",
        "app_profile_from": "app_profile",
        "email": "operator@example.com",
        "password": "S3curePasskeyReady",
        "dry_run": true,
        "export_as": "login_form_plan"
      }
    },
    {
      "type": "apply",
      "op": "authenticate_with_passkey",
      "params": {
        "from": "last_ui_tree",
        "app_profile_from": "app_profile",
        "dry_run": true,
        "export_as": "passkey_auth_plan"
      }
    }
  ]
}
