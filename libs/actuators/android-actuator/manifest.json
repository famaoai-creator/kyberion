{
  "actuator_id": "android-actuator",
  "version": "1.1.0",
  "description": "Android Device Actuator — ADB pipeline + Android CLI for AI agents (layout, screen capture/resolve, describe, docs search)",
  "contract_schema": "schemas/mobile-device-pipeline.schema.json",
  "resilience_tier": "adaptive_retry",
  "recovery_policy": {
    "fallback_strategy": "adb_retry",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 250,
      "maxDelayMs": 2000,
      "factor": 2,
      "jitter": true
    },
    "retryable_categories": ["resource_unavailable", "timeout", "network"]
  },
  "capabilities": [
    {
      "op": "pipeline",
      "schema_ref": "schemas/mobile-device-pipeline.schema.json",
      "platforms": ["darwin", "linux", "win32"],
      "prerequisites": {
        "binaries": ["adb"],
        "env": ["ANDROID_HOME"],
        "platforms": ["darwin", "linux", "win32"],
        "install": {
          "darwin": "Android Studio または cmdline-tools を導入し ANDROID_HOME を設定",
          "linux": "Android cmdline-tools を導入し ANDROID_HOME を設定"
        }
      }
    }
  ]
}
