{
  "actuator_id": "video-composition-actuator",
  "version": "1.0.0",
  "description": "Governed deterministic composed-video bundle preparation actuator",
  "resilience_tier": "adaptive_retry",
  "recovery_policy": {
    "fallback_strategy": "video_bundle_retry",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 250,
      "maxDelayMs": 2000,
      "factor": 2,
      "jitter": true
    },
    "retryable_categories": ["resource_unavailable", "timeout"]
  },
  "capabilities": [
    { "op": "prepare_video_composition", "platforms": ["darwin", "linux", "win32"] },
    { "op": "compile_narrated_video_brief", "platforms": ["darwin", "linux", "win32"] },
    { "op": "create_narrated_intro_movie", "platforms": ["darwin", "linux", "win32"] },
    { "op": "list_video_composition_templates", "platforms": ["darwin", "linux", "win32"] },
    { "op": "await_video_composition_job", "platforms": ["darwin", "linux", "win32"] },
    { "op": "pipeline", "platforms": ["darwin", "linux", "win32"] }
  ],
  "entrypoint": "src/index.ts"
}
