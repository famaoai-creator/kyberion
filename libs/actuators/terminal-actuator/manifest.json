{
  "actuator_id": "terminal-actuator",
  "version": "1.0.0",
  "description": "PTY-driven Terminal Actuator",
  "contract_schema": "schemas/terminal-action.schema.json",
  "resilience_tier": "adaptive_retry",
  "recovery_policy": {
    "fallback_strategy": "session_read_retry",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 250,
      "maxDelayMs": 2000,
      "factor": 2,
      "jitter": true
    },
    "retryable_categories": ["network", "timeout", "resource_unavailable"]
  },
  "capabilities": [
    { "op": "spawn", "platforms": ["darwin", "linux", "win32"] },
    { "op": "poll", "platforms": ["darwin", "linux", "win32"] },
    { "op": "write", "platforms": ["darwin", "linux", "win32"] },
    { "op": "kill", "platforms": ["darwin", "linux", "win32"] },
    { "op": "computer_interaction", "schema_ref": "schemas/computer-interaction.schema.json", "platforms": ["darwin", "linux", "win32"] }
  ]
}
