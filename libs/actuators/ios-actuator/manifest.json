{
  "actuator_id": "ios-actuator",
  "version": "1.1.0",
  "description": "simctl-driven iOS Simulator Actuator",
  "contract_schema": "schemas/mobile-device-pipeline.schema.json",
  "resilience_tier": "adaptive_retry",
  "recovery_policy": {
    "fallback_strategy": "simctl_retry",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 250,
      "maxDelayMs": 2000,
      "factor": 2,
      "jitter": true
    },
    "retryable_categories": ["resource_unavailable", "timeout", "network"]
  },
  "capabilities": [
    {
      "op": "pipeline",
      "schema_ref": "schemas/mobile-device-pipeline.schema.json",
      "platforms": ["darwin"],
      "prerequisites": {
        "binaries": ["xcrun", "xcodebuild"],
        "platforms": ["darwin"],
        "install": {
          "darwin": "Xcode を App Store から導入し、`sudo xcode-select -s /Applications/Xcode.app` を実行"
        }
      }
    }
  ]
}
