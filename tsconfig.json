{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@agent/core": ["libs/core/skill-wrapper.cjs"],
      "@agent/core/*": ["libs/core/*"]
    }
  },
  "include": ["skills/**/scripts/**/*.ts", "libs/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage", "test-results"]
}
