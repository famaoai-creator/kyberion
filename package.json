{
  "name": "kyberion",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Kyberion Ecosystem",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "libs/core",
    "libs/shared-*",
    "libs/actuators/*",
    "satellites/*"
  ],
  "scripts": {
    "test": "vitest run tests/smoke.test.ts",
    "test:unit": "vitest run libs/core/",
    "test:core": "vitest run libs/core/",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:plugins": "vitest run tests/plugins.test.ts",
    "test:all": "pnpm run build && vitest run",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "validate": "node dist/scripts/validate_skills.js && node dist/scripts/validate_schemas.js",
    "doctor": "node dist/scripts/doctor.js",
    "generate-index": "node dist/scripts/generate_skill_index.js && node dist/scripts/sync_docs.js",
    "cli": "node dist/scripts/cli.js",
    "mission:create": "npx tsx scripts/create_mission.ts",
    "mission:handoff": "npx tsx scripts/mission_controller.ts handoff",
    "vital": "npx tsx scripts/run_pipeline.ts --input pipelines/vital-check.json",
    "diagnose": "npx tsx scripts/run_pipeline.ts --input pipelines/system-diagnostics.json",
    "issue:ingest": "npx tsx scripts/ingest_issue.ts",
    "onboard": "npx tsx scripts/onboarding_wizard.ts",
    "mission:journal": "npx tsx scripts/mission_journal.ts",
    "dashboard": "npx tsx scripts/sovereign_dashboard.ts",
    "capabilities": "npx tsx scripts/capability_discovery.ts",
    "system:upgrade:check": "npx tsx scripts/run_pipeline.ts --input pipelines/system-upgrade-check.json",
    "system:upgrade:execute": "npx tsx scripts/run_pipeline.ts --input pipelines/system-upgrade-execute.json",
    "init": "npm run init-wizard",
    "init-wizard": "node dist/scripts/init_wizard.js",
    "vision:start": "npx tsx presence/sensors/visual-buffer-daemon.ts &",
    "vision:stop": "pkill -f visual-buffer-daemon",
    "bootstrap": "node dist/scripts/bootstrap.js",
    "benchmark": "node dist/scripts/benchmark.js",
    "plugin": "node dist/scripts/plugin-manager.js",
    "create-skill": "node dist/scripts/create_skill.js",
    "audit": "node dist/scripts/audit_skills.js",
    "pipeline": "node dist/scripts/pipeline-runner.js",
    "catalog": "node dist/scripts/generate_docs.js",
    "health": "node dist/scripts/check_skills_health.js",
    "sanitize": "node dist/scripts/skill-sanitizer.js",
    "build:all": "pnpm run sanitize && pnpm run typecheck",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "dev": "pnpm run typecheck && pnpm run lint && pnpm run test:unit",
    "ci": "pnpm run validate && pnpm run test:all && pnpm run typecheck",
    "archive": "node dist/scripts/archive_missions.js",
    "generate:types": "node dist/scripts/generate_types.js",
    "vault:mount": "node dist/scripts/vault_mount.js",
    "prepare": "husky",
    "mirror": "node tools/chronos-mirror/bridge.cjs & cd tools/chronos-mirror && pnpm run dev",
    "nerve:pulse": "node dist/scripts/pulse_aggregator.js",
    "nerve:start": "launchctl load -w ~/Library/LaunchAgents/kyberion.*.plist",
    "nerve:stop": "launchctl unload -w ~/Library/LaunchAgents/kyberion.*.plist",
    "nerve:status": "cat active/shared/runtime/pulse.json | jq ."
  },
  "lint-staged": {
    "knowledge/**/*.md": [
      "echo 'Syncing knowledge index...'"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "@types/express": "^5.0.6",
    "@types/html-to-docx": "^1.8.0",
    "@types/marked": "^6.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.16",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.13.6",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "gif-encoder-2": "^1.0.5",
    "googleapis": "^144.0.0",
    "html-to-docx": "^1.8.0",
    "jimp": "^0.22.12",
    "js-yaml": "^4.1.1",
    "jschardet": "^3.1.4",
    "jszip": "^3.10.1",
    "languagedetect": "^2.0.0",
    "mammoth": "^1.11.0",
    "marked": "^12.0.2",
    "node-pty": "^1.1.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.38.0",
    "sqlite3": "^5.1.7",
    "tesseract.js": "^7.0.0",
    "ws": "^8.19.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.2.1",
    "@types/yargs": "^17.0.35",
    "c8": "^10.1.3",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "8.0.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "marked": "^12.0.0",
      "xmldom": "npm:@xmldom/xmldom@^0.8.10",
      "trim-newlines": "^3.0.1",
      "jszip": "^3.10.1",
      "tar": "^7.5.8",
      "esbuild": "^0.25.0",
      "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz",
      "nth-check": "^2.0.1"
    },
    "ignoredBuiltDependencies": [],
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty",
      "puppeteer",
      "sqlite3",
      "tesseract.js"
    ]
  },
  "overrides": {
    "form-data": "^4.0.0"
  }
}
