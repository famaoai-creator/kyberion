{
  "name": "gemini-skills",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Gemini skills",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "index.js",
  "workspaces": [
    "skills/**/*",
    "libs/core"
  ],
  "scripts": {
    "test": "node tests/smoke.test.cjs",
    "test:unit": "node tests/unit.test.cjs",
    "test:core": "node dist/scripts/bootstrap.js && node tests/unit/core-lib.test.cjs",
    "test:secure-io": "node dist/scripts/bootstrap.js && node tests/unit/secure-io.test.cjs",
    "test:metrics": "node dist/scripts/bootstrap.js && node tests/unit/metrics.test.cjs",
    "test:integration": "node tests/integration.test.cjs",
    "test:coverage": "c8 node tests/unit.test.cjs",
    "test:plugins": "node tests/plugins.test.cjs",
    "test:ts": "vitest run",
    "test:all": "pnpm run test:unit && pnpm run test:core && pnpm run test:secure-io && pnpm run test:metrics && pnpm run test:integration && pnpm run test:plugins && pnpm run test:ts && pnpm test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "validate": "node dist/scripts/validate_skills.js && node dist/scripts/validate_schemas.js",
    "doctor": "node dist/scripts/doctor.js",
    "generate-index": "node dist/scripts/generate_skill_index.js && node dist/scripts/sync_docs.js",
    "cli": "node dist/scripts/cli.js",
    "init-wizard": "node dist/scripts/init_wizard.js",
    "bootstrap": "node dist/scripts/bootstrap.js",
    "benchmark": "node dist/scripts/benchmark.js",
    "plugin": "node dist/scripts/plugin-manager.js",
    "create-skill": "node dist/scripts/create_skill.js",
    "audit": "node dist/scripts/audit_skills.js",
    "pipeline": "node dist/scripts/pipeline-runner.js",
    "catalog": "node dist/scripts/generate_docs.js",
    "health": "node dist/scripts/check_skills_health.js",
    "sanitize": "node dist/scripts/skill-sanitizer.js",
    "build:all": "pnpm run sanitize && pnpm run typecheck",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "dev": "pnpm run typecheck && pnpm run lint && pnpm run test:unit",
    "ci": "pnpm run validate && pnpm run test:all && pnpm run typecheck",
    "archive": "node dist/scripts/archive_missions.js",
    "generate:types": "node dist/scripts/generate_types.js",
    "vault:mount": "node dist/scripts/vault_mount.js",
    "prepare": "husky",
    "mirror": "node tools/chronos-mirror/bridge.cjs & cd tools/chronos-mirror && pnpm run dev"
  },
  "lint-staged": {
    "knowledge/**/*.md": [
      "node dist/scripts/generate_knowledge_index.js"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "axios": "^1.13.6",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "exceljs": "^4.4.0",
    "googleapis": "^144.0.0",
    "js-yaml": "^4.1.1",
    "pptxgenjs": "^4.0.1",
    "sqlite3": "^5.1.7",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.1",
    "@types/yargs": "^17.0.35",
    "c8": "^10.1.3",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.1"
  },
  "pnpm": {
    "overrides": {
      "marked": "^12.0.0",
      "xmldom": "npm:@xmldom/xmldom@^0.8.10",
      "trim-newlines": "^3.0.1",
      "jszip": "^3.10.1",
      "tar": "^7.5.8",
      "esbuild": "^0.25.0",
      "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz",
      "nth-check": "^2.0.1"
    }
  },
  "overrides": {
    "form-data": "^4.0.0"
  }
}
