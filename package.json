{
  "name": "kyberion",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for Kyberion Ecosystem",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "libs/core",
    "libs/shared-*",
    "libs/actuators/*",
    "satellites/*",
    "presence/displays/*",
    "presence/bridge/*"
  ],
  "scripts": {
    "test": "vitest run tests/smoke.test.ts",
    "test:unit": "vitest run libs/core/ libs/actuators/",
    "test:core": "vitest run libs/core/",
    "test:integration": "vitest run tests/smoke.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm run build && vitest run",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm run build:packages && pnpm run build:actuators && pnpm run build:repo && pnpm run build:ui",
    "build:packages": "pnpm --filter '@agent/core' --filter '@agent/shared-*' build",
    "build:actuators": "tsc -p tsconfig.actuators.json",
    "build:repo": "tsc",
    "build:ui": "pnpm --dir presence/displays/chronos-mirror-v2 build",
    "check:esm": "node dist/scripts/check_esm_integrity.js",
    "check:catalogs": "node dist/scripts/check_catalog_integrity.js",
    "check:governance-rules": "node dist/scripts/check_governance_rules.js",
    "sync:intent-contract-memory": "node dist/scripts/sync_intent_contract_memory.js",
    "sync:component-inventory": "node dist/scripts/sync_component_inventory.js",
    "knowledge:rank": "node dist/scripts/context_ranker.js",
    "knowledge:sync": "node dist/scripts/run_pipeline.js --input pipelines/knowledge-sync.json",
    "orchestration:jobs": "node dist/scripts/run_pipeline.js --input pipelines/orchestration-jobs.json",
    "analysis:job": "node dist/scripts/run_pipeline.js --input pipelines/analysis-job.json",
    "judgment:job": "node dist/scripts/run_pipeline.js --input pipelines/judgment-job.json",
    "check:intent-domain-coverage": "node dist/scripts/check_intent_domain_coverage.js",
    "check:contract-schemas": "node dist/scripts/check_contract_schemas.js",
    "check:contract-semver": "node dist/scripts/check_contract_semver.js",
    "check:pr-title": "pnpm tsx scripts/check_pr_title.ts",
    "check:commit-subject": "pnpm tsx scripts/check_commit_subject.ts",
    "check:pipeline-shell-independence": "node dist/scripts/check_pipeline_shell_independence.js",
    "license:audit": "node dist/scripts/license_audit.js",
    "check:golden": "node dist/scripts/check_golden_output.js",
    "voice:upgrade": "node dist/scripts/voice_upgrade.js",
    "voice:upgrade-cloud": "KYBERION_VOICE_UPGRADE_ALIAS=cloud node dist/scripts/voice_upgrade.js",
    "voice:upgrade-local": "KYBERION_VOICE_UPGRADE_ALIAS=local node dist/scripts/voice_upgrade.js",
    "check:doc-examples": "node dist/scripts/check_doc_examples.js",
    "check:first-win-smoke": "node dist/scripts/check_first_win_smoke.js",
    "find:dead-code": "node dist/scripts/find_dead_code.js",
    "dev:watch": "pnpm vitest watch libs/core/",
    "check:tier-hygiene": "node dist/scripts/check_tier_hygiene.js",
    "smoke:intent": "node dist/scripts/intent_smoke.js",
    "watch:tenant-drift": "node dist/scripts/watch_tenant_drift.js",
    "export:validation-bundle": "node dist/scripts/export_validation_bundle.js",
    "meeting:run": "node dist/scripts/meeting_orchestrator.js",
    "meeting:participate": "node dist/scripts/meeting_participate.js",
    "env:bootstrap": "node dist/scripts/bootstrap_environment.js",
    "meeting:consent": "node dist/scripts/voice_consent.js",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run build && pnpm run typecheck && pnpm run check:esm && pnpm run check:catalogs && pnpm run check:governance-rules && pnpm run check:intent-domain-coverage && pnpm run check:contract-schemas && pnpm run check:contract-semver && pnpm run check:pipeline-shell-independence && pnpm run check:first-win-smoke && pnpm run check:doc-examples && pnpm run check:tier-hygiene && pnpm run check:mos-no-write-api",
    "check:mos-no-write-api": "pnpm --filter @presence/operator-surface exec vitest run --config vitest.config.mjs",
    "doctor": "node dist/scripts/run_doctor.js",
    "generate-index": "node dist/scripts/cli.js list > /dev/null",
    "cli": "node dist/scripts/cli.js",
    "cli:preview": "node dist/scripts/cli.js preview",
    "cli:schedule": "node dist/scripts/cli.js schedule",
    "mission": "node dist/scripts/mission_controller.js",
    "mission:prewarm": "node dist/scripts/mission_controller.js prewarm",
    "mission:create": "node dist/scripts/create_mission.js",
    "mission:team": "node dist/scripts/compose_mission_team.js",
    "agent-runtime:supervisor": "node dist/scripts/run_agent_runtime_supervisor.js",
    "agent-runtime:daemon": "node dist/scripts/agent_runtime_supervisor_daemon.js",
    "agent-runtime:status": "node dist/scripts/agent_runtime_supervisor_status.js",
    "agent-runtime:manage": "node dist/scripts/agent_runtime_manager.js",
    "mission:orchestrator": "node dist/scripts/run_mission_orchestration_event_worker.js",
    "mission:handoff": "node dist/scripts/mission_controller.js handoff",
    "vital": "node dist/scripts/run_pipeline.js --input pipelines/vital-check.json",
    "vital:json": "node dist/scripts/vital_check.js --format=json",
    "diagnose": "node dist/scripts/run_pipeline.js --input pipelines/system-diagnostics.json",
    "issue:ingest": "node dist/scripts/ingest_issue.js",
    "onboard": "node dist/scripts/onboarding_wizard.js",
    "onboard:apply": "node dist/scripts/onboarding_apply.js",
    "mission:journal": "node dist/scripts/mission_journal.js",
    "dashboard": "node dist/scripts/sovereign_dashboard.js",
    "dashboard:onboarding": "node dist/scripts/sovereign_dashboard.js --once --focus onboarding",
    "control": "node dist/scripts/control_plane_cli.js",
    "surfaces:reconcile": "node dist/scripts/surface_runtime.js --action reconcile",
    "surfaces:status": "node dist/scripts/surface_runtime.js --action status",
    "surfaces:start": "node dist/scripts/surface_runtime.js --action start",
    "surfaces:stop": "node dist/scripts/surface_runtime.js --action stop",
    "generation:schedule": "node dist/scripts/run_generation_schedule.js",
    "generation:daemon": "node dist/scripts/run_generation_schedule_daemon.js",
    "voice:conversation:turn": "node dist/scripts/run_realtime_voice_conversation.js",
    "voice:profile:promote": "node dist/scripts/promote_voice_profile.js",
    "voice:setup": "command -v uv >/dev/null 2>&1 && uv venv --python ~/.pyenv/versions/3.11.5/bin/python3 .venv && uv pip install -r requirements-voice.txt || (~/.pyenv/versions/3.11.5/bin/python3 -m venv .venv && .venv/bin/pip install -r requirements-voice.txt)",
    "voice:health": "pnpm pipeline --input pipelines/voice-health-check.json",
    "voice:clone": "pnpm pipeline --input pipelines/clone-my-voice.json",
    "voice:speak": "pnpm pipeline --input pipelines/speak-with-my-voice.json",
    "customer:create": "pnpm tsx scripts/customer_create.ts",
    "slack:bridge": "node dist/satellites/slack-bridge/src/index.js",
    "chronos:dev": "pnpm --filter @presence/chronos-mirror-v2 dev",
    "chronos:lint": "pnpm --dir presence/displays/chronos-mirror-v2 lint",
    "chronos:build": "pnpm --dir presence/displays/chronos-mirror-v2 build",
    "terminal:bridge": "pnpm --filter @presence/terminal-bridge start",
  "capabilities": "node dist/scripts/capability_discovery.js",
  "provider-capabilities:scan": "node dist/scripts/scan_provider_cli_capabilities.js",
  "provider-capabilities:report": "node dist/scripts/generate_provider_cli_capability_report.js",
  "examples": "node dist/scripts/example_discovery.js",
    "system:upgrade:check": "node dist/scripts/run_pipeline.js --input pipelines/system-upgrade-check.json",
    "system:upgrade:execute": "node dist/scripts/run_pipeline.js --input pipelines/system-upgrade-execute.json",
    "init": "npm run init-wizard",
    "init-wizard": "node dist/scripts/init_wizard.js",
    "bootstrap": "pnpm build && node dist/scripts/surface_runtime.js --action reconcile",
    "benchmark": "node dist/scripts/benchmark.js",
    "plugin": "node dist/scripts/plugin-manager.js",
    "pipeline": "node dist/scripts/run_pipeline.js",
    "pipeline:super": "node dist/scripts/run_super_pipeline.js",
    "intent:run": "node dist/scripts/run_intent.js",
    "release:notes": "node dist/scripts/extract_changelog_section.js",
    "migration:run": "pnpm tsx scripts/run_migrations.ts",
    "migration:rollback": "pnpm tsx scripts/run_migrations.ts --rollback",
    "catalog": "node dist/scripts/generate_docs.js",
    "build:all": "pnpm run typecheck",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "dev": "pnpm run typecheck && pnpm run lint && pnpm run test:unit",
    "ci": "pnpm run validate && pnpm run test:all",
    "archive": "node dist/scripts/archive_missions.js",
    "generate:types": "node dist/scripts/generate_types.js",
    "project-os:init": "node dist/scripts/generate_project_os.js",
    "vault:mount": "node dist/scripts/vault_mount.js",
    "prepare": "husky",
    "nerve:pulse": "node dist/scripts/pulse_aggregator.js",
    "nerve:start": "pnpm surfaces:reconcile",
    "nerve:stop": "pnpm surfaces:stop",
    "nerve:status": "pnpm surfaces:status"
  },
  "lint-staged": {
    "knowledge/**/*.md": [
      "echo 'Syncing knowledge index...'"
    ]
  },
  "dependencies": {
    "@agent/core": "workspace:*",
    "@agent/shared-business": "workspace:*",
    "@agent/shared-media": "workspace:*",
    "@agent/shared-nerve": "workspace:*",
    "@agent/shared-network": "workspace:*",
    "@agent/shared-vision": "workspace:*",
    "@agentclientprotocol/sdk": "^0.16.1",
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@anthropic-ai/claude-code": "^2.1.76",
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openai/codex": "^0.114.0",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "@types/express": "^5.0.6",
    "@types/html-to-docx": "^1.8.0",
    "@types/marked": "^6.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.16",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.13.6",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "claude-code": "^1.0.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "gif-encoder-2": "^1.0.5",
    "googleapis": "^144.0.0",
    "html-to-docx": "^1.8.0",
    "jimp": "^0.22.12",
    "js-yaml": "^4.1.1",
    "jschardet": "^3.1.4",
    "jszip": "^3.10.1",
    "languagedetect": "^2.0.0",
    "mammoth": "^1.11.0",
    "marked": "^12.0.2",
    "node-pty": "^1.1.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.38.0",
    "sqlite3": "^5.1.7",
    "tesseract.js": "^7.0.0",
    "ws": "^8.19.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "fast-check": "4.6.0",
    "@next/eslint-plugin-next": "^16.2.0",
    "@playwright/test": "^1.41.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.2.1",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^4.1.0",
    "c8": "^10.1.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "hyperframes": "^0.4.30",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "8.0.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "marked": "^12.0.0",
      "xmldom": "npm:@xmldom/xmldom@^0.8.10",
      "trim-newlines": "^3.0.1",
      "jszip": "^3.10.1",
      "tar": "^7.5.8",
      "esbuild": "^0.25.0",
      "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz",
      "nth-check": "^2.0.1"
    },
    "_note": "Build script approval lives in pnpm-workspace.yaml allowBuilds (single source of truth for pnpm 11+)."
  },
  "overrides": {
    "form-data": "^4.0.0"
  }
}
