{
  "name": "gemini-skills",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Gemini skills",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "index.js",
  "workspaces": [
    "skills/**/*",
    "libs/core"
  ],
  "scripts": {
    "test": "node tests/smoke.test.cjs",
    "test:unit": "node tests/unit.test.cjs",
    "test:core": "node scripts/bootstrap.cjs && node tests/unit/core-lib.test.cjs",
    "test:secure-io": "node scripts/bootstrap.cjs && node tests/unit/secure-io.test.cjs",
    "test:metrics": "node scripts/bootstrap.cjs && node tests/unit/metrics.test.cjs",
    "test:integration": "node tests/integration.test.cjs",
    "test:coverage": "c8 node tests/unit.test.cjs",
    "test:plugins": "node tests/plugins.test.cjs",
    "test:ts": "vitest run",
    "test:all": "pnpm run test:unit && pnpm run test:core && pnpm run test:secure-io && pnpm run test:metrics && pnpm run test:integration && pnpm run test:plugins && pnpm run test:ts && pnpm test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/validate_skills.cjs && node scripts/validate_schemas.cjs",
    "doctor": "node scripts/doctor.cjs",
    "generate-index": "node scripts/generate_skill_index.cjs && node scripts/sync_docs.cjs",
    "cli": "node scripts/cli.cjs",
    "benchmark": "node scripts/benchmark.cjs",
    "plugin": "node scripts/plugin-manager.cjs",
    "create-skill": "node scripts/create_skill.cjs",
    "audit": "node scripts/audit_skills.cjs",
    "pipeline": "node scripts/pipeline-runner.cjs",
    "catalog": "node scripts/generate_docs.cjs",
    "health": "node scripts/check_skills_health.cjs",
    "sanitize": "node scripts/skill-sanitizer.cjs",
    "build:all": "pnpm run sanitize && pnpm run typecheck",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "dev": "pnpm run typecheck && pnpm run lint && pnpm run test:unit",
    "ci": "pnpm run validate && pnpm run test:all && pnpm run typecheck",
    "archive": "node scripts/archive_missions.cjs",
    "generate:types": "node scripts/generate_types.cjs",
    "prepare": "husky",
    "mirror": "node tools/chronos-mirror/bridge.cjs & cd tools/chronos-mirror && pnpm run dev"
  },
  "lint-staged": {
    "knowledge/**/*.md": [
      "node scripts/generate_knowledge_index.cjs"
    ]
  },
  "dependencies": {
    "axios": "^1.13.5",
    "chalk": "^4.1.2",
    "exceljs": "^4.4.0",
    "googleapis": "^144.0.0",
    "js-yaml": "^4.1.1",
    "sqlite3": "^5.1.7",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.1",
    "@types/yargs": "^17.0.35",
    "c8": "^10.1.3",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.1"
  },
  "overrides": {
    "form-data": "^4.0.0"
  }
}
