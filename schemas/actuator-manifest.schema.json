{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Actuator Capability Manifest",
  "type": "object",
  "required": ["actuator_id", "version", "capabilities"],
  "properties": {
    "actuator_id": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "contract_schema": { "type": "string" },
    "resilience_tier": {
      "type": "string",
      "description": "High-level resilience posture for the actuator, e.g. adaptive_retry."
    },
    "recovery_policy": {
      "type": "object",
      "description": "Retry and fallback contract used when the actuator encounters transient failure.",
      "properties": {
        "fallback_strategy": { "type": "string" },
        "retry": {
          "type": "object",
          "properties": {
            "maxRetries": { "type": "number" },
            "initialDelayMs": { "type": "number" },
            "maxDelayMs": { "type": "number" },
            "factor": { "type": "number" },
            "jitter": { "type": "boolean" }
          }
        },
        "retryable_categories": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op", "platforms"],
        "properties": {
          "op": { "type": "string" },
          "schema_ref": { "type": "string" },
          "platforms": {
            "type": "array",
            "items": { "type": "string", "enum": ["darwin", "linux", "win32"] }
          },
          "requirements": {
            "type": "object",
            "properties": {
              "bin": { "type": "array", "items": { "type": "string" } },
              "lib": { "type": "array", "items": { "type": "string" } },
              "env": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
