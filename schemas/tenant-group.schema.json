{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/tenant-group.schema.json",
  "title": "Tenant Group Profile",
  "description": "Explicit confidential sharing group. Members may access artifacts under the declared shared prefixes; direct tenant-to-tenant access still requires brokered missions.",
  "type": "object",
  "required": ["tenant_group_id", "display_name", "status", "member_tenants", "shared_prefixes"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "tenant_group_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,30}$" },
    "display_name": { "type": "string" },
    "status": { "type": "string", "enum": ["active", "suspended", "archived"] },
    "member_tenants": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,30}$" },
      "uniqueItems": true
    },
    "shared_prefixes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^knowledge/confidential/shared/[a-z][a-z0-9-]{1,30}/"
      },
      "uniqueItems": true
    },
    "purpose": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
