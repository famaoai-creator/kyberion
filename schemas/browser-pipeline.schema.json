{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Browser Pipeline ADF v2.1.0",
  "description": "ADF for browser automation pipelines based on Playwright semantics.",
  "type": "object",
  "required": ["action", "steps"],
  "properties": {
    "action": { "const": "pipeline" },
    "options": {
      "type": "object",
      "properties": {
        "headless": { "type": "boolean" },
        "viewport": {
          "type": "object",
          "properties": {
            "width": { "type": "integer" },
            "height": { "type": "integer" }
          }
        },
        "locale": { "type": "string", "default": "ja-JP" },
        "record_trace": { "type": "boolean" },
        "record_video": { "type": "boolean" },
        "max_steps": { "type": "integer" },
        "timeout_ms": { "type": "integer" },
        "user_data_dir": { "type": "string" },
        "profile_directory": { "type": "string" },
        "browser_channel": { "enum": ["chromium", "chrome"] },
        "launch_args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "navigation_policy": {
          "type": "object",
          "properties": {
            "allowed_origins": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "allow_private_network": { "type": "boolean", "default": false },
            "allow_data_url": { "type": "boolean", "default": true }
          },
          "additionalProperties": false
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "op"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["capture", "transform", "apply", "control"] },
          "op": {
            "enum": [
              "distill_dom",
              "goto",
              "screenshot",
              "content",
              "evaluate",
              "snapshot",
              "tabs",
              "console",
              "network",
              "query_elements",
              "extract_text_ref",
              "session_health",
              "action_trail",
              "title",
              "url",
              "export_session_handoff",
              "passkey_credentials",
              "passkey_events",
              "llm_decide",
              "regex_extract",
              "json_query",
              "export_failure_bundle",
              "export_adf",
              "export_playwright",
              "click",
              "click_first_match",
              "click_ref",
              "fill",
              "fill_ref",
              "fill_secret_ref",
              "press",
              "press_ref",
              "scroll",
              "scroll_ref",
              "wait",
              "wait_ref",
              "log",
              "extension_session",
              "import_session_handoff",
              "authenticate_passkey",
              "clear_passkey_credentials",
              "delete_passkey",
              "list_profiles",
              "register_passkey",
              "set_passkey_presence",
              "set_passkey_user_verified",
              "close_session",
              "if",
              "open_tab",
              "pause_for_operator",
              "ref",
              "select_tab",
              "select_tab_matching",
              "while",
              "setup_passkey_authenticator",
              "remove_passkey_authenticator"
            ]
          },
          "params": { "type": "object" }
        }
      }
    }
  }
}
