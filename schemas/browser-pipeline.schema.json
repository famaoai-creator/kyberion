{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Browser Pipeline ADF v2.1.0",
  "description": "ADF for browser automation pipelines based on Playwright semantics.",
  "type": "object",
  "required": ["action", "steps"],
  "properties": {
    "action": { "const": "pipeline" },
    "options": {
      "type": "object",
      "properties": {
        "headless": { "type": "boolean" },
        "viewport": {
          "type": "object",
          "properties": {
            "width": { "type": "integer" },
            "height": { "type": "integer" }
          }
        },
        "locale": { "type": "string", "default": "ja-JP" },
        "record_trace": { "type": "boolean" },
        "record_video": { "type": "boolean" },
        "max_steps": { "type": "integer" },
        "timeout_ms": { "type": "integer" },
        "user_data_dir": { "type": "string" },
        "profile_directory": { "type": "string" },
        "browser_channel": { "enum": ["chromium", "chrome"] },
        "launch_args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "op"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["capture", "transform", "apply", "control"] },
          "op": { 
            "enum": [
              "goto", "screenshot", "content", "evaluate",
              "regex_extract", "json_query",
              "click", "fill", "press", "wait", "log",
              "if", "while",
              "setup_passkey_authenticator",
              "remove_passkey_authenticator",
              "register_passkey",
              "authenticate_passkey",
              "delete_passkey",
              "passkey_credentials",
              "passkey_events",
              "set_passkey_user_verified",
              "set_passkey_presence",
              "clear_passkey_credentials",
              "list_profiles"
            ]
          },
          "params": { "type": "object" }
        }
      }
    }
  }
}
