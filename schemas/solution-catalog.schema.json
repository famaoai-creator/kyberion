{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SolutionCatalog",
  "description": "E2E-06 Task 3: the only source customer-facing replies may ground solution claims in. limitations is REQUIRED — what we cannot promise is part of the catalog.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "solutions"],
  "properties": {
    "version": { "type": "string" },
    "solutions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "summary", "capabilities", "limitations"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "limitations": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "faq": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["q", "a"],
              "properties": { "q": { "type": "string" }, "a": { "type": "string" } }
            }
          },
          "reference_links": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
