{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReconcileStrategy",
  "type": "object",
  "required": ["strategies"],
  "properties": {
    "strategies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["bidirectional-mapping", "git-provenance", "template-injection", "aggregator"] },
          "params": { "type": "object" }
        }
      }
    }
  }
}
