{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kyberion Design Pattern",
  "description": "Definition of a document design pattern for human consumption, usable by Media-Actuator.",
  "type": "object",
  "required": ["pattern_id", "category", "target_audience", "layout_strategy"],
  "properties": {
    "pattern_id": { "type": "string" },
    "category": { "enum": ["strategic", "technical", "analytical", "operational", "relational"] },
    "target_audience": { "type": "string" },
    "description": { "type": "string" },
    "layout_strategy": {
      "type": "object",
      "properties": {
        "visual_weight": { "enum": ["visual_heavy", "balanced", "text_heavy"] },
        "structure": { "type": "array", "items": { "type": "string" } },
        "color_palette": { "type": "string" }
      }
    },
    "media_actuator_config": {
      "type": "object",
      "properties": {
        "template_id": { "type": "string" },
        "engine": { "enum": ["puppeteer", "d2", "mermaid", "chartjs"] },
        "styles": { "type": "object" }
      }
    }
  }
}
