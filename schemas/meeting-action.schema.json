{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Meeting Actuator Request",
  "description": "Abstracted request for online meeting participation (Zoom, Teams, Google Meet).",
  "type": "object",
  "required": ["action", "params"],
  "properties": {
    "action": {
      "enum": ["join", "leave", "speak", "listen", "chat", "status"]
    },
    "params": {
      "type": "object",
      "properties": {
        "platform": { "enum": ["zoom", "teams", "meet", "auto"] },
        "provider": { "enum": ["google_meet", "teams_pipeline", "zoom", "auto"] },
        "provider_profile_id": { "type": "string" },
        "execution_profile_id": { "type": "string" },
        "mode": { "enum": ["transcribe", "realtime"] },
        "node": { "enum": ["local", "named-node"] },
        "audio_bridge": { "enum": ["blackhole", "pulseaudio", "none"] },
        "url_policy": { "enum": ["explicit_only", "explicit_or_detected"] },
        "url": { "type": "string", "format": "uri" },
        "meeting_id": { "type": "string" },
        "passcode": { "type": "string" },
        "text": { "type": "string" },
        "duration_sec": { "type": "integer" }
      }
    }
  }
}
