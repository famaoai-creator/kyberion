{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.dev/schemas/knowledge-package.schema.json",
  "title": "Kyberion Knowledge Package",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "content"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_version",
        "package_id",
        "origin_agent_id",
        "origin_tenant_id",
        "source_tier",
        "requested_target_tier",
        "content_hash",
        "created_at",
        "provenance",
        "trust_status",
        "signature",
        "payload_encoding"
      ],
      "properties": {
        "package_version": { "type": "string", "minLength": 1 },
        "package_id": { "type": "string", "minLength": 1 },
        "origin_agent_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$" },
        "origin_tenant_id": { "type": "string", "minLength": 1 },
        "origin_project_id": { "type": "string" },
        "source_tier": { "enum": ["personal", "confidential", "public"] },
        "requested_target_tier": { "enum": ["personal", "confidential", "public"] },
        "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "created_at": { "type": "string", "format": "date-time" },
        "provenance": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "trust_status": { "enum": ["unverified", "verified", "rejected"] },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "enum": ["absent", "verified", "rejected"] },
            "algorithm": { "const": "hmac-sha256" },
            "key_id": { "type": "string", "minLength": 1 },
            "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          },
          "allOf": [
            {
              "if": { "properties": { "status": { "const": "verified" } } },
              "then": { "required": ["algorithm", "key_id", "value"] }
            }
          ]
        },
        "payload_encoding": { "const": "utf8" }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "raw_data"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"
        },
        "raw_data": { "type": "string" }
      }
    }
  }
}
