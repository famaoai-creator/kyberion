{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kyberion Knowledge Package (KKP)",
  "type": "object",
  "required": ["metadata", "content"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["package_id", "origin_agent_id", "timestamp", "hash"],
      "properties": {
        "package_id": { "type": "string" },
        "origin_agent_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "domain": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "hash": { "type": "string" },
        "signature": { "type": "string" },
        "visibility": { "type": "string", "enum": ["public", "confidential"] }
      }
    },
    "content": {
      "type": "object",
      "required": ["path", "raw_data"],
      "properties": {
        "path": { "type": "string" },
        "format": { "type": "string", "default": "markdown" },
        "raw_data": { "type": "string" }
      }
    }
  }
}
