{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Voice Actuator Request",
  "description": "Single voice request or lightweight voice pipeline envelope.",
  "anyOf": [
    {
      "$ref": "../knowledge/public/schemas/voice-generation-adf.schema.json"
    },
    {
      "$ref": "../knowledge/public/schemas/voice-profile-registration.schema.json"
    },
    {
      "$ref": "../knowledge/public/schemas/voice-sample-collection.schema.json"
    },
    {
      "$ref": "../knowledge/public/schemas/voice-sample-recording.schema.json"
    },
    {
      "$ref": "../knowledge/public/schemas/voice-sample-collection-registration.schema.json"
    },
    {
      "type": "object",
      "required": ["action", "params"],
      "properties": {
        "action": { "enum": ["speak_local", "list_voices", "record_voice_sample", "collect_voice_samples", "collect_and_register_voice_profile", "register_voice_profile", "transcribe_voice_sample"] },
        "params": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["action", "steps"],
      "properties": {
        "action": { "const": "pipeline" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "anyOf": [
              {
                "$ref": "../knowledge/public/schemas/voice-generation-adf.schema.json"
              },
              {
                "$ref": "../knowledge/public/schemas/voice-profile-registration.schema.json"
              },
              {
                "$ref": "../knowledge/public/schemas/voice-sample-collection.schema.json"
              },
              {
                "$ref": "../knowledge/public/schemas/voice-sample-recording.schema.json"
              },
              {
                "$ref": "../knowledge/public/schemas/voice-sample-collection-registration.schema.json"
              },
              {
                "type": "object",
                "required": ["action", "params"],
                "properties": {
                  "action": { "enum": ["speak_local", "list_voices", "record_voice_sample", "collect_voice_samples", "collect_and_register_voice_profile", "register_voice_profile", "transcribe_voice_sample"] },
                  "params": { "type": "object" }
                }
              }
            ]
          }
        }
      }
    }
  ]
}
