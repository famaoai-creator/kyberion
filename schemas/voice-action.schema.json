{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Voice Actuator Request",
  "description": "Single voice request or lightweight voice pipeline envelope.",
  "$defs": {
    "audioRouteParams": {
      "type": "object",
      "required": ["action", "params"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "list_audio_routes" },
        "params": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "bus": { "enum": ["blackhole", "stub"] } }
        }
      }
    },
    "probeAudioRoute": {
      "type": "object",
      "required": ["action", "params"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "probe_audio_route" },
        "params": {
          "type": "object",
          "required": ["bus"],
          "additionalProperties": false,
          "properties": {
            "bus": { "enum": ["blackhole", "stub"] },
            "input_device_uid": { "type": "string", "minLength": 1, "maxLength": 256 },
            "output_device_uid": { "type": "string", "minLength": 1, "maxLength": 256 },
            "expected_device_label": { "type": "string", "minLength": 1, "maxLength": 256 }
          }
        }
      }
    },
    "verifyTtsLoopback": {
      "type": "object",
      "required": ["action", "params"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "verify_tts_loopback" },
        "params": {
          "type": "object",
          "required": ["request_id", "text", "audio_route"],
          "additionalProperties": false,
          "properties": {
            "request_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
            "mission_id": { "type": "string", "minLength": 1, "maxLength": 256 },
            "tenant_slug": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,30}$" },
            "text": { "type": "string", "minLength": 1, "maxLength": 10000 },
            "expected_text": { "type": "string", "minLength": 1, "maxLength": 10000 },
            "language": { "type": "string", "minLength": 2, "maxLength": 35 },
            "voice_profile_id": { "type": "string", "minLength": 1, "maxLength": 256 },
            "operator_confirmed": { "type": "boolean" },
            "stt_bridge_id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$" },
            "dry_run": { "type": "boolean" },
            "audio_route": {
              "type": "object",
              "required": ["bus"],
              "additionalProperties": false,
              "properties": {
                "bus": { "enum": ["blackhole", "stub"] },
                "input_device_uid": { "type": "string", "minLength": 1, "maxLength": 256 },
                "output_device_uid": { "type": "string", "minLength": 1, "maxLength": 256 },
                "expected_device_label": { "type": "string", "minLength": 1, "maxLength": 256 }
              }
            },
            "format": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "encoding": { "const": "pcm_s16le" },
                "sample_rate_hz": { "enum": [16000, 24000, 48000] },
                "channels": { "enum": [1, 2] }
              }
            },
            "timing": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "pre_roll_ms": { "type": "number", "minimum": 0, "maximum": 10000 },
                "post_roll_ms": { "type": "number", "minimum": 0, "maximum": 10000 },
                "max_duration_ms": { "type": "number", "minimum": 20, "maximum": 120000 },
                "silence_timeout_ms": { "type": "number", "minimum": 20, "maximum": 30000 }
              }
            },
            "quality": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "minimum_similarity": { "type": "number", "minimum": 0, "maximum": 1 },
                "minimum_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "maximum_clipping_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
                "maximum_drop_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            },
            "persistence": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "retain_audio": { "type": "boolean" },
                "retain_transcript": { "type": "boolean" },
                "output_dir": { "type": "string", "minLength": 1, "maxLength": 512 }
              }
            }
          }
        }
      }
    }
  },
  "anyOf": [
    { "$ref": "#/$defs/audioRouteParams" },
    { "$ref": "#/$defs/probeAudioRoute" },
    { "$ref": "#/$defs/verifyTtsLoopback" },
    {
      "$ref": "../knowledge/product/schemas/voice-generation-adf.schema.json"
    },
    {
      "$ref": "../knowledge/product/schemas/voice-profile-registration.schema.json"
    },
    {
      "$ref": "../knowledge/product/schemas/voice-sample-collection.schema.json"
    },
    {
      "$ref": "../knowledge/product/schemas/voice-sample-recording.schema.json"
    },
    {
      "$ref": "../knowledge/product/schemas/voice-sample-verification.schema.json"
    },
    {
      "$ref": "../knowledge/product/schemas/voice-sample-collection-registration.schema.json"
    },
    {
      "type": "object",
      "required": ["action", "params"],
      "properties": {
        "action": {
          "enum": [
            "health",
            "speak_local",
            "list_voices",
            "record_voice_sample",
            "record_verify_repair_voice_sample",
            "collect_voice_samples",
            "collect_and_register_voice_profile",
            "register_voice_profile",
            "transcribe",
            "transcribe_voice_sample"
          ]
        },
        "params": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["action", "steps"],
      "properties": {
        "action": { "const": "pipeline" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "anyOf": [
              { "$ref": "#/$defs/audioRouteParams" },
              { "$ref": "#/$defs/probeAudioRoute" },
              { "$ref": "#/$defs/verifyTtsLoopback" },
              {
                "$ref": "../knowledge/product/schemas/voice-generation-adf.schema.json"
              },
              {
                "$ref": "../knowledge/product/schemas/voice-profile-registration.schema.json"
              },
              {
                "$ref": "../knowledge/product/schemas/voice-sample-collection.schema.json"
              },
              {
                "$ref": "../knowledge/product/schemas/voice-sample-recording.schema.json"
              },
              {
                "$ref": "../knowledge/product/schemas/voice-sample-verification.schema.json"
              },
              {
                "$ref": "../knowledge/product/schemas/voice-sample-collection-registration.schema.json"
              },
              {
                "type": "object",
                "required": ["action", "params"],
                "properties": {
                  "action": {
                    "enum": [
                      "health",
                      "speak_local",
                      "list_voices",
                      "record_voice_sample",
                      "record_verify_repair_voice_sample",
                      "collect_voice_samples",
                      "collect_and_register_voice_profile",
                      "register_voice_profile",
                      "transcribe",
                      "transcribe_voice_sample"
                    ]
                  },
                  "params": { "type": "object" }
                }
              }
            ]
          }
        }
      }
    }
  ]
}
