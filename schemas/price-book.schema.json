{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PriceBook",
  "description": "E2E-06 Task 3/5: the only source of prices in customer-facing replies and quotes. Quote math is deterministic rule application — never model arithmetic. When CO-03 (financial model) lands, this file migrates there.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "currency", "items"],
  "properties": {
    "version": { "type": "string" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sku", "name", "unit", "unit_price"],
        "properties": {
          "sku": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "unit": { "type": "string", "minLength": 1 },
          "unit_price": { "type": "number", "minimum": 0 },
          "notes": { "type": "string" }
        }
      }
    },
    "estimate_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_kind", "base_hours", "rate_sku"],
        "properties": {
          "task_kind": { "type": "string", "minLength": 1 },
          "base_hours": { "type": "number", "minimum": 0 },
          "rate_sku": { "type": "string", "minLength": 1 },
          "size_multipliers": {
            "type": "object",
            "additionalProperties": { "type": "number", "minimum": 0 }
          }
        }
      }
    }
  }
}
