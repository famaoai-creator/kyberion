{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "System Pipeline ADF v2.0.0",
  "description": "ADF for defining OS-level pipelines including keyboard, mouse, and system governance.",
  "type": "object",
  "required": ["action", "steps"],
  "properties": {
    "action": { "const": "pipeline" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "op"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["capture", "transform", "apply", "control"] },
          "op": {
            "enum": [
              "screenshot", "clipboard_read", "get_focused_input", "get_screen_size", "window_list", "chrome_tab_list",
              "read_file", "read_json", "probe", "glob_files", "scan_directory", "pulse_status",
              "exec", "shell", "cli_health_check", "list_missions", "list_projects", "list_capabilities",
              "list_incidents", "list_knowledge", "list_running_apps", "list_input_devices", "list_displays", "list_media_devices", "list_tool_runtimes", "list_service_runtimes", "control_media_devices",
              "collect_artifacts", "sample_traces", "vision_consult", "test_screen_stream", "test_screen_mp4_roundtrip", "test_camera_injection",
              "regex_extract", "json_query", "sre_analyze", "run_js",
              "scroll", "drag", "clipboard_write", "system_notify", "open_file", "app_quit", "process_kill", "run_applescript",
              "keyboard", "paste_text", "press_key", "voice_input_toggle", "mouse_click", "mouse_move", "activate_application",
              "open_url", "write_file", "write_artifact", "write_json", "mkdir", "log", "voice", "native_tts_speak",
              "check_native_tts", "notify", "wait", "if", "while",
              "system:screenshot", "system:clipboard_read", "system:get_focused_input", "system:get_screen_size", "system:window_list", "system:chrome_tab_list",
              "system:read_file", "system:read_json", "system:probe", "system:glob_files", "system:scan_directory", "system:pulse_status",
              "system:exec", "system:shell", "system:cli_health_check", "system:list_missions", "system:list_projects", "system:list_capabilities",
              "system:list_incidents", "system:list_knowledge", "system:list_running_apps", "system:list_input_devices", "system:list_displays", "system:list_media_devices", "system:list_tool_runtimes", "system:list_service_runtimes", "system:control_media_devices",
              "system:collect_artifacts", "system:sample_traces", "system:vision_consult", "system:test_screen_stream", "system:test_screen_mp4_roundtrip", "system:test_camera_injection",
              "system:regex_extract", "system:json_query", "system:sre_analyze", "system:run_js",
              "system:scroll", "system:drag", "system:clipboard_write", "system:system_notify", "system:open_file", "system:app_quit", "system:process_kill", "system:run_applescript",
              "system:keyboard", "system:paste_text", "system:press_key", "system:voice_input_toggle", "system:mouse_click", "system:mouse_move", "system:activate_application",
              "system:open_url", "system:write_file", "system:write_artifact", "system:write_json", "system:mkdir", "system:log", "system:voice", "system:native_tts_speak",
              "system:check_native_tts", "system:notify", "system:wait", "system:if", "system:while",
              "core:if", "core:while"
            ]
          },
          "params": {
            "type": "object",
            "properties": {
              "text": { "type": "string", "description": "Text for keyboard or voice output" },
              "application": { "type": "string", "description": "Application name to target when taking a focused-window screenshot" },
              "window_title": { "type": "string", "description": "Optional window title hint for screenshot metadata and future targeting" },
              "window_match_policy": { "type": "string", "enum": ["strict", "prefix", "contains"], "description": "How to match window_title when targeting a window screenshot" },
              "capture_mode": { "type": "string", "enum": ["screen", "focused_window"], "description": "Screenshot mode; focused_window is the default when application is provided" },
              "display_index": { "type": "integer", "minimum": 0, "description": "Display index to target when capturing or recording screen output" },
              "display_name": { "type": "string", "description": "Display name to target when display_index is omitted" },
              "dictation_keycode": { "type": "integer", "minimum": 1, "description": "macOS dictation key code for voice input toggle" },
              "x": { "type": "number", "description": "X coordinate for mouse" },
              "y": { "type": "number", "description": "Y coordinate for mouse" },
              "cmd": { "type": "string", "description": "Shell command to execute" },
              "command": { "type": "string", "description": "CLI command to execute (for exec/cli_health_check)" },
              "args": { "type": "array", "items": { "type": "string" }, "description": "Arguments for the command" },
              "cwd": { "type": "string", "description": "Current working directory" },
              "env": { "type": "object", "description": "Environment variables" },
              "timeout_ms": { "type": "number", "description": "Timeout in milliseconds" },
              "allow_error": { "type": "boolean", "description": "Whether to continue on non-zero exit code" },
              "input": { "type": "string", "description": "Stdin input for the command" },
              "path": { "type": "string", "description": "File or directory path" },
              "pattern": { "type": "string", "description": "Regex pattern" },
              "template": { "type": "string", "description": "Replacement template with {{var}} support" },
              "message": { "type": "string", "description": "Message string for log-style operations" },
              "export_as": { "type": "string", "description": "Context key to store the result" }
            }
          }
        }
      }
    }
  }
}
