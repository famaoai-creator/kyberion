{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Secret Mutation Approval Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "kind",
    "status",
    "created_at",
    "requested_by",
    "target",
    "justification",
    "risk",
    "workflow"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "const": "secret_mutation"
    },
    "status": {
      "enum": ["pending", "approved", "rejected", "expired", "applied", "failed"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "requested_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "actor_id", "actor_role"],
      "properties": {
        "surface": {
          "enum": ["slack", "chronos", "terminal", "presence", "api", "system"]
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        },
        "actor_role": {
          "type": "string",
          "minLength": 1
        },
        "mission_id": {
          "type": "string",
          "minLength": 1
        },
        "runtime_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service_id", "secret_key", "mutation"],
      "properties": {
        "service_id": {
          "type": "string",
          "minLength": 1
        },
        "secret_key": {
          "type": "string",
          "minLength": 1
        },
        "mutation": {
          "enum": ["set", "rotate", "delete", "refresh", "metadata_update"]
        },
        "store": {
          "enum": ["os_keychain", "connection_document", "vault"]
        },
        "new_value_fingerprint": {
          "type": "string"
        },
        "existing_value_present": {
          "type": "boolean"
        }
      }
    },
    "justification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "impact_summary": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requested_effects": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "restart_scope", "requires_strong_auth"],
      "properties": {
        "level": {
          "enum": ["low", "medium", "high", "critical"]
        },
        "restart_scope": {
          "enum": ["none", "runtime", "surface", "service", "manual"]
        },
        "requires_strong_auth": {
          "type": "boolean"
        },
        "policy_id": {
          "type": "string"
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_id", "mode", "required_roles", "stages", "approvals"],
      "properties": {
        "workflow_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "enum": ["all_required", "any_of", "staged"]
        },
        "required_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "current_stage": {
          "type": "string"
        },
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stage_id", "required_roles"],
            "properties": {
              "stage_id": {
                "type": "string",
                "minLength": 1
              },
              "required_roles": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "approvals": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "status"],
            "properties": {
              "role": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "enum": ["pending", "approved", "rejected", "skipped"]
              },
              "approved_by": {
                "type": "string"
              },
              "approved_at": {
                "type": "string",
                "format": "date-time"
              },
              "auth_method": {
                "enum": ["surface_session", "totp", "passkey", "manual"]
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "apply_result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "applied_at": {
          "type": "string",
          "format": "date-time"
        },
        "applied_by": {
          "type": "string"
        },
        "result": {
          "enum": ["success", "failed", "rolled_back"]
        },
        "audit_ref": {
          "type": "string"
        }
      }
    }
  }
}
