{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gateway Adapter Profile Schema",
  "description": "Schema for adapter profiles that wrap external SaaS/Web APIs into Kyberion capabilities.",
  "type": "object",
  "required": ["adapter_id", "provider", "capability_id", "auth_profile", "status"],
  "properties": {
    "adapter_id": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "capability_id": {
      "type": "string"
    },
    "auth_profile": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["oauth2", "api_key", "bearer", "none"]
        },
        "authorize_url": { "type": "string" },
        "token_url": { "type": "string" },
        "scopes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "operations": {
      "type": "object",
      "description": "Mapping of action names to their 3-tier execution alternatives",
      "additionalProperties": {
        "type": "object",
        "required": ["alternatives"],
        "properties": {
          "risk_class": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["cli", "api", "sdk"]
                },
                "command": { "type": "string", "description": "For type: cli" },
                "args": { "type": "array", "items": { "type": "string" }, "description": "For type: cli" },
                "method": { "type": "string", "description": "For type: api" },
                "path": { "type": "string", "description": "For type: api" },
                "payload_template": { "type": "object", "description": "For type: api" },
                "headers": { "type": "object", "description": "For type: api" },
                "output_mapping": {
                  "type": "object",
                  "additionalProperties": { "type": "string" },
                  "description": "Transforms the output payload"
                }
              }
            }
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "experimental"]
    }
  }
}
