{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wisdom Actuator Request",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "enum": [
        "knowledge_search",
        "knowledge_inject",
        "knowledge_export",
        "knowledge_import"
      ]
    },
    "params": {
      "type": "object",
      "properties": {
        "tier": {
          "type": "string",
          "enum": ["personal", "confidential", "public"]
        },
        "query": {
          "type": "string"
        },
        "export_as": {
          "type": "string"
        },
        "limit": {
          "type": "number"
        }
      }
    }
  }
}
