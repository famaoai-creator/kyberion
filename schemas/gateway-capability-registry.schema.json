{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gateway Capability Registry Schema",
  "type": "object",
  "required": ["version", "capabilities"],
  "properties": {
    "version": { "type": "string" },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability_id", "adapter_profile_path", "status"],
        "properties": {
          "capability_id": { "type": "string" },
          "adapter_profile_path": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  }
}
