{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MissionContract",
  "type": "object",
  "required": ["mission_id", "skill", "action", "tier"],
  "properties": {
    "mission_id": { "type": "string", "pattern": "^[a-z0-9\\-_]+$" },
    "tier": {
      "type": "string",
      "enum": ["personal", "confidential", "public"],
      "description": "The security tier of the mission. 'personal' missions are stored in knowledge/personal/missions, 'confidential' in active/missions/confidential, and 'public' in active/missions/public."
    },
    "role": { "type": "string" },
    "skill": { "type": "string" },
    "action": { "type": "string" },
    "static_params": { "type": "object" },
    "safety_gate": {
      "type": "object",
      "properties": {
        "risk_level": { "type": "integer", "minimum": 1, "maximum": 5 },
        "require_sudo": { "type": "boolean" },
        "approved_by_sovereign": { "type": "boolean" }
      }
    },
    "knowledge_injections": {
      "type": "array",
      "description": "Declarative knowledge scope this mission draws on. Resolved at runtime by tag/domain query (knowledge-index.ts), not by literal path, so it survives knowledge/ directory reorganizations.",
      "items": {
        "type": "object",
        "required": ["tier"],
        "properties": {
          "tier": {
            "type": "string",
            "enum": ["personal", "confidential", "public"],
            "description": "Knowledge tier this entry draws from; drives mission tier auto-elevation directly (no path sniffing)."
          },
          "project": {
            "type": "string",
            "description": "Required scoping when tier is 'confidential': matches knowledge/confidential/{project}/."
          },
          "domains": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Knowledge domains to search, e.g. 'design-patterns', 'procedures/browser'."
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Frontmatter/hint tags to match, e.g. 'browser-automation', 'pptx'."
          }
        }
      }
    }
  }
}
