{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Service Manifest",
  "description": "Definition of background services that should be active in the system.",
  "type": "object",
  "patternProperties": {
    "^[a-zA-Z0-9_-]+$": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the service script relative to the root."
        },
        "description": {
          "type": "string",
          "description": "Description of the service's purpose."
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Optional environment variables for the service."
        }
      },
      "required": ["path", "description"]
    }
  }
}
