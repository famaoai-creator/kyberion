{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Environment Blueprint Schema",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "infrastructure": {
      "type": "object",
      "properties": {
        "directories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string" },
              "target": { "type": "string" },
              "type": { "enum": ["file", "dir", "junction"] }
            },
            "required": ["source", "target"]
          }
        },
        "initial_files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "content": { "type": "string" }
            },
            "required": ["path", "content"]
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "command": { "type": "string" },
              "args": { "type": "array", "items": { "type": "string" } },
              "optional": { "type": "boolean" }
            },
            "required": ["command"]
          }
        }
      }
    }
  },
  "required": ["name", "infrastructure"]
}
