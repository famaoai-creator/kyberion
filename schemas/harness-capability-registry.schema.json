{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Harness Capability Registry Schema",
  "description": "Schema for the central registry of all active host-native CLI capabilities.",
  "type": "object",
  "required": ["version", "capabilities"],
  "properties": {
    "version": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability_id", "adapter_profile_path", "status"],
        "properties": {
          "capability_id": {
            "type": "string"
          },
          "adapter_profile_path": {
            "type": "string",
            "description": "Path to the Harness Adapter Profile JSON file"
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated", "quarantined", "experimental"]
          },
          "description": {
            "type": "string"
          },
          "added_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
