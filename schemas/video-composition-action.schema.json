{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Video Composition Actuator Request",
  "description": "Compile governed composed-video bundles from a video-composition-adf contract.",
  "anyOf": [
    {
      "$ref": "../knowledge/public/schemas/video-composition-adf.schema.json"
    },
    {
      "type": "object",
      "required": ["action", "params"],
      "properties": {
        "action": {
          "enum": [
            "prepare_video_composition",
            "compile_narrated_video_brief",
            "list_video_composition_templates",
            "get_video_composition_job_status",
            "await_video_composition_job",
            "cancel_video_composition_job",
            "get_video_composition_queue"
          ]
        },
        "params": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["action", "params"],
      "properties": {
        "action": { "const": "compile_narrated_video_brief" },
        "params": {
          "type": "object",
          "additionalProperties": false,
          "required": ["narrated_video_brief"],
          "properties": {
            "narrated_video_brief": {
              "$ref": "../knowledge/public/schemas/narrated-video-brief.schema.json"
            }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["action", "steps"],
      "properties": {
        "action": { "const": "pipeline" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "anyOf": [
              {
                "$ref": "../knowledge/public/schemas/video-composition-adf.schema.json"
              },
              {
                "type": "object",
                "required": ["action", "params"],
                "properties": {
                  "action": {
                    "enum": [
                      "prepare_video_composition",
                      "compile_narrated_video_brief",
                      "list_video_composition_templates",
                      "get_video_composition_job_status",
                      "await_video_composition_job",
                      "cancel_video_composition_job",
                      "get_video_composition_queue"
                    ]
                  },
                  "params": { "type": "object" }
                }
              },
              {
                "type": "object",
                "required": ["action", "params"],
                "properties": {
                  "action": { "const": "compile_narrated_video_brief" },
                  "params": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["narrated_video_brief"],
                    "properties": {
                      "narrated_video_brief": {
                        "$ref": "../knowledge/public/schemas/narrated-video-brief.schema.json"
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    }
  ]
}
