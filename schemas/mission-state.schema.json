{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/mission-state.schema.json",
  "title": "Mission State",
  "type": "object",
  "required": [
    "mission_id",
    "tier",
    "status",
    "execution_mode",
    "priority",
    "assigned_persona",
    "confidence_score",
    "git",
    "history"
  ],
  "properties": {
    "mission_id": { "type": "string", "minLength": 1 },
    "mission_type": { "type": "string" },
    "tenant_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "tenant_slug": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,30}$" },
    "cross_tenant_brokerage": {
      "type": "object",
      "required": ["source_tenants", "purpose", "approved_by", "approved_at", "expires_at"],
      "properties": {
        "source_tenants": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,30}$" }
        },
        "purpose": { "type": "string", "minLength": 1 },
        "approved_by": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "vision_ref": { "type": "string" },
    "tier": { "type": "string", "enum": ["personal", "confidential", "public"] },
    "status": {
      "type": "string",
      "enum": ["planned", "active", "validating", "distilling", "completed", "paused", "failed", "archived"]
    },
    "execution_mode": { "type": "string", "enum": ["local", "delegated"] },
    "priority": { "type": "number" },
    "assigned_persona": { "type": "string", "minLength": 1 },
    "confidence_score": { "type": "number" },
    "git": {
      "type": "object",
      "required": ["branch", "start_commit", "latest_commit", "checkpoints"],
      "properties": {
        "branch": { "type": "string" },
        "start_commit": { "type": "string" },
        "latest_commit": { "type": "string" },
        "checkpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["task_id", "commit_hash", "ts"],
            "properties": {
              "task_id": { "type": "string" },
              "commit_hash": { "type": "string" },
              "ts": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ts", "event", "note"],
        "properties": {
          "ts": { "type": "string" },
          "event": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "note": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
