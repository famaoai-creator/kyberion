{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mission State Protocol (MSP) v2.0",
  "type": "object",
  "required": [
    "mission_id",
    "version",
    "status",
    "priority"
  ],
  "properties": {
    "mission_id": {
      "type": "string",
      "description": "Unique mission identifier"
    },
    "version": {
      "type": "string",
      "default": "2.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "planned",
        "active",
        "paused",
        "validating",
        "distilling",
        "completed",
        "failed",
        "archived"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "local",
        "delegated"
      ],
      "default": "local"
    },
    "delegation": {
      "type": "object",
      "properties": {
        "agent_id": {
          "type": "string"
        },
        "a2a_message_id": {
          "type": "string"
        },
        "remote_repo_url": {
          "type": "string"
        },
        "last_sync_ts": {
          "type": "string",
          "format": "date-time"
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "pending",
            "verified",
            "rejected"
          ]
        },
        "evidence_hashes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 5
    },
    "owner": {
      "type": "string",
      "default": "famao"
    },
    "assigned_persona": {
      "type": "string"
    },
    "git": {
      "type": "object",
      "properties": {
        "branch": {
          "type": "string"
        },
        "start_commit": {
          "type": "string"
        },
        "latest_commit": {
          "type": "string"
        },
        "checkpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "task_id": {
                "type": "string"
              },
              "commit_hash": {
                "type": "string"
              },
              "ts": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in-progress",
              "completed"
            ]
          },
          "completed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "last_action": {
          "type": "string"
        },
        "next_step": {
          "type": "string"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "associated_projects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ts",
          "event"
        ],
        "properties": {
          "ts": {
            "type": "string",
            "format": "date-time"
          },
          "event": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant to which this mission belongs, linking it to a specific Vision."
    },
    "vision_ref": {
      "type": "string",
      "description": "Reference to the specific Vision document or concept guiding this mission."
    },
    "type": {
      "type": "string",
      "enum": [
        "evaluation",
        "development",
        "research"
      ],
      "default": "development",
      "description": "Type of mission defining its permissions and focus."
    },
    "external_ref": {
      "type": "string",
      "description": "Reference to an external issue, ticket, or trigger URL."
    }
  }
}
