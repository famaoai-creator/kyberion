{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/track-policy-override.schema.json",
  "title": "Track Policy Override",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "description": { "type": "string" },
    "track_types": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "typical_lifecycle": { "type": "string", "minLength": 1 },
          "gate_profile": { "type": "string", "minLength": 1 },
          "entry_criteria": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "exit_criteria": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "recommended_pipeline": { "type": "string" },
          "mission_class": { "type": "string" },
          "tier": {
            "type": "string",
            "enum": ["personal", "confidential", "public"]
          },
          "note": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "lifecycle_models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "phases": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "gates_per_phase": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
