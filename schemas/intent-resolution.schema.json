{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/intent-resolution.schema.json",
  "title": "Intent Resolution Contract",
  "type": "object",
  "required": [
    "request_id",
    "normalized_intent",
    "missing_inputs",
    "resolution_shape",
    "outcome_kind",
    "authority_level",
    "rationale"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 8
    },
    "normalized_intent": {
      "type": "string",
      "minLength": 1
    },
    "missing_inputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "resolution_shape": {
      "type": "string",
      "enum": ["direct_answer", "task_session", "mission", "project_bootstrap"]
    },
    "outcome_kind": {
      "type": "string",
      "enum": ["answer", "artifact", "approval_ready_plan", "service_change", "status_report"]
    },
    "authority_level": {
      "type": "string",
      "enum": ["autonomous", "approval_required", "human_clarification_required"]
    },
    "project_context": {
      "type": "object",
      "required": ["confidence"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
