{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Install Package Map Schema",
  "type": "object",
  "required": ["version", "entries"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "patterns", "install_type", "package_name"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "patterns": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "install_type": { "type": "string", "enum": ["brew", "pip"] },
          "package_name": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" }
        }
      }
    }
  }
}
