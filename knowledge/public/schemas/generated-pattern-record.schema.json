{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/generated-pattern-record.schema.json",
  "title": "Generated Pattern Record",
  "type": "object",
  "required": ["record_id", "kind", "tier", "title", "summary", "candidate_id", "created_at", "applicability", "reusable_steps", "expected_outcome"],
  "properties": {
    "record_id": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "const": "pattern" },
    "tier": { "type": "string", "enum": ["personal", "confidential", "public"] },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string" },
    "task_session_id": { "type": "string" },
    "specialist_id": { "type": "string" },
    "locale": { "type": "string" },
    "artifact_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "created_at": { "type": "string", "minLength": 1 },
    "applicability": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "reusable_steps": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "expected_outcome": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
