{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Specialist Catalog",
  "type": "object",
  "required": ["version", "specialists"],
  "properties": {
    "version": { "type": "string" },
    "specialists": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["label", "description", "conversation_agent", "team_roles", "capabilities"],
        "properties": {
          "label": { "type": "string" },
          "description": { "type": "string" },
          "conversation_agent": { "type": "string" },
          "team_roles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
