{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/organization-work-loop.schema.json",
  "title": "Organization Work Loop Summary",
  "type": "object",
  "required": ["intent", "context", "resolution", "outcome_design", "process_design", "execution_boundary", "teaming", "authority", "learning"],
  "properties": {
    "intent": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": { "type": "string" }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "required": ["tier", "service_bindings"],
      "properties": {
        "project_id": { "type": "string" },
        "project_name": { "type": "string" },
        "track_id": { "type": "string" },
        "track_name": { "type": "string" },
        "tier": {
          "type": "string",
          "enum": ["personal", "confidential", "public"]
        },
        "locale": { "type": "string" },
        "service_bindings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "resolution": {
      "type": "object",
      "required": ["execution_shape"],
      "properties": {
        "execution_shape": {
          "type": "string",
          "enum": ["direct_reply", "task_session", "mission", "project_bootstrap"]
        },
        "task_type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "outcome_design": {
      "type": "object",
      "required": ["outcome_ids", "labels"],
      "properties": {
        "outcome_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "labels": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "process_design": {
      "type": "object",
      "required": ["plan_outline", "intake_requirements", "operator_checklist"],
      "properties": {
        "plan_outline": {
          "type": "array",
          "items": { "type": "string" }
        },
        "intake_requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "operator_checklist": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "execution_boundary": {
      "type": "object",
      "required": ["llm_zone", "knowledge_zone", "compiler_zone", "executor_zone", "rule"],
      "properties": {
        "llm_zone": {
          "type": "object",
          "required": ["allowed", "forbidden"],
          "properties": {
            "allowed": {
              "type": "array",
              "items": { "type": "string" }
            },
            "forbidden": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "knowledge_zone": {
          "type": "object",
          "required": ["owns"],
          "properties": {
            "owns": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "compiler_zone": {
          "type": "object",
          "required": ["responsibilities"],
          "properties": {
            "responsibilities": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "executor_zone": {
          "type": "object",
          "required": ["responsibilities"],
          "properties": {
            "responsibilities": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "rule": { "type": "string" }
      },
      "additionalProperties": false
    },
    "teaming": {
      "type": "object",
      "required": ["team_roles"],
      "properties": {
        "specialist_id": { "type": "string" },
        "specialist_label": { "type": "string" },
        "conversation_agent": { "type": "string" },
        "team_roles": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["requires_approval"],
      "properties": {
        "requires_approval": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "learning": {
      "type": "object",
      "required": ["reusable_refs"],
      "properties": {
        "reusable_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
