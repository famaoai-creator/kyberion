{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/generated-sop-record.schema.json",
  "title": "Generated SOP Record",
  "type": "object",
  "required": ["record_id", "kind", "tier", "title", "summary", "candidate_id", "created_at", "procedure_steps", "safety_notes", "escalation_conditions"],
  "properties": {
    "record_id": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "const": "sop_candidate" },
    "tier": { "type": "string", "enum": ["personal", "confidential", "public"] },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string" },
    "task_session_id": { "type": "string" },
    "specialist_id": { "type": "string" },
    "locale": { "type": "string" },
    "artifact_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "created_at": { "type": "string", "minLength": 1 },
    "procedure_steps": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "safety_notes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "escalation_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
