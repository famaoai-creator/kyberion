{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kyberion Pipeline ADF",
  "type": "object",
  "required": ["steps"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["pipeline"]
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "context": {
      "type": "object"
    },
    "options": {
      "type": "object",
      "properties": {
        "max_steps": {
          "type": "number"
        },
        "timeout_ms": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["op"],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["capture", "transform", "apply", "control"]
          },
          "op": {
            "type": "string",
            "minLength": 1
          },
          "params": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
