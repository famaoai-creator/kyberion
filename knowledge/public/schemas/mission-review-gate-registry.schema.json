{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "defaults", "gates", "mode_rules"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_mode"],
      "properties": {
        "review_mode": { "type": "string", "enum": ["lean", "standard", "strict"] }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "description", "required_in_modes"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "required_in_modes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["lean", "standard", "strict"] }
          },
          "applies_to": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mission_classes": { "type": "array", "items": { "type": "string" } },
              "delivery_shapes": { "type": "array", "items": { "type": "string" } },
              "risk_profiles": { "type": "array", "items": { "type": "string" } },
              "workflow_patterns": { "type": "array", "items": { "type": "string" } },
              "stages": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "mode_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "review_mode"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "review_mode": { "type": "string", "enum": ["lean", "standard", "strict"] },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mission_classes": { "type": "array", "items": { "type": "string" } },
              "delivery_shapes": { "type": "array", "items": { "type": "string" } },
              "risk_profiles": { "type": "array", "items": { "type": "string" } },
              "workflow_patterns": { "type": "array", "items": { "type": "string" } },
              "stages": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
