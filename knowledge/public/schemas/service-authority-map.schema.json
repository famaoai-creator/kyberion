{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Service Authority Map Schema",
  "type": "object",
  "required": ["version", "services"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "service_id", "authorities"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "service_id": {
            "type": "string",
            "minLength": 1
          },
          "authorities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "summary": {
            "type": "string"
          }
        }
      }
    }
  }
}
