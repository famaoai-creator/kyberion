{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["mission_id", "mission_type", "tier", "template", "assignments"],
  "properties": {
    "mission_id": { "type": "string" },
    "mission_type": { "type": "string" },
    "tier": { "type": "string" },
    "template": { "type": "string" },
    "assigned_persona": { "type": "string" },
    "mission_classification": {
      "$ref": "./mission-classification.schema.json"
    },
    "generated_at": { "type": "string" },
    "assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["team_role", "required", "status"],
        "properties": {
          "team_role": { "type": "string" },
          "required": { "type": "boolean" },
          "status": { "enum": ["assigned", "unfilled"] },
          "agent_id": { "type": ["string", "null"] },
          "authority_role": { "type": ["string", "null"] },
          "delegation_contract": {
            "type": ["object", "null"],
            "required": [
              "ownership_scope",
              "allowed_delegate_team_roles",
              "escalation_parent_team_role",
              "required_scope_classes",
              "resolved_scope_classes",
              "allowed_write_scopes"
            ],
            "properties": {
              "ownership_scope": { "type": "string" },
              "allowed_delegate_team_roles": { "type": "array", "items": { "type": "string" } },
              "escalation_parent_team_role": { "type": ["string", "null"] },
              "required_scope_classes": { "type": "array", "items": { "type": "string" } },
              "resolved_scope_classes": { "type": "array", "items": { "type": "string" } },
              "allowed_write_scopes": { "type": "array", "items": { "type": "string" } }
            }
          },
          "provider": { "type": ["string", "null"] },
          "modelId": { "type": ["string", "null"] },
          "required_capabilities": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
