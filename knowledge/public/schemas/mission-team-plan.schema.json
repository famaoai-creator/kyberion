{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["mission_id", "mission_type", "tier", "template", "assignments"],
  "properties": {
    "mission_id": { "type": "string" },
    "mission_type": { "type": "string" },
    "tier": { "type": "string" },
    "template": { "type": "string" },
    "assigned_persona": { "type": "string" },
    "mission_classification": {
      "$ref": "./mission-classification.schema.json"
    },
    "generated_at": { "type": "string" },
    "team_governance": {
      "type": "object",
      "required": ["lifecycle", "composition"],
      "properties": {
        "lifecycle": {
          "type": "object",
          "required": [
            "max_parallel_members",
            "max_members",
            "max_messages_per_run",
            "max_wall_clock_minutes",
            "max_member_turns",
            "shutdown_policy",
            "resume_policy",
            "cooldown_minutes"
          ],
          "properties": {
            "max_parallel_members": { "type": "integer", "minimum": 1 },
            "max_members": { "type": "integer", "minimum": 1 },
            "max_messages_per_run": { "type": "integer", "minimum": 1 },
            "max_wall_clock_minutes": { "type": "integer", "minimum": 1 },
            "max_member_turns": { "type": "integer", "minimum": 1 },
            "shutdown_policy": {
              "type": "string",
              "enum": ["graceful_handoff", "manual", "auto_shutdown"]
            },
            "resume_policy": {
              "type": "string",
              "enum": ["checkpoint_resume", "manual_resume"]
            },
            "cooldown_minutes": { "type": "integer", "minimum": 0 }
          }
        },
        "composition": {
          "type": "object",
          "required": ["required_roles", "optional_roles", "assigned_roles", "unfilled_required_roles"],
          "properties": {
            "required_roles": { "type": "array", "items": { "type": "string" } },
            "optional_roles": { "type": "array", "items": { "type": "string" } },
            "assigned_roles": { "type": "array", "items": { "type": "string" } },
            "unfilled_required_roles": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["team_role", "required", "status"],
        "properties": {
          "team_role": { "type": "string" },
          "required": { "type": "boolean" },
          "status": { "enum": ["assigned", "unfilled"] },
          "agent_id": { "type": ["string", "null"] },
          "authority_role": { "type": ["string", "null"] },
          "delegation_contract": {
            "type": ["object", "null"],
            "required": [
              "ownership_scope",
              "allowed_delegate_team_roles",
              "escalation_parent_team_role",
              "required_scope_classes",
              "resolved_scope_classes",
              "allowed_write_scopes"
            ],
            "properties": {
              "ownership_scope": { "type": "string" },
              "allowed_delegate_team_roles": { "type": "array", "items": { "type": "string" } },
              "escalation_parent_team_role": { "type": ["string", "null"] },
              "required_scope_classes": { "type": "array", "items": { "type": "string" } },
              "resolved_scope_classes": { "type": "array", "items": { "type": "string" } },
              "allowed_write_scopes": { "type": "array", "items": { "type": "string" } }
            }
          },
          "provider": { "type": ["string", "null"] },
          "modelId": { "type": ["string", "null"] },
          "required_capabilities": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
