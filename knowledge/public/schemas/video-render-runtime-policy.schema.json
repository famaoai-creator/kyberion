{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "video-render-runtime-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "queue", "progress", "bundle", "render"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "queue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["concurrency", "cancellation"],
      "properties": {
        "concurrency": { "type": "integer", "minimum": 1, "maximum": 4 },
        "cancellation": { "type": "string", "enum": ["queued_only", "queued_or_running"] }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["throttle_ms", "min_percent_delta", "emit_heartbeat"],
      "properties": {
        "throttle_ms": { "type": "integer", "minimum": 50, "maximum": 5000 },
        "min_percent_delta": { "type": "number", "minimum": 0, "maximum": 100 },
        "emit_heartbeat": { "type": "boolean" }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_bundle_root", "copy_declared_assets"],
      "properties": {
        "default_bundle_root": { "type": "string", "minLength": 1 },
        "copy_declared_assets": { "type": "boolean" }
      }
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_output_formats", "enable_backend_rendering"],
      "properties": {
        "allowed_output_formats": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["mp4", "mov", "webm"] }
        },
        "enable_backend_rendering": { "type": "boolean" }
      }
    }
  }
}
