{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "video-content-brief.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "audience",
    "objective",
    "distribution_channel",
    "content_type",
    "presentation_mode",
    "promise",
    "desired_takeaway",
    "constraints",
    "proof_points",
    "design_system_ref"
  ],
  "properties": {
    "kind": { "type": "string", "const": "video-content-brief" },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "distribution_channel": { "type": "string", "minLength": 1 },
    "content_type": { "type": "string", "minLength": 1 },
    "presentation_mode": {
      "type": "string",
      "enum": ["howto", "promo", "vtuber"]
    },
    "promise": { "type": "string", "minLength": 1 },
    "desired_takeaway": { "type": "string", "minLength": 1 },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "proof_points": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "content_requirements": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "fixed_inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "customer": { "type": "string", "minLength": 1 },
        "use_case": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "tone": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 2 },
    "duration_sec": { "type": "number", "minimum": 3, "maximum": 300 },
    "design_system_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system_id"],
      "properties": {
        "system_id": { "type": "string", "minLength": 1 },
        "brand_name": { "type": "string", "minLength": 1 },
        "theme": { "type": "string", "minLength": 1 },
        "background_color": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$" },
        "layout_family": { "type": "string", "minLength": 1 },
        "motion_profile": { "type": "string", "minLength": 1 },
        "logo_path": { "type": "string", "minLength": 1 },
        "hero_path": { "type": "string", "minLength": 1 },
        "fps": { "type": "integer", "minimum": 1, "maximum": 60 }
      }
    }
  }
}
