{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "knowledge/public/schemas/contextual-intent-frame.schema.json",
  "title": "Contextual Intent Frame",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "source_text", "locale", "action", "object", "subject", "source_binding", "missing", "assumptions", "confidence"],
  "properties": {
    "kind": {
      "type": "string",
      "const": "contextual_intent_frame"
    },
    "source_text": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "enum": ["ja-JP", "en-US"]
    },
    "action": {
      "type": "string",
      "enum": ["read", "change", "unknown"]
    },
    "object": {
      "type": "string",
      "enum": ["calendar_events", "calendar_schedule", "unknown"]
    },
    "subject": {
      "type": "string",
      "enum": ["operator_self", "team", "unknown"]
    },
    "date_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": {
          "type": "string",
          "enum": ["today", "tomorrow", "this_week", "next_week", "this_month", "next_month", "custom"]
        },
        "normalized": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "timezone": {
              "type": "string"
            },
            "start_iso": {
              "type": "string"
            },
            "end_iso": {
              "type": "string"
            }
          }
        }
      }
    },
    "source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates", "confidence"],
      "properties": {
        "candidates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["operator_default_calendar", "google_calendar", "outlook_calendar", "browser_calendar"]
          }
        },
        "selected": {
          "type": "string",
          "enum": ["operator_default_calendar", "google_calendar", "outlook_calendar", "browser_calendar"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence_breakdown": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "object": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "subject": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "date_range": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_binding": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
