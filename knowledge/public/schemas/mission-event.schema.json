{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mission Control Event",
  "type": "object",
  "required": ["ts", "event_id", "event_type"],
  "properties": {
    "ts": { "type": "string" },
    "event_id": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": [
        "mission_state_changed",
        "task_issued",
        "task_claimed",
        "task_submitted",
        "task_reviewed",
        "task_completed",
        "task_accepted",
        "lease_granted",
        "lease_denied",
        "lease_released",
        "runtime_spawned",
        "runtime_reaped",
        "handoff_written",
        "handoff_consumed",
        "mission_issued",
        "mission_orchestration_started",
        "mission_team_staffed",
        "mission_kickoff_completed",
        "mission_plan_ready",
        "mission_followup_requested",
        "mission_followup_dispatched",
        "mission_reconciliation_completed"
      ]
    },
    "mission_id": { "type": "string" },
    "task_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "resource_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "causation_id": { "type": "string" },
    "decision": { "type": "string" },
    "why": { "type": "string" },
    "policy_used": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "payload": { "type": "object" }
  },
  "additionalProperties": true
}
