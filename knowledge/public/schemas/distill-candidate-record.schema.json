{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/distill-candidate-record.schema.json",
  "title": "Distill Candidate Record",
  "type": "object",
  "required": ["candidate_id", "source_type", "title", "summary", "status", "target_kind", "created_at", "updated_at"],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "enum": ["task_session", "mission", "artifact"] },
    "tier": { "type": "string", "enum": ["personal", "confidential", "public"] },
    "project_id": { "type": "string" },
    "track_id": { "type": "string" },
    "track_name": { "type": "string" },
    "mission_id": { "type": "string" },
    "task_session_id": { "type": "string" },
    "artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["proposed", "promoted", "archived"] },
    "target_kind": { "type": "string", "enum": ["pattern", "sop_candidate", "knowledge_hint", "report_template"] },
    "specialist_id": { "type": "string" },
    "locale": { "type": "string" },
    "work_loop": { "$ref": "./organization-work-loop.schema.json" },
    "promoted_ref": { "type": "string" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
