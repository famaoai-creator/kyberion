{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "video-storyboard.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "format", "beats"],
  "properties": {
    "kind": { "type": "string", "const": "video-storyboard" },
    "version": { "type": "string", "minLength": 1 },
    "format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 320 },
        "height": { "type": "integer", "minimum": 320 }
      }
    },
    "audio_direction": { "type": "string" },
    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["beat_id", "title", "start_sec", "duration_sec", "visual_direction"],
        "properties": {
          "beat_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "start_sec": { "type": "number", "minimum": 0 },
          "duration_sec": { "type": "number", "minimum": 0.1 },
          "vo_cue": { "type": "string" },
          "visual_direction": { "type": "string", "minLength": 1 },
          "asset_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
