{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Service Endpoints Catalog",
  "type": "object",
  "required": ["default_pattern", "services"],
  "properties": {
    "default_pattern": { "type": "string" },
    "services": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "base_url": { "type": "string" },
          "preset_path": { "type": "string" },
          "credential_suffixes": {
            "type": "object",
            "properties": {
              "accessToken": {
                "type": "array",
                "items": { "type": "string" }
              },
              "appToken": {
                "type": "array",
                "items": { "type": "string" }
              },
              "refreshToken": {
                "type": "array",
                "items": { "type": "string" }
              },
              "clientId": {
                "type": "array",
                "items": { "type": "string" }
              },
              "clientSecret": {
                "type": "array",
                "items": { "type": "string" }
              },
              "redirectUri": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "anyOf": [
          { "required": ["base_url"] },
          { "required": ["preset_path"] }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
