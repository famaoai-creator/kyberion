{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/generated-knowledge-hint-record.schema.json",
  "title": "Generated Knowledge Hint Record",
  "type": "object",
  "required": ["record_id", "kind", "tier", "title", "summary", "candidate_id", "created_at", "hint_scope", "hint_triggers", "recommended_refs"],
  "properties": {
    "record_id": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "const": "knowledge_hint" },
    "tier": { "type": "string", "enum": ["personal", "confidential", "public"] },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string" },
    "track_id": { "type": "string" },
    "track_name": { "type": "string" },
    "task_session_id": { "type": "string" },
    "specialist_id": { "type": "string" },
    "locale": { "type": "string" },
    "work_loop": { "$ref": "./organization-work-loop.schema.json" },
    "artifact_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "created_at": { "type": "string", "minLength": 1 },
    "hint_scope": { "type": "string", "minLength": 1 },
    "hint_triggers": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "recommended_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
