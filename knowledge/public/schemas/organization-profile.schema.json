{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "organization-profile.schema.json",
  "title": "Organization Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "organization_id", "name", "mission_defaults", "team_defaults", "llm"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "organization_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "operating_principles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mission_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_mission_class": {
          "type": "string",
          "minLength": 1
        },
        "default_team_template": {
          "type": "string",
          "minLength": 1
        },
        "default_agent_profile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "team_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_team_template": {
          "type": "string",
          "minLength": 1
        },
        "team_template_catalog_id": {
          "type": "string",
          "minLength": 1
        },
        "default_lifecycle_template": {
          "type": "string",
          "minLength": 1
        },
        "max_parallel_missions": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "purpose_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "default_profile": {
          "type": "string",
          "minLength": 1
        },
        "profile_overrides": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "description": { "type": "string" },
              "command": { "type": "string", "minLength": 1 },
              "args": {
                "type": "array",
                "items": { "type": "string" }
              },
              "timeout_ms": { "type": "number", "minimum": 1 },
              "response_format": { "type": "string", "minLength": 1 },
              "adapter": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
