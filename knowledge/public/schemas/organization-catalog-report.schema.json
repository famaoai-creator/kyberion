{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/organization-catalog-report.schema.json",
  "title": "Organization Catalog Report",
  "type": "object",
  "required": ["requested", "resolved", "selected_catalog", "catalogs"],
  "properties": {
    "requested": {
      "type": "string",
      "minLength": 1
    },
    "resolved": {
      "type": "string",
      "minLength": 1
    },
    "selected_catalog": {
      "type": "string",
      "minLength": 1
    },
    "selected_only": {
      "type": "boolean"
    },
    "summary": {
      "type": "object",
      "required": [
        "total_count",
        "selected_count",
        "template_count",
        "required_role_count",
        "optional_role_count"
      ],
      "properties": {
        "total_count": {
          "type": "integer",
          "minimum": 0
        },
        "selected_count": {
          "type": "integer",
          "minimum": 0
        },
        "template_count": {
          "type": "integer",
          "minimum": 0
        },
        "required_role_count": {
          "type": "integer",
          "minimum": 0
        },
        "optional_role_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "catalogs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "catalog_id",
          "organization_id",
          "selected",
          "template_ids",
          "template_count",
          "required_role_count",
          "optional_role_count"
        ],
        "properties": {
          "catalog_id": {
            "type": "string",
            "minLength": 1
          },
          "organization_id": {
            "type": "string",
            "minLength": 1
          },
          "selected": {
            "type": "boolean"
          },
          "template_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "template_count": {
            "type": "integer",
            "minimum": 0
          },
          "required_role_count": {
            "type": "integer",
            "minimum": 0
          },
          "optional_role_count": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
