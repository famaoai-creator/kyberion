{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/intent-contract.schema.json",
  "title": "Intent Contract",
  "type": "object",
  "required": [
    "kind",
    "source_text",
    "intent_id",
    "goal",
    "resolution",
    "required_inputs",
    "outcome_ids",
    "approval",
    "delivery_mode",
    "clarification_needed",
    "confidence",
    "why"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["intent-contract"]
    },
    "source_text": {
      "type": "string"
    },
    "intent_id": {
      "type": "string"
    },
    "goal": {
      "type": "object",
      "required": ["summary", "success_condition"],
      "properties": {
        "summary": { "type": "string" },
        "success_condition": { "type": "string" }
      },
      "additionalProperties": false
    },
    "resolution": {
      "type": "object",
      "required": ["execution_shape"],
      "properties": {
        "execution_shape": {
          "type": "string",
          "enum": ["direct_reply", "task_session", "mission", "project_bootstrap"]
        },
        "task_type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "required_inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outcome_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approval": {
      "type": "object",
      "required": ["requires_approval"],
      "properties": {
        "requires_approval": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["one_shot", "managed_program"]
    },
    "clarification_needed": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "why": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
