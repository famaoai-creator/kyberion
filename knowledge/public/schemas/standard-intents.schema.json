{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "standard-intents.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "ux_contract": { "type": "string" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "intents": {
      "type": "array",
      "items": { "$ref": "#/$defs/intent" }
    }
  },
  "required": ["version", "intents"],
  "$defs": {
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shape": { "type": "string" },
        "task_kind": { "type": "string" },
        "result_shape": { "type": "string" }
      }
    },
    "pipelineStep": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "type": "string", "minLength": 1 },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["op"]
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "surface_examples": {
          "type": "array",
          "items": { "type": "string" }
        },
        "plan_outline": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outcome_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "specialist_id": { "type": "string" },
        "trigger_keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "intake_requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resolution": { "$ref": "#/$defs/resolution" },
        "pipeline": {
          "type": "array",
          "items": { "$ref": "#/$defs/pipelineStep" }
        }
      },
      "required": ["id", "category", "description", "trigger_keywords"]
    }
  }
}
