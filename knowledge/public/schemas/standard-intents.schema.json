{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "standard-intents.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "ux_contract": { "type": "string" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "intents": {
      "type": "array",
      "items": { "$ref": "#/$defs/intent" }
    }
  },
  "required": ["version", "intents"],
  "$defs": {
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shape": { "type": "string" },
        "task_kind": { "type": "string" },
        "result_shape": { "type": "string" }
      }
    },
    "pipelineStep": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": { "type": "string", "minLength": 1 },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["op"]
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "outcome_execution",
            "environment_setup",
            "actuator_management",
            "llm_reasoning_setup",
            "knowledge_lifecycle",
            "system_observability",
            "mission_process",
            "governance_control"
          ]
        },
        "legacy_category": { "type": "string", "minLength": 1 },
        "exposed_to_surface": { "type": "boolean" },
        "target": {
          "type": "string",
          "enum": [
            "outcome",
            "environment",
            "actuator",
            "llm",
            "knowledge",
            "system_state",
            "mission_process",
            "agent_team",
            "external_service"
          ]
        },
        "action": {
          "type": "string",
          "enum": [
            "create",
            "change",
            "inspect",
            "diagnose",
            "prepare",
            "verify",
            "activate",
            "query",
            "distill",
            "organize",
            "compose",
            "delegate",
            "execute",
            "review",
            "promote"
          ]
        },
        "object": { "type": "string", "minLength": 1 },
        "execution_shape": {
          "type": "string",
          "enum": [
            "direct_reply",
            "task_session",
            "mission",
            "project_bootstrap",
            "browser_session",
            "pipeline",
            "actuator_action"
          ]
        },
        "mission_class": {
          "type": "string",
          "enum": [
            "product_delivery",
            "code_change",
            "research_and_absorption",
            "content_and_media",
            "operations_and_release",
            "environment_and_recovery",
            "decision_support",
            "customer_engagement",
            "platform_onboarding"
          ]
        },
        "risk_profile": {
          "type": "string",
          "enum": ["low", "review_required", "approval_required", "high_stakes"]
        },
        "description": { "type": "string", "minLength": 1 },
        "surface_examples": {
          "type": "array",
          "items": { "type": "string" }
        },
        "plan_outline": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outcome_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "specialist_id": { "type": "string" },
        "trigger_keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "intake_requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resolution": { "$ref": "#/$defs/resolution" },
        "pipeline": {
          "type": "array",
          "items": { "$ref": "#/$defs/pipelineStep" }
        }
      },
      "required": [
        "id",
        "category",
        "legacy_category",
        "exposed_to_surface",
        "target",
        "action",
        "object",
        "execution_shape",
        "mission_class",
        "risk_profile",
        "description",
        "trigger_keywords",
        "outcome_ids"
      ]
    }
  }
}
