{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/mission-seed-record.schema.json",
  "title": "Mission Seed Record",
  "type": "object",
  "required": [
    "seed_id",
    "project_id",
    "title",
    "summary",
    "status",
    "specialist_id",
    "created_at"
  ],
  "properties": {
    "seed_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "track_id": { "type": "string" },
    "track_name": { "type": "string" },
    "source_task_session_id": { "type": "string" },
    "source_work_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["proposed", "ready", "promoted", "archived"]
    },
    "specialist_id": { "type": "string", "minLength": 1 },
    "outcome_id": { "type": "string" },
    "mission_type_hint": { "type": "string" },
    "locale": { "type": "string" },
    "work_loop": { "$ref": "./organization-work-loop.schema.json" },
    "promoted_mission_id": { "type": "string" },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
