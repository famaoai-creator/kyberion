{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "knowledge/public/schemas/contextual-intent-learning.schema.json",
  "title": "Contextual Intent Learning",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "entries"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "utterance",
        "intent_id",
        "action",
        "object",
        "subject",
        "source_binding",
        "clarification_needed",
        "confirmed",
        "tier",
        "locale",
        "recorded_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "utterance": {
          "type": "string",
          "minLength": 1
        },
        "intent_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": ["read", "change", "unknown"]
        },
        "object": {
          "type": "string",
          "enum": ["calendar_events", "calendar_schedule", "unknown"]
        },
        "subject": {
          "type": "string",
          "enum": ["operator_self", "team", "unknown"]
        },
        "date_range": {
          "type": "string",
          "enum": ["today", "tomorrow", "this_week", "next_week", "this_month", "next_month", "custom"]
        },
        "source_binding": {
          "type": "string",
          "enum": ["operator_default_calendar", "google_calendar", "outlook_calendar", "browser_calendar"]
        },
        "clarification_needed": {
          "type": "boolean"
        },
        "confirmed": {
          "type": "boolean"
        },
        "tier": {
          "type": "string",
          "enum": ["personal", "confidential", "public"]
        },
        "locale": {
          "type": "string",
          "enum": ["ja-JP", "en-US"]
        },
        "response_shape": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
