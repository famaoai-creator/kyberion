{
  "service_id": "media-generation",
  "name": "Kyberion Generative Media and Capture Unified Presets",
  "recovery_policy": {
    "fallback_strategy": "service_then_cli",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 500,
      "maxDelayMs": 10000,
      "factor": 2,
      "jitter": true
    },
    "retryable_categories": ["network", "rate_limit", "timeout", "resource_unavailable"]
  },
  "operations": {
    "generate_image": {
      "type": "auto",
      "alternatives": [
        {
          "type": "api",
          "base_url": "http://127.0.0.1:8188",
          "path": "prompt",
          "method": "POST",
          "payload_template": {
            "prompt": "{{workflow}}"
          },
          "output_mapping": { "prompt_id": "prompt_id" },
          "description": "Local ComfyUI image workflow via HTTP API"
        },
        {
          "type": "cli",
          "command": "/Users/famao/kyberion-runtimes/vision/venv/bin/comfy",
          "args": ["run", "--workflow", "{{workflow_path}}", "--wait"],
          "description": "Local ComfyUI image workflow via CLI"
        }
      ]
    },
    "generate_video": {
      "type": "auto",
      "alternatives": [
        {
          "type": "api",
          "base_url": "http://127.0.0.1:8188",
          "path": "prompt",
          "method": "POST",
          "payload_template": {
            "prompt": "{{workflow}}"
          },
          "output_mapping": { "prompt_id": "prompt_id" },
          "description": "Local ComfyUI video workflow via HTTP API"
        },
        {
          "type": "cli",
          "command": "/Users/famao/kyberion-runtimes/vision/venv/bin/comfy",
          "args": ["run", "--workflow", "{{workflow_path}}", "--wait"],
          "description": "Local ComfyUI video workflow via CLI"
        }
      ]
    },
    "generate_music": {
      "type": "auto",
      "alternatives": [
        {
          "type": "api",
          "base_url": "http://127.0.0.1:8188",
          "path": "prompt",
          "method": "POST",
          "payload_template": {
            "prompt": "{{workflow}}"
          },
          "output_mapping": { "prompt_id": "prompt_id" },
          "description": "Local ComfyUI audio/music workflow via HTTP API"
        },
        {
          "type": "cli",
          "command": "/Users/famao/kyberion-runtimes/vision/venv/bin/comfy",
          "args": ["run", "--workflow", "{{workflow_path}}", "--wait"],
          "description": "Local ComfyUI audio/music workflow via CLI"
        }
      ]
    },
    "run_workflow": {
      "type": "auto",
      "alternatives": [
        {
          "type": "api",
          "base_url": "http://127.0.0.1:8188",
          "path": "prompt",
          "method": "POST",
          "payload_template": {
            "prompt": "{{workflow}}"
          },
          "output_mapping": { "prompt_id": "prompt_id" },
          "description": "Generic ComfyUI workflow via HTTP API"
        },
        {
          "type": "cli",
          "command": "/Users/famao/kyberion-runtimes/vision/venv/bin/comfy",
          "args": ["run", "--workflow", "{{workflow_path}}", "--wait"],
          "description": "Generic ComfyUI workflow via CLI"
        }
      ]
    },
    "capture_screen": {
      "type": "cli",
      "command": "screencapture",
      "args": ["-x", "-t", "jpg", "{{output}}"],
      "description": "macOS Native Screen Capture"
    },
    "record_screen": {
      "type": "cli",
      "command": "ffmpeg",
      "args": ["-f", "avfoundation", "-i", "1:0", "-t", "{{duration}}", "-y", "{{output}}"],
      "description": "Screen Recording via FFmpeg"
    }
  }
}
