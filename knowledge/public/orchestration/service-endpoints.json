{
  "default_pattern": "https://api.{service_id}.com/v1",
  "services": {
    "aws-ce": {
      "base_url": "https://ce.us-east-1.amazonaws.com",
      "preset_path": "knowledge/public/orchestration/service-presets/aws-ce.json"
    },
    "backlog": {
      "base_url": "https://{{space}}.backlog.com/api/v2",
      "preset_path": "knowledge/public/orchestration/service-presets/backlog.json",
      "credential_suffixes": {
        "accessToken": [
          "API_KEY"
        ]
      }
    },
    "brave-search": {
      "preset_path": "knowledge/public/orchestration/service-presets/brave-search.json"
    },
    "canva": {
      "base_url": "https://api.canva.com/rest/v1",
      "preset_path": "knowledge/public/orchestration/service-presets/canva.json"
    },
    "comfyui": {
      "preset_path": "knowledge/public/orchestration/service-presets/comfyui.json"
    },
    "confluence": {
      "base_url": "https://{{domain}}.atlassian.net/wiki/api/v2",
      "preset_path": "knowledge/public/orchestration/service-presets/confluence.json"
    },
    "github": {
      "base_url": "https://api.github.com",
      "preset_path": "knowledge/public/orchestration/service-presets/github.json"
    },
    "github-mcp": {
      "preset_path": "knowledge/public/orchestration/service-presets/github-mcp.json"
    },
    "gitlab": {
      "base_url": "https://{{host}}.com/api/v4",
      "preset_path": "knowledge/public/orchestration/service-presets/gitlab.json"
    },
    "google-maps": {
      "preset_path": "knowledge/public/orchestration/service-presets/google-maps.json"
    },
    "google-workspace": {
      "preset_path": "knowledge/public/orchestration/service-presets/google-workspace.json",
      "allow_unsafe_cli": true
    },
    "jira": {
      "base_url": "https://atlassian.net/rest/api/3",
      "preset_path": "knowledge/public/orchestration/service-presets/jira.json"
    },
    "media-generation": {
      "preset_path": "knowledge/public/orchestration/service-presets/media-generation.json"
    },
    "meeting": {
      "preset_path": "knowledge/public/orchestration/service-presets/meeting.json"
    },
    "moltbook": {
      "base_url": "https://www.moltbook.com/api/v1"
    },
    "notion": {
      "base_url": "https://api.notion.com/v1",
      "preset_path": "knowledge/public/orchestration/service-presets/notion.json"
    },
    "slack": {
      "base_url": "https://slack.com/api",
      "preset_path": "knowledge/public/orchestration/service-presets/slack.json",
      "credential_suffixes": {
        "accessToken": [
          "ACCESS_TOKEN",
          "BOT_TOKEN",
          "TOKEN"
        ],
        "appToken": [
          "APP_TOKEN"
        ]
      }
    },
    "smoke-test": {
      "base_url": "https://postman-echo.com",
      "preset_path": "knowledge/public/orchestration/service-presets/smoke-test.json"
    },
    "sqlite": {
      "preset_path": "knowledge/public/orchestration/service-presets/sqlite.json"
    },
    "vision": {
      "preset_path": "knowledge/public/orchestration/service-presets/media-generation.json"
    },
    "voice": {
      "preset_path": "knowledge/public/orchestration/service-presets/voice.json"
    },
    "whisper": {
      "preset_path": "knowledge/public/orchestration/service-presets/whisper.json"
    },
    "youtube": {
      "preset_path": "knowledge/public/orchestration/service-presets/youtube.json"
    },
    "zendesk": {
      "base_url": "https://{{subdomain}}.zendesk.com/api/v2",
      "preset_path": "knowledge/public/orchestration/service-presets/zendesk.json"
    }
  }
}
