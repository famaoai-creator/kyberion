      "required_capabilities": ["reasoning", "coordination", "analysis"],
      "compatible_authority_roles": ["mission_controller", "ecosystem_architect"],
      "allowed_delegate_team_roles": ["planner", "implementer", "reviewer", "tester", "product_strategist", "experience_designer", "operator", "surface_liaison", "devils_advocate", "counterparty_persona", "facilitator", "relationship_curator"],
      "escalation_parent_team_role": null,
      "required_scope_classes": ["mission_state"],
      "ownership_scope": "Owns end-to-end mission objective, integration, and final acceptance.",
      "selection_hints": {
        "preferred_agents": ["nerve-agent", "sovereign-brain"],
        "preferred_models": ["auto-gemini-3"]
      },
      "autonomy_level": "high"
    },
    "planner": {
      "description": "Breaks mission intent into an execution strategy and task graph.",
