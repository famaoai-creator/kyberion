  },
  "pricing_defaults": {
    "cloud": {
      "compute_unit": 0.02,
      "storage_gb": 0.10,
      "bandwidth_gb": 0.05
    },
    "tokens": {
      "input_1k": 0.0005,
      "output_1k": 0.0015
    }
  }
}
