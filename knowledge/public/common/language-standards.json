{
  "v": "1.0.0",
  "supported_extensions": {
    "code": [".js", ".cjs", ".mjs", ".ts", ".tsx", ".py", ".go", ".rs", ".java", ".rb", ".cs", ".php", ".swift", ".kt"],
    "document": [".md", ".txt", ".pdf", ".docx", ".xlsx", ".pptx"],
    "data": [".json", ".yaml", ".yml", ".csv", ".xml"],
