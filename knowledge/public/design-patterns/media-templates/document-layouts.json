    "tracker": {
      "default_template": "operator-tracker-standard",
      "templates": {
        "operator-tracker-standard": {
          "document_profile": "operator-tracker",
          "locale": "en-US",
          "fonts": {
            "heading": "Aptos",
            "body": "Aptos"
          },
          "colors": {
            "primary": "#0F172A",
            "secondary": "#334155",
            "accent": "#2563EB",
            "background": "#FFFFFF",
            "text": "#111827",
            "success": "#DCFCE7",
            "warning": "#FEF3C7",
            "danger": "#FEE2E2",
            "info": "#DBEAFE",
            "muted": "#F8FAFC",
            "border": "#CBD5E1"
          },
          "layout": {
            "title_row_height": 30,
            "subtitle_row_height": 20,
            "summary_row_height": 20,
            "header_row_height": 22,
            "data_row_height": 20,
            "zoom_scale": 95,
            "freeze_header": true,
            "banded_rows": true,
            "default_column_width": 18
          },
          "tones": {
            "default": "info",
            "states": {
              "info": { "fill": "info", "text_color": "#111827", "bold": true },
              "success": { "fill": "success", "text_color": "#166534", "bold": true },
              "warning": { "fill": "warning", "text_color": "#92400E", "bold": true },
              "danger": { "fill": "danger", "text_color": "#991B1B", "bold": true }
            }
          },
          "validation_defaults": {
            "status": {
              "type": "list",
              "values": ["Done", "In Progress", "Watch", "Blocked"],
              "errorTitle": "Invalid Status",
              "error": "Use one of: Done, In Progress, Watch, Blocked"
            },
            "priority": {
              "type": "list",
              "values": ["P1", "P2", "P3"],
              "errorTitle": "Invalid Priority",
              "error": "Use one of: P1, P2, P3"
            },
            "type": {
              "type": "list",
              "values": ["Risk", "Assumption", "Issue", "Dependency"],
              "errorTitle": "Invalid Type",
              "error": "Use one of: Risk, Assumption, Issue, Dependency"
            }
          },
          "conditional_format_defaults": {
            "status": {
              "key_column": "status",
              "tones": {
                "Done": "success",
                "In Progress": "warning",
                "Watch": "danger",
                "Blocked": "danger"
              }
            },
            "overdue_finish": {
              "key_column": "finish",
              "status_column": "status",
              "done_values": ["Done"],
              "tone": "danger"
            }
          }
        }
      }
    }
