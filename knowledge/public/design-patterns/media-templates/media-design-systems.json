{
  "version": "1.0.0",
  "default_system": "executive-standard",
  "systems": {
    "executive-standard": {
      "theme": "kyberion-standard",
      "profiles": ["executive-proposal", "summary-report"],
      "branding": {
        "tone": "executive",
        "logo_url": "/assets/logos/kyberion-logo.png"
      },
      "tenant_overrides": {
        "client-a": {
          "matchers": ["aster bank", "client-a"],
          "theme": "client-a",
          "branding": {
            "brand_name": "Aster Bank",
            "logo_url": "/vault/tenants/client-a/logo.png",
            "tone": "corporate"
          }
        },
        "client-b": {
          "matchers": ["client-b"],
          "theme": "client-b",
          "branding": {
            "brand_name": "Client B",
            "tone": "modern"
          }
        }
      },
      "semantic_overrides": {
        "summary": {
          "pptx": {
            "body_font_size_delta": 1,
            "visual_fill_role": "accent"
          }
        },
        "decision": {
          "pptx": {
            "title_align": "center",
            "body_font_size_delta": 2
          }
        }
      },
      "slide_layout_overrides": {
        "decision-cta": {
          "body": {
            "style": {
              "fontSize": 20
            }
          }
        }
      }
    },
    "sovereign-vision": {
      "theme": "kyberion-sovereign",
      "profiles": ["vision-proposal"],
      "branding": {
        "tone": "visionary"
      },
      "semantic_overrides": {
        "hero": {
          "pptx": {
            "body_font_size_delta": 3,
            "body_color_role": "primary"
          }
        },
        "architecture": {
          "pptx": {
            "visual_fill_role": "accent",
            "visual_text_role": "primary"
          }
        }
      },
      "slide_layout_overrides": {
        "immersive-vision": {
          "title": {
            "style": {
              "fontSize": 28
            }
          }
        }
      }
    },
    "operator-ops": {
      "theme": "kyberion-standard",
      "profiles": ["operator-tracker"],
      "branding": {
        "tone": "operational"
      },
      "semantic_overrides": {
        "signals": {
          "tracker": {
            "priority": 0
          }
        },
        "execution": {
          "tracker": {
            "priority": 1
          }
        }
      }
    },
    "narrated-video": {
      "theme": "kyberion-standard",
      "profiles": ["narrated-howto-video", "product-walkthrough-video", "operator-demo-video"],
      "branding": {
        "tone": "operational",
        "caption_style": "lower-third"
      },
      "mode_overrides": {
        "howto": {
          "video": {
            "layout_family": "howto-guide",
            "density": "medium",
            "motion_profile": "guided-step",
            "caption_style": "lower-third",
            "typography_scale": "balanced",
            "overlay_density": "medium",
            "camera_distance": "wide"
          }
        },
        "promo": {
          "video": {
            "layout_family": "promo-spot",
            "density": "low",
            "motion_profile": "value-punch",
            "caption_style": "lower-third",
            "typography_scale": "expressive",
            "overlay_density": "dense",
            "camera_distance": "tight"
          }
        },
        "vtuber": {
          "video": {
            "layout_family": "vtuber-stage",
            "density": "medium",
            "motion_profile": "on-air",
            "caption_style": "lower-third",
            "typography_scale": "balanced",
            "overlay_density": "medium",
            "camera_distance": "medium-close"
          }
        }
      },
      "semantic_overrides": {
        "hook": {
          "video": {
            "layout_family": "hero",
            "density": "low",
            "motion_profile": "value-promise"
          }
        },
        "process": {
          "video": {
            "layout_family": "process-flow",
            "density": "medium",
            "motion_profile": "guided-step"
          }
        },
        "proof": {
          "video": {
            "layout_family": "evidence",
            "density": "medium",
            "motion_profile": "artifact-reveal"
          }
        },
        "demo": {
          "video": {
            "layout_family": "process-flow",
            "density": "medium",
            "motion_profile": "guided-step"
          }
        },
        "decision": {
          "video": {
            "layout_family": "decision",
            "density": "low",
            "motion_profile": "decisive"
          }
        },
        "cta": {
          "video": {
            "layout_family": "cta",
            "density": "low",
            "motion_profile": "minimal"
          }
        }
      }
    },
    "solution-architecture": {
      "theme": "aws-architecture",
      "profiles": ["solution-overview"],
      "branding": {
        "tone": "technical"
      },
      "semantic_overrides": {
        "architecture": {
          "pptx": {
            "visual_fill_role": "accent",
            "visual_text_role": "primary"
          }
        }
      }
    }
  }
}
