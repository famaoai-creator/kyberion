      "page_layout": "cover",
      "title": "Client Proposal",
      "subtitle": "A practical structure for discovery, scope alignment, and delivery confidence",
      "body": "Designed for consultative sales and implementation planning."
    },
    {
      "page_layout": "content",
      "title": "Agenda",
      "body": [
        "1. Current challenge and context",
        "2. Recommended solution shape",
        "3. Delivery plan and governance",
        "4. Commercial structure and next steps"
      ],
      "elements": [
        {
          "type": "shape",
          "shapeType": "roundRect",
          "pos": { "x": 5.8, "y": 1.6, "w": 2.8, "h": 1.8 },
