          "style": { "fill": "FEE2E2", "color": "991B1B", "fontSize": 18, "bold": true, "align": "center", "valign": "middle" }
        }
      ]
    },
    {
      "page_layout": "content",
      "title": "Proposed Solution",
      "body": [
        "Introduce a mission-driven operating model with governed execution.",
        "Standardize request intake, pattern-driven outputs, and review loops.",
        "Create reusable templates for leadership and delivery artifacts."
      ],
      "elements": [
        {
          "type": "shape",
