    {
      "page_layout": "content",
      "title": "Challenge",
      "body": [
        "Mission-critical work is delayed by context fragmentation.",
        "Teams lack a repeatable operating pattern for complex requests.",
        "Visibility is inconsistent across planning, execution, and review."
      ],
      "elements": [
        {
          "type": "shape",
          "shapeType": "rect",
          "pos": { "x": 5.8, "y": 1.5, "w": 2.8, "h": 2.0 },
