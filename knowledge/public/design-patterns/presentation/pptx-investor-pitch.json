          "style": { "fill": "FEE2E2", "color": "991B1B", "fontSize": 20, "bold": true, "align": "center", "valign": "middle" }
        }
      ]
    },
    {
      "page_layout": "content",
      "title": "Solution",
      "body": [
        "One operating layer for reasoning, execution, and memory.",
        "Mission-based workflows align strategy, change control, and validation.",
        "Actuators convert approved intent into digital output."
      ],
