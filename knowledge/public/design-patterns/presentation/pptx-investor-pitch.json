      "title": "Problem",
      "body": [
        "Teams rely on fragmented AI workflows that break at handoff points.",
        "High-value work still depends on manual translation from intent to execution.",
        "Operational trust declines when auditability is weak."
      ],
      "elements": [
        {
          "type": "shape",
          "shapeType": "rect",
          "pos": { "x": 5.7, "y": 1.5, "w": 3.0, "h": 2.2 },
