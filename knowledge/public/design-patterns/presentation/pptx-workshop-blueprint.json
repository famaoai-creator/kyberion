          "pos": { "x": 5.8, "y": 1.8, "w": 0.35, "h": 0.35 },
          "style": { "fill": "0EA5E9", "line": "0EA5E9" }
        },
        {
          "type": "shape",
          "shapeType": "ellipse",
          "pos": { "x": 7.1, "y": 1.8, "w": 0.35, "h": 0.35 },
          "style": { "fill": "0284C7", "line": "0284C7" }
        },
        {
          "type": "shape",
          "shapeType": "ellipse",
          "pos": { "x": 8.4, "y": 1.8, "w": 0.35, "h": 0.35 },
          "style": { "fill": "0369A1", "line": "0369A1" }
        }
      ]
    },
    {
      "page_layout": "content",
      "title": "Breakout Instructions",
      "body": [
        "Assign one owner per group and one scribe.",
        "Work from prompts, not open discussion.",
        "Return with one recommendation and one risk."
      ],
      "elements": [
        {
          "type": "shape",
          "shapeType": "rect",
          "pos": { "x": 5.8, "y": 1.4, "w": 2.8, "h": 2.1 },
