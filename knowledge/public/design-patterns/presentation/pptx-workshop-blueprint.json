      "page_layout": "cover",
      "title": "Workshop Blueprint",
      "subtitle": "A facilitation-ready slide structure for focused working sessions",
      "body": "Built for kickoff workshops, planning sessions, and alignment meetings."
    },
    {
      "page_layout": "content",
      "title": "Agenda",
      "body": [
        "Context and success criteria",
        "Review of current state",
        "Breakout work by theme",
        "Decision capture and next steps"
      ],
      "elements": [
        {
          "type": "shape",
          "shapeType": "roundRect",
          "pos": { "x": 5.8, "y": 1.5, "w": 2.8, "h": 1.8 },
          "text": "90 minutes\n4 segments",
          "style": { "fill": "DBEAFE", "color": "1D4ED8", "fontSize": 20, "bold": true, "align": "center", "valign": "middle" }
        }
      ]
    },
    {
      "page_layout": "content",
      "title": "Session Map",
      "body": [
        "Start with shared context to anchor decision quality.",
        "Use timed breakout prompts to generate options.",
        "End with explicit ownership and due dates."
      ],
      "elements": [
        {
          "type": "line",
          "pos": { "x": 5.8, "y": 2.0, "w": 3.0, "h": 0.0 },
