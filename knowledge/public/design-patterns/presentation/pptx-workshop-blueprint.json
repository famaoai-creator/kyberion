          "style": { "fill": "E0F2FE", "color": "075985", "fontSize": 18, "bold": true, "align": "center", "valign": "middle" }
        }
      ]
    },
    {
      "page_layout": "content",
      "title": "Action Plan",
      "body": [
        "Capture decisions while the group is present.",
        "Name owners and due dates before close.",
        "Schedule the follow-up checkpoint immediately."
      ],
