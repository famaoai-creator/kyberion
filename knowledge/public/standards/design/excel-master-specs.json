{
  "master_name": "Kyberion-Financial-Master",
  "styles": {
    "header": {
      "fill": { "type": "pattern", "pattern": "solid", "fgColor": { "argb": "FF232F3E" } },
      "font": { "color": { "argb": "FFFFFFFF" }, "bold": true, "size": 12 },
      "alignment": { "vertical": "middle", "horizontal": "center" },
      "border": { "bottom": { "style": "medium", "color": { "argb": "FFFF9900" } } }
    },
    "data_row": {
      "font": { "size": 11, "name": "Arial" },
      "alignment": { "vertical": "middle" }
    },
    "currency_cell": {
      "numFmt": "\"¥\"#,##0;[Red]\"¥\"-#,##0"
    },
    "total_row": {
      "font": { "bold": true, "size": 12 },
      "fill": { "type": "pattern", "pattern": "solid", "fgColor": { "argb": "FFF4F7F9" } },
      "border": { "top": { "style": "thin" }, "bottom": { "style": "double" } }
    }
  },
  "table_presets": {
    "TableStyleMedium2": {
      "header_row": { "bg": "FF4472C4", "font": "FFFFFFFF", "bold": true },
      "stripe_row": { "bg": "FFD9E1F2" },
      "whole_table": { "border": "FF4472C4" }
    },
    "TableStyleLight1": {
      "header_row": { "bg": "FFFFFFFF", "font": "FF000000", "bold": true, "border_bottom": "medium" },
      "whole_table": { "border": "FFD9D9D9" }
    }
  },
  "layout": {
    "default_column_width": 25,
    "hide_gridlines": true
  }
}
