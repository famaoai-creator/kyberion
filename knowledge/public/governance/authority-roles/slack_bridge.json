{
  "role": "slack_bridge",
  "description": "Slack gateway authority for channel ingress and observability.",
  "default_persona": "worker",
  "write_scopes": [
    "presence/bridge/runtime/",
    "active/shared/coordination/channels/slack/",
    "active/shared/coordination/orchestration/",
    "active/shared/observability/channels/slack/",
    "active/shared/observability/mission-control/",
    "active/audit/"
  ],
  "scope_classes": [
    "communication_surface",
    "coordination_runtime",
    "observability",
    "audit"
  ],
  "allowed_actuators": [
    "presence-actuator",
    "artifact-actuator",
    "approval-actuator"
  ],
  "tier_access": [
    "public",
    "confidential"
  ]
}
