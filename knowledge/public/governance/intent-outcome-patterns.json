  "patterns": [
    {
      "intent_id": "bootstrap-project",
      "canonical_flow": [
        "intent normalization",
        "project bootstrap task session",
        "project record creation",
        "default track resolution",
        "kickoff work and mission seed creation"
      ],
      "contract_layers": [
        "task_session",
        "organization_work_loop",
        "project_record",
        "mission_seed"
      ],
      "primary_outcome_ids": ["project_created"],
      "evidence": [
        "project record",
        "kickoff task session artifact",
        "bootstrap mission seeds"
      ],
      "completion_criteria": [
        "project record exists",
        "project has governed root path",
        "default track exists or resolves",
        "follow-up work items are seeded"
      ],
      "follow_up": [
        "Chronos or CLI can inspect tracks",
        "mission seed can be promoted"
      ]
    },
