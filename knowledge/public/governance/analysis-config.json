{
  "version": "1.0.0",
  "name": "Context Analysis Configuration",
  "description": "Parameters for co-occurrence analysis and graph generation.",
  "algorithms": {
    "cooccurrence": {
      "pipeline_dir": "pipelines",
      "skill_dir": "skills",
      "threshold": 1
    },
    "ranking": {
      "index_path": "knowledge/orchestration/knowledge_index.json",
      "weights": { "title": 10, "id": 5, "tag": 15, "category": 3, "role": 25 }
    },
    "graph": {
      "knowledge_dir": "knowledge",
      "output_path": "knowledge/Ecosystem_Map.md",
      "mermaid_theme": "base"
    }
  },
  "auto_update": { "related_skills": true, "related_knowledge": true }
}
