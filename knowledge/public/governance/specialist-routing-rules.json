{
  "version": "1.0.0",
  "rules": [
    {
      "id": "project-bootstrap",
      "match": {
        "intent_ids": ["bootstrap-project"],
        "shapes": ["project_bootstrap"]
      },
      "specialist_id": "project-lead"
    },
    {
      "id": "browser-routing",
      "match": {
        "intent_ids": ["open-site", "browser-step"],
        "shapes": ["browser_session"]
      },
      "specialist_id": "browser-operator"
    },
    {
      "id": "document-delivery",
      "match": {
        "intent_ids": ["generate-presentation", "generate-report", "generate-workbook"],
        "task_types": ["presentation_deck", "report_document", "workbook_wbs"]
      },
      "specialist_id": "document-specialist"
    },
    {
      "id": "service-operations",
      "match": {
        "intent_ids": ["inspect-service"],
        "task_types": ["service_operation"]
      },
      "specialist_id": "service-operator"
    },
    {
      "id": "knowledge-queries",
      "match": {
        "intent_ids": ["knowledge-query", "live-query"],
        "query_types": ["knowledge_search", "web_search", "weather", "location"]
      },
      "specialist_id": "knowledge-specialist"
    },
    {
      "id": "analysis-work",
      "match": {
        "intent_ids": ["cross-project-remediation", "incident-informed-review"],
        "task_types": ["analysis"]
      },
      "specialist_id": "knowledge-specialist"
    },
    {
      "id": "harness-evolution",
      "match": {
        "intent_ids": ["evolve-agent-harness"]
      },
      "specialist_id": "harness-engineer"
    }
  ],
  "fallback_specialist_id": "surface-concierge"
}
