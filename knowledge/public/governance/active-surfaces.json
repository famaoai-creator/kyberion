{
  "version": 1,
  "surfaces": [
    {
      "id": "presence-studio",
      "kind": "ui",
      "description": "Expressive realtime surface for subtitles, transcript, and voice-channel presence state.",
      "command": "node",
      "args": ["dist/presence/displays/presence-studio/server.js"],
      "cwd": ".",
      "shutdownPolicy": "detached",
      "startupMode": "workspace-app",
      "ownerType": "surface-runtime-manifest",
      "port": 3031,
      "healthPath": "/health",
      "enabled": true
    },
    {
      "id": "voice-hub",
      "kind": "service",
      "description": "Managed voice ingress service that emits governed voice stimuli and reflects them into the expressive surface.",
      "command": "node",
      "args": ["dist/satellites/voice-hub/server.js"],
      "cwd": ".",
      "shutdownPolicy": "detached",
      "startupMode": "background",
      "ownerType": "surface-runtime-manifest",
      "port": 3032,
      "healthPath": "/health",
      "enabled": true
    },
    {
      "id": "slack-bridge",
      "kind": "gateway",
      "description": "Slack Socket Mode ingress gateway and surface-agent host",
      "service_id": "slack",
      "preset_path": "knowledge/public/orchestration/service-presets/slack.json",
      "command": "node",
      "args": ["dist/satellites/slack-bridge/src/index.js"],
      "env": {
        "MISSION_ID": "MSN-SYSTEM-SENSORY-HUB",
        "KYBERION_PERSONA": "sovereign",
        "MISSION_ROLE": "slack_bridge"
      },
      "cwd": ".",
      "shutdownPolicy": "detached",
      "startupMode": "background",
      "ownerType": "surface-runtime-manifest",
      "enabled": true
    },
    {
      "id": "nexus-daemon",
      "kind": "service",
      "description": "Background system nerve daemon for stimuli routing and terminal dispatch",
      "command": "node",
      "args": ["dist/presence/bridge/nexus-daemon.js"],
      "cwd": ".",
      "shutdownPolicy": "detached",
      "startupMode": "background",
      "ownerType": "surface-runtime-manifest",
      "enabled": true
    },
    {
      "id": "terminal-bridge",
      "kind": "service",
      "description": "Background terminal bridge service for runtime sessions",
      "command": "pnpm",
      "args": ["--dir", "presence/bridge/terminal", "start"],
      "cwd": ".",
      "shutdownPolicy": "detached",
      "startupMode": "background",
      "ownerType": "surface-runtime-manifest",
      "enabled": true
    },
    {
      "id": "chronos-mirror-v2",
      "kind": "ui",
      "description": "Interactive Chronos control surface served as a workspace application",
      "command": "pnpm",
      "args": ["--dir", "presence/displays/chronos-mirror-v2", "start", "-H", "127.0.0.1", "-p", "3000"],
      "cwd": ".",
      "shutdownPolicy": "detached",
      "startupMode": "workspace-app",
      "ownerType": "surface-runtime-manifest",
      "port": 3000,
      "healthPath": "/api/agents",
      "enabled": true
    },
    {
      "id": "oauth-callback-surface",
      "kind": "service",
      "description": "Loopback-only OAuth callback receiver that completes token exchange into Personal-tier connections.",
      "command": "node",
      "args": ["dist/scripts/oauth_callback_surface.js"],
      "cwd": ".",
      "shutdownPolicy": "detached",
      "startupMode": "background",
      "ownerType": "surface-runtime-manifest",
      "port": 8787,
      "healthPath": "/health",
      "enabled": true
    }
  ]
}
