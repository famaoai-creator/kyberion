{
  "version": 1,
  "surfaces": [
    {
      "id": "presence-studio",
      "kind": "ui",
      "description": "Expressive realtime surface for subtitles, transcript, and voice-channel presence state.",
      "command": "node",
      "args": [
        "dist/presence/displays/presence-studio/server.js"
      ],
      "cwd": ".",
      "shutdownPolicy": "detached",
      "startupMode": "workspace-app",
      "ownerType": "surface-runtime-manifest",
      "port": 3031,
      "healthPath": "/health",
      "enabled": true
    }
  ]
}