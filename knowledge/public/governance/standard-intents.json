      "surface_examples": [
        "今週の進捗レポートを作って",
        "会議の報告書をdocxで作って"
      ],
      "plan_outline": ["collect the reporting context", "draft the document structure", "generate the report artifact"],
      "outcome_ids": ["artifact:docx"],
      "specialist_id": "document-specialist",
      "trigger_keywords": ["report", "docx", "pdf", "レポート", "報告書"],
      "resolution": {
        "shape": "task_session",
        "task_kind": "report_document",
        "result_shape": "artifact"
      }
    },
    {
      "id": "generate-workbook",
      "category": "surface",
      "description": "Create a workbook artifact such as an Excel WBS or structured sheet.",
      "surface_examples": [
        "プロジェクトのWBSをエクセルで作って",
        "座席表をxlsxにして"
      ],
      "plan_outline": ["collect the source structure", "map it into rows and columns", "generate the workbook artifact"],
      "outcome_ids": ["artifact:xlsx"],
