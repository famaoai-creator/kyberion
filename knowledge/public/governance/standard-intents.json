    {
      "id": "inspect-service",
      "category": "surface",
      "description": "Inspect service state or logs and return a concise summary.",
      "surface_examples": [
        "voice-hub の状態を見て",
        "presence-studio のログを見て"
      ],
      "plan_outline": ["inspect runtime state or logs", "distill the relevant signal", "return a concise summary"],
      "outcome_ids": ["service_summary", "approval_request"],
      "specialist_id": "service-operator",
      "trigger_keywords": ["status", "logs", "state", "状態", "ログ"],
      "resolution": {
        "shape": "task_session",
        "task_kind": "service_operation",
        "result_shape": "summary"
      }
    },
    {
      "id": "knowledge-query",
      "category": "surface",
      "description": "Search accumulated governed knowledge and return a concise answer with relevant sources.",
      "surface_examples": [
        "mission authority を教えて",
        "ナレッジで planner を調べて"
      ],
      "plan_outline": ["search governed knowledge", "rank the relevant sources", "return a concise answer with citations"],
      "intake_requirements": ["knowledge scope", "question or topic"],
      "outcome_ids": ["knowledge_answer"],
      "specialist_id": "knowledge-specialist",
      "trigger_keywords": ["knowledge", "ナレッジ", "調べて", "教えて"],
      "resolution": {
        "shape": "direct_reply",
        "result_shape": "knowledge_answer"
      }
    },
    {
      "id": "cross-project-remediation",
      "category": "surface",
      "description": "Review past requirements, incidents, or prior fixes and identify where the same bug or control gap must be propagated and remediated.",
      "surface_examples": [
        "過去の要件定義を横断的に見て横展開されていないバグを修正して",
        "Review prior requirements and find where the same bug still needs to be fixed",
        "同じ不具合が未展開のプロジェクトを洗い出して remediation plan を作って"
      ],
      "plan_outline": ["search governed requirements and prior evidence", "identify likely propagation gaps", "prepare a governed remediation plan and follow-up work"],
      "intake_requirements": ["source corpus", "target scope", "known issue or gap"],
      "outcome_ids": ["remediation_plan"],
      "specialist_id": "knowledge-specialist",
      "trigger_keywords": ["横断", "横展開", "未展開", "過去の要件定義", "不具合", "バグ", "requirements", "propagate", "propagation", "remediation", "same bug", "fix across"],
      "resolution": {
        "shape": "task_session",
        "task_kind": "analysis",
        "result_shape": "plan"
      }
    },
    {
      "id": "incident-informed-review",
      "category": "surface",
      "description": "Review code, design, or delivery scope in the light of prior incidents and return findings, risks, and required follow-up checks.",
      "surface_examples": [
        "過去のインシデント結果を踏まえてレビューを実施して",
        "Review this change based on prior incidents and known failures",
        "障害の振り返りを踏まえて今回の設計をレビューして"
      ],
      "plan_outline": ["search incident and failure history", "review the current target against those lessons", "return governed findings and follow-up checks"],
      "intake_requirements": ["incident basis", "review target", "expected decision or release scope"],
      "outcome_ids": ["review_findings"],
      "specialist_id": "knowledge-specialist",
      "trigger_keywords": ["インシデント", "障害", "振り返り", "レビュー", "known failures", "prior incidents", "incident-informed", "review based on", "postmortem"],
      "resolution": {
        "shape": "task_session",
        "task_kind": "analysis",
        "result_shape": "review"
      }
    },
    {
      "id": "evolve-agent-harness",
      "category": "surface",
      "description": "Improve an agent harness through a benchmark-driven experiment loop with baseline, one-change iteration, and governed keep or discard decisions.",
      "surface_examples": [
        "このエージェントのハーネスを benchmark ベースで改善して",
        "Improve this agent harness against the benchmark and keep only general wins",
        "program.md 方式で改善ループを定義してハーネスを良くして"
      ],
      "plan_outline": [
        "establish the target harness and protected edit boundary",
        "run the baseline benchmark or evaluation corpus",
        "cluster failure modes and choose one general improvement",
        "rerun evaluation and record keep or discard evidence"
      ],
      "intake_requirements": ["target harness", "evaluation corpus or benchmark", "success metric"],
      "outcome_ids": ["harness_experiment_report"],
      "specialist_id": "harness-engineer",
      "trigger_keywords": ["harness", "agent harness", "benchmark", "verifier", "score", "program.md", "meta-agent", "改善ループ", "ハーネス", "ベンチマーク", "評価", "keep", "discard"],
      "resolution": {
        "shape": "task_session",
        "task_kind": "analysis",
        "result_shape": "report"
      }
    },
    {
      "id": "live-query",
      "category": "surface",
      "description": "Return live information such as weather, location, or web search results.",
      "surface_examples": [
        "今日の天気を教えて",
        "今の場所を教えて",
        "WebでOpenAI Responses APIを検索して"
      ],
      "plan_outline": ["resolve the live query target", "fetch the current information", "summarize the answer for the surface"],
      "outcome_ids": ["live_answer"],
      "specialist_id": "knowledge-specialist",
      "trigger_keywords": ["weather", "location", "web", "search", "天気", "場所", "検索"],
      "resolution": {
        "shape": "direct_reply",
        "result_shape": "live_answer"
      }
    },
    {
      "id": "reconcile-ecosystem",
      "category": "operator",
      "description": "Perform full ecosystem reconciliation (dates, docs, integrity).",
      "trigger_keywords": ["sync", "reconcile", "update all"],
      "pipeline": [
        { "op": "wisdom:reconcile", "params": { "strategy_path": "knowledge/governance/wisdom-reconcile-strategy.json" } },
        { "op": "system:log", "params": { "message": "Full ecosystem reconciliation complete." } }
      ]
    },
    {
      "id": "audit-security",
      "category": "operator",
      "description": "Scan for PII and check pulse integrity.",
      "trigger_keywords": ["security", "audit", "pii", "check"],
      "pipeline": [
        { "op": "wisdom:scan_pii", "params": {} },
        { "op": "system:pulse_status", "params": { "export_as": "ledger_ok" } },
        { "op": "system:log", "params": { "message": "Security audit finished. Ledger valid: {{ledger_ok}}" } }
      ]
    },
    {
      "id": "rebuild-env",
      "category": "operator",
      "description": "Rebuild all actuators and redeploy ecosystem.",
      "trigger_keywords": ["rebuild", "deploy", "setup"],
      "pipeline": [
        { "op": "orchestrator:deploy", "params": {} },
        { "op": "system:log", "params": { "message": "Ecosystem rebuilt and redeployed." } }
      ]
    },
    {
      "id": "validate-all",
      "category": "operator",
      "description": "Validate all schemas and metadata.",
      "trigger_keywords": ["validate", "verify"],
      "pipeline": [
        { "op": "modeling:reconcile", "params": { "strategy_path": "knowledge/governance/modeling-strategy.json" } },
        { "op": "system:log", "params": { "message": "Schema validation complete." } }
      ]
    },
    {
      "id": "maintenance-routine",
      "category": "operator",
      "description": "Run routine maintenance tasks (fix shebangs, sanitize deps).",
      "trigger_keywords": ["maintenance", "sanitize", "fix"],
      "pipeline": [
        { "op": "code:reconcile", "params": { "strategy_path": "knowledge/governance/code-strategy.json" } },
        { "op": "system:log", "params": { "message": "Maintenance routine finished." } }
      ]
    }
  ]
}
