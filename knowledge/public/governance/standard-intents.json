        "3枚の要約スライドを作って"
      ],
      "plan_outline": ["gather required source material", "shape the deck outline", "generate the presentation artifact"],
      "outcome_ids": ["artifact:pptx"],
      "specialist_id": "document-specialist",
      "trigger_keywords": ["pptx", "powerpoint", "slides", "スライド", "パワポ", "パワーポイント"],
