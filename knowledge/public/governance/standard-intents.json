{
  "version": "2.0.0",
  "ux_contract": "Intent -> Plan -> State -> Result",
  "notes": [
    "This catalog is user-facing first. It describes what people ask Kyberion to do.",
    "Mission, task session, actuator, and ADF details remain backend execution concerns unless inspection is needed.",
    "Legacy operator and maintenance intents remain available for internal and operator use."
  ],
  "intents": [
    {
      "id": "bootstrap-project",
      "category": "surface",
      "description": "Create a new long-lived project context and prepare the first work items.",
      "surface_examples": [
        "Webサービスを作って",
        "新しいプロジェクトを立ち上げて",
        "新規事業の管理基盤を作って"
      ],
      "plan_outline": ["frame the project goal", "create a governed project record", "prepare the first work items"],
      "outcome_ids": ["project_created"],
      "specialist_id": "project-lead",
      "trigger_keywords": ["プロジェクト", "Webサービス", "作って", "立ち上げて", "build a service"],
      "resolution": {
        "shape": "project_bootstrap",
        "result_shape": "project_created"
      }
    },
    {
      "id": "capture-photo",
      "category": "surface",
      "description": "Capture a photo for record keeping, sharing, or OCR source use.",
      "surface_examples": [
        "ちょっと写真をとって",
        "共有用の写真を撮って",
        "この紙をOCR用に撮影して"
      ],
      "plan_outline": ["understand the capture purpose", "capture the governed image artifact", "return the stored result"],
      "outcome_ids": ["artifact:image"],
      "specialist_id": "surface-concierge",
      "trigger_keywords": ["写真", "撮影", "photo", "picture", "camera", "OCR"],
      "resolution": {
        "shape": "task_session",
        "task_kind": "capture_photo",
        "result_shape": "artifact"
      }
    },
    {
      "id": "open-site",
      "category": "surface",
      "description": "Open a website or navigate the active browser session to a requested destination.",
      "surface_examples": [
        "日経新聞を開いて",
        "Open OpenAI docs",
        "このサイトを見せて"
      ],
      "plan_outline": ["resolve destination", "open or focus browser", "navigate and confirm the page"],
      "outcome_ids": ["browser_navigation"],
      "specialist_id": "browser-operator",
      "trigger_keywords": ["open", "site", "browser", "開いて", "サイト", "見せて"],
      "resolution": {
        "shape": "browser_session",
        "result_shape": "browser_navigation"
      }
    },
    {
      "id": "browser-step",
      "category": "surface",
      "description": "Continue an active browser conversation session with a step command or confirmation.",
      "surface_examples": [
        "左下の承認ボタンを押して",
        "1つ目",
        "それで進めて"
      ],
      "plan_outline": ["understand the active browser step", "pick the intended target", "execute and report the outcome"],
      "outcome_ids": ["browser_step"],
      "specialist_id": "browser-operator",
      "trigger_keywords": ["押して", "クリック", "1つ目", "2つ目", "それ", "進めて"],
      "resolution": {
        "shape": "browser_session",
        "result_shape": "browser_step"
      }
    },
    {
      "id": "generate-presentation",
      "category": "surface",
      "description": "Create a presentation artifact such as a PowerPoint deck.",
      "surface_examples": [
        "このPDFをパワポにして",
