{
  "version": "2.0.0",
  "name": "Global Wisdom Distillation Policy",
  "description": "Rules for automated insight extraction and knowledge evolution.",
  "llm": {
    "profiles": {
      "heavy": {
        "description": "Deep reasoning — distillation, architectural review",
        "command": "claude",
        "args": ["-p", "{prompt}", "--model", "opus", "--output-format", "json"],
        "timeout_ms": 180000,
        "response_format": "json_envelope"
      },
      "standard": {
        "description": "General purpose — validation, summarization",
        "command": "claude",
        "args": ["-p", "{prompt}", "--output-format", "json"],
        "timeout_ms": 120000,
        "response_format": "json_envelope"
      },
      "light": {
        "description": "Fast, low-cost — tagging, classification",
        "command": "claude",
        "args": ["-p", "{prompt}", "--model", "haiku", "--output-format", "json"],
        "timeout_ms": 30000,
        "response_format": "json_envelope"
      }
    },
    "purpose_map": {
      "distill":   "heavy",
      "validate":  "standard",
      "summarize": "light",
      "classify":  "light"
    },
    "default_profile": "standard"
  },
  "rules": [
    {
      "id": "RULE-W001",
      "trigger": "mission_completion",
      "action": "distill_mission",
      "target_tier": "confidential",
      "output_dir": "knowledge/incidents"
    },
    {
      "id": "RULE-W002",
      "trigger": "scheduled_weekly",
      "action": "distill_ledger",
      "target_tier": "public",
      "output_dir": "knowledge/evolution"
    },
    {
      "id": "RULE-W003",
      "trigger": "manual_archive",
      "action": "distill_archives",
      "target_tier": "public",
      "output_dir": "knowledge/operations"
    }
  ],
  "tier_mapping": {
    "public": "knowledge/evolution",
    "confidential": "knowledge/incidents",
    "personal": "vault/private/wisdom"
  }
}
