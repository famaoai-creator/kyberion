        "knowledge/public/orchestration/",
        "active/shared/auth-grants.json"
      ],
      "allow_write": []
    },
    "nexus_daemon": {
      "allow_read": [
        "presence/bridge/runtime/",
        "presence/bridge/channel-registry.json",
        "active/shared/runtime/terminal/",
        "active/shared/logs/",
        "active/missions/MSN-SYSTEM-NERVE/",
        "active/audit/"
      ],
      "allow_write": [
        "presence/bridge/runtime/",
        "active/shared/runtime/terminal/",
        "active/shared/logs/",
        "active/missions/MSN-SYSTEM-NERVE/",
