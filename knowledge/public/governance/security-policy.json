{
  "$schema": "../../../schemas/governance-policy.schema.json",
  "version": "1.2.0",
  "default_allow": [
    "active/missions/${MISSION_ID}/",
    "active/shared/tmp/",
    "active/shared/exports/",
    "work/metrics/",
    "active/shared/runtime/"
  ],
  "tenant_scope": {
    "slug_pattern": "^[a-z][a-z0-9-]{1,30}$",
    "protected_prefixes": [
      "knowledge/confidential/"
    ],
    "shared_prefixes": [
      "knowledge/confidential/tenant-groups/",
      "knowledge/confidential/heuristics/",
      "knowledge/confidential/relationships/"
    ],
    "broker_requirements": {
      "require_approved_by": true,
      "require_approved_at": true,
      "require_expires_at": true
    }
  },
  "tier_restrictions": {
    "personal": {
      "allow_read": ["personal", "sovereign", "ecosystem_architect"],
      "allow_write": ["personal", "sovereign"],
      "block_message": "Sovereign Sanctuary: Access restricted to authorized personal processes only."
    },
    "confidential": {
      "allow_read": ["confidential", "public", "sovereign", "ecosystem_architect"],
      "allow_write": ["confidential", "sovereign", "ecosystem_architect"],
      "block_message": "Organization Confidential: Higher tier required."
    }
  },
  "persona_permissions": {
    "sovereign": {
      "allow_read": [
        ".git/",
        "active/",
        "customer/",
        "docs/",
        "knowledge/",
        "libs/",
        "pipelines/",
        "plugins/",
        "presence/",
        "satellites/",
        "schemas/",
        "scripts/",
        "tests/",
        "vault/",
        "work/",
        "README.md",
        "CAPABILITIES_GUIDE.md",
        "CONTRIBUTING.md",
        "AGENTS.md",
        "package.json",
        "pnpm-workspace.yaml",
        "tsconfig.json",
        "tsconfig.actuators.json",
        "vitest.config.mts"
      ],
      "allow_write": [
        ".git/",
        "active/",
        "customer/",
        "docs/",
        "knowledge/",
        "libs/",
        "pipelines/",
        "plugins/",
        "presence/",
        "satellites/",
        "schemas/",
        "scripts/",
        "tests/",
        "vault/",
        "work/",
        "README.md",
        "CAPABILITIES_GUIDE.md",
        "CONTRIBUTING.md",
        "AGENTS.md",
        "package.json",
        "pnpm-workspace.yaml",
        "tsconfig.json",
        "tsconfig.actuators.json",
        "vitest.config.mts"
      ]
    },
    "ecosystem_architect": {
      "allow_read": [
        "knowledge/",
        "libs/",
        "scripts/",
        "pipelines/",
        "schemas/",
        "presence/",
        "satellites/",
        "plugins/",
        "active/",
        "README.md",
        "CAPABILITIES_GUIDE.md",
        "CONTRIBUTING.md",
        "AGENTS.md",
        "extracted_design.json",
        "hoge.pdf"
      ],
      "allow_write": [
        "active/",
        "knowledge/",
        "libs/",
        "scripts/",
        "pipelines/",
        "schemas/",
        "presence/",
        "satellites/",
        "plugins/",
        "README.md",
        "CAPABILITIES_GUIDE.md",
        "CONTRIBUTING.md",
        "AGENTS.md",
        "extracted_design.json",
        "hoge.pdf"
      ]
    },
    "worker": {
      "allow_read": [
        "active/projects/",
        "active/shared/tmp/",
        "active/missions/${MISSION_ID}/",
        "knowledge/public/"
      ],
      "allow_write": [
        "active/projects/",
        "active/shared/tmp/",
        "active/missions/${MISSION_ID}/evidence/"
      ]
    },
    "analyst": {
      "allow_read": ["knowledge/", "active/audit/"],
      "allow_write": ["active/shared/tmp/", "knowledge/evolution/"]
    }
  },
  "authority_role_permissions": {
    "mission_controller": {
      "allow_read": [
        "active/missions/",
        "active/archive/missions/",
        "active/audit/",
        "active/shared/",
        "knowledge/personal/",
        "knowledge/confidential/",
        "knowledge/evolution/",
        "registry.json"
      ],
      "allow_write": [
        "active/missions/",
        "active/archive/missions/",
        "active/audit/",
        "active/shared/",
        "active/shared/coordination/",
        "active/shared/observability/mission-control/",
        "knowledge/personal/missions/",
        "knowledge/personal/governance/",
        "knowledge/evolution/",
        "vault/private/wisdom/",
        "registry.json"
      ]
    },
    "knowledge_steward": {
      "allow_read": [
        "customer/"
      ],
      "allow_write": [
        "customer/"
      ]
    },
    "run_pipeline": {
      "allow_write": [
        "active/shared/tmp/",
        "active/shared/logs/traces/",
        "customer/${KYBERION_CUSTOMER}/logs/traces/",
        "knowledge/public/governance/voice-profile-registry.json",
        "knowledge/public/governance/voice-engine-registry.json",
        "knowledge/public/governance/voice-engines/"
      ]
    },
    "run_super_pipeline": {
      "allow_write": [
        "active/shared/tmp/",
        "active/shared/logs/traces/",
        "customer/${KYBERION_CUSTOMER}/logs/traces/",
        "knowledge/public/governance/voice-profile-registry.json",
        "knowledge/public/governance/voice-engine-registry.json",
        "knowledge/public/governance/voice-engines/"
      ]
    },
    "software_developer": {
      "allow_read": [
        "active/projects/",
        "tests/",
        "libs/actuators/"
      ],
      "allow_write": [
        "active/projects/",
        "tests/",
        "libs/actuators/"
      ]
    },
    "ruthless_auditor": {
      "allow_read": ["active/audit/"],
      "allow_write": [
        "active/audit/"
      ]
    },
    "cyber_security": {
      "allow_read": [
        "active/audit/security/",
        "knowledge/security/"
      ],
      "allow_write": [
        "active/audit/security/",
        "knowledge/security/"
      ]
    },
    "infrastructure_sentinel": {
      "allow_read": [
        "active/shared/coordination/channels/",
        "active/shared/observability/",
        "active/shared/runtime/",
        "presence/bridge/runtime/"
      ],
      "allow_write": [
        "active/shared/coordination/channels/",
        "active/shared/observability/",
        "active/shared/runtime/",
        "presence/bridge/runtime/"
      ]
    },
    "slack_bridge": {
      "allow_read": [
        "presence/bridge/runtime/",
        "active/shared/coordination/channels/slack/",
        "active/shared/coordination/channels/chronos/outbox/",
        "active/shared/coordination/orchestration/",
        "active/shared/observability/channels/slack/",
        "active/shared/observability/mission-control/",
        "active/audit/"
      ],
      "allow_write": [
        "presence/bridge/runtime/",
        "active/shared/coordination/channels/slack/",
        "active/shared/coordination/channels/chronos/outbox/",
        "active/shared/coordination/orchestration/",
