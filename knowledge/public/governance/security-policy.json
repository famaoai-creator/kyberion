  "authority_permissions": {
    "SUDO": {
      "allow_read": ["/"],
      "allow_write": ["/"]
    },
    "KNOWLEDGE_WRITE": {
      "allow_read": ["knowledge/"],
      "allow_write": ["knowledge/"]
    },
    "GIT_WRITE": {
      "allow_read": [
        ".git/",
        "README.md",
        "AGENTS.md",
        "libs/",
        "scripts/",
        "tests/",
        "knowledge/",
        "satellites/",
        "presence/"
      ],
      "allow_write": [
        ".git/",
        "README.md",
        "AGENTS.md",
        "libs/",
        "scripts/",
        "tests/",
        "knowledge/",
        "satellites/",
        "presence/"
      ]
    },
    "SECRET_READ": {
      "allow_read": [
        "vault/",
        "knowledge/personal/connections/",
        "active/shared/auth-grants.json"
      ]
    },
    "NETWORK_FETCH": {
      "allow_read": ["knowledge/public/orchestration/"]
    },
    "SYSTEM_EXEC": {
      "allow_read": ["active/shared/tmp/", "active/shared/exports/"],
      "allow_write": ["active/shared/tmp/", "active/shared/exports/"]
    }
  },
  "project_permissions": {
    "canton-node": {
      "description": "Canton SV Node project data",
      "allowed_personas": ["ecosystem_architect"],
      "allowed_roles": ["SUDO", "canton-admin"]
    },
    "_default": {
      "description": "Default confidential access",
      "allowed_personas": ["ecosystem_architect"],
      "allowed_roles": ["SUDO"]
    }
  },
  "quality_requirements": {
    "require_test_success": true,
    "require_seal": false,
    "require_blockchain_anchor": false,
    "min_coverage_pct": 0
  },
  "a2a_policy": {
    "min_trust_score_personal": 8.0,
    "min_trust_score_confidential": 5.0,
    "mandatory_external_audit": true
  },
  "network_guardrails": {
    "allowed_domains": [
      "localhost",
      "127.0.0.1",
      "github.com",
      "api.github.com",
      "registry.npmjs.org",
      "pnpm.io",
      "google.com",
      "generativelanguage.googleapis.com",
      "canva.com",
      "api.canva.com"
    ],
    "max_request_size_kb": 2048,
    "max_requests_per_mission": 50,
    "leak_detection_enabled": true
  }
}
