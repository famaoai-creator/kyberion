{
  "$schema": "../../../schemas/governance-policy.schema.json",
  "version": "1.2.0",
  "default_allow": [
    "active/missions/${MISSION_ID}/",
    "active/shared/tmp/",
    "active/shared/exports/",
    "work/metrics/",
    "active/shared/runtime/"
  ],
  "tier_restrictions": {
    "personal": {
      "allow_read": ["personal", "sovereign", "ecosystem_architect"],
      "allow_write": ["personal", "sovereign"],
      "block_message": "Sovereign Sanctuary: Access restricted to authorized personal processes only."
    },
    "confidential": {
      "allow_read": ["confidential", "public", "sovereign", "ecosystem_architect"],
      "allow_write": ["confidential", "sovereign", "ecosystem_architect"],
      "block_message": "Organization Confidential: Higher tier required."
    }
  },
  "role_permissions": {
    "sovereign": {
      "allow_write": ["/"]
    },
    "ecosystem_architect": {
      "allow_write": [
        "active/",
        "knowledge/",
        "libs/",
        "scripts/",
        "pipelines/",
        "schemas/",
        "presence/",
        "satellites/",
        "plugins/",
        "README.md",
        "CAPABILITIES_GUIDE.md",
        "CONTRIBUTING.md",
        "AGENTS.md",
        "extracted_design.json",
        "hoge.pdf"
      ]
    },
    "mission_controller": {
      "allow_write": [
        "active/missions/",
        "active/archive/missions/",
        "active/audit/",
        "active/shared/",
        "knowledge/personal/missions/",
        "knowledge/personal/governance/",
        "knowledge/evolution/",
        "registry.json"
      ]
    },
    "worker": {
      "allow_write": [
        "active/projects/",
        "active/shared/tmp/",
        "active/missions/${MISSION_ID}/evidence/"
      ]
    },
    "analyst": {
      "allow_read": ["knowledge/", "active/audit/"],
      "allow_write": ["active/shared/tmp/", "knowledge/evolution/"]
    },
    "software_developer": {
      "allow_write": [
        "active/projects/",
        "tests/",
        "libs/actuators/"
      ]
    },
    "ruthless_auditor": {
      "allow_write": [
        "active/audit/"
      ]
    },
    "cyber_security": {
      "allow_write": [
        "active/audit/security/",
        "knowledge/security/"
      ]
    },
    "surface_runtime": {
      "allow_write": [
        "active/shared/runtime/",
        "active/shared/logs/surfaces/",
        "active/audit/"
      ]
    }
  },
  "quality_requirements": {
    "require_test_success": true,
    "require_seal": false,
    "require_blockchain_anchor": false,
    "min_coverage_pct": 0
  },
  "a2a_policy": {
    "min_trust_score_personal": 8.0,
    "min_trust_score_confidential": 5.0,
    "mandatory_external_audit": true
  },
  "network_guardrails": {
    "allowed_domains": [
      "localhost",
      "127.0.0.1",
      "github.com",
      "api.github.com",
      "registry.npmjs.org",
      "pnpm.io",
      "google.com",
      "generativelanguage.googleapis.com"
    ],
    "max_request_size_kb": 2048,
    "max_requests_per_mission": 50,
    "leak_detection_enabled": true
  }
}
