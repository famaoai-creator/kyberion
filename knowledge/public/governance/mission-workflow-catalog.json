{
  "version": "1.0.0",
  "defaults": {
    "workflow_id": "single-track-default"
  },
  "patterns": {
    "single_track_execution": {
      "description": "Single owner executes one bounded track and returns one primary result."
    },
    "coordinated_multi_track_execution": {
      "description": "One owner coordinates multiple domain tracks and integrates outputs."
    },
    "stage_gated_delivery": {
      "description": "Progression is gated by explicit review/approval checkpoints."
    },
    "exploratory_to_deterministic_conversion": {
      "description": "Start with exploration, then compile stable governed contracts for deterministic execution."
    },
    "pipeline_crystallization_loop": {
      "description": "Explore the work, crystallize the stable shape into a pipeline, then freeze it for reproducible execution."
    },
    "capability_lifecycle_procedure": {
      "description": "Discover, normalize, register, reconcile, activate, observe, refresh, and retire governed capabilities under a shared lifecycle skeleton."
    }
  },
  "templates": [
    {
      "id": "stage-gated-high-stakes",
      "pattern": "stage_gated_delivery",
      "description": "High-stakes work requiring explicit checkpoint gates.",
      "match": {
        "risk_profiles": ["high_stakes", "approval_required"],
        "execution_shapes": ["mission", "project_bootstrap"]
      },
      "phases": ["intake", "planning", "contract_authoring", "preflight", "execution", "verification", "delivery", "retrospective"]
    },
    {
      "id": "explore-then-govern",
      "pattern": "exploratory_to_deterministic_conversion",
      "description": "Use exploration before deterministic governed execution; this is the pre-pipeline crystallization path.",
      "match": {
        "delivery_shapes": ["interactive_exploration"]
      },
      "phases": ["intake", "classification", "planning", "contract_authoring", "execution", "verification", "delivery"]
    },
    {
      "id": "crystallize-then-freeze",
      "pattern": "pipeline_crystallization_loop",
      "description": "Convert an exploratory mission into a stable pipeline artifact, then freeze the stable execution shape.",
      "match": {
        "mission_classes": ["decision_support", "research_and_absorption", "operations_and_release"],
        "delivery_shapes": ["interactive_exploration", "multi_artifact_pipeline"]
      },
      "phases": ["intake", "classification", "planning", "normalization", "contract_authoring", "verification", "freeze", "delivery"]
    },
    {
      "id": "capability-reconcile-and-refresh",
      "pattern": "capability_lifecycle_procedure",
      "description": "Use the shared capability lifecycle skeleton to scan, normalize, register, reconcile, and refresh provider/gateway/platform capabilities.",
      "match": {
        "mission_classes": ["operations_and_release", "platform_onboarding"],
        "delivery_shapes": ["multi_artifact_pipeline", "task_session"],
        "risk_profiles": ["review_required", "approval_required", "high_stakes"]
      },
      "phases": ["intake", "classification", "planning", "discovery", "normalization", "registration", "reconciliation", "activation", "observation", "refresh", "retirement", "delivery"]
    },
    {
      "id": "coordinated-multi-track",
      "pattern": "coordinated_multi_track_execution",
      "description": "Cross-system work requiring a coordinated owner and delegated specialists.",
      "match": {
        "delivery_shapes": ["cross_system_change", "multi_artifact_pipeline"],
        "execution_shapes": ["mission", "project_bootstrap", "task_session"]
      },
      "phases": ["intake", "classification", "planning", "contract_authoring", "execution", "verification", "delivery"]
    },
    {
      "id": "decision-support-exploratory",
      "pattern": "exploratory_to_deterministic_conversion",
      "description": "Decision-support missions start interactive (stakeholder 1-on-1s, hypothesis divergence, rehearsal) and end producing governed evidence artifacts (readiness_matrix / dissent-log / heuristic-entry).",
      "match": {
        "mission_classes": ["decision_support"]
      },
      "phases": ["intake", "classification", "planning", "execution", "verification", "delivery", "retrospective"]
    },
    {
      "id": "customer-engagement-stage-gated",
      "pattern": "stage_gated_delivery",
      "description": "Customer-facing missions (requirements elicitation, discovery, kickoff) route through stage-gated delivery so the transcript → draft → review → customer signoff sequence is explicit.",
      "match": {
        "mission_classes": ["customer_engagement"]
      },
      "phases": ["intake", "classification", "planning", "contract_authoring", "execution", "verification", "delivery", "retrospective"]
    },
    {
      "id": "platform-onboarding-stage-gated",
      "pattern": "stage_gated_delivery",
      "description": "Platform onboarding missions (organization integration, secrets rotation, adapter registration) route through strict stage gates — cross_system_change delivery, SECURITY_READY and ARCHITECTURE_READY required, because these touch governance-scope config.",
      "match": {
        "mission_classes": ["platform_onboarding"]
      },
      "phases": ["intake", "classification", "planning", "contract_authoring", "preflight", "execution", "verification", "delivery", "retrospective"]
    },
    {
      "id": "deterministic-patrol-aggregation",
      "pattern": "pipeline_crystallization_loop",
      "description": "Deterministic multi-site patrol workflow. Use pipelines/fragments/executive-report-patrol.json after session handoff and target list are bound.",
      "match": {
        "mission_classes": ["operations_and_release"],
        "delivery_shapes": ["multi_artifact_pipeline"],
        "intent_ids": ["generate-report"]
      },
      "phases": ["intake", "planning", "session_handoff", "execution", "normalization", "delivery"]
    },
    {
      "id": "governed-content-narration",
      "pattern": "coordinated_multi_track_execution",
      "description": "Governed presentation narration workflow. Use pipelines/fragments/governed-voice-narration.json when PPTX input and voice profile are available.",
      "match": {
        "mission_classes": ["content_and_media"],
        "delivery_shapes": ["multi_artifact_pipeline"],
        "intent_ids": ["generate-presentation"]
      },
      "phases": ["intake", "design", "generation", "narration_layer", "rendering", "delivery"]
    },
    {
      "id": "gated-incident-containment",
      "pattern": "stage_gated_delivery",
      "description": "High-integrity security incident containment workflow. Use pipelines/fragments/security-incident-containment.json with explicit approval and audit gates.",
      "match": {
        "mission_classes": ["operations_and_release"],
        "delivery_shapes": ["cross_system_change"],
        "risk_profiles": ["high_stakes", "approval_required"]
      },
      "phases": ["triage", "evidence_collection", "approval_gate", "containment", "audit_finalization", "delivery"]
    },
    {
      "id": "loyalty-mediated-purchase",
      "pattern": "coordinated_multi_track_execution",
      "description": "Purchase workflow through point/loyalty sites. Chain browser-point-site-hop and browser-purchase-checkout fragments, with payment approval gated.",
      "match": {
        "mission_classes": ["operations_and_release"],
        "delivery_shapes": ["single_artifact"],
        "risk_profiles": ["approval_required"]
      },
      "phases": ["intake", "point_site_hop", "item_selection", "checkout_preflight", "approval_gate", "payment", "delivery"]
    },
    {
      "id": "travel-booking-end-to-end",
      "pattern": "stage_gated_delivery",
      "description": "End-to-end travel booking workflow. Chain browser-travel-search-select and browser-purchase-checkout fragments with selection rationale and payment approval.",
      "match": {
        "mission_classes": ["operations_and_release"],
        "delivery_shapes": ["single_artifact"],
        "risk_profiles": ["approval_required"]
      },
      "phases": ["intake", "search_options", "selection_recommendation", "checkout_preflight", "approval_gate", "payment", "delivery"]
    },
    {
      "id": "meeting-proxy-live-participation",
      "pattern": "stage_gated_delivery",
      "description": "Live meeting proxy workflow for Zoom/Teams/Meet browser participation. Requires meeting-participation-runtime readiness and voice consent before speaking.",
      "match": {
        "mission_classes": ["operations_and_release"],
        "delivery_shapes": ["cross_system_change", "multi_artifact_pipeline"],
        "risk_profiles": ["approval_required", "high_stakes"],
        "intent_ids": ["meeting-operations"]
      },
      "phases": ["intake", "briefing", "environment_bootstrap", "voice_consent", "browser_participation", "transcript_capture", "postprocess", "delivery"]
    },
    {
      "id": "ai-meeting-facilitator-followup",
      "pattern": "coordinated_multi_track_execution",
      "description": "AI meeting facilitator workflow. Run the live meeting flow, extract action items, dispatch operator-owned work, and track team-member follow-up.",
      "match": {
        "mission_classes": ["operations_and_release"],
        "delivery_shapes": ["multi_artifact_pipeline"],
        "intent_ids": ["meeting-operations"],
        "task_types": ["meeting_operations"]
      },
      "phases": ["intake", "agenda_and_role_boundary", "live_facilitation", "postprocess", "self_execution", "team_tracking", "delivery"]
    },
    {
      "id": "action-item-tracking-followup",
      "pattern": "stage_gated_delivery",
      "description": "Cron-able action-item follow-up workflow backed by action-item-store. Restricted or non-declarative items remain gated until explicit confirmation.",
      "match": {
        "mission_classes": ["operations_and_release"],
        "delivery_shapes": ["single_artifact", "long_running_job"],
        "risk_profiles": ["review_required"]
      },
      "phases": ["load_pending_items", "policy_filter", "reminder_generation", "append_reminder_receipts", "delivery"]
    },
    {
      "id": "single-track-default",
      "pattern": "single_track_execution",
      "description": "Default workflow for straightforward bounded work.",
      "match": {
        "delivery_shapes": ["single_artifact", "long_running_job", "*"],
        "execution_shapes": ["direct_reply", "task_session", "mission", "project_bootstrap"]
      },
      "phases": ["intake", "planning", "execution", "verification", "delivery"]
    }
  ]
}
