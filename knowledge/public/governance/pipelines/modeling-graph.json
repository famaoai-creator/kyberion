{
  "action": "pipeline",
  "steps": [
    {
      "id": "load-index",
      "type": "capture",
      "op": "read_json",
      "params": { "path": "knowledge/public/orchestration/global_actuator_index.json", "export_as": "index_data" }
    },
    {
      "id": "query-actuators",
      "type": "transform",
      "op": "json_query",
      "params": { "from": "index_data", "path": "actuators", "export_as": "actuator_list" }
    },
    {
      "id": "gen-mermaid",
      "type": "transform",
      "op": "mermaid_gen",
      "params": { "from": "actuator_list", "export_as": "mermaid_code" }
    },
    {
      "id": "write-graph",
      "type": "apply",
      "op": "write_file",
      "params": { "path": "docs/developer/architecture/dependency-graph.mmd", "from": "mermaid_code" }
    },
    {
      "id": "log-success",
      "type": "apply",
      "op": "log",
      "params": { "message": "Mermaid dependency graph generated at docs/developer/architecture/dependency-graph.mmd" }
    }
  ]
}
