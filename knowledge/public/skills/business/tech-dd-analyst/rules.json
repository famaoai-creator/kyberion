      { "path": "team.contributors", "op": ">=", "value": 3, "points": 5 },
      { "path": "arch.hasMonorepo", "op": "===", "value": true, "points": 10 },
      { "path": "arch.testFramework", "op": "!==", "value": "none", "points": 10 }
