{
  "web_search": {
    "enabled": true,
    "provider": "duckduckgo_html",
    "maxResults": 3,
    "timeoutMs": 5000
  },
  "weather": {
    "enabled": true,
    "provider": "open_meteo",
    "geocodingUrl": "https://geocoding-api.open-meteo.com/v1/search",
    "forecastUrl": "https://api.open-meteo.com/v1/forecast",
    "timeoutMs": 5000
  },
  "location": {
    "enabled": true,
    "provider": "presence_context",
    "providers": [
      {
        "id": "ipapi",
        "provider": "ipapi",
        "url": "https://ipapi.co/json/"
      },
      {
        "id": "ipwho",
        "provider": "ipwho",
        "url": "https://ipwho.is/"
      }
    ]
  },
  "knowledge": {
    "enabled": true,
    "provider": "context_ranker",
    "limit": 4,
    "scope": "repository",
    "phase": "alignment",
    "role": "presence_surface_agent"
  }
}
