{
  "version": "1.1.0",
  "rules": [
    {
      "id": "service-mutation",
      "intent_ids": ["inspect-service"],
      "when": {
        "payload_field": "operation",
        "any_of": ["restart", "start", "stop"]
      },
      "requires_approval": true,
      "missing_requirements": ["approval_confirmation"]
    },
    {
      "id": "secret-grant-access",
      "intent_ids": ["secret:grant_access"],
      "requires_approval": true,
      "missing_requirements": ["dual_key_confirmation"]
    },
    {
      "id": "auth-grant-authority",
      "intent_ids": ["auth:grant_authority"],
      "requires_approval": true,
      "missing_requirements": ["dual_key_confirmation"]
    },
    {
      "id": "config-policy-update",
      "intent_ids": ["config:update"],
      "when": {
        "payload_field": "scope",
        "any_of": ["governance", "policy", "review_gate"]
      },
      "requires_approval": true,
      "missing_requirements": ["approval_confirmation"]
    },
    {
      "id": "vault-direct-write",
      "intent_ids": ["vault:write"],
      "requires_approval": true,
      "missing_requirements": ["dual_key_confirmation"]
    },
    {
      "id": "claude-browser-interactive",
      "intent_ids": ["claude:browser_interactive"],
      "requires_approval": true,
      "missing_requirements": ["approval_confirmation"]
    },
    {
      "id": "claude-document-generation",
      "intent_ids": ["claude:document_generation"],
      "requires_approval": true,
      "missing_requirements": ["approval_confirmation"]
    },
    {
      "id": "browser-extension-execute",
      "intent_ids": ["browser:extension_execute"],
      "requires_approval": true,
      "missing_requirements": ["approval_confirmation"]
    },
    {
      "id": "customer-outbound-send",
      "intent_ids": ["customer:outbound"],
      "requires_approval": true,
      "missing_requirements": ["approval_confirmation"]
    },
    {
      "id": "security-audit-deliver",
      "intent_ids": ["security-audit-service", "security-audit:deliver"],
      "requires_approval": true,
      "missing_requirements": ["approval_confirmation"]
    },
    {
      "id": "feature-expansion-release",
      "intent_ids": ["feature-expansion-delivery", "feature-expansion:release"],
      "requires_approval": true,
      "missing_requirements": ["approval_confirmation"]
    }
  ],
  "defaults": {
    "requires_approval": false
  }
}
