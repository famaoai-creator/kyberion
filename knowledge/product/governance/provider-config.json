{
  "version": "1.0.0",
  "description": "Agent provider configuration. Defines default provider priority, default model IDs, and lifecycle boot commands. Read by agent-provider-resolution.ts and agent-lifecycle.ts. Edit here to change provider order or upgrade model IDs without code changes.",
  "default_priority": ["agy", "gemini", "claude", "codex", "copilot"],
  "default_models": {
    "agy": "agy",
    "gemini": "gemini-3.5-flash",
    "claude": "claude-opus-4-8",
    "codex": "gpt-5.5",
    "copilot": "claude-sonnet-4-6"
  },
  "runtime_defaults": {
    "anthropic-default": "claude-opus-4-8",
    "anthropic-fast": "claude-sonnet-5",
    "gemini-default": "gemini-3.5-flash",
    "gemini-fast": "gemini-3.1-flash-lite",
    "openai-vision": "gpt-5.5",
    "codex-default": "gpt-5.5",
    "copilot-default": "claude-sonnet-4-6"
  },
  "lifecycle": {
    "gemini": {
      "boot_command": "gemini",
      "boot_args": ["--acp", "-y"],
      "default_model": "gemini-3.5-flash"
    },
    "copilot": {
      "boot_command": "gh",
      "boot_args": ["copilot", "--", "--acp", "--allow-all"],
      "default_model": "claude-sonnet-4-6"
    }
  }
}
