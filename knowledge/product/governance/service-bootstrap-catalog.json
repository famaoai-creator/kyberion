{
  "version": "1.0.0",
  "entries": [
    {
      "id": "github-new-project",
      "service_id": "github",
      "service_type": "github",
      "binding_id": "github:default:new-project",
      "scope": "repository",
      "target": "default/new-project",
      "allowed_actions": [
        "read",
        "push_branch",
        "pull_request"
      ],
      "utterance_patterns": [
        {
          "type": "regex",
          "value": "(github|git hub|webサービス|web service)"
        }
      ],
      "summary": "Default repository bootstrap binding for new web service projects."
    },
    {
      "id": "google-workspace-workspace",
      "service_id": "google-workspace",
      "service_type": "google-workspace",
      "binding_id": "google-workspace:default:workspace",
      "scope": "workspace",
      "target": "default",
      "allowed_actions": [
        "read",
        "send_message",
        "create_event",
        "create_doc"
      ],
      "utterance_patterns": [
        {
          "type": "regex",
          "value": "\\b(gmail|calendar|drive|docs|sheets|meet|google workspace)\\b"
        }
      ],
      "summary": "Default Google Workspace binding for mail, calendar, docs, and drive workflows."
    },
    {
      "id": "m365-workspace",
      "service_id": "m365",
