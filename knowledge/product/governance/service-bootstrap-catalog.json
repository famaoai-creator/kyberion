      "utterance_patterns": [
        {
          "type": "regex",
          "value": "\\b(outlook|teams|sharepoint|onedrive|microsoft 365|m365)\\b"
        }
      ],
      "summary": "Default Microsoft 365 binding for email, calendar, and collaboration workflows."
    },
