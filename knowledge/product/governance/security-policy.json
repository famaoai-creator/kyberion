{
  "$schema": "../../../schemas/governance-policy.schema.json",
  "version": "1.3.0",
  "default_allow": [
    "active/missions/${MISSION_ID}/",
    "active/missions/confidential/${MISSION_ID}/",
    "active/missions/personal/${MISSION_ID}/",
    "active/missions/public/${MISSION_ID}/",
    "active/shared/tmp/",
    "active/shared/exports/",
    "work/metrics/",
    "active/shared/runtime/",
    "active/audit/",
    "active/shared/logs/",
    "active/shared/runtime/session/",
    "active/shared/runtime/ttl/",
    "active/shared/MEMORY.md",
    "active/shared/MEMORY.volatile.json",
    "active/INDEX.volatile.md",
    "active/INDEX.volatile.json",
    "active/personal/"
  ],
  "volatile_face_policy": {
    "description": "Volatile Knowledge Layer (working-memory) path governance. tier_restrictions apply — active/personal/ is personal tier only.",
    "paths": {
      "session": "active/shared/runtime/session/<session_id>/",
      "mission": "active/missions/<TIER>/<MISSION_ID>/MEMORY.md",
      "project": "active/projects/<TIER>/<project>/MEMORY.md",
      "personal": "active/personal/",
      "global": "active/shared/MEMORY.md",
      "daily_journal": "active/personal/journal/<YYYY-MM-DD>.md",
      "today_todo": "active/personal/today/TODO.md",
      "weekly": "active/personal/weekly/<YYYY>-W<WW>.md",
      "adhoc_ttl": "active/shared/runtime/ttl/"
    },
    "personal_tier_paths": ["active/personal/"],
    "sidecar_pattern": "*.volatile.json",
    "schema_ref": "schemas/volatile-knowledge.schema.json"
  },
  "tenant_scope": {
    "slug_pattern": "^[a-z][a-z0-9-]{1,30}$",
    "protected_prefixes": ["knowledge/confidential/"],
    "shared_prefixes": [
      "knowledge/confidential/tenant-groups/",
      "knowledge/confidential/heuristics/",
      "knowledge/confidential/relationships/"
    ],
    "broker_requirements": {
      "require_approved_by": true,
      "require_approved_at": true,
      "require_expires_at": true
    }
  },
  "tier_restrictions": {
    "personal": {
      "allow_read": ["personal", "sovereign", "ecosystem_architect"],
      "allow_write": ["personal", "sovereign"],
      "block_message": "Sovereign Sanctuary: Access restricted to authorized personal processes only."
    },
    "confidential": {
      "allow_read": ["confidential", "public", "sovereign", "ecosystem_architect"],
      "allow_write": ["confidential", "sovereign"],
      "block_message": "Organization Confidential: Higher tier required."
    },
    "product": {
      "allow_read": ["sovereign", "ecosystem_architect", "worker", "analyst"],
      "allow_write": ["sovereign", "ecosystem_architect"],
      "block_message": "Product tier: Kyberion system content. Ecosystem Architect persona required to write."
    }
  },
  "persona_permissions": {
    "sovereign": {
      "allow_read": [
        ".git/",
        "active/",
        "customer/",
        "docs/",
        "knowledge/",
        "libs/",
