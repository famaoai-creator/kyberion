  "authority_permissions": {
    "SUDO": {
      "allow_read": ["/"],
      "allow_write": ["/"]
    },
    "KNOWLEDGE_WRITE": {
      "allow_read": ["knowledge/"],
      "allow_write": ["knowledge/"]
    },
    "GIT_WRITE": {
      "allow_read": [
        ".git/",
        "README.md",
        "AGENTS.md",
        "libs/",
        "scripts/",
        "tests/",
        "knowledge/",
        "satellites/",
        "presence/"
