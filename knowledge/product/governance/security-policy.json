        "satellites/",
        "presence/"
      ]
    },
    "SECRET_READ": {
      "allow_read": ["vault/", "knowledge/personal/connections/", "active/shared/auth-grants.json"]
    },
    "NETWORK_FETCH": {
      "allow_read": ["knowledge/product/orchestration/"]
    },
    "SYSTEM_EXEC": {
      "allow_read": ["active/shared/tmp/", "active/shared/exports/"],
      "allow_write": ["active/shared/tmp/", "active/shared/exports/"]
