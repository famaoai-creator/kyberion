    "stub": {
      "adapter": "stub",
      "selection": {
        "display_name": "Deterministic stub (offline)",
        "availability": { "kind": "always" }
      },
      "capabilities": ["text", "structured_output"],
      "supported_parameters": []
    }
  },
  "profiles": {
    "default-codex": {
      "mode": "codex-cli",
      "model_ref": "openai:gpt-5.6-sol",
      "capabilities": ["text", "structured_output", "tools"],
      "tools_enabled": true,
      "allowed_tools": ["read_file", "list_directory"]
    },
    "claude-cli-default": {
      "mode": "claude-cli",
      "capabilities": ["text", "structured_output", "tools"]
    },
    "gemini-cli-default": {
      "mode": "gemini-cli",
      "capabilities": ["text", "structured_output", "tools"]
    },
    "copilot-default": {
      "mode": "copilot",
      "capabilities": ["text", "structured_output", "tools"]
    },
    "anthropic-default": {
      "mode": "anthropic",
      "capabilities": ["text", "structured_output", "tools", "vision"]
    },
    "openrouter-default": {
      "mode": "openrouter",
      "capabilities": ["text", "structured_output", "tools", "vision"]
    },
    "nemotron-default": { "mode": "nemotron-api", "capabilities": ["text", "structured_output"] },
    "ollama-default": { "mode": "ollama", "capabilities": ["text", "structured_output"] },
    "vllm-default": { "mode": "vllm", "capabilities": ["text", "structured_output"] },
    "lmstudio-default": { "mode": "lmstudio", "capabilities": ["text", "structured_output"] },
    "llamacpp-default": { "mode": "llamacpp", "capabilities": ["text", "structured_output"] },
    "mlx-default": { "mode": "mlx", "capabilities": ["text", "structured_output"] },
    "localai-default": { "mode": "localai", "capabilities": ["text", "structured_output"] },
    "local-default": { "mode": "local", "capabilities": ["text", "structured_output"] },
    "stub-default": { "mode": "stub", "capabilities": ["text", "structured_output"] },
    "agy-default": {
      "mode": "agy-cli",
      "capabilities": ["text", "structured_output", "tools"],
      "tools_enabled": true,
      "allowed_tools": ["read_file", "list_directory"]
    },
    "subagent-local": {
      "mode": "ollama",
      "capabilities": ["text", "structured_output", "tools"],
      "timeout_ms": 60000
    },
    "code-architect-claude": {
      "mode": "anthropic",
      "model_ref": "anthropic:claude-sonnet-5",
      "capabilities": ["text", "structured_output", "tools", "vision"],
      "tools_enabled": true,
      "allowed_tools": ["read_file", "list_directory"]
    },
    "fast-local": {
      "mode": "vllm",
      "capabilities": ["text", "structured_output"],
      "timeout_ms": 30000
    }
  },
  "roles": {
    "default": { "candidates": ["default-codex", "agy-default"], "requires": ["text"] },
    "subagent": {
      "candidates": ["subagent-local", "default-codex", "agy-default"],
      "requires": ["text", "structured_output"]
    },
    "code_architect": {
      "candidates": ["code-architect-claude", "default-codex"],
      "requires": ["text", "structured_output", "tools"]
    },
    "fast_classifier": {
      "candidates": ["fast-local", "default-codex"],
      "requires": ["text", "structured_output"]
    },
    "researcher": {
      "candidates": ["default-codex", "code-architect-claude"],
      "requires": ["text", "structured_output"]
    }
  },
  "fallback": { "max_attempts": 3, "max_in_place_retries": 3, "on_unsupported_parameter": "reject" }
}
