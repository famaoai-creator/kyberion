        "availability": {
          "kind": "env_any",
          "names": ["KYBERION_OLLAMA_URL", "OLLAMA_HOST", "KYBERION_LOCAL_LLM_URL"]
        }
      },
      "preset": "ollama",
      "endpoint_policy": "local",
      "model_policy": "local-unregistered",
      "capabilities": ["text", "structured_output"],
      "supported_parameters": [
        "temperature",
        "top_p",
        "top_k",
        "min_p",
        "stop",
        "presence_penalty",
