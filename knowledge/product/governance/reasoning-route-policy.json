{
  "version": "1.0.0",
  "runtime_adapters": {
    "codex-cli": {
      "adapter": "codex-cli",
      "selection": {
        "display_name": "Codex CLI",
        "model_provider": "openai",
        "discovery_provider": "codex",
        "availability": { "kind": "provider_discovery" }
      },
      "capabilities": ["text", "structured_output", "tools"],
      "supported_parameters": ["effort"]
    },
    "agy-cli": {
      "adapter": "agy-cli",
      "selection": {
        "display_name": "Agy CLI",
        "model_provider": "gemini",
        "discovery_provider": "agy",
        "availability": { "kind": "provider_discovery" }
      },
      "capabilities": ["text", "structured_output", "tools"],
      "supported_parameters": ["effort"]
    },
    "claude-cli": {
      "adapter": "claude-cli",
      "selection": {
        "display_name": "Claude CLI",
        "model_provider": "anthropic",
        "discovery_provider": "claude",
        "availability": { "kind": "provider_discovery" }
      },
      "capabilities": ["text", "structured_output", "tools", "vision"],
      "supported_parameters": ["effort"]
    },
    "gemini-cli": {
      "adapter": "gemini-cli",
      "selection": {
        "display_name": "Gemini CLI",
        "model_provider": "gemini",
        "discovery_provider": "gemini",
        "availability": { "kind": "provider_discovery" }
      },
      "capabilities": ["text", "structured_output", "tools", "vision"],
      "supported_parameters": ["effort"]
    },
    "copilot": {
      "adapter": "copilot",
      "selection": {
        "display_name": "GitHub Copilot",
        "model_provider": "anthropic",
        "discovery_provider": "copilot",
        "availability": { "kind": "provider_discovery" }
      },
      "capabilities": ["text", "structured_output", "tools"],
      "supported_parameters": ["effort"]
    },
    "anthropic": {
      "adapter": "anthropic-sdk",
      "selection": {
        "display_name": "Anthropic API",
        "model_provider": "anthropic",
        "availability": { "kind": "env_any", "names": ["ANTHROPIC_API_KEY"] }
      },
      "capabilities": ["text", "structured_output", "tools", "vision"],
      "supported_parameters": ["temperature", "top_p", "stop", "effort"]
    },
    "openrouter": {
      "adapter": "openai-compatible",
      "selection": {
        "display_name": "OpenRouter",
        "model_provider": "openai",
        "availability": {
          "kind": "env_any",
          "names": ["OPENROUTER_API_KEY", "KYBERION_OPENROUTER_KEY"]
        }
      },
      "endpoint_policy": "public",
      "model_policy": "approved",
      "capabilities": ["text", "structured_output", "tools", "vision"],
      "supported_parameters": [
        "temperature",
        "top_p",
        "stop",
        "presence_penalty",
        "frequency_penalty"
      ]
    },
    "nemotron-api": {
      "adapter": "openai-compatible",
      "selection": {
        "display_name": "Nemotron API",
        "model_provider": "openai",
        "availability": { "kind": "env_any", "names": ["KYBERION_NEMOTRON_URL"] }
      },
      "endpoint_policy": "public",
      "model_policy": "approved",
      "capabilities": ["text", "structured_output"],
      "supported_parameters": [
        "temperature",
        "top_p",
        "stop",
        "presence_penalty",
        "frequency_penalty"
      ]
    },
