{
  "version": "1.0.0",
  "description": "Actuator operation registry. Defines which ops belong to each domain and shared op pools. Read by actuator-op-registry.ts to classify pipeline step types (capture/transform/apply). Add new ops here rather than editing source code.",
  "shared_capture_ops": [
    "read", "read_file", "read_json", "fetch", "shell", "list", "glob_files",
    "search", "goto", "content", "evaluate", "vision_consult", "pulse_status",
    "discover_capabilities", "discover_skills", "screenshot", "pptx_extract"
  ],
  "shared_transform_ops": [
    "regex_extract", "regex_replace", "json_query", "run_js", "yaml_update",
    "json_parse", "path_join", "array_count", "array_filter", "variable_hydrate",
    "json_update", "markdown_to_pdf", "apply_theme", "apply_pattern", "merge_content",
    "set", "document_diagram_asset_from_brief", "document_diagram_render_from_brief",
    "document_spreadsheet_design_from_brief", "document_report_design_from_brief",
    "theme_from_pptx_design"
  ],
  "shared_apply_ops": [
    "write", "write_file", "log", "click", "fill", "press", "wait", "delete",
    "mkdir", "symlink", "git_checkpoint", "voice", "notify", "keyboard",
    "mouse_click", "deploy", "append", "copy", "move", "pptx_render",
    "xlsx_render", "docx_render", "pdf_render", "drawio_write", "mermaid_render",
    "d2_render"
  ],
  "domains": {
    "media": {
      "capture": ["pptx_extract"],
      "transform": ["regex_extract", "regex_replace", "json_query", "run_js", "yaml_update",
        "json_parse", "path_join", "array_count", "array_filter", "variable_hydrate",
        "json_update", "markdown_to_pdf", "apply_theme", "apply_pattern", "merge_content",
        "set", "document_diagram_asset_from_brief", "document_diagram_render_from_brief",
        "document_spreadsheet_design_from_brief", "document_report_design_from_brief",
        "theme_from_pptx_design"],
      "apply": ["write", "write_file", "log", "click", "fill", "press", "wait", "delete",
        "mkdir", "symlink", "git_checkpoint", "voice", "notify", "keyboard",
        "mouse_click", "deploy", "append", "copy", "move", "pptx_render",
        "xlsx_render", "docx_render", "pdf_render", "drawio_write", "mermaid_render",
        "d2_render"]
    },
    "browser": {
      "capture": ["goto", "content", "evaluate", "screenshot"],
      "apply": ["click", "fill", "press", "wait", "log", "extension_session"]
    },
    "system": {
      "capture": ["shell", "list", "pulse_status"],
      "apply": ["log", "notify", "voice", "voice_input_toggle"]
    },
    "service": {
      "capture": ["read", "list"],
      "apply": ["deploy", "log", "notify"]
    },
    "file": {
      "capture": ["read", "read_file", "read_json", "list", "glob_files"],
      "transform": ["json_parse", "json_query", "path_join"],
      "apply": ["write", "write_file", "append", "copy", "move", "delete", "mkdir", "symlink"]
    },
    "code": {
      "capture": ["read", "read_file", "list", "glob_files"],
      "transform": ["apply_pattern", "merge_content", "set"],
      "apply": ["write", "write_file", "append", "copy", "move", "log"]
    },
    "wisdom": {
      "capture": ["search", "read", "read_file"],
      "transform": ["regex_extract", "regex_replace", "json_query", "yaml_update", "json_parse"],
      "apply": ["log", "register_presentation_preference_profile"]
    },
    "network": {
      "capture": ["fetch", "read"],
      "apply": ["log"]
    },
    "orchestrator": {
      "capture": ["discover_capabilities", "discover_skills"],
      "apply": ["deploy", "log"]
    },
    "gemini": {
      "capture": ["extensions", "skills", "hooks", "mcp"],
      "apply": ["prompt", "log"]
    },
    "gh": {
      "capture": [],
      "apply": ["pr", "issue", "repo", "api", "run-workflow", "skill", "agent-task"]
    },
    "codex": {
      "capture": ["review", "app-server", "cloud", "mcp", "features"],
      "apply": ["exec", "plugin"]
    }
  }
}
