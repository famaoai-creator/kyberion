{
  "action": "pipeline",
  "steps": [
    {
      "id": "discover",
      "type": "capture",
      "op": "discover_capabilities",
      "params": { "export_as": "all_capabilities" }
    },
    {
      "id": "log-discovery",
      "type": "apply",
      "op": "log",
      "params": { "message": "Discovered {{all_capabilities.length}} capabilities." }
    }
  ]
}
