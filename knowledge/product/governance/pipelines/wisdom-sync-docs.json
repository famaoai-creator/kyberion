{
  "action": "pipeline",
  "steps": [
    {
      "id": "sync-component-inventory",
      "type": "capture",
      "op": "shell",
      "params": {
        "cmd": "pnpm exec tsx scripts/sync_component_inventory.ts",
        "export_as": "sync_output"
      }
    },
    {
      "id": "log-sync",
      "type": "apply",
      "op": "log",
      "params": { "message": "Component inventory synchronized: {{sync_output}}" }
    }
  ]
}
