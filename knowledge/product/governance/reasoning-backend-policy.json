{
  "version": "1.0.0",
  "mode_aliases": {
    "gemini-api": "gemini-cli",
    "nemotron": "nemotron-api"
  },
  "allowed_modes": [
    "claude-cli",
    "codex-cli",
    "claude-agent",
    "anthropic",
    "gemini-cli",
    "agy-cli",
    "copilot",
    "local",
    "nemotron-api",
    "openrouter",
    "stub"
  ],
  "auto_select_env_priority": [
    {
      "env": "ANTHROPIC_API_KEY",
      "mode": "anthropic"
    },
    {
      "env": "GEMINI_API_KEY",
      "mode": "gemini-cli"
    },
    {
      "env": "KYBERION_NEMOTRON_URL",
      "mode": "nemotron-api"
    },
    {
      "env": "KYBERION_LOCAL_LLM_URL",
      "mode": "local"
    },
    {
      "env": "KYBERION_OPENROUTER_KEY",
      "mode": "openrouter"
    },
    {
      "env": "OPENROUTER_API_KEY",
      "mode": "openrouter"
    },
    {
      "env": "CLAUDECODE",
      "mode": "claude-agent"
    }
  ],
  "cli_preference_rules": [
    {
      "env_any": ["CODEX_CLI", "CODEX_VERSION"],
      "env_equals": {
        "TERM_PROGRAM": "codex"
      },
      "provider": "codex",
      "mode": "codex-cli"
    },
    {
      "env_any": ["GEMINI_CLI"],
      "provider": "gemini",
      "mode": "gemini-cli"
    },
    {
      "env_any": ["AGY_CLI", "ANTIGRAVITY_CLI"],
      "provider": "agy",
      "mode": "agy-cli"
    }
  ],
  "provider_fallback_order": [
    {
      "provider": "codex",
      "mode": "codex-cli"
    },
    {
      "provider": "gemini",
      "mode": "gemini-cli"
    },
    {
      "provider": "agy",
      "mode": "agy-cli"
    },
    {
      "provider": "copilot",
      "mode": "copilot"
    }
  ],
  "default_mode": "codex-cli"
}
