{
  "version": "1.0.0",
  "organization_id": "it-managed-services",
  "templates": {
    "operations": {
      "required_roles": ["owner", "operator"],
      "optional_roles": ["planner", "tester", "tracker", "surface_liaison"],
      "lifecycle": {
        "max_parallel_members": 6,
        "max_members": 8,
        "max_messages_per_run": 80,
        "max_wall_clock_minutes": 300,
        "max_member_turns": 10,
        "shutdown_policy": "graceful_handoff",
        "resume_policy": "checkpoint_resume",
        "cooldown_minutes": 8
      }
    },
    "incident": {
      "required_roles": ["owner", "operator"],
      "optional_roles": ["planner", "reviewer", "surface_liaison"],
      "lifecycle": {
        "max_parallel_members": 6,
        "max_members": 8,
        "max_messages_per_run": 90,
        "max_wall_clock_minutes": 180,
        "max_member_turns": 8,
        "shutdown_policy": "graceful_handoff",
        "resume_policy": "checkpoint_resume",
        "cooldown_minutes": 5
      }
    },
    "security_scan": {
      "optional_roles": ["reviewer", "tracker"]
    }
  }
}
