{
  "version": "1.0.0",
  "organization_id": "marketing-agency",
  "templates": {
    "default": {
      "required_roles": ["owner", "planner", "implementer", "reviewer"],
      "optional_roles": ["experience_designer", "relationship_curator", "scribe"],
      "lifecycle": {
        "max_parallel_members": 5,
        "max_members": 8,
        "max_messages_per_run": 80,
        "max_wall_clock_minutes": 300,
        "max_member_turns": 12,
        "shutdown_policy": "graceful_handoff",
        "resume_policy": "checkpoint_resume",
        "cooldown_minutes": 8
      }
    },
    "development": {
      "optional_roles": ["experience_designer", "tester"]
    }
  }
}
