{
  "version": "1.0.0",
  "edge_labels": [
    {
      "label": "uses",
      "style_parts": [
        "dashed=1",
        "strokeOpacity=55"
      ]
    },
    {
      "label": "source",
      "style_parts": [
        "dashed=1",
