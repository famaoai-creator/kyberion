{
  "version": "1.0.0",
  "tenant_guard": {
    "require_zero_drift": true
  },
  "required_services": {
    "comfyui": {
      "required_keys_any": ["base_url", "output_dir"]
    },
    "whisper": {
      "required_keys_any": ["whisperkit_base_url", "whisper_cli_path"]
    },
    "voice": {
      "required_keys_any": ["voice_python_bin", "voice_name"]
    },
    "meeting": {
      "required_keys_any": ["meeting_python_bin"]
    }
  }
}
