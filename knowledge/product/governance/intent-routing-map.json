    "check-kyberion-vital":          "vital-check",
    "diagnose-kyberion-system":      "system-diagnostics",
    "run-system-upgrade-check":      "system-upgrade-check",
    "verify-environment-readiness":  "baseline-check",
    "inspect-environment-readiness": "baseline-check",
    "inspect-runtime-supervisor":    "system-diagnostics",
    "verify-audit-chain":            "system-diagnostics",
    "speak-with-my-voice":           "knowledge/product/pipeline-templates/speak-with-my-voice",
    "generate-narrated-video":       "knowledge/product/pipeline-templates/kyberion-howto-narrated-demo",
    "clone-my-voice":                "knowledge/product/pipeline-templates/clone-my-voice",
    "contract-review":               "knowledge/product/pipeline-templates/contract-review",
    "review-text":                   "knowledge/product/pipeline-templates/review-text",
    "assimilate-gateway-capability": "assimilate-gateway-capability",
    "diverge-hypotheses":            "knowledge/product/pipeline-templates/hypothesis-tree",
    "multi-agent-consensus":         "knowledge/product/pipeline-templates/stakeholder-consensus-orchestrator"
  },
  "mission_intent_action_map": {
    "create-mission":        "create",
    "classify-mission":      "classify",
    "select-mission-workflow": "workflow",
    "compose-mission-team":  "compose_team",
    "prewarm-mission-team":  "prewarm_team",
    "delegate-mission-task": "delegate_task",
    "review-worker-output":  "review_output",
    "handoff-mission":       "handoff",
    "distill-mission":       "distill",
    "close-mission":         "close",
    "inspect-mission-state": "inspect_state"
  },
  "direct_intent_commands": {
    "bootstrap-kyberion-runtime": { "command": "pnpm", "args": ["env:bootstrap"] },
    "verify-actuator-capability":  { "command": "pnpm", "args": ["capabilities"] }
  },
  "track_intent_policy_map": {
    "request-feature-development": {
      "track_type": "delivery",
      "default_lifecycle": "default-sdlc",
      "min_confidence_to_autostart": 0.75
    },
    "remediate-security-incident": {
      "track_type": "incident",
      "default_lifecycle": "incident-response",
      "min_confidence_to_autostart": 0.85
    },
    "explore-product-solution": {
      "track_type": "product_discovery",
      "default_lifecycle": "discovery-sdlc",
      "min_confidence_to_autostart": 0.75
    },
    "apply-infrastructure-change": {
      "track_type": "change",
      "default_lifecycle": "change-control",
      "min_confidence_to_autostart": 0.8
    },
    "define-engineering-governance": {
      "track_type": "engineering_governance",
      "default_lifecycle": "governance-sdlc",
      "min_confidence_to_autostart": 0.8
    },
    "define-operational-process": {
      "track_type": "operational_governance",
      "default_lifecycle": "governance-sdlc",
      "min_confidence_to_autostart": 0.8
    }
  }
}
