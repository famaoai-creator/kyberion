{
  "version": "1.0.0",
  "defaults": {
    "mission_class": "code_change",
    "delivery_shape": "single_artifact",
    "risk_profile": "review_required",
    "stage": "intake"
  },
  "stage_progression": [
    "intake",
    "classification",
    "planning",
    "contract_authoring",
    "preflight",
    "execution",
    "verification",
    "delivery",
    "retrospective"
  ],
  "mission_class_rules": [
    {
      "id": "class-environment-recovery",
      "match": {
        "mission_type_hints": ["incident"]
      },
      "mission_class": "environment_and_recovery"
    },
    {
      "id": "class-environment-recovery-utterance",
      "match": {
        "utterance_patterns": ["recover", "recovery", "resume", "復旧", "再開"]
      },
      "mission_class": "environment_and_recovery"
    },
    {
      "id": "class-operations-release",
      "match": {
        "task_types": ["service_operation", "meeting_operations"]
      },
      "mission_class": "operations_and_release"
    },
    {
      "id": "class-operations-release-schedule-intent",
      "match": {
        "intent_ids": ["schedule-coordination"]
      },
      "mission_class": "customer_engagement"
    },
    {
      "id": "class-operations-release-meeting-utterance",
      "match": {
        "utterance_patterns": [
          "会議",
          "ミーティング",
          "打ち合わせ",
          "Teams",
          "Zoom",
          "Meet",
          "ファシリテート",
          "進行して",
          "議事録",
          "アクションアイテム",
          "代理参加"
        ]
      },
      "mission_class": "operations_and_release"
    },
    {
      "id": "class-operations-release-meeting-intent",
      "match": {
        "intent_ids": ["meeting-operations"]
      },
      "mission_class": "operations_and_release"
    },
    {
      "id": "class-operations-release-hint",
      "match": {
        "mission_type_hints": ["operations"]
      },
      "mission_class": "operations_and_release"
    },
    {
      "id": "class-research-absorption",
      "match": {
        "task_types": ["analysis"]
      },
      "mission_class": "research_and_absorption"
    },
    {
      "id": "class-research-absorption-intent",
      "match": {
        "intent_ids": [
          "cross-project-remediation",
          "incident-informed-review",
          "evolve-agent-harness"
        ]
      },
      "mission_class": "research_and_absorption"
    },
    {
      "id": "class-content-media",
      "match": {
        "task_types": [
          "presentation_deck",
          "report_document",
          "document_generation",
          "capture_photo"
        ]
      },
      "mission_class": "content_and_media"
    },
    {
      "id": "class-content-media-intent",
      "match": {
        "intent_ids": ["generate-presentation", "generate-report"]
      },
      "mission_class": "content_and_media"
    },
    {
      "id": "class-product-delivery",
      "match": {
        "shapes": ["project_bootstrap"]
      },
      "mission_class": "product_delivery"
    },
    {
      "id": "class-product-delivery-intent",
      "match": {
        "intent_ids": ["bootstrap-project"]
      },
      "mission_class": "product_delivery"
    },
    {
      "id": "class-decision-support",
      "match": {
        "task_types": [
          "decision_support",
          "consensus_building",
          "hypothesis_exploration",
          "counterfactual_analysis",
          "negotiation_prep",
          "rehearsal",
          "intuition_capture"
        ]
      },
      "mission_class": "decision_support"
    },
    {
      "id": "class-decision-support-utterance",
      "match": {
        "utterance_patterns": [
          "迷って",
          "落とし所",
          "反対され",
          "根回し",
          "nemawashi",
          "リハーサル",
          "意思決定",
          "交渉準備",
          "直観",
          "もしこうしていたら",
          "decision",
          "dilemma",
          "rehearse",
          "counterfactual"
        ]
      },
      "mission_class": "decision_support"
    },
    {
      "id": "class-decision-support-intent",
      "match": {
        "intent_ids": [
          "explore-hypotheses",
          "build-stakeholder-consensus",
          "prepare-negotiation",
          "rehearse-session",
          "capture-intuition",
          "analyze-counterfactual"
        ]
      },
      "mission_class": "decision_support"
    },
    {
      "id": "class-customer-engagement",
      "match": {
        "task_types": [
          "customer_engagement",
          "requirements_elicitation",
          "customer_meeting",
          "customer_followup"
        ]
      },
      "mission_class": "customer_engagement"
    },
    {
      "id": "class-customer-engagement-utterance",
      "match": {
        "utterance_patterns": [
          "要件定義",
          "要件ヒアリング",
          "要件整理",
          "顧客ヒアリング",
          "お客さん.*打ち合わせ",
          "お客様.*打ち合わせ",
          "客先ミーティング",
          "kickoff meeting",
          "discovery call",
          "elicit requirements",
          "requirements gathering",
          "customer interview"
        ]
      },
      "mission_class": "customer_engagement"
    },
    {
      "id": "class-customer-engagement-intent",
      "match": {
        "intent_ids": [
          "elicit-requirements",
          "run-customer-meeting",
          "draft-requirements",
          "schedule-customer-followup"
        ]
      },
      "mission_class": "customer_engagement"
    },
    {
      "id": "class-platform-onboarding",
      "match": {
        "task_types": [
          "platform_onboarding",
          "organization_setup",
          "integration_setup",
          "secrets_rotation",
          "governance_configuration"
        ]
      },
      "mission_class": "platform_onboarding"
    },
    {
      "id": "class-platform-onboarding-utterance",
      "match": {
        "utterance_patterns": [
          "組織統合",
          "組織導入",
          "Kyberion を.*導入",
          "Kyberion を.*入れる",
          "前提条件を整える",
          "前提整備",
          "オンボーディング設定",
          "組織固有.*設定",
          "CI/CD.*連携",
          "CI/CD.*統合",
          "SIEM.*連携",
          "シークレット.*整備",
          "platform onboarding",
          "organization setup",
          "integration setup",
          "wire up.*CI",
          "configure.*(secrets|STT|voice engine)"
        ]
      },
      "mission_class": "platform_onboarding"
    },
    {
      "id": "class-platform-onboarding-intent",
      "match": {
        "intent_ids": [
          "onboard-organization",
          "configure-integrations",
          "rotate-secrets",
          "register-adapter"
        ]
      },
      "mission_class": "platform_onboarding"
    }
  ],
  "delivery_shape_rules": [
    {
      "id": "delivery-interactive-exploration",
      "match": {
        "task_types": ["browser"]
      },
      "delivery_shape": "interactive_exploration"
    },
    {
      "id": "delivery-long-running",
      "match": {
        "task_types": ["service_operation"]
      },
      "delivery_shape": "long_running_job"
    },
    {
      "id": "delivery-long-running-intent",
      "match": {
        "intent_ids": ["inspect-service"]
      },
      "delivery_shape": "long_running_job"
    },
    {
      "id": "delivery-meeting-operations",
      "match": {
        "task_types": ["meeting_operations"]
      },
      "delivery_shape": "interactive_exploration"
    },
    {
      "id": "delivery-pipeline",
      "match": {
        "task_types": ["document_generation"]
      },
      "delivery_shape": "multi_artifact_pipeline"
    },
    {
      "id": "delivery-pipeline-bootstrap",
      "match": {
        "shapes": ["project_bootstrap"]
      },
      "delivery_shape": "multi_artifact_pipeline"
    },
    {
      "id": "delivery-cross-system",
      "match": {
        "mission_type_hints": ["incident"]
      },
      "delivery_shape": "cross_system_change"
    },
    {
      "id": "delivery-cross-system-intent",
      "match": {
        "intent_ids": ["cross-project-remediation"]
      },
      "delivery_shape": "cross_system_change"
    },
    {
      "id": "delivery-single-artifact",
      "match": {
        "task_types": ["presentation_deck", "report_document", "capture_photo"]
      },
      "delivery_shape": "single_artifact"
    },
    {
      "id": "delivery-decision-support-interactive",
      "match": {
        "task_types": ["consensus_building", "negotiation_prep", "rehearsal"]
      },
      "delivery_shape": "interactive_exploration"
    },
    {
      "id": "delivery-decision-support-artifact",
      "match": {
        "task_types": ["hypothesis_exploration", "counterfactual_analysis", "intuition_capture"]
      },
      "delivery_shape": "single_artifact"
    },
    {
      "id": "delivery-customer-engagement",
      "match": {
        "task_types": [
          "customer_engagement",
          "requirements_elicitation",
          "customer_meeting",
          "customer_followup"
        ]
      },
      "delivery_shape": "single_artifact"
    },
    {
      "id": "delivery-platform-onboarding",
      "match": {
        "task_types": [
          "platform_onboarding",
          "organization_setup",
          "integration_setup",
          "secrets_rotation",
          "governance_configuration"
        ]
      },
      "delivery_shape": "cross_system_change"
    }
  ],
  "risk_profile_rules": [
    {
      "id": "risk-high-stakes",
      "match": {
        "mission_type_hints": ["incident"]
      },
      "risk_profile": "high_stakes"
    },
    {
      "id": "risk-high-stakes-utterance",
      "match": {
        "utterance_patterns": ["outage", "security", "breach", "緊急", "障害"]
      },
      "risk_profile": "high_stakes"
    },
    {
      "id": "risk-approval-required",
      "match": {
        "task_types": ["service_operation"]
      },
      "risk_profile": "approval_required"
    },
    {
      "id": "risk-meeting-operations",
      "match": {
        "task_types": ["meeting_operations"]
      },
      "risk_profile": "review_required"
    },
    {
      "id": "risk-approval-required-bootstrap",
      "match": {
        "intent_ids": ["bootstrap-project"]
      },
      "risk_profile": "approval_required"
    },
    {
      "id": "risk-review-required",
      "match": {
        "task_types": ["analysis", "document_generation"],
        "shapes": ["task_session", "mission"]
      },
      "risk_profile": "review_required"
    },
    {
      "id": "risk-decision-support-consensus",
      "match": {
        "task_types": ["consensus_building", "negotiation_prep"]
      },
      "risk_profile": "review_required"
    },
    {
      "id": "risk-customer-engagement",
      "match": {
        "task_types": [
          "customer_engagement",
          "requirements_elicitation",
          "customer_meeting",
          "customer_followup"
        ]
      },
      "risk_profile": "review_required"
    },
    {
      "id": "risk-platform-onboarding",
      "match": {
        "task_types": ["platform_onboarding", "organization_setup", "secrets_rotation"]
      },
      "risk_profile": "high_stakes"
    }
  ],
  "stage_rules": [
    {
      "id": "stage-classification",
      "stage": "classification",
      "when": {
        "signals_any": ["classified"]
      }
    },
    {
      "id": "stage-classification-artifact",
      "stage": "classification",
      "when": {
        "artifacts_any": ["intent-resolution-packet.json"]
      }
    },
    {
      "id": "stage-planning",
      "stage": "planning",
      "when": {
        "signals_any": ["plan_ready"]
      }
    },
    {
      "id": "stage-planning-artifact",
      "stage": "planning",
      "when": {
        "artifacts_any": ["plan", "workflow-catalog"]
      }
    },
    {
      "id": "stage-contract-authoring",
      "stage": "contract_authoring",
      "when": {
        "signals_any": ["draft_contract_ready"]
      }
    },
    {
      "id": "stage-contract-authoring-artifact",
      "stage": "contract_authoring",
      "when": {
        "artifacts_any": ["contract", "adf"]
      }
    },
    {
      "id": "stage-preflight",
      "stage": "preflight",
      "when": {
        "signals_any": ["preflight_passed"]
      }
    },
    {
      "id": "stage-preflight-artifact",
      "stage": "preflight",
      "when": {
        "artifacts_any": ["preflight-report", "validation-report"]
      }
    },
    {
      "id": "stage-execution",
      "stage": "execution",
      "when": {
        "signals_any": ["execution_started"]
      }
    },
    {
      "id": "stage-execution-artifact",
      "stage": "execution",
      "when": {
        "artifacts_any": ["execution-receipt", "runtime/"]
      }
    },
    {
      "id": "stage-verification",
      "stage": "verification",
      "when": {
        "signals_any": ["verification_passed"]
      }
    },
    {
      "id": "stage-verification-artifact",
      "stage": "verification",
      "when": {
        "artifacts_any": ["verification", "test-report"]
      }
    },
    {
      "id": "stage-delivery",
      "stage": "delivery",
      "when": {
        "signals_any": ["delivery_ready"]
      }
    },
    {
      "id": "stage-delivery-artifact",
      "stage": "delivery",
      "when": {
        "artifacts_any": ["delivery-pack", "exports/"]
      }
    },
    {
      "id": "stage-retrospective",
      "stage": "retrospective",
      "when": {
        "signals_any": ["retrospective_captured"]
      }
    },
    {
      "id": "stage-retrospective-artifact",
      "stage": "retrospective",
      "when": {
        "artifacts_any": ["retrospective", "knowledge-hint", "feedback-loop"]
      }
    }
  ]
}
