{
  "version": 1,
  "surfaces": [
    {
      "id": "discord-bridge",
      "kind": "gateway",
      "description": "Discord Bot ingress gateway and surface-agent host",
      "command": "node",
      "args": [
        "dist/satellites/discord-bridge/src/index.js"
      ],
      "env": {
        "MISSION_ID": "MSN-SYSTEM-SENSORY-HUB",
        "KYBERION_PERSONA": "sovereign",
        "MISSION_ROLE": "surface_runtime"
      },
      "cwd": ".",
      "shutdownPolicy": "detached",
      "startupMode": "background",
      "ownerType": "surface-runtime-manifest",
      "enabled": false
    }
  ]
}