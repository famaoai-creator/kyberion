{
  "version": "1.0.0",
  "weights": {
    "rule_match": 0.4,
    "success_rate": 0.4,
    "recent_failure_penalty": 0.15,
    "latency_cost": 0.05
  },
  "thresholds": {
    "min_sample_count_for_autoselect": 5,
    "min_score_delta_for_override": 0.1
  },
  "risk_controls": {
    "high_stakes_requires_approval": true,
    "allow_fallback_when_no_memory": true
  }
}
