{
  "version": "1.0.0",
  "default_backend_ids": {
    "image": "media-generation.comfyui",
    "voice": "voice.local_say",
    "video": "video.hyperframes_cli",
    "music": "media-generation.comfyui.music"
  },
  "backends": [
    {
      "backend_id": "media-generation.comfyui",
      "modality": "image",
      "display_name": "ComfyUI Media Generation",
      "kind": "service_preset",
      "provider": "comfyui",
      "status": "active",
      "platforms": ["any"],
      "supports": {
        "artifact_formats": ["png", "jpg", "jpeg", "webp"],
        "async": true
      },
      "service_id": "media-generation",
      "action": "generate_image",
      "notes": "Routes governed image generation through the media-generation service preset. ComfyUI availability and managed location are also tracked via the service runtime abstraction."
    },
    {
      "backend_id": "media-generation.comfyui.video",
      "modality": "video",
      "display_name": "ComfyUI Video Generation",
      "kind": "service_preset",
      "provider": "comfyui",
      "status": "active",
      "platforms": ["any"],
      "supports": {
        "artifact_formats": ["mp4", "mov", "webm", "gif"],
        "async": true
      },
      "service_id": "media-generation",
      "action": "generate_video",
      "fallback_backend_id": "video.hyperframes_cli",
      "notes": "Compatibility-specific video contract for the shared ComfyUI runtime."
    },
    {
      "backend_id": "media-generation.google.veo-3.1",
      "modality": "video",
      "display_name": "Google Veo 3.1 Video Generation API",
      "kind": "api",
      "provider": "google_veo",
      "status": "active",
      "platforms": ["any"],
      "model": "veo-3.1-generate-preview",
      "api_key_env": "KYBERION_GEMINI_VIDEO_API_KEY|GEMINI_API_KEY",
      "endpoint_env": "KYBERION_GEMINI_VIDEO_URL",
      "supports": {
        "artifact_formats": ["mp4"],
        "async": true,
        "mux_audio": true
      },
      "notes": "Direct Google Gemini API adapter. Select explicitly; the default remains HyperFrames."
    },
    {
      "backend_id": "media-generation.runway.gen4.5",
      "modality": "video",
      "display_name": "Runway Gen-4.5 Video Generation API",
      "kind": "api",
      "provider": "runway",
      "status": "active",
      "platforms": ["any"],
      "model": "gen4.5",
      "api_key_env": "KYBERION_RUNWAY_API_KEY|RUNWAYML_API_SECRET",
      "endpoint_env": "KYBERION_RUNWAY_VIDEO_URL",
      "supports": {
        "artifact_formats": ["mp4"],
        "async": true
      },
      "notes": "Provider adapter for Runway text-to-video and image-to-video task APIs."
    },
    {
      "backend_id": "media-generation.runway.seedance2",
      "modality": "video",
      "display_name": "Runway Seedance 2 Video Generation API",
      "kind": "api",
      "provider": "runway",
      "status": "active",
      "platforms": ["any"],
      "model": "seedance2",
      "api_key_env": "KYBERION_RUNWAY_API_KEY|RUNWAYML_API_SECRET",
      "endpoint_env": "KYBERION_RUNWAY_VIDEO_URL",
      "supports": {
        "artifact_formats": ["mp4"],
        "async": true
      },
      "notes": "Same provider abstraction as Gen-4.5; model selection stays in the governed backend registry."
    },
    {
      "backend_id": "media-generation.runway.gemini-omni-flash",
      "modality": "video",
      "display_name": "Runway Gemini Omni Flash Video Generation API",
      "kind": "api",
      "provider": "runway",
      "status": "active",
      "platforms": ["any"],
      "model": "gemini_omni_flash",
      "api_key_env": "KYBERION_RUNWAY_API_KEY|RUNWAYML_API_SECRET",
      "endpoint_env": "KYBERION_RUNWAY_VIDEO_URL",
      "supports": {
        "artifact_formats": ["mp4"],
        "async": true,
        "mux_audio": true
      },
      "notes": "Runway-hosted Gemini Omni Flash route for conversational or reference-guided clips."
    },
    {
      "backend_id": "media-generation.openai.sora-2",
      "modality": "video",
      "display_name": "OpenAI Sora 2 Video Generation API",
      "kind": "api",
      "provider": "openai_sora",
      "status": "active",
      "platforms": ["any"],
      "model": "sora-2",
      "api_key_env": "KYBERION_OPENAI_VIDEO_API_KEY|OPENAI_API_KEY",
      "endpoint_env": "KYBERION_OPENAI_VIDEO_URL",
      "supports": {
        "artifact_formats": ["mp4"],
        "async": true,
        "mux_audio": true
      },
      "notes": "Direct OpenAI Videos API adapter. Verify account access before production use."
    },
    {
      "backend_id": "media-generation.minimax.hailuo-2.3",
      "modality": "video",
      "display_name": "MiniMax Hailuo 2.3 Video Generation API",
      "kind": "api",
      "provider": "minimax_hailuo",
      "status": "active",
      "platforms": ["any"],
      "model": "MiniMax-Hailuo-2.3",
      "api_key_env": "KYBERION_MINIMAX_VIDEO_API_KEY|MINIMAX_API_KEY",
      "endpoint_env": "KYBERION_MINIMAX_VIDEO_URL",
      "supports": {
        "artifact_formats": ["mp4"],
        "async": true
      },
      "notes": "Direct MiniMax asynchronous task and file retrieval adapter."
    },
    {
      "backend_id": "media-generation.comfyui.music",
      "modality": "music",
      "display_name": "ComfyUI Music Generation",
      "kind": "service_preset",
      "provider": "comfyui",
      "status": "active",
      "platforms": ["any"],
      "supports": {
        "artifact_formats": ["mp3", "wav", "flac"],
        "async": true
      },
      "service_id": "media-generation",
      "action": "generate_music",
      "notes": "Compatibility-specific music contract for the shared ComfyUI runtime."
    },
    {
      "backend_id": "media-generation.gemini",
      "modality": "image",
      "display_name": "Google AI Studio Gemini Image Generation",
      "kind": "service_preset",
      "provider": "gemini_api",
      "status": "active",
      "platforms": ["any"],
      "supports": {
        "artifact_formats": ["jpg", "jpeg", "png", "webp"],
        "async": false
      },
      "service_id": "gemini",
      "action": "generate_image",
      "notes": "Routes image generation through the Gemini API / AI Studio service preset using GEMINI_API_KEY."
    },
    {
      "backend_id": "media-generation.host_agent",
      "modality": "image",
      "display_name": "Host Agent Tool Image Generation",
      "kind": "agent_tool",
      "provider": "antigravity",
      "status": "active",
      "platforms": ["any"],
      "supports": {
        "artifact_formats": ["jpg", "jpeg", "png", "webp"],
        "async": false
      },
      "notes": "Requests the outer agent/host environment (e.g. agy / Antigravity IDE) to generate the image via its native tool and stores it."
    },
    {
      "backend_id": "media-generation.local_flux",
      "modality": "image",
      "display_name": "Local FLUX Image Generation",
      "kind": "cli",
      "provider": "mflux",
      "status": "active",
      "platforms": ["darwin"],
      "supports": {
        "artifact_formats": ["png", "jpg", "jpeg", "webp"],
        "async": false
      },
      "command": "uvx",
      "args": ["--from", "mflux", "mflux-generate"],
      "fallback_backend_id": "media-generation.comfyui",
      "notes": "Apple Silicon local FLUX generation via the governed tool runtime registry. Tuned via KYBERION_MFLUX_* env policy."
    },
    {
      "backend_id": "media-generation.apple_playground",
      "modality": "image",
      "display_name": "Apple Image Playground",
      "kind": "local",
      "provider": "apple_image_playground",
      "status": "active",
      "platforms": ["darwin"],
      "supports": {
        "artifact_formats": ["png"],
        "async": false
      },
      "fallback_backend_id": "media-generation.local_flux",
      "notes": "macOS Apple Silicon Image Playground via the governed native capability bridge. Availability is probed separately from Foundation Models and degrades to local FLUX when unavailable."
    },
    {
      "backend_id": "voice.local_say",
      "modality": "voice",
      "display_name": "Local System TTS",
      "kind": "local",
      "provider": "system_tts",
      "status": "active",
      "platforms": ["darwin", "linux", "win32"],
      "supports": {
        "playback": true,
        "artifact_formats": ["wav", "aiff"]
      },
      "notes": "Local fallback voice backend for playback and artifact generation."
    },
    {
      "backend_id": "video.hyperframes_cli",
      "modality": "video",
      "display_name": "HyperFrames CLI Renderer",
      "kind": "cli",
      "provider": "hyperframes",
      "status": "active",
      "platforms": ["any"],
      "supports": {
        "artifact_formats": ["mp4", "mov", "webm", "gif"],
        "async": true,
        "mux_audio": true
      },
      "command": "npx",
      "args": ["hyperframes", "render"],
      "notes": "Deterministic HTML-to-video render backend with optional narration mux."
    }
  ]
}
