{
  "version": "1.0.0",
  "defaults": {
    "unknown_scope_behavior": "allow_with_warning"
  },
  "scope_classes": {
    "mission_state": {
      "description": "Mission control state and orchestration records.",
      "allow_prefixes": [
        "active/missions/",
        "active/archive/missions/",
        "active/shared/coordination/",
        "active/shared/runtime/mission_queue.jsonl"
      ]
    },
    "knowledge_core": {
      "description": "Governed knowledge and architecture assets.",
      "allow_prefixes": [
        "knowledge/"
      ]
    },
    "codebase_core": {
      "description": "Core implementation and automation code.",
      "allow_prefixes": [
        "libs/core/",
        "libs/actuators/",
        "scripts/",
        "schemas/",
        "pipelines/",
        "tests/"
      ]
    },
    "project_delivery": {
      "description": "Project-local delivery artifacts and outputs.",
      "allow_prefixes": [
        "active/projects/",
        "active/shared/exports/"
      ]
    },
    "tenant_confidential": {
      "description": "Tenant-specific confidential knowledge and assets.",
      "allow_prefixes": [
        "knowledge/confidential/${TENANT_SLUG}/",
        "knowledge/personal/tenants/${TENANT_SLUG}/"
      ]
    },
    "communication_surface": {
      "description": "Surface/gateway communication channels and runtime state.",
      "allow_prefixes": [
        "presence/bridge/runtime/",
        "active/shared/coordination/channels/",
        "active/shared/coordination/chronos/"
      ]
    },
    "operations_runtime": {
      "description": "Operational runtime state and terminal resources.",
      "allow_prefixes": [
        "active/shared/runtime/",
        "active/shared/logs/"
      ]
    },
    "observability": {
      "description": "Observability and metrics traces.",
      "allow_prefixes": [
        "active/shared/observability/"
      ]
    },
    "audit": {
      "description": "Audit and governance traces.",
      "allow_prefixes": [
        "active/audit/"
      ]
    },
    "confidential_heuristics": {
      "description": "Personal judgment heuristics captured by intuition-capture missions. Intended writers: decision_support missions with subtype=intuition_capture. Mission-aware enforcement deferred to preflight layer.",
      "allow_prefixes": [
        "knowledge/confidential/heuristics/"
      ]
    },
    "confidential_relationships": {
      "description": "Structured relationship-graph nodes (trust_level, history, communication_style, ng_topics, outstanding_asks). Intended writers: presence-actuator and voice-actuator hooks only. Actuator-aware enforcement deferred to runtime.",
      "allow_prefixes": [
        "knowledge/confidential/relationships/"
      ]
    }
  }
}
