{
  "action": "pipeline",
  "name": "action-item-tracking",
  "version": "2.0.0",
  "description": "Iterates pending team_member items in the active mission and emits one reminder per item via the configured channel adapter. Designed to run on cron / scheduler. The reminder is recorded on the action item itself (idempotent on (sent_at, channel)).",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type without roles.",
  "context": {
    "mission_id": "",
    "tone": "friendly",
    "language": "ja",
    "max_items_per_run": 20
  },
  "steps": [
    {
      "id": "open_log",
      "role": "sink",
      "op": "system:log",
      "params": {
        "message": "📨 action-item-tracking starting for mission {{mission_id}}; max_items={{max_items_per_run}}."
      }
    },
    {
      "id": "iterate_pending",
      "role": "sink",
      "op": "meeting:track_pending_action_items",
      "params": {
        "mission_id": "{{mission_id}}",
        "tone": "{{tone}}",
        "language": "{{language}}",
        "max_items": "{{max_items_per_run}}",
        "output_path": "{{mission_evidence_dir}}/action-item-tracking-report.json"
      }
    },
    {
      "id": "log_summary",
      "role": "sink",
      "op": "system:log",
      "params": {
        "message": "✅ Reminder pass complete: see {{mission_evidence_dir}}/action-item-tracking-report.json"
      }
    }
  ]
}
