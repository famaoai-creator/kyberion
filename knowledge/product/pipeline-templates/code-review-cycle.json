{
  "action": "pipeline",
  "name": "code-review-cycle",
  "version": "2.0.0",
  "description": "SDLC code review phase: treat a diff (or changed-files list) as the review topic, run 3 adversarial personas (senior-dev / security-auditor / red-team) via a2a_fanout + cross_critique, and persist surviving concerns to dissent-log.json so the reviewer role can triage.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type only (no channel data flow — all communication via file paths in context).",
  "context": {
    "mission_id": "",
    "review_topic": "Review the changes below for correctness, security, and risk.",
    "diff_input_path": "active/missions/{{mission_id}}/evidence/diff.patch",
    "hypotheses_output": "active/missions/{{mission_id}}/evidence/code-review-raw.json",
    "critique_output": "active/missions/{{mission_id}}/evidence/code-review-critique.json",
    "dissent_output": "active/missions/{{mission_id}}/evidence/dissent-log.json",
    "personas": ["Senior Developer", "Security Auditor", "Red Team Adversary"]
  },
  "steps": [
    {
      "id": "diverge_review",
      "role": "sink",
      "op": "wisdom:a2a_fanout",
      "params": {
        "personas_from": "personas",
        "min_hypotheses_per_persona": 2,
        "topic": "{{review_topic}} Diff at {{diff_input_path}}.",
        "output_path": "{{hypotheses_output}}"
      }
    },
    {
      "id": "cross_critique",
      "role": "sink",
      "op": "wisdom:cross_critique",
      "params": {
        "input": "{{hypotheses_output}}",
        "personas_from": "personas",
        "output_path": "{{critique_output}}"
      }
    },
    {
      "id": "record_dissent",
      "role": "sink",
      "op": "wisdom:emit_dissent_log",
      "params": {
        "source": "{{critique_output}}",
        "output_path": "{{dissent_output}}",
        "mission_id": "{{mission_id}}",
        "topic": "code-review"
      }
    }
  ]
}
