{
  "action": "pipeline",
  "name": "Developer Productivity Audit",
  "version": "2.0.0",
  "description": "Analyzes codebase metrics and quality signals.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used export_as without roles.",
  "steps": [
    {
      "role": "sink",
      "op": "system:log",
      "params": { "message": "📈 Starting Productivity Audit..." }
    },
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "ts_file_count", "type": "ShellResult" },
      "params": { "cmd": "find libs src -name '*.ts' | wc -l" }
    },
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "test_file_count", "type": "ShellResult" },
      "params": { "cmd": "find tests libs -name '*.test.ts' -o -name '*.spec.ts' | wc -l" }
    },
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "fixme_count", "type": "ShellResult" },
      "params": { "cmd": "grep -r 'FIXME' libs src 2>/dev/null | wc -l" }
    },
    {
      "role": "sink",
      "op": "system:log",
      "params": { "message": "📊 Metrics Summary:" }
    },
    {
      "role": "sink",
      "op": "system:log",
      "consumes": "ts_file_count",
      "params": { "message": "  - Source Files (.ts): {{ts_file_count}}" }
    },
    {
      "role": "sink",
      "op": "system:log",
      "consumes": "test_file_count",
      "params": { "message": "  - Test Files: {{test_file_count}}" }
    },
    {
      "role": "sink",
      "op": "system:log",
      "consumes": "fixme_count",
      "params": { "message": "  - FIXME items: {{fixme_count}}" }
    },
    {
      "role": "transform",
      "op": "system:shell",
      "consumes": ["ts_file_count", "test_file_count", "fixme_count"],
      "produces": { "channel": "productivity_score", "type": "ShellResult" },
      "params": {
        "cmd": "node -e \"const ts = parseInt('{{ts_file_count}}'); const tests = parseInt('{{test_file_count}}'); const fixme = parseInt('{{fixme_count}}'); console.log(Math.round((tests / ts) * 100 - fixme))\""
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "consumes": "productivity_score",
      "params": { "message": "🚀 Calculated Productivity Score: {{productivity_score}}" }
    }
  ]
}
