{
  "action": "pipeline",
  "name": "audio-to-requirements",
  "version": "2.0.0",
  "description": "End-to-end customer_engagement pipeline: transcribe a meeting recording via the registered SpeechToTextBridge, then run extract_requirements on the resulting transcript. Stub bridge accepts a pre-baked <audio>.transcript.txt sidecar when no real STT backend is available.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "context": {
    "mission_id": "",
    "project_name": "",
    "language": "ja",
    "customer_name": "",
    "customer_person_slug": "",
    "customer_org": ""
  },
  "steps": [
    {
      "id": "transcribe",
      "role": "source",
      "op": "wisdom:transcribe_audio",
      "produces": { "channel": "transcript", "type": "Transcript" },
      "params": {
        "audio_path": "{{mission_evidence_dir}}/call-recording.wav",
        "language": "{{language}}",
        "output_path": "{{mission_evidence_dir}}/call-recording.wav.transcript.txt"
      }
    },
    {
      "id": "log_transcription",
      "role": "sink",
      "op": "system:log",
      "consumes": "transcript",
      "params": {
        "message": "Transcribed via {{transcript.backend}} → {{transcript.written_to}} (synthetic={{transcript.synthetic}})"
      }
    },
    {
      "id": "extract",
      "role": "transform",
      "op": "wisdom:extract_requirements",
      "consumes": "transcript",
      "produces": { "channel": "extraction", "type": "RequirementsExtraction" },
      "params": {
        "mission_id": "{{mission_id}}",
        "project_name": "{{project_name}}",
        "source_path": "{{mission_evidence_dir}}/call-recording.wav.transcript.txt",
        "source_type": "call_transcript",
        "language": "{{language}}",
        "customer_name": "{{customer_name}}",
        "customer_person_slug": "{{customer_person_slug}}",
        "customer_org": "{{customer_org}}"
      }
    },
    {
      "id": "log_extraction",
      "role": "sink",
      "op": "system:log",
      "consumes": "extraction",
      "params": {
        "message": "Extracted requirements v{{extraction.version}} at {{extraction.draft_path}} (completeness passed={{extraction.completeness.passed}})"
      }
    }
  ]
}
