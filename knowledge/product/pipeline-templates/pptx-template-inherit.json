{
  "pipeline_id": "pptx-template-inherit",
  "version": "2.0.0",
  "description": "Read a multi-owner PPTX template, auto-detect the slides belonging to the specified owner labels (footer match), apply text replacements, and emit a submission-ready file. Use case: monthly reporting decks where each contributor returns only their own slide(s).",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1.1 used type + export_as.",
  "action": "pipeline",
  "context": {
    "source_pptx": "active/shared/tmp/pptx-input/template.pptx",
    "output_pptx": "active/shared/tmp/pptx-output/submission.pptx",
    "owner_labels": ["owner_name_goes_here"],
    "run_replacements": {},
    "paragraph_replacements": []
  },
  "steps": [
    {
      "id": "inspect_source",
      "role": "source",
      "op": "pptx_slide_text",
      "produces": { "channel": "source_slides", "type": "PptxSlides" },
      "params": {
        "path": "{{source_pptx}}"
      }
    },
    {
      "id": "find_owner_slides",
      "role": "transform",
      "op": "find_slides_by_owner",
      "consumes": "source_slides",
      "produces": { "channel": "owner_match", "type": "OwnerMatch" },
      "params": {
        "slides_from": "source_slides",
        "owner_labels_from": "owner_labels",
        "match_mode": "substring"
      }
    },
    {
      "id": "filter_to_owner_slides",
      "role": "sink",
      "op": "pptx_filter_slides",
      "consumes": "owner_match",
      "params": {
        "source": "{{source_pptx}}",
        "path": "active/shared/tmp/pptx-output/_stage1_filtered.pptx",
        "keep_indices": "{{owner_match.indices}}"
      }
    },
    {
      "id": "apply_run_replacements",
      "role": "sink",
      "op": "pptx_patch",
      "params": {
        "source": "active/shared/tmp/pptx-output/_stage1_filtered.pptx",
        "path": "active/shared/tmp/pptx-output/_stage2_patched.pptx",
        "replacements": "{{run_replacements}}"
      }
    },
    {
      "id": "apply_paragraph_replacements",
      "role": "sink",
      "op": "pptx_patch_paragraphs",
      "params": {
        "source": "active/shared/tmp/pptx-output/_stage2_patched.pptx",
        "path": "{{output_pptx}}",
        "paragraph_replacements": "{{paragraph_replacements}}"
      }
    },
    {
      "id": "verify_output",
      "role": "source",
      "op": "pptx_slide_text",
      "produces": { "channel": "output_slides", "type": "PptxSlides" },
      "params": {
        "path": "{{output_pptx}}"
      }
    },
    {
      "id": "diff_report",
      "role": "transform",
      "op": "pptx_diff",
      "consumes": ["source_slides", "output_slides"],
      "produces": { "channel": "change_report", "type": "DiffReport" },
      "params": {
        "before_from": "source_slides",
        "after_from": "output_slides"
      }
    }
  ]
}
