{
  "action": "pipeline",
  "pipeline_id": "intent-validate-api-pci",
  "name": "Validate API Documentation for PCI-DSS Compliance",
  "version": "2.0.0",
  "description": "Validates that API documentation correctly implements PCI-DSS security controls.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "variables": {
    "api_doc_path": "docs/api/swagger.json",
    "output_path": "active/shared/tmp/validate-pci.json"
  },
  "steps": [
    {
      "role": "sink",
      "op": "system:log",
      "params": { "message": "🚀 Starting PCI-DSS Validation for {{api_doc_path}}" }
    },
    {
      "id": "validate-pci",
      "role": "source",
      "op": "reasoning:analyze",
      "produces": { "channel": "validation_result", "type": "ValidationResult" },
      "params": {
        "instruction": "Validate the API documentation against PCI-DSS requirements. Specifically, check if credit card numbers (PAN) are being logged or transmitted in plain text according to the schema definitions.",
        "context": ["{{api_doc_path}}"],
        "analysisType": "compliance_validation"
      }
    },
    {
      "role": "sink",
      "op": "system:write_file",
      "consumes": "validation_result",
      "params": {
        "path": "{{output_path}}",
        "content": "{{validation_result}}",
        "format": "json"
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "params": { "message": "✅ Validation complete. Results saved to {{output_path}}" }
    }
  ]
}
