{
  "action": "pipeline",
  "name": "voice-learning-setup",
  "version": "2.0.0",
  "description": "Voice profile learning + test synthesis. Persona-parameterized — set context.persona_name and context.profile_id. Samples must exist at knowledge/personal/voice/samples/{{profile_id}}/.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used export_as without roles.",
  "context": {
    "persona_name": "the operator",
    "profile_id": "operator-default-v1",
    "test_text": "こんにちは、私は {{persona_name}} のデジタルプロファイルです。学習した音声でミーティングに参加する準備が整いました。",
    "provider": "local",
    "python_bin": "python3"
  },
  "steps": [
    {
      "role": "gate",
      "op": "core:include",
      "params": {
        "fragment": "fragments/voice-runtime-preflight.json",
        "context": {
          "python_bin": "{{python_bin}}",
          "sample_dir": "knowledge/personal/voice/samples/{{profile_id}}"
        }
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "params": {
        "message": "🎙️ {{persona_name}} の音声プロファイル ({{profile_id}}) 学習セットアップを開始します。"
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "params": {
        "message": "サンプル ({{profile_id}}.wav / .mp3) を knowledge/personal/voice/samples/{{profile_id}}/ に配置してください。"
      }
    },
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "learning_result", "type": "LearningResult" },
      "params": {
        "cmd": "{{python_bin}} libs/actuators/voice-actuator/scripts/voice_learning_bridge.py '{\"action\": \"learn\", \"params\": {\"profile_id\": \"{{profile_id}}\", \"sample_dir\": \"knowledge/personal/voice/samples/{{profile_id}}\", \"provider\": \"{{provider}}\"}}'"}
    },
    {
      "role": "sink",
      "op": "system:log",
      "consumes": "learning_result",
      "params": { "message": "✅ 学習結果: {{learning_result}}" }
    },
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "test_synthesis_result", "type": "SynthesisResult" },
      "params": {
        "cmd": "{{python_bin}} libs/actuators/voice-actuator/scripts/voice_learning_bridge.py '{\"action\": \"generate\", \"params\": {\"text\": \"{{test_text}}\", \"profile_id\": \"{{profile_id}}\", \"provider\": \"{{provider}}\"}}'"
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "consumes": "test_synthesis_result",
      "params": { "message": "✨ テスト発話完了: {{test_synthesis_result}}" }
    }
  ]
}
