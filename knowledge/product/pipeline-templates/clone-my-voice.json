{
  "action": "pipeline",
  "name": "clone-my-voice",
  "version": "2.0.0",
  "description": "声のクローン作成パイプライン。3サンプルを録音・トランスクリプト登録し、mlx_audio_qwen3 エンジンでの ICL クローンプロフィールを作成する。収録直後の staging は active/shared/tmp/voice-samples/<profile_id>/、登録後の参照先は active/shared/runtime/voice-profiles/<profile_id>/ に移る。必須 context vars: profile_id, display_name。オプション: duration_sec (default 12), language (default ja)。モデルダウンロード済みであること（HuggingFace 接続が必要、初回のみ）。",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "context": {
    "profile_id": "my-voice-v1",
    "display_name": "市村 Voice v1",
    "duration_sec": 12,
    "language": "ja"
  },
  "steps": [
    {
      "id": "check_sox",
      "role": "source",
      "op": "system:cli_health_check",
      "produces": { "channel": "sox_health", "type": "HealthCheck" },
      "params": { "command": "sox", "args": ["--version"] }
    },
    {
      "id": "gate_sox",
      "role": "gate",
      "op": "core:if",
      "consumes": "sox_health",
      "params": {
        "condition": { "from": "sox_health.available", "operator": "eq", "value": false },
        "then": [
          { "id": "error_no_sox", "role": "sink", "op": "system:log", "params": { "message": "[clone-my-voice] sox が見つかりません。brew install sox を実行してください。" } },
          { "id": "halt_missing_sox", "role": "sink", "op": "system:shell", "params": { "cmd": "exit 1" } }
        ]
      }
    },
    {
      "id": "mkdir_samples",
      "role": "sink",
      "op": "system:mkdir",
      "params": { "path": "active/shared/tmp/voice-samples/{{profile_id}}" }
    },
    {
      "id": "generate_cue_audio",
      "role": "source",
      "op": "system:exec",
      "produces": { "channel": "cue_gen", "type": "ExecResult" },
      "params": {
        "command": "say",
        "args": ["-v", "Eddy (Japanese (Japan))", "-o", "active/shared/tmp/voice-cue.aiff", "録音を開始します。どうぞ"]
      }
    },
    {
      "id": "notify_sample1",
      "role": "sink",
      "op": "system:system_notify",
      "params": {
        "title": "🎙 録音 1/3",
        "message": "「こんにちは。私の名前は市村です。今日はKyberionの音声クローン機能をテストしています。よろしくお願いします。」",
        "subtitle": "合図の後に話し始めてください"
      }
    },
    {
      "id": "cue_sample1",
      "role": "source",
      "op": "system:exec",
      "produces": { "channel": "cue1", "type": "ExecResult" },
      "params": { "command": "afplay", "args": ["active/shared/tmp/voice-cue.aiff"] }
    },
    {
      "id": "record_sample1",
      "role": "source",
      "op": "system:exec",
      "produces": { "channel": "record1", "type": "RecordingResult" },
      "params": {
        "command": ".venv/bin/python3",
        "args": ["libs/actuators/voice-actuator/scripts/record_bridge.py", "{\"action\":\"record\",\"params\":{\"duration\":{{duration_sec}},\"output_path\":\"active/shared/tmp/voice-samples/{{profile_id}}/sample-01.wav\"}}"],
        "timeout_ms": 25000
      }
    },
    {
      "id": "transcript_sample1",
      "role": "sink",
      "op": "system:write_artifact",
      "params": {
        "path": "active/shared/tmp/voice-samples/{{profile_id}}/sample-01.wav.transcript.txt",
        "content": "こんにちは。私の名前は市村です。今日はKyberionの音声クローン機能をテストしています。よろしくお願いします。"
      }
    },
    {
      "id": "notify_sample2",
      "role": "sink",
      "op": "system:system_notify",
      "params": {
        "title": "🎙 録音 2/3",
        "message": "「Kyberionは自律型AIエージェントシステムです。音声、画像、ブラウザ操作など様々な機能を備えています。」",
        "subtitle": "合図の後に話し始めてください"
      }
    },
    {
      "id": "cue_sample2",
      "role": "source",
      "op": "system:exec",
      "produces": { "channel": "cue2", "type": "ExecResult" },
      "params": { "command": "afplay", "args": ["active/shared/tmp/voice-cue.aiff"] }
    },
    {
      "id": "record_sample2",
      "role": "source",
      "op": "system:exec",
      "produces": { "channel": "record2", "type": "RecordingResult" },
      "params": {
        "command": ".venv/bin/python3",
        "args": ["libs/actuators/voice-actuator/scripts/record_bridge.py", "{\"action\":\"record\",\"params\":{\"duration\":{{duration_sec}},\"output_path\":\"active/shared/tmp/voice-samples/{{profile_id}}/sample-02.wav\"}}"],
        "timeout_ms": 25000
      }
    },
    {
      "id": "transcript_sample2",
      "role": "sink",
      "op": "system:write_artifact",
      "params": {
        "path": "active/shared/tmp/voice-samples/{{profile_id}}/sample-02.wav.transcript.txt",
        "content": "Kyberionは自律型AIエージェントシステムです。音声、画像、ブラウザ操作など様々な機能を備えています。"
      }
    },
    {
      "id": "notify_sample3",
      "role": "sink",
      "op": "system:system_notify",
      "params": {
        "title": "🎙 録音 3/3",
        "message": "「本日の天気は晴れです。気温は二十五度で、過ごしやすい一日になりそうです。午後からは少し風が強くなる予報です。」",
        "subtitle": "合図の後に話し始めてください"
      }
    },
    {
      "id": "cue_sample3",
      "role": "source",
      "op": "system:exec",
      "produces": { "channel": "cue3", "type": "ExecResult" },
      "params": { "command": "afplay", "args": ["active/shared/tmp/voice-cue.aiff"] }
    },
    {
      "id": "record_sample3",
      "role": "source",
      "op": "system:exec",
      "produces": { "channel": "record3", "type": "RecordingResult" },
      "params": {
        "command": ".venv/bin/python3",
        "args": ["libs/actuators/voice-actuator/scripts/record_bridge.py", "{\"action\":\"record\",\"params\":{\"duration\":{{duration_sec}},\"output_path\":\"active/shared/tmp/voice-samples/{{profile_id}}/sample-03.wav\"}}"],
        "timeout_ms": 25000
      }
    },
    {
      "id": "transcript_sample3",
      "role": "sink",
      "op": "system:write_artifact",
      "params": {
        "path": "active/shared/tmp/voice-samples/{{profile_id}}/sample-03.wav.transcript.txt",
        "content": "本日の天気は晴れです。気温は二十五度で、過ごしやすい一日になりそうです。午後からは少し風が強くなる予報です。"
      }
    },
    {
      "id": "copy_transcript1_to_collection",
      "role": "sink",
      "op": "system:log",
      "params": { "message": "[clone-my-voice] 録音完了。プロフィール登録を開始します。" }
    },
    {
      "id": "register_profile",
      "role": "source",
      "op": "voice:collect_and_register_voice_profile",
      "produces": { "channel": "registration_result", "type": "VoiceRegistrationResult" },
      "params": {
        "action": "collect_and_register_voice_profile",
        "request_id": "clone-{{profile_id}}-{{language}}",
        "profile": {
          "profile_id": "{{profile_id}}",
          "display_name": "{{display_name}}",
          "tier": "personal",
          "languages": ["{{language}}"],
          "default_engine_id": "mlx_audio_qwen3",
          "notes": "ICL voice clone via mlx-audio Qwen3-TTS. clone-my-voice pipeline."
        },
        "samples": [
          { "sample_id": "sample-01", "path": "active/shared/tmp/voice-samples/{{profile_id}}/sample-01.wav", "language": "{{language}}" },
          { "sample_id": "sample-02", "path": "active/shared/tmp/voice-samples/{{profile_id}}/sample-02.wav", "language": "{{language}}" },
          { "sample_id": "sample-03", "path": "active/shared/tmp/voice-samples/{{profile_id}}/sample-03.wav", "language": "{{language}}" }
        ],
        "policy": { "allow_update": true }
      }
    },
    {
      "id": "announce_runtime_store",
      "role": "sink",
      "op": "system:log",
      "consumes": "registration_result",
      "params": { "message": "[clone-my-voice] 学習済み音声は active/shared/runtime/voice-profiles/{{profile_id}}/ に保存されました。tmp は収録 staging 用です。" }
    },
    {
      "id": "notify_done",
      "role": "sink",
      "op": "system:system_notify",
      "consumes": "registration_result",
      "params": {
        "title": "✅ 声のクローン登録完了",
        "message": "プロフィール {{profile_id}} が登録されました。学習済み音声は active/shared/runtime/voice-profiles/{{profile_id}}/ に保存されています。pnpm voice:speak で発話テストできます。",
        "subtitle": "clone-my-voice"
      }
    },
    {
      "id": "log_result",
      "role": "sink",
      "op": "system:log",
      "consumes": "registration_result",
      "params": { "message": "[clone-my-voice] 完了: {{registration_result}}" }
    }
  ]
}
