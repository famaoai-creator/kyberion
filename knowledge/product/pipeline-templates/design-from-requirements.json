{
  "action": "pipeline",
  "name": "design-from-requirements",
  "version": "2.0.0",
  "description": "SDLC design phase: read the mission's requirements-draft.json, derive an architectural design-spec.json via the registered ReasoningBackend, and evaluate the ARCHITECTURE_READY gate. Blocks downstream work when open_decisions[].blocking=true remain.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "context": {
    "mission_id": "",
    "project_name": "",
    "requirements_draft_path": "active/missions/{{mission_id}}/evidence/requirements-draft.json",
    "additional_context": ""
  },
  "steps": [
    {
      "id": "extract",
      "role": "source",
      "op": "wisdom:extract_design_spec",
      "produces": { "channel": "design_extraction", "type": "DesignExtraction" },
      "params": {
        "mission_id": "{{mission_id}}",
        "project_name": "{{project_name}}",
        "requirements_draft_path": "{{requirements_draft_path}}",
        "additional_context": "{{additional_context}}"
      }
    },
    {
      "id": "log_extraction",
      "role": "sink",
      "op": "system:log",
      "consumes": "design_extraction",
      "params": {
        "message": "Design spec v{{design_extraction.version}} produced at {{design_extraction.draft_path}} (ARCHITECTURE_READY passed={{design_extraction.architecture_ready.passed}})"
      }
    }
  ]
}
