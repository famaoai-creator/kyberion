{
  "pipeline_id": "executive-narrative-bridge",
  "version": "2.0.0",
  "description": "Transform technical mission artifacts into stakeholder-ready narratives.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1.1 used type + export_as.",
  "action": "pipeline",
  "steps": [
    {
      "id": "guard-confidential-tier",
      "role": "gate",
      "op": "if",
      "params": {
        "condition": {
          "from": "mission_tier",
          "operator": "eq",
          "value": "confidential"
        },
        "then": [
          {
            "id": "collect-deliverables",
            "role": "source",
            "op": "system:collect_artifacts",
            "produces": { "channel": "technical_artifacts", "type": "ArtifactCollection" },
            "params": {
              "mission_ids": ["{{target_mission_id}}"],
              "patterns": ["*.md", "*.json"]
            }
          },
          {
            "id": "narrative-synthesis",
            "role": "transform",
            "op": "reasoning:transform",
            "consumes": "technical_artifacts",
            "produces": { "channel": "executive_narrative", "type": "ExecutiveNarrative" },
            "params": {
              "instruction": "Translate technical achievement into executive value. Focus on ROI, strategic alignment, and future options created. Use high-signal, low-noise language.",
              "context": ["{{technical_artifacts}}"]
            }
          },
          {
            "id": "emit-brief",
            "role": "sink",
            "op": "wisdom:write_file",
            "consumes": "executive_narrative",
            "params": {
              "path": "{{mission_evidence_dir}}/executive-briefing.md",
              "content": "{{executive_narrative}}"
            }
          }
        ],
        "else": [
          {
            "id": "reject-public-run",
            "role": "sink",
            "op": "system:log",
            "params": {
              "message": "executive-narrative-bridge requires mission_tier=confidential."
            }
          }
        ]
      }
    }
  ]
}
