{
  "pipeline_id": "setup-messaging-bridge",
  "version": "2.0.0",
  "description": "Onboard and activate a declared messaging bridge implementation.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "action": "pipeline",
  "steps": [
    {
      "id": "summarize-platform",
      "role": "source",
      "op": "reasoning:analyze",
      "produces": { "channel": "bridge_guidance", "type": "TextResult" },
      "params": {
        "instruction": "Summarize the requested messaging platform and the known operating constraints. Do not invent runtime IDs or shell commands.",
        "context": ["{{platform_id}}", "{{target_platform}}", "{{credentials_hint}}"]
      }
    },
    {
      "id": "require-platform-id",
      "role": "gate",
      "op": "core:if",
      "params": {
        "condition": { "from": "platform_id", "operator": "exists" },
        "then": [
          {
            "id": "route-slack-bridge",
            "role": "gate",
            "op": "core:if",
            "params": {
              "condition": { "from": "platform_id", "operator": "eq", "value": "slack" },
              "then": [
                {
                  "id": "check-readiness",
                  "role": "source",
                  "op": "system:shell",
                  "produces": { "channel": "install_status", "type": "ShellResult" },
                  "params": {
                    "cmd": "test -d satellites/slack-bridge && echo installed || echo not_installed"
                  }
                },
                {
                  "id": "verify-bridge-package",
                  "role": "gate",
                  "op": "core:if",
                  "params": {
                    "condition": { "from": "install_status", "operator": "eq", "value": "installed" },
                    "then": [
                      {
                        "id": "reconcile-surfaces",
                        "role": "sink",
                        "op": "service:reconcile",
                        "params": {
                          "service_id": "surface-runtime",
                          "action": "reconcile",
                          "params": {
                            "manifest_path": "knowledge/product/governance/active-surfaces.json",
                            "cleanup": false
                          }
                        }
                      },
                      {
                        "id": "log-success",
                        "role": "sink",
                        "op": "system:log",
                        "params": {
                          "message": "✅ Messaging bridge for slack is now ACTIVE and governed via active-surfaces.json."
                        }
                      }
                    ],
                    "else": [
                      {
                        "id": "log-missing-bridge",
                        "role": "sink",
                        "op": "system:log",
                        "params": {
                          "message": "⚠️ slack bridge source package is missing. Scaffold satellites/slack-bridge before activation."
                        }
                      },
                      {
                        "id": "fail-missing-bridge",
                        "role": "sink",
                        "op": "system:shell",
                        "params": {
                          "cmd": "exit 1"
                        }
                      }
                    ]
                  }
                }
              ],
              "else": [
                {
                  "id": "route-imessage-bridge",
                  "role": "gate",
                  "op": "core:if",
                  "params": {
                    "condition": { "from": "platform_id", "operator": "eq", "value": "imessage" },
                    "then": [
                      {
                        "id": "check-host-platform",
                        "role": "source",
                        "op": "system:shell",
                        "produces": { "channel": "host_platform", "type": "ShellResult" },
                        "params": {
                          "cmd": "case \"{{platform_name}}\" in darwin) echo darwin ;; *) echo unsupported ;; esac"
                        }
                      },
                      {
                        "id": "verify-host-platform",
                        "role": "gate",
                        "op": "core:if",
                        "params": {
                          "condition": { "from": "host_platform", "operator": "eq", "value": "darwin" },
                          "then": [
                            {
                              "id": "check-readiness",
                              "role": "source",
                              "op": "system:shell",
                              "produces": { "channel": "install_status", "type": "ShellResult" },
                              "params": {
                                "cmd": "test -d satellites/imessage-bridge && echo installed || echo not_installed"
                              }
                            },
                            {
                              "id": "verify-bridge-package",
                              "role": "gate",
                              "op": "core:if",
                              "params": {
                                "condition": { "from": "install_status", "operator": "eq", "value": "installed" },
                                "then": [
                                  {
                                    "id": "reconcile-surfaces",
                                    "role": "sink",
                                    "op": "service:reconcile",
                                    "params": {
                                      "service_id": "surface-runtime",
                                      "action": "reconcile",
                                      "params": {
                                        "manifest_path": "knowledge/product/governance/active-surfaces.json",
                                        "cleanup": false
                                      }
                                    }
                                  },
                                  {
                                    "id": "log-success",
                                    "role": "sink",
                                    "op": "system:log",
                                    "params": {
                                      "message": "✅ Messaging bridge for imessage is now ACTIVE and governed via active-surfaces.json."
                                    }
                                  }
                                ],
                                "else": [
                                  {
                                    "id": "log-missing-bridge",
                                    "role": "sink",
                                    "op": "system:log",
                                    "params": {
                                      "message": "⚠️ imessage bridge source package is missing. Scaffold satellites/imessage-bridge before activation."
                                    }
                                  },
                                  {
                                    "id": "fail-missing-bridge",
                                    "role": "sink",
                                    "op": "system:shell",
                                    "params": {
                                      "cmd": "exit 1"
                                    }
                                  }
                                ]
                              }
                            }
                          ],
                          "else": [
                            {
                              "id": "log-unsupported-host",
                              "role": "sink",
                              "op": "system:log",
                              "params": {
                                "message": "iMessage bridge activation requires macOS. The current host is not Darwin."
                              }
                            },
                            {
                              "id": "fail-unsupported-host",
                              "role": "sink",
                              "op": "system:shell",
                              "params": {
                                "cmd": "exit 1"
                              }
                            }
                          ]
                        }
                      }
                    ],
                    "else": [
                      {
                        "id": "log-unsupported-platform",
                        "role": "sink",
                        "op": "system:log",
                        "params": {
                          "message": "Messaging bridge activation currently supports declared bridge implementations only. {{platform_id}} needs a scaffolded satellite and manifest entry before activation."
                        }
                      },
                      {
                        "id": "fail-unsupported-platform",
                        "role": "sink",
                        "op": "system:shell",
                        "params": {
                          "cmd": "exit 1"
                        }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ],
        "else": [
          {
            "id": "log-missing-platform-id",
            "role": "sink",
            "op": "system:log",
            "params": {
              "message": "Provide platform_id in the pipeline context before onboarding a messaging bridge."
            }
          },
          {
            "id": "fail-missing-platform-id",
            "role": "sink",
            "op": "system:shell",
            "params": {
              "cmd": "exit 1"
            }
          }
        ]
      }
    }
  ]
}
