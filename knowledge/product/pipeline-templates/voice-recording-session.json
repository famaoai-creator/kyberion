{
  "action": "pipeline",
  "name": "voice-recording-session",
  "version": "2.0.0",
  "description": "Guides an operator to record a voice sample for cloning. Persona-parameterized — set context.persona_name (display name) and context.profile_id (slug, lowercase). Sample lands in knowledge/personal/voice/samples/{{profile_id}}/.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used export_as without roles.",
  "context": {
    "persona_name": "the operator",
    "profile_id": "operator-default-v1",
    "duration_sec": 10,
    "script_display_hold_ms": 1000,
    "script_text": "こんにちは。私は{{persona_name}}です。Kyberion のデジタルプロファイルを作成するための音声サンプルを録音しています。",
    "output_path": "knowledge/personal/voice/samples/{{profile_id}}/sample_01.wav"
  },
  "steps": [
    {
      "role": "gate",
      "op": "core:include",
      "params": {
        "fragment": "fragments/voice-runtime-preflight.json"
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "params": {
        "message": "🎙️ {{persona_name}} の音声録音セッションを開始します (profile={{profile_id}})。"
      }
    },
    {
      "role": "source",
      "op": "voice:record_voice_sample",
      "produces": { "channel": "recording_result", "type": "VoiceSampleRecordingResult" },
      "params": {
        "action": "record_voice_sample",
        "request_id": "voice-recording-{{profile_id}}",
        "sample_id": "sample-01",
        "duration_sec": "{{duration_sec}}",
        "language": "ja",
        "prompt_text": "{{script_text}}",
        "recording_countdown_sec": 3,
        "prompt_display_hold_ms": "{{script_display_hold_ms}}",
        "output_path": "{{output_path}}"
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "consumes": "recording_result",
      "params": {
        "message": "✅ 録音結果: {{recording_result}}"
      }
    }
  ]
}
