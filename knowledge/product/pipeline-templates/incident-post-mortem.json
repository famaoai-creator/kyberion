{
  "pipeline_id": "incident-post-mortem",
  "version": "2.0.0",
  "description": "Analyze an execution failure, identify root causes, and propose a repair ADF or mitigation plan.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "action": "pipeline",
  "steps": [
    {
      "id": "guard-confidential-tier",
      "role": "gate",
      "op": "if",
      "params": {
        "condition": {
          "from": "mission_tier",
          "operator": "eq",
          "value": "confidential"
        },
        "then": [
          {
            "id": "collect-orchestrator-log",
            "role": "source",
            "op": "system:read_file",
            "produces": { "channel": "orchestrator_log", "type": "LogText" },
            "params": {
              "path": "active/shared/runtime/orchestrator.log"
            }
          },
          {
            "id": "collect-surface-log",
            "role": "source",
            "op": "system:read_file",
            "produces": { "channel": "surface_log", "type": "LogText" },
            "params": {
              "path": "active/shared/runtime/surface.log"
            }
          },
          {
            "id": "collect-supervisor-log",
            "role": "source",
            "op": "system:read_file",
            "produces": { "channel": "supervisor_log", "type": "LogText" },
            "params": {
              "path": "active/shared/runtime/supervisor.log"
            }
          },
          {
            "id": "collect-trace",
            "role": "source",
            "op": "system:collect_artifacts",
            "produces": { "channel": "incident_trace", "type": "IncidentTrace" },
            "params": {
              "mission_ids": ["{{target_mission_id}}"],
              "patterns": ["trace.json", "TASK_BOARD.md"]
            }
          },
          {
            "id": "analyze-failure",
            "role": "transform",
            "op": "reasoning:analyze",
            "consumes": ["orchestrator_log", "surface_log", "supervisor_log", "incident_trace"],
            "produces": { "channel": "post_mortem_report", "type": "PostMortemReport" },
            "params": {
              "instruction": "Perform a technical post-mortem. Categorize the failure (Environment, Logic, Governance). Identify the root cause from the logs and trace. Propose a Repair ADF step or a system configuration change to prevent this in the future.",
              "context": ["{{orchestrator_log}}", "{{surface_log}}", "{{supervisor_log}}", "{{incident_trace}}"]
            }
          },
          {
            "id": "emit-incident-record",
            "role": "sink",
            "op": "system:write_artifact",
            "consumes": "post_mortem_report",
            "params": {
              "kind": "incident_report",
              "title": "Incident Post-Mortem: {{incident_id}}",
              "content": "{{post_mortem_report}}",
              "path": "knowledge/incidents/post_mortem_{{incident_id}}.md"
            }
          }
        ],
        "else": [
          {
            "id": "reject-public-run",
            "role": "sink",
            "op": "system:log",
            "params": {
              "message": "incident-post-mortem requires mission_tier=confidential."
            }
          }
        ]
      }
    }
  ]
}
