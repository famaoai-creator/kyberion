{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/mesh-topic-subscription.schema.json",
  "title": "Mesh Topic Subscription",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "subscription_id",
    "tenant_id",
    "topic",
    "peer_id",
    "filters",
    "expires_at",
    "policy_version"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "mesh-topic-subscription"
    },
    "subscription_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "peer_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,63}$"
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_kinds", "payload_classifications"],
      "properties": {
        "request_kinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "review.request",
              "workitem.claim",
              "workitem.handoff",
              "workitem.status_update",
              "capability.query",
              "notification.publish"
            ]
          }
        },
        "payload_classifications": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["public", "confidential"]
          }
        }
      }
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    }
  }
}
