{
  "type": "object",
  "required": [
    "version",
    "mode_aliases",
    "allowed_modes",
    "auto_select_env_priority",
    "cli_preference_rules",
    "provider_fallback_order",
    "default_mode"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "route_policy_ref": {
      "type": "string"
    },
    "mode_aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "allowed_modes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "auto_select_env_priority": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["env", "mode"],
        "properties": {
          "env": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "cli_preference_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mode", "provider"],
        "properties": {
          "env_any": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "env_equals": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "provider": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "provider_fallback_order": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "mode"],
        "properties": {
          "provider": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "default_mode": {
      "type": "string"
    },
    "openrouter": {
      "type": "object",
      "required": ["default_profile", "default_cost_policy", "required_parameters"],
      "properties": {
        "default_profile": {
          "enum": ["free-router", "free-pinned", "explicit"]
        },
        "default_cost_policy": {
          "enum": ["free-only", "paid-allowed"]
        },
        "required_parameters": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
