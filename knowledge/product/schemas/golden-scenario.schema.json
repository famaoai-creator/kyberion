{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/golden-scenario.schema.json",
  "title": "Procedure Golden Scenario (success verification)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scenario_id", "procedure_id", "success_conditions", "captured_from", "version"],
  "properties": {
    "schema_version": { "const": "golden-scenario.v1" },
    "scenario_id": { "type": "string", "minLength": 1 },
    "procedure_id": { "type": "string", "minLength": 1 },
    "success_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {
            "enum": [
              "ref_visible",
              "text_present",
              "response_field",
              "screenshot_state",
              "file_generated",
              "theme_applied",
              "structure_match"
            ]
          },
          "role": { "type": "string", "maxLength": 80 },
          "name_contains": { "type": "string", "maxLength": 500 },
          "params": { "type": "object" }
        }
      }
    },
    "captured_from": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+" }
  }
}
