{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/defect-record.schema.json",
  "title": "Defect Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "defect_id",
    "project_id",
    "title",
    "status",
    "severity",
    "priority",
    "source_test_refs",
    "reproduction_steps",
    "expected_result",
    "observed_result",
    "created_at"
  ],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "defect_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "open",
        "in_progress",
        "fixed",
        "retest",
        "closed",
        "reopened",
        "duplicate",
        "cannot_reproduce",
        "accepted_risk"
      ]
    },
    "severity": { "type": "string", "enum": ["blocker", "critical", "major", "minor", "trivial"] },
    "priority": { "type": "string", "enum": ["p0", "p1", "p2", "p3"] },
    "source_test_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "reproduction_steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "expected_result": { "type": "string", "minLength": 1 },
    "observed_result": { "type": "string", "minLength": 1 },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "fix_ref": { "type": "string", "minLength": 1 },
    "retest_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "fingerprint": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
