{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/mesh-peer-registration.schema.json",
  "title": "Mesh Peer Registration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "peer_id",
    "tenant_id",
    "endpoint_ref",
    "key_ref",
    "status",
    "registered_at"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "mesh-peer-registration"
    },
    "peer_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,63}$"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "endpoint_ref": {
      "type": "string",
      "minLength": 1
    },
    "key_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["enrolled", "revoked", "suspended"]
    },
    "registered_at": {
      "type": "string",
      "format": "date-time"
    },
    "revoked_at": {
      "type": "string",
      "format": "date-time"
    },
    "allowed_request_kinds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "review.request",
          "workitem.claim",
          "workitem.handoff",
          "workitem.status_update",
          "capability.query",
          "notification.publish"
        ]
      }
    }
  }
}
