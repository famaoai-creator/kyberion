{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/narrated-video-upload-package.schema.json",
  "title": "Narrated Video Upload Package",
  "description": "Staged package for YouTube upload preparation prior to public release.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "publish_plan_ref",
    "target_url",
    "checklist",
    "video_artifact_ref",
    "visibility",
    "approval_boundary"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "narrated-video-upload-package"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "publish_plan_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_url": {
      "type": "string",
      "minLength": 1
    },
    "video_artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "thumbnail_ref": {
      "type": "string",
      "minLength": 1
    },
    "caption_ref": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "visibility": {
      "type": "string",
      "enum": ["private", "unlisted", "public"]
    },
    "approval_boundary": {
      "type": "string",
      "enum": ["before_upload", "before_public_release"]
    },
    "checklist": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "scheduled_publish_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
