{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/mesh-capability-advertisement.schema.json",
  "title": "Mesh Capability Advertisement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "capability_id",
    "version",
    "peer_id",
    "tenant_id",
    "roles",
    "request_kinds",
    "approval_policy",
    "visibility",
    "advertised_at"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "mesh-capability-advertisement"
    },
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "peer_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,63}$"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "request_kinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "review.request",
          "workitem.claim",
          "workitem.handoff",
          "workitem.status_update",
          "capability.query",
          "notification.publish"
        ]
      }
    },
    "approval_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requires_explicit_acceptance",
        "requires_local_validation",
        "requires_policy_check"
      ],
      "properties": {
        "requires_explicit_acceptance": {
          "type": "boolean"
        },
        "requires_local_validation": {
          "type": "boolean"
        },
        "requires_policy_check": {
          "type": "boolean"
        }
      }
    },
    "visibility": {
      "type": "string",
      "enum": ["peer", "tenant"]
    },
    "advertised_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
