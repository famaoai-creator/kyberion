{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/mission-work-reconciliation.schema.json",
  "title": "Mission Existing Work Reconciliation",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "mission_id", "source", "adopted_by", "reason", "tasks"],
  "properties": {
    "kind": { "const": "mission-work-reconciliation" },
    "version": { "const": "1.0.0" },
    "mission_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]+$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "branch", "commit"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "pattern": "^[a-fA-F0-9]{7,64}$" }
      }
    },
    "adopted_by": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 8 },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "kind"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "kind": {
          "type": "string",
          "enum": ["artifact", "test_report", "review", "trace", "receipt"]
        }
      }
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion", "evidence_refs"],
      "properties": {
        "criterion": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "status", "exit_code", "evidence_refs"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "status": { "const": "passed" },
        "exit_code": { "const": 0 },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "evidence", "criteria", "verification"],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/criterion" }
        },
        "verification": { "$ref": "#/$defs/verification" }
      }
    }
  }
}
