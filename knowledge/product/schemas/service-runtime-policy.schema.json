{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "service-runtime-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "managed_roots": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "service_runtime_root": { "type": "string", "minLength": 1 },
        "cache_root": { "type": "string", "minLength": 1 }
      },
      "required": ["service_runtime_root", "cache_root"]
    },
    "mode_preference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "local_service": { "type": "string", "enum": ["trial_first", "installed_first", "installed_only"] },
        "remote_service": { "type": "string", "enum": ["trial_first", "installed_first", "installed_only"] }
      },
      "required": ["local_service", "remote_service"]
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provision_requires_approval": { "type": "boolean" },
        "pin_requires_approval": { "type": "boolean" }
      },
      "required": ["provision_requires_approval", "pin_requires_approval"]
    }
  },
  "required": ["version", "managed_roots", "mode_preference", "approval"]
}
