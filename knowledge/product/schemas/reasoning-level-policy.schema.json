{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reasoning-level-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "low_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "fast_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["low_confidence", "fast_confidence"]
    },
    "fast_shapes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["direct_reply", "task_session"]
      }
    },
    "cache_ttl_hours": {
      "type": "number",
      "minimum": 1
    },
    "rules": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "shadow_model_map": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "COGNITIVE_EXPLORATORY": { "type": "string", "minLength": 1 },
        "COGNITIVE_STANDARD": { "type": "string", "minLength": 1 },
        "REACTION_FAST": { "type": "string", "minLength": 1 },
        "REFLEX_DETERMINISTIC": { "type": "string", "minLength": 1 }
      }
    },
    "task_model_routing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": { "$ref": "#/$defs/task_model_route" },
        "phases": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mechanical": { "$ref": "#/$defs/task_phase_routing" },
            "plan": { "$ref": "#/$defs/task_phase_routing" },
            "implement": { "$ref": "#/$defs/task_phase_routing" },
            "review": { "$ref": "#/$defs/task_phase_routing" }
          }
        }
      },
      "required": ["default", "phases"]
    }
  },
  "required": ["version", "thresholds", "fast_shapes", "rules"],
  "$defs": {
    "task_model_route": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tier": {
          "type": "string",
          "enum": ["small", "standard", "large"]
        },
        "effort": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "model_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["tier", "effort", "model_id"]
    },
    "task_phase_routing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": { "$ref": "#/$defs/task_model_route" },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "S": { "$ref": "#/$defs/task_model_route" },
            "M": { "$ref": "#/$defs/task_model_route" },
            "L": { "$ref": "#/$defs/task_model_route" }
          }
        },
        "risk": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "low": { "$ref": "#/$defs/task_model_route" },
            "medium": { "$ref": "#/$defs/task_model_route" },
            "high": { "$ref": "#/$defs/task_model_route" },
            "approval_required": { "$ref": "#/$defs/task_model_route" },
            "high_stakes": { "$ref": "#/$defs/task_model_route" }
          }
        }
      },
      "required": ["default"]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "simple-greeting-reflex",
            "high-risk-exploratory",
            "ambiguous-exploratory",
            "known-low-risk-fast",
            "default-standard"
          ]
        },
        "level": {
          "type": "string",
          "enum": [
            "COGNITIVE_EXPLORATORY",
            "COGNITIVE_STANDARD",
            "REACTION_FAST",
            "REFLEX_DETERMINISTIC"
          ]
        }
      },
      "required": ["id", "level"]
    }
  }
}
