{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/project-mission-ledger.schema.json",
  "title": "Project Mission Ledger",
  "type": "object",
  "required": ["project_id", "entries"],
  "properties": {
    "project_id": { "type": "string" },
    "project_name": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mission_id", "relationship_type", "status", "summary"],
        "properties": {
          "mission_id": { "type": "string" },
          "relationship_type": {
            "type": "string",
            "enum": ["belongs_to", "supports", "governs", "independent"]
          },
          "status": { "type": "string" },
          "summary": { "type": "string" },
          "affected_artifacts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "gate_impact": {
            "type": "string",
            "enum": ["none", "informational", "review_required", "blocking"]
          },
          "traceability_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "owner": { "type": "string" },
          "last_updated": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
