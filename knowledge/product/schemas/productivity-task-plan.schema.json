{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/productivity-task-plan.schema.json",
  "title": "Productivity Task Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "request",
    "domains",
    "steps",
    "approval",
    "missing_inputs",
    "recommended_pipeline",
    "evidence_plan",
    "execution"
  ],
  "properties": {
    "kind": { "const": "productivity-task-plan" },
    "version": { "const": "1.0.0" },
    "request": { "type": "string", "minLength": 1 },
    "primary_intent_id": { "type": "string", "minLength": 1 },
    "domains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/domain" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "blocked_step_ids", "reasons"],
      "properties": {
        "required": { "type": "boolean" },
        "blocked_step_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "reasons": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "missing_inputs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "recommended_pipeline": { "type": "string", "minLength": 1 },
    "evidence_plan": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "external_effects_executed"],
      "properties": {
        "mode": { "const": "dry_run" },
        "external_effects_executed": { "const": false }
      }
    }
  },
  "$defs": {
    "domain": {
      "type": "string",
      "enum": [
        "calendar",
        "meeting",
        "email",
        "document",
        "presentation",
        "browser",
        "connected_systems"
      ]
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "domain",
        "title",
        "effect",
        "capability",
        "approval_required",
        "execution_mode",
        "evidence"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "domain": { "$ref": "#/$defs/domain" },
        "title": { "type": "string", "minLength": 1 },
        "effect": {
          "type": "string",
          "enum": ["read", "draft", "external_write", "financial_commit"]
        },
        "capability": { "type": "string", "pattern": "^[a-z-]+:[a-z0-9_-]+$" },
        "approval_required": { "type": "boolean" },
        "execution_mode": { "const": "preview_only" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
