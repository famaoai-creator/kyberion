{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/agent-routing-decision.schema.json",
  "title": "Agent Routing Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "source_text",
    "intent_id",
    "mode",
    "scope",
    "autonomy",
    "boundary_crossing",
    "fanout",
    "owner",
    "artifact_count",
    "stop_condition",
    "rationale"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "agent-routing-decision"
    },
    "source_text": {
      "type": "string"
    },
    "intent_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": ["prompt", "subagent", "coordination"]
    },
    "scope": {
      "type": "string",
      "enum": ["single_artifact", "multi_artifact", "stateful_flow", "boundary_crossing"]
    },
    "autonomy": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "boundary_crossing": {
      "type": "boolean"
    },
    "fanout": {
      "type": "string",
      "enum": ["none", "parallel", "review", "cross_critique"]
    },
    "owner": {
      "type": "string"
    },
    "delegates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_count": {
      "type": "integer",
      "minimum": 1
    },
    "stop_condition": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    }
  }
}
