{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "model-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "default_model_id": { "type": "string", "minLength": 1 },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/modelEntry" }
    }
  },
  "required": ["version", "default_model_id", "models"],
  "$defs": {
    "confidenceBand": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "roleFit": {
      "type": "string",
      "enum": ["primary", "secondary", "not_recommended"]
    },
    "modelEntry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["approved", "candidate", "deprecated", "blocked"]
        },
        "role_fit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "intent_compiler": { "$ref": "#/$defs/roleFit" },
            "surface_agent": { "$ref": "#/$defs/roleFit" },
            "analysis": { "$ref": "#/$defs/roleFit" },
            "coding": { "$ref": "#/$defs/roleFit" }
          },
          "required": ["intent_compiler", "surface_agent", "analysis", "coding"]
        },
        "cost_band": {
          "type": "string",
          "enum": ["low", "medium", "high", "very_high"]
        },
        "latency_band": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "structured_output_confidence": { "$ref": "#/$defs/confidenceBand" },
        "tool_use_confidence": { "$ref": "#/$defs/confidenceBand" },
        "multilingual_confidence": { "$ref": "#/$defs/confidenceBand" },
        "reasoning_confidence": { "$ref": "#/$defs/confidenceBand" },
        "capability_tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": { "type": "string" }
      },
      "required": [
        "model_id",
        "provider",
        "family",
        "status",
        "role_fit",
        "cost_band",
        "latency_band",
        "structured_output_confidence",
        "tool_use_confidence",
        "multilingual_confidence",
        "reasoning_confidence",
        "capability_tags"
      ]
    }
  }
}
