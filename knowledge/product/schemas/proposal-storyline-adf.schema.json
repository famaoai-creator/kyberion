{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Proposal Storyline ADF",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "title", "slides"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["proposal-storyline-adf"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "client": {
      "type": "string"
    },
    "core_message": {
      "type": "string"
    },
    "document_profile": { "type": "string" },
    "design_system_id": { "type": "string" },
    "branding": {
      "type": "object",
      "additionalProperties": true
    },
    "layout_template_id": { "type": "string" },
    "narrative_pattern_id": { "type": "string" },
    "recommended_theme": { "type": "string" },
    "recommended_layout_template_id": { "type": "string" },
    "toc": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "objective"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "body": {
            "type": "array",
            "items": { "type": "string" }
          },
          "visual": { "type": "string" },
          "media_kind": { "type": "string" },
          "layout_key": { "type": "string" },
          "semantic_type": { "type": "string" },
          "pattern_id": { "type": "string" },
          "slide_pattern": {
            "type": "object",
            "additionalProperties": true
          },
          "body_zone": { "type": "string" },
          "design_system_id": { "type": "string" },
          "branding": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
