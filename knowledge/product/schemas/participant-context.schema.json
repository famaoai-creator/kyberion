{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/participant-context.schema.json",
  "title": "Reasoning Participant Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "participant_id",
    "team_role_id",
    "perspective_ids",
    "agent_profile_id",
    "authority_role_id",
    "reasoning_route_id",
    "security_scope"
  ],
  "properties": {
    "participant_id": { "type": "string", "minLength": 1 },
    "organization_role_id": { "type": "string", "minLength": 1 },
    "team_role_id": { "type": "string", "minLength": 1 },
    "perspective_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "agent_profile_id": { "type": "string", "minLength": 1 },
    "authority_role_id": { "type": "string", "minLength": 1 },
    "reasoning_route_id": { "type": "string", "minLength": 1 },
    "security_scope": { "$ref": "security-scope.schema.json" }
  }
}
