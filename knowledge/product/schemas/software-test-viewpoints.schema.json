{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/software-test-viewpoints.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "viewpoints"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "viewpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["viewpoint_id", "category", "title", "prompts", "default_risk"],
        "properties": {
          "viewpoint_id": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$" },
          "category": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "prompts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "default_risk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "applicability_tags": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    }
  }
}
