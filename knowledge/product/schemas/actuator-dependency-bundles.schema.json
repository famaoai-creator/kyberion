{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Actuator Dependency Bundles Schema",
  "type": "object",
  "required": ["version", "bundles"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "actuator", "dependency_ids"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "actuator": { "type": "string", "minLength": 1 },
          "dependency_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "summary": { "type": "string" }
        }
      }
    }
  }
}
