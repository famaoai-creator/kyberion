{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "voice-sample-collection.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "action": { "const": "collect_voice_samples" },
    "request_id": { "type": "string", "minLength": 1 },
    "profile_draft": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "tier": { "type": "string", "enum": ["personal", "confidential", "public"] },
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 2 }
        },
        "default_engine_id": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      },
      "required": ["profile_id", "display_name", "tier", "languages", "default_engine_id"]
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "sample_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "language": { "type": "string", "minLength": 2 },
          "note": { "type": "string" }
        },
        "required": ["sample_id", "path"]
      }
    }
  },
  "required": ["action", "request_id", "samples"]
}
