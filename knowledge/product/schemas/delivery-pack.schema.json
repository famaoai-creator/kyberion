{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Delivery Pack",
  "type": "object",
  "required": ["kind", "pack_id", "summary", "artifacts"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["delivery-pack"]
    },
    "pack_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "main_artifact_id": {
      "type": "string"
    },
    "request_text": {
      "type": "string"
    },
    "conversation_summary": {
      "type": "string"
    },
    "recommended_next_action": {
      "type": "string"
    },
    "artifacts_by_role": {
      "type": "object",
      "properties": {
        "primary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "specification": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "path"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "path": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
