{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "provider-capability-scan-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/providerPolicy" }
    }
  },
  "required": ["version", "providers"],
  "$defs": {
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeout_ms": { "type": "number", "minimum": 1 },
        "max_output_mb": { "type": "number", "minimum": 1 },
        "evidence": { "type": "string" }
      },
      "required": ["command"]
    },
    "capabilityEvidenceProbe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capability_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "probe": { "$ref": "#/$defs/probe" }
      },
      "required": ["capability_ids", "probe"]
    },
    "providerPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "primary_probe": { "$ref": "#/$defs/probe" },
        "evidence_probes": {
          "type": "array",
          "items": { "$ref": "#/$defs/capabilityEvidenceProbe" }
        }
      },
      "required": ["provider", "primary_probe"]
    }
  }
}
