{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/task-result.schema.json",
  "title": "Task Result",
  "type": "object",
  "required": ["summary", "artifacts", "verification_done", "gaps", "needs"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "verification_done": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "needs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
