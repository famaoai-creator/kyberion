{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/points-portal-clickout-usecase.schema.json",
  "title": "Points Portal Clickout Use Case",
  "description": "Governed use-case contract for moving from a points portal advertiser page to a merchant landing page without reservation confirmation, payment execution, credential export, or session handoff export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "usecase_id",
    "mode",
    "points_portal",
    "merchant",
    "auth_strategy",
    "portal_detail_url",
    "clickout",
    "landing_match",
    "blocked_actions",
    "evidence_required",
    "success_criteria",
    "artifact_policy",
    "preflight"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["points-portal-clickout-usecase"]
    },
    "usecase_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "mode": {
      "type": "string",
      "enum": ["simulation", "assisted_booking"]
    },
    "points_portal": {
      "$ref": "#/definitions/siteRef"
    },
    "merchant": {
      "$ref": "#/definitions/siteRef"
    },
    "auth_strategy": {
      "$ref": "#/definitions/authStrategy"
    },
    "portal_detail_url": {
      "type": "string",
      "minLength": 1,
      "pattern": "^https://"
    },
    "clickout": {
      "$ref": "#/definitions/clickout"
    },
    "landing_match": {
      "$ref": "#/definitions/landingMatch"
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "allOf": [
        {
          "contains": {
            "const": "reservation_confirmation"
          }
        },
        {
          "contains": {
            "const": "payment_execution"
          }
        },
        {
          "contains": {
            "const": "session_handoff_export"
          }
        }
      ],
      "items": {
        "type": "string",
        "enum": [
          "reservation_confirmation",
          "payment_execution",
          "cancellation",
          "profile_mutation",
          "credential_export",
          "session_handoff_export",
          "session_handoff_import",
          "new_site_login"
        ]
      },
      "uniqueItems": true
    },
    "evidence_required": {
      "type": "array",
      "minItems": 1,
      "allOf": [
        {
          "contains": {
            "const": "portal_detail_screenshot"
          }
        },
        {
          "contains": {
            "const": "merchant_landing_screenshot"
          }
        },
        {
          "contains": {
            "const": "tabs_after_landing"
          }
        }
      ],
      "items": {
        "type": "string",
        "enum": [
          "portal_name",
          "merchant_page",
          "reward_rate",
          "terms_snapshot",
          "timestamp",
          "portal_detail_screenshot",
          "clickout_confirmation",
          "tabs_before_clickout",
          "tabs_after_landing",
          "merchant_landing_snapshot",
          "merchant_landing_screenshot",
          "network_after_landing",
          "exported_adf",
          "tracking_warning"
        ]
      },
      "uniqueItems": true
    },
    "success_criteria": {
      "$ref": "#/definitions/successCriteria"
    },
    "artifact_policy": {
      "$ref": "#/definitions/artifactPolicy"
    },
    "preflight": {
      "$ref": "#/definitions/preflight"
    },
    "notes": {
      "type": "string"
    }
  },
  "definitions": {
    "siteRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "display_name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "account_ref": {
          "type": "string",
          "pattern": "^(personal|confidential)/[A-Za-z0-9_./:@-]+$"
        }
      }
    },
    "authStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "approval_required"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["dedicated_browser_profile", "manual_login", "cdp_existing_browser"]
        },
        "browser_profile_ref": {
          "type": "string",
          "pattern": "^(browser://profile/|active/shared/runtime/browser/profiles/)[A-Za-z0-9_./:@-]+$"
        },
        "approval_required": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "clickout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector", "operator_confirmation_required"],
      "properties": {
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "selector_strategy": {
          "type": "string",
          "enum": ["css", "role", "text"],
          "default": "css"
        },
        "button_text_hint": {
          "type": "string"
        },
        "operator_confirmation_required": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "landingMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url_includes"],
      "properties": {
        "url_includes": {
          "type": "string",
          "minLength": 1
        },
        "title_includes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "successCriteria": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "landing_url_includes",
        "handoff_export_absent",
        "blocked_actions_not_executed",
        "merchant_landing_captured"
      ],
      "properties": {
        "landing_url_includes": {
          "type": "string",
          "minLength": 1
        },
        "landing_title_includes": {
          "type": "string",
          "minLength": 1
        },
        "handoff_export_absent": {
          "type": "boolean",
          "const": true
        },
        "blocked_actions_not_executed": {
          "type": "boolean",
          "const": true
        },
        "merchant_landing_captured": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "artifactPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forbid_session_handoff_export",
        "allowed_artifact_roots",
        "retain_browser_profile",
        "delete_continue_files"
      ],
      "properties": {
        "forbid_session_handoff_export": {
          "type": "boolean",
          "const": true
        },
        "allowed_artifact_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["active/shared/tmp/browser", "active/shared/runtime/browser"]
          },
          "uniqueItems": true
        },
        "retain_browser_profile": {
          "type": "boolean"
        },
        "delete_continue_files": {
          "type": "boolean"
        }
      }
    },
    "preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_clickout_selector",
        "require_landing_match",
        "require_blocked_actions",
        "deny_ops"
      ],
      "properties": {
        "require_clickout_selector": {
          "type": "boolean",
          "const": true
        },
        "require_landing_match": {
          "type": "boolean",
          "const": true
        },
        "require_blocked_actions": {
          "type": "boolean",
          "const": true
        },
        "deny_ops": {
          "type": "array",
          "minItems": 1,
          "contains": {
            "const": "export_session_handoff"
          },
          "items": {
            "type": "string",
            "enum": [
              "export_session_handoff",
              "import_session_handoff",
              "payment_execution",
              "reservation_confirmation",
              "profile_mutation"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
