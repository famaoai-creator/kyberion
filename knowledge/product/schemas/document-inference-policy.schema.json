{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "document-inference-policy",
  "type": "object",
  "required": ["version", "type_rules", "profile_rules"],
  "properties": {
    "version": { "type": "string" },
    "type_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["document_type", "keywords"],
        "properties": {
          "document_type": { "type": "string" },
          "keywords": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "profile_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["document_type", "profile_ids", "keywords"],
        "properties": {
          "document_type": { "type": "string" },
          "profile_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "keywords": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
