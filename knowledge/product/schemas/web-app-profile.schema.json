{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Web App Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["app_id", "title", "base_url"],
  "properties": {
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "base_url": {
      "type": "string",
      "minLength": 1
    },
    "guarded_routes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "login_route": {
      "type": "string"
    },
    "logout_route": {
      "type": "string"
    },
    "execution_preset": {
      "type": "string"
    },
    "session_handoff": {
      "$ref": "./webview-session-handoff.schema.json"
    },
    "selectors": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "login": {
          "type": "object",
          "additionalProperties": true
        },
        "navigation": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "debug_routes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "session_export": {
          "type": "string"
        }
      }
    }
  }
}
