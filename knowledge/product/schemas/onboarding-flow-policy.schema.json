{
  "$id": "https://kyberion.local/schemas/onboarding-flow-policy.schema.json",
  "title": "Onboarding Flow Policy",
  "type": "object",
  "required": [
    "version",
    "phase_titles",
    "tutorial_plan_title",
    "tutorial_next_step_title",
    "tutorial_skipped_message",
    "tutorial_default_summary",
    "complete_message"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "phase_titles": {
      "type": "object",
      "required": ["identity", "services", "tenants", "tutorial", "summary"],
      "properties": {
        "identity": {
          "$ref": "#/$defs/localizedText"
        },
        "services": {
          "$ref": "#/$defs/localizedText"
        },
        "tenants": {
          "$ref": "#/$defs/localizedText"
        },
        "tutorial": {
          "$ref": "#/$defs/localizedText"
        },
        "summary": {
          "$ref": "#/$defs/localizedText"
        }
      },
      "additionalProperties": false
    },
    "tutorial_plan_title": {
      "$ref": "#/$defs/localizedText"
    },
    "tutorial_next_step_title": {
      "$ref": "#/$defs/localizedText"
    },
    "tutorial_skipped_message": {
      "$ref": "#/$defs/localizedText"
    },
    "tutorial_default_summary": {
      "$ref": "#/$defs/localizedText"
    },
    "complete_message": {
      "$ref": "#/$defs/localizedText"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "localizedText": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": ["en"],
          "additionalProperties": false,
          "properties": {
            "en": {
              "type": "string",
              "minLength": 1
            },
            "ja": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
