{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "execution-receipt-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "required_sections": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": ["intent", "deliverable", "missing_inputs", "approval", "execution", "status"]
      }
    },
    "clarification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_blocking_questions_per_turn": { "type": "integer", "minimum": 1, "maximum": 5 },
        "must_explain_missing_inputs": { "type": "boolean" }
      },
      "required": ["max_blocking_questions_per_turn", "must_explain_missing_inputs"]
    },
    "compactness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_interpreted_goal_chars": { "type": "integer", "minimum": 40, "maximum": 400 },
        "max_next_action_chars": { "type": "integer", "minimum": 20, "maximum": 240 }
      },
      "required": ["max_interpreted_goal_chars", "max_next_action_chars"]
    },
    "approval_binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "require_policy_refs_when_approval_required": { "type": "boolean" },
        "require_reason_when_approval_required": { "type": "boolean" }
      },
      "required": ["require_policy_refs_when_approval_required", "require_reason_when_approval_required"]
    },
    "routing_binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_modes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["one_shot", "managed_program"] }
        },
        "allowed_routing": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["local_only", "host_only", "dual_path"] }
        }
      },
      "required": ["allowed_modes", "allowed_routing"]
    }
  },
  "required": [
    "version",
    "required_sections",
    "clarification",
    "compactness",
    "approval_binding",
    "routing_binding"
  ]
}
