{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Proposal Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "title", "client", "objective", "audience", "story"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["proposal-brief"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "client": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "document_profile": {
      "type": "string"
    },
    "layout_template_id": {
      "type": "string"
    },
    "render_target": {
      "type": "string"
    },
    "locale": {
      "type": "string"
    },
    "audience": {
      "type": "array",
      "items": { "type": "string" }
    },
    "story": {
      "type": "object",
      "additionalProperties": false,
      "required": ["core_message", "chapters"],
      "properties": {
        "core_message": {
          "type": "string",
          "minLength": 1
        },
        "chapters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tone": {
          "type": "string"
        },
        "closing_cta": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "point"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "point": { "type": "string", "minLength": 1 }
        }
      }
    },
    "required_sections": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
