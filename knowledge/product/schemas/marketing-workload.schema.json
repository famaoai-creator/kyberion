{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyberion.example/schemas/marketing-workload.schema.json",
  "title": "Marketing workload contracts",
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "claim": {
      "type": "object",
      "required": ["id", "text", "source", "confidence", "public_use", "permitted_channels"],
      "properties": {
        "id": { "type": "string", "pattern": "^claim-[a-zA-Z0-9_-]+$" },
        "text": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "source_location": { "type": "string" },
        "confidence": { "enum": ["unverified", "reviewed", "verified"] },
        "public_use": { "type": "boolean" },
        "permitted_channels": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "gate_result": {
      "type": "object",
      "required": ["gate_id", "status", "reasons", "evidence"],
      "properties": {
        "gate_id": { "enum": ["G0", "G1", "G2", "G3", "G4", "G5", "G6"] },
        "status": { "enum": ["passed", "failed"] },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "required": [
        "review_id",
        "artifact_path",
        "artifact_sha256",
        "reviewer_role",
        "verdict",
        "findings"
      ],
      "properties": {
        "review_id": { "type": "string", "minLength": 1 },
        "artifact_path": { "type": "string", "minLength": 1 },
        "artifact_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "reviewer_role": { "type": "string", "minLength": 1 },
        "verdict": { "enum": ["approved", "changes_requested", "rejected"] },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["severity", "category", "description"],
            "properties": {
              "severity": { "enum": ["blocking", "suggestion"] },
              "category": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "required_action": { "type": "string" },
              "location": { "type": "object", "additionalProperties": { "type": "string" } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "publication_approval": {
      "type": "object",
      "required": [
        "approval_id",
        "mission_id",
        "approved_artifacts",
        "destination",
        "title",
        "description",
        "approved_by",
        "approval_decisions",
        "approved_at",
        "expires_at",
        "risk_level",
        "review_ids",
        "shared_approval"
      ],
      "properties": {
        "approval_id": { "type": "string", "minLength": 1 },
        "mission_id": { "type": "string", "minLength": 1 },
        "approved_artifacts": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/artifact" }
        },
        "destination": {
          "type": "object",
          "required": ["service", "account", "visibility"],
          "properties": {
            "service": { "type": "string", "minLength": 1 },
            "account": { "type": "string", "minLength": 1 },
            "visibility": { "type": "string", "minLength": 1 },
            "publish_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "cta_url": { "type": "string", "format": "uri" },
        "approved_by": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "approval_decisions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["approved_by", "decided_by_type", "authenticated", "approved_at"],
            "properties": {
              "approved_by": { "type": "string", "minLength": 1 },
              "decided_by_type": { "const": "human" },
              "authenticated": { "const": true },
              "approved_at": { "type": "string", "format": "date-time" }
            },
            "additionalProperties": false
          }
        },
        "approved_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "risk_level": { "type": "integer", "minimum": 0, "maximum": 4 },
        "review_ids": { "type": "array", "items": { "type": "string" } },
        "shared_approval": {
          "type": "object",
          "required": ["storage_channel", "request_id", "payload_hash", "effect_binding"],
          "properties": {
            "storage_channel": { "type": "string", "minLength": 1 },
            "request_id": { "type": "string", "format": "uuid" },
            "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "effect_binding": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "publication_evidence": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["url", "screenshot", "verification"] },
        "value": { "type": "string" },
        "path": { "type": "string" },
        "name": { "type": "string" },
        "status": { "enum": ["passed", "failed"] }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": ["intake", "claim_register"],
  "properties": {
    "intake": {
      "type": "object",
      "required": [
        "outcome",
        "audience",
        "owner",
        "channels",
        "deliverables",
        "deadline",
        "success_criteria",
        "data_classification",
        "publication_intent",
        "risk_level"
      ],
      "properties": {
        "outcome": { "type": "string", "minLength": 1 },
        "audience": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "owner": { "type": "string", "minLength": 1 },
        "approvers": { "type": "array", "items": { "type": "string" } },
        "channels": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "deliverables": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "deadline": { "type": "string", "format": "date-time" },
        "success_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "data_classification": { "enum": ["public", "confidential", "personal"] },
        "publication_intent": { "enum": ["none", "internal", "public"] },
        "risk_level": { "type": "integer", "minimum": 0, "maximum": 4 },
        "claim_ids": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "claim_register": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
    "reviews": { "type": "array", "items": { "$ref": "#/$defs/review" } },
    "publication_approval": { "$ref": "#/$defs/publication_approval" },
    "publication_evidence": { "type": "array", "items": { "$ref": "#/$defs/publication_evidence" } }
  },
  "additionalProperties": false
}
