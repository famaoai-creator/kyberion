{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/peer-conversation-session.schema.json",
  "title": "Peer Conversation Session",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "local_peer_id",
    "remote_peer_id",
    "topic",
    "status",
    "transport",
    "related_work_item_ids",
    "transcript",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "session_id": { "type": "string", "minLength": 1 },
    "local_peer_id": { "type": "string", "minLength": 1 },
    "remote_peer_id": { "type": "string", "minLength": 1 },
    "topic": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["open", "active", "closed", "blocked", "failed"] },
    "transport": { "type": "string", "enum": ["peer-messaging"] },
    "related_work_item_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "transcript": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "message_id",
          "kind",
          "direction",
          "sender_peer_id",
          "recipient_peer_id",
          "text",
          "created_at"
        ],
        "properties": {
          "message_id": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": ["open", "message", "reply", "handoff", "close", "status"]
          },
          "direction": { "type": "string", "enum": ["inbound", "outbound"] },
          "sender_peer_id": { "type": "string", "minLength": 1 },
          "recipient_peer_id": { "type": "string", "minLength": 1 },
          "text": { "type": "string" },
          "created_at": { "type": "string" },
          "reply_to_message_id": { "type": "string" },
          "related_work_item_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "last_message_at": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
