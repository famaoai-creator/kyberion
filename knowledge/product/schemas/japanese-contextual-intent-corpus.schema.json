{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "knowledge/product/schemas/japanese-contextual-intent-corpus.schema.json",
  "title": "Japanese Contextual Intent Corpus",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "locale", "items"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "enum": ["ja-JP"]
    },
    "description": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "minItems": 50,
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "object", "subject"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["read", "change", "unknown"]
        },
        "object": {
          "type": "string",
          "enum": ["calendar_events", "calendar_schedule", "unknown"]
        },
        "subject": {
          "type": "string",
          "enum": ["operator_self", "team", "unknown"]
        },
        "date_range": {
          "type": "string",
          "enum": ["today", "tomorrow", "this_week", "next_week", "this_month", "next_month", "custom"]
        },
        "source_binding": {
          "type": "string",
          "enum": ["operator_default_calendar", "google_calendar", "outlook_calendar", "browser_calendar"]
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent_id", "execution_shape", "result_shape"],
      "properties": {
        "intent_id": {
          "type": "string",
          "minLength": 1
        },
        "execution_shape": {
          "type": "string",
          "enum": ["direct_reply", "task_session", "mission", "project_bootstrap"]
        },
        "result_shape": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "utterance", "expected_frame", "expected_route", "clarification_needed"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "utterance": {
          "type": "string",
          "minLength": 1
        },
        "expected_frame": {
          "$ref": "#/$defs/frame"
        },
        "expected_route": {
          "$ref": "#/$defs/route"
        },
        "clarification_needed": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
