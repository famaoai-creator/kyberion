{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["mission_class", "delivery_shape", "risk_profile", "stage", "matched_rules", "evidence"],
  "properties": {
    "mission_class": {
      "type": "string",
      "enum": [
        "product_delivery",
        "code_change",
        "research_and_absorption",
        "content_and_media",
        "operations_and_release",
        "environment_and_recovery",
        "decision_support",
        "customer_engagement",
        "platform_onboarding"
      ]
    },
    "delivery_shape": {
      "type": "string",
      "enum": [
        "single_artifact",
        "multi_artifact_pipeline",
        "long_running_job",
        "interactive_exploration",
        "cross_system_change"
      ]
    },
    "risk_profile": {
      "type": "string",
      "enum": ["low", "review_required", "approval_required", "high_stakes"]
    },
    "stage": {
      "type": "string",
      "enum": [
        "intake",
        "classification",
        "planning",
        "contract_authoring",
        "preflight",
        "execution",
        "verification",
        "delivery",
        "retrospective"
      ]
    },
    "matched_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mission_class_rule_id": { "type": "string" },
        "delivery_shape_rule_id": { "type": "string" },
        "risk_rule_id": { "type": "string" },
        "stage_rule_id": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normalized_artifact_paths", "normalized_signals"],
      "properties": {
        "normalized_artifact_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "normalized_signals": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
