{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "authority_roles"],
  "properties": {
    "version": { "type": "string" },
    "authority_roles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "write_scopes", "scope_classes", "allowed_actuators", "tier_access"],
        "properties": {
          "description": { "type": "string" },
          "write_scopes": { "type": "array", "items": { "type": "string" } },
          "scope_classes": { "type": "array", "items": { "type": "string" } },
          "allowed_actuators": { "type": "array", "items": { "type": "string" } },
          "tier_access": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
