{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/work-scope-policy.schema.json",
  "title": "Work Scope Policy",
  "description": "Policy for deciding the minimum execution shape and when task scope must promote to mission scope.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "defaults", "mandatory_triggers", "accumulation_triggers", "rules"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accumulation_trigger_threshold"],
      "properties": {
        "accumulation_trigger_threshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "mandatory_triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "accumulation_triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "promotion_required", "rationale"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "when": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "minimum_catalog_shapes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "direct_reply",
                    "actuator_action",
                    "browser_session",
                    "task_session",
                    "pipeline",
                    "mission",
                    "project_bootstrap"
                  ]
                }
              },
              "mandatory_trigger_present": {
                "type": "boolean"
              },
              "accumulation_trigger_count_at_least": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "promotion_required": {
            "type": "boolean"
          },
          "result_shape": {
            "type": "string",
            "enum": [
              "direct_reply",
              "actuator_action",
              "browser_session",
              "task_session",
              "pipeline",
              "mission",
              "project_bootstrap"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
