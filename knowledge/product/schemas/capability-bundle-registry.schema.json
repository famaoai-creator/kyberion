{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/capability-bundle-registry.schema.json",
  "title": "Capability Bundle Registry",
  "type": "object",
  "required": ["version", "bundles"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["bundle_id", "status", "kind", "summary"],
        "properties": {
          "bundle_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["active", "experimental", "conceptual", "deprecated"]
          },
          "kind": {
            "type": "string",
            "enum": ["actuator-pipeline-bundle", "capability-bundle"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "source_bundle_path": {
            "type": "string"
          },
          "harness_capability_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "intents": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_actuators": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "references": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
