{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "workflow-registration-request.schema.json",
  "title": "Workflow Registration Request",
  "description": "Compact spec consumed by scripts/register_workflow.ts to dynamically register a new mission workflow template together with its intent, domain-ontology entry, and track routing (and optional gate profile / governance body). The script expands this into schema-valid catalog entries that pass check:governance-rules and check:workflow-catalog-refs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "title",
    "description",
    "mission_class",
    "risk_profile",
    "team_template",
    "intent",
    "phases"
  ],
  "properties": {
    "workflow_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "pattern": {
      "type": "string",
      "enum": [
        "stage_gated_delivery",
        "single_track_execution",
        "coordinated_multi_track_execution",
        "exploratory_to_deterministic_conversion",
        "pipeline_crystallization_loop",
        "capability_lifecycle_procedure",
        "aidlc_code_change"
      ],
      "default": "stage_gated_delivery"
    },
    "mission_class": { "type": "string" },
    "risk_profile": {
      "type": "string",
      "enum": ["low", "review_required", "approval_required", "high_stakes"]
    },
    "delivery_shape": { "type": "string", "default": "multi_artifact_pipeline" },
    "team_template": { "type": "string" },
    "aliases": {
      "description": "Additional intent_ids that should match this workflow template.",
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "track_type": { "type": "string" },
        "default_lifecycle": { "type": "string" },
        "min_confidence_to_autostart": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "action",
        "object",
        "outcome_ids",
        "specialist_id",
        "trigger_keywords"
      ],
      "properties": {
        "target": { "type": "string" },
        "action": { "type": "string" },
        "object": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "outcome_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "specialist_id": { "type": "string" },
        "trigger_keywords": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "surface_examples": { "type": "array", "items": { "type": "string" } },
        "plan_outline": { "type": "array", "items": { "type": "string" } },
        "intake_requirements": { "type": "array", "items": { "type": "string" } },
        "actuator_requirements": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "exposed_to_surface": { "type": "boolean", "default": true }
      }
    },
    "lead_phases": {
      "description": "Standard string phases injected before the first custom phase.",
      "type": "array",
      "items": { "type": "string", "enum": ["intake", "classification"] },
      "default": ["intake", "classification"]
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "kind", "gate_id", "checks"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "title": { "type": "string" },
          "kind": { "type": "string", "enum": ["judgment", "deterministic", "review", "approval"] },
          "gate_id": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "preflight_before": {
            "type": "boolean",
            "description": "Inject the standard 'preflight' string phase before this phase."
          },
          "team_role": { "type": "string", "default": "implementer" },
          "description": { "type": "string" },
          "deliverable": { "type": "string" },
          "deliverable_kind": { "type": "string", "enum": ["doc", "deck", "code", "media"] },
          "pipeline_ref": { "type": "string" },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "estimated_scope": { "type": "string", "enum": ["S", "M", "L"], "default": "M" },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high", "approval_required", "high_stakes"],
            "default": "medium"
          },
          "review_target_suffix": {
            "type": "string",
            "description": "Required when kind=review: the task_id_suffix of the deliverable task being reviewed."
          },
          "checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "evidence_exists",
                "reviewer_approved",
                "deliverable_quality",
                "human_override"
              ]
            }
          }
        }
      }
    },
    "gate_profile_gates": {
      "description": "Optional gate-profile-registry gate entries to append under the given profile id.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": { "type": "string" },
        "gates": { "type": "array", "items": { "type": "object" } }
      }
    },
    "governance_bodies": {
      "description": "Optional governance-body-registry body entries to append.",
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
