{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2A Task Contract",
  "type": "object",
  "required": ["intent", "text", "context"],
  "properties": {
    "intent": { "type": "string" },
    "text": { "type": "string" },
    "objective": { "type": "string" },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "expected_outputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rationale": { "type": "string" },
    "prior_decisions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "context": {
      "type": "object",
      "required": ["mission_id", "team_role"],
      "properties": {
        "mission_id": { "type": "string" },
        "team_role": { "type": "string" },
        "execution_mode": { "type": "string" },
        "channel": { "type": "string" },
        "thread": { "type": "string" },
        "slack_channel": { "type": "string" },
        "correlation_id": { "type": "string" },
        "task_model_hint": { "type": "object" },
        "model_hint": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
