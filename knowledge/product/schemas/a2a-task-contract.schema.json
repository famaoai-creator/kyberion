{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2A Task Contract",
  "type": "object",
  "required": ["intent", "text", "context"],
  "properties": {
    "intent": { "type": "string" },
    "text": { "type": "string" },
    "context": {
      "type": "object",
      "required": ["mission_id", "team_role"],
      "properties": {
        "mission_id": { "type": "string" },
        "team_role": { "type": "string" },
        "execution_mode": { "type": "string" },
        "channel": { "type": "string" },
        "thread": { "type": "string" },
        "slack_channel": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
