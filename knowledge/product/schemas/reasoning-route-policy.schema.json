{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reasoning-route-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "runtime_adapters", "profiles", "roles", "fallback"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "runtime_adapters": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/runtimeAdapter" }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/profile" }
    },
    "roles": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/role" }
    },
    "fallback": { "$ref": "#/$defs/fallback" }
  },
  "$defs": {
    "runtimeAdapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter", "capabilities", "supported_parameters"],
      "properties": {
        "adapter": { "type": "string", "minLength": 1 },
        "selection": { "$ref": "#/$defs/selection" },
        "preset": { "type": "string", "minLength": 1 },
        "endpoint_policy": { "type": "string", "enum": ["local", "public"] },
        "model_policy": { "type": "string", "enum": ["approved", "local-unregistered"] },
        "capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "supported_parameters": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "parameter_aliases": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "availability"],
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "model_provider": { "type": "string", "minLength": 1 },
        "discovery_provider": { "type": "string", "minLength": 1 },
        "availability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "type": "string", "enum": ["always", "env_any", "provider_discovery"] },
            "names": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            }
          }
        }
      }
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "top_p": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "top_k": { "type": "integer", "minimum": 0 },
        "min_p": { "type": "number", "minimum": 0, "maximum": 1 },
        "presence_penalty": { "type": "number", "minimum": -2, "maximum": 2 },
        "frequency_penalty": { "type": "number", "minimum": -2, "maximum": 2 },
        "stop": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "maxItems": 4 }
          ]
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "model_ref": { "type": "string", "minLength": 1 },
        "capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "tools_enabled": { "type": "boolean" },
        "allowed_tools": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["read_file", "write_file", "list_directory", "shell_exec"]
          }
        },
        "context_window_tokens": { "type": "integer", "minimum": 1 },
        "max_completion_tokens": { "type": "integer", "minimum": 1 },
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "sampling": { "$ref": "#/$defs/sampling" }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates"],
      "properties": {
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "requires": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "sampling": { "$ref": "#/$defs/sampling" }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_attempts", "max_in_place_retries"],
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 10 },
        "max_in_place_retries": { "type": "integer", "minimum": 0, "maximum": 5 },
        "on_unsupported_parameter": {
          "type": "string",
          "enum": ["reject", "warn-and-drop", "translate"]
        }
      }
    }
  }
}
