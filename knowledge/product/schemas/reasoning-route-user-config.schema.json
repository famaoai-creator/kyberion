{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reasoning-route-user-config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "revision": { "type": "integer", "minimum": 0 },
    "updated_at": { "type": "string", "minLength": 1 },
    "last_change": { "type": "string", "maxLength": 200 },
    "roles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "profile": { "type": "string", "minLength": 1 },
          "candidates": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "sampling": { "$ref": "#/definitions/sampling" }
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": { "type": "string", "minLength": 1 },
          "model": { "type": "string", "minLength": 1 },
          "model_ref": { "type": "string", "minLength": 1 },
          "capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "tools_enabled": { "type": "boolean" },
          "allowed_tools": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["read_file", "write_file", "list_directory", "shell_exec"]
            }
          },
          "context_window_tokens": { "type": "integer", "minimum": 1 },
          "max_completion_tokens": { "type": "integer", "minimum": 1 },
          "timeout_ms": { "type": "integer", "minimum": 1 },
          "sampling": { "$ref": "#/definitions/sampling" }
        }
      }
    }
  },
  "definitions": {
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "top_p": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "top_k": { "type": "integer", "minimum": 0 },
        "min_p": { "type": "number", "minimum": 0, "maximum": 1 },
        "presence_penalty": { "type": "number", "minimum": -2, "maximum": 2 },
        "frequency_penalty": { "type": "number", "minimum": -2, "maximum": 2 },
        "stop": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "maxItems": 4 }
          ]
        }
      }
    }
  }
}
