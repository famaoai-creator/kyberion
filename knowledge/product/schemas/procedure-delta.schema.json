{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/procedure-delta.schema.json",
  "title": "Procedure Self-Repair Delta",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "procedure_id", "anchor", "delta_recording_ref", "reason", "created_at"],
  "properties": {
    "schema_version": { "const": "procedure-delta.v1" },
    "procedure_id": { "type": "string", "minLength": 1 },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_index"],
      "properties": {
        "step_index": { "type": "integer", "minimum": 0 },
        "ref_snapshot_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "delta_recording_ref": { "type": "string", "minLength": 1 },
    "reason": { "enum": ["ambiguity", "handoff", "new_popup", "mfa"] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
