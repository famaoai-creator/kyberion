{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Actuator Request Archetypes",
  "type": "object",
  "required": ["default_archetype", "archetypes"],
  "properties": {
    "default_archetype": { "type": "string" },
    "archetypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "trigger_keywords",
          "summary_template",
          "normalized_scope",
          "target_actuators",
          "deliverables",
          "required_inputs"
        ],
        "properties": {
          "id": { "type": "string" },
          "trigger_keywords": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "summary_template": { "type": "string" },
          "normalized_scope": {
            "type": "array",
            "items": { "type": "string" }
          },
          "target_actuators": {
            "type": "array",
            "items": { "type": "string" }
          },
          "deliverables": {
            "type": "array",
            "items": { "type": "string" }
          },
          "required_inputs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
