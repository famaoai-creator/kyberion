{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "surface-query-providers.schema.json",
  "title": "Surface Query Providers Schema",
  "type": "object",
  "properties": {
    "web_search": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": { "type": "string", "minLength": 1 },
        "maxResults": { "type": "number" },
        "timeoutMs": { "type": "number" }
      },
      "additionalProperties": true
    },
    "weather": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": { "type": "string", "minLength": 1 },
        "timeoutMs": { "type": "number" }
      },
      "additionalProperties": true
    },
    "location": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "knowledge": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": { "type": "string", "minLength": 1 },
        "limit": { "type": "number" },
        "scope": { "type": "string" },
        "phase": { "type": "string" },
        "role": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
