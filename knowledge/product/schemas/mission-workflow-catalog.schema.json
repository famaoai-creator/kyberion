{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "defaults",
    "patterns",
    "templates"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_id"
      ],
      "properties": {
        "workflow_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "patterns": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description"
        ],
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "pattern",
          "match",
          "phases"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "pattern": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mission_classes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "delivery_shapes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "risk_profiles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "execution_shapes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "intent_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "task_types": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "phases": {
            "type": "array",
            "minItems": 1,
            "items": {
              "oneOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "$ref": "#/definitions/phaseSpec"
                }
              ]
            }
          }
        }
      }
    }
  },
  "definitions": {
    "phaseSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "judgment",
            "deterministic",
            "review",
            "approval"
          ]
        },
        "pipeline_ref": {
          "type": "string",
          "minLength": 1
        },
        "brief_ref": {
          "type": "string",
          "minLength": 1
        },
        "entry_gate": {
          "$ref": "#/definitions/phaseGate"
        },
        "exit_gate": {
          "$ref": "#/definitions/phaseGate"
        },
        "default_tasks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/phaseTaskSpec"
          }
        }
      }
    },
    "phaseGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "checks"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "enum": [
                  "evidence_exists",
                  "schema_valid",
                  "command_succeeds",
                  "reviewer_approved",
                  "human_override",
                  "deliverable_quality",
                  "llm_review",
                  "custom"
                ]
              },
              "params": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "phaseTaskSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id_suffix",
        "description"
      ],
      "properties": {
        "task_id_suffix": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 12
        },
        "team_role": {
          "type": "string",
          "minLength": 1
        },
        "phase_kind": {
          "enum": [
            "implement",
            "review"
          ]
        },
        "deliverable": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "enum": [
            "low",
            "medium",
            "high",
            "approval_required",
            "high_stakes"
          ]
        },
        "estimated_scope": {
          "enum": [
            "S",
            "M",
            "L"
          ]
        },
        "expected_output_format": {
          "enum": [
            "text",
            "files",
            "structured"
          ]
        },
        "review_target_suffix": {
          "type": "string",
          "minLength": 1
        },
        "deliverable_kind": {
          "enum": [
            "doc",
            "deck",
            "code",
            "media"
          ]
        },
        "pipeline_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
