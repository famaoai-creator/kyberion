{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "defaults", "patterns", "templates"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_id"],
      "properties": {
        "workflow_id": { "type": "string", "minLength": 1 }
      }
    },
    "patterns": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description"],
        "properties": {
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "pattern", "match", "phases"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "pattern": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mission_classes": { "type": "array", "items": { "type": "string" } },
              "delivery_shapes": { "type": "array", "items": { "type": "string" } },
              "risk_profiles": { "type": "array", "items": { "type": "string" } },
              "execution_shapes": { "type": "array", "items": { "type": "string" } },
              "intent_ids": { "type": "array", "items": { "type": "string" } },
              "task_types": { "type": "array", "items": { "type": "string" } }
            }
          },
          "phases": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
