{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/procedures.schema.json",
  "title": "Intent-Driven Procedure Catalog (substrate-neutral)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "procedures"],
  "properties": {
    "schema_version": { "const": "procedures.v1" },
    "procedures": {
      "type": "array",
      "items": { "$ref": "#/definitions/procedure" }
    }
  },
  "definitions": {
    "procedure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "procedure_id",
        "substrate",
        "adapter",
        "target",
        "intent_phrases",
        "pipeline_ref",
        "risk_class",
        "version",
        "status"
      ],
      "properties": {
        "procedure_id": { "type": "string", "minLength": 1 },
        "substrate": { "enum": ["browser", "desktop", "service", "media"] },
        "adapter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["recorder", "executor"],
          "properties": {
            "recorder": { "type": "string", "minLength": 1 },
            "executor": { "type": "string", "minLength": 1 },
            "recording_ref": { "type": "string", "minLength": 1 },
            "recipe_ref": { "type": "string", "minLength": 1 }
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "origins": { "type": "array", "items": { "type": "string", "pattern": "^https?://" } },
            "services": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "platform": { "type": "string", "minLength": 1 }
          }
        },
        "intent_phrases": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 200 }
        },
        "execution_substrate": { "enum": ["extension", "playwright"] },
        "pipeline_ref": { "type": "string", "minLength": 1 },
        "required_inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "label", "type"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$" },
              "label": { "type": "string", "minLength": 1, "maxLength": 200 },
              "type": { "enum": ["string", "number", "boolean", "table", "date"] },
              "optional": { "type": "boolean" }
            }
          }
        },
        "required_secrets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "scope"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "scope": { "type": "string", "minLength": 1 }
            }
          }
        },
        "risk_class": { "enum": ["low", "medium", "high"] },
        "golden_scenario_ref": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+" },
        "status": { "enum": ["active", "deprecated"] }
      }
    }
  }
}
