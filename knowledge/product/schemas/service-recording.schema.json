{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/service-recording.schema.json",
  "title": "Service Procedure Recording (substrate: service)",
  "description": "A recorded sequence of service:preset action calls. Substrate adapter for the intent-driven automation master contract. params carry only literals or {{input.*}}/{{channel.*}} placeholders — never secret values (auth is request-level via secret-guard).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "recording_id", "source", "created_at", "target", "steps", "risk_summary"],
  "properties": {
    "schema_version": { "const": "service-recording.v1" },
    "recording_id": { "type": "string", "minLength": 1 },
    "source": { "const": "service-capture" },
    "created_at": { "type": "string", "format": "date-time" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "services"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "services": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/step" }
    },
    "risk_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires_manual_review", "approval_required_count"],
      "properties": {
        "requires_manual_review": { "type": "boolean" },
        "approval_required_count": { "type": "integer", "minimum": 0 }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "decisions"],
      "properties": {
        "status": { "enum": ["pending", "in_review", "approved", "rejected"] },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step_id", "status"],
            "properties": {
              "step_id": { "type": "string", "minLength": 1 },
              "status": { "enum": ["pending", "approved", "rejected"] },
              "reason": { "type": "string", "maxLength": 500 }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "service_id", "action", "summary", "risk_class"],
      "properties": {
        "step_id": { "type": "string", "minLength": 1 },
        "service_id": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
        "risk_class": { "enum": ["read", "low", "high"] },
        "params": { "type": "object", "additionalProperties": true },
        "produces": { "type": "string", "minLength": 1 },
        "consumes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
