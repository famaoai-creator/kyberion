{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/intent-use-case-scenario.schema.json",
  "title": "Intent Use-Case Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "scenario_id",
    "source_text",
    "intent_id",
    "title",
    "goal",
    "actors",
    "trigger",
    "preconditions",
    "inputs",
    "steps",
    "outputs",
    "success_conditions",
    "resolution",
    "governance",
    "handoff",
    "confidence",
    "provenance"
  ],
  "properties": {
    "kind": { "const": "intent-use-case-scenario" },
    "schema_version": { "const": "1.0.0" },
    "scenario_id": { "type": "string", "minLength": 1 },
    "source_text": { "type": "string", "minLength": 1 },
    "intent_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "success_condition"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "success_condition": { "type": "string", "minLength": 1 }
      }
    },
    "actors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "collaborators"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "collaborators": { "type": "array", "items": { "type": "string" } }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["utterance"],
      "properties": {
        "utterance": { "type": "string", "minLength": 1 },
        "channel": { "type": "string" }
      }
    },
    "preconditions": { "type": "array", "items": { "type": "string" } },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required", "source"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "source": { "enum": ["user", "context", "runtime", "derived"] },
          "description": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sequence", "action", "owner"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "sequence": { "type": "integer", "minimum": 1 },
          "action": { "type": "string", "minLength": 1 },
          "owner": { "enum": ["kyberion", "user", "external"] },
          "execution_shape": { "type": "string" },
          "requires_approval": { "type": "boolean" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "success_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_shape"],
      "properties": {
        "execution_shape": { "type": "string", "minLength": 1 },
        "task_type": { "type": "string" },
        "workflow_id": { "type": "string" },
        "workflow_pattern": { "type": "string" }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_profile", "requires_approval", "review_mode", "required_gate_ids"],
      "properties": {
        "risk_profile": { "enum": ["low", "review_required", "approval_required", "high_stakes"] },
        "requires_approval": { "type": "boolean" },
        "review_mode": { "enum": ["lean", "standard", "strict"] },
        "required_gate_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "next_action", "missing_inputs", "clarification_question_ids"],
      "properties": {
        "status": { "enum": ["ready", "needs_clarification", "blocked"] },
        "next_action": {
          "enum": [
            "execute",
            "clarify_inputs",
            "confirm_scope",
            "request_approval",
            "resolve_runtime"
          ]
        },
        "missing_inputs": { "type": "array", "items": { "type": "string" } },
        "clarification_question_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resolution_confidence", "resolution_candidates"],
      "properties": {
        "resolution_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "resolution_candidates": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
