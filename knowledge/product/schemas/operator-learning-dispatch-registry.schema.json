{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator-learning-dispatch-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "rules"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "dispatch"],
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "priority": { "type": "integer" },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "intent_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "categories": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "mission_classes": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "targets": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "actions": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "risk_profiles": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["low", "review_required", "approval_required", "high_stakes"]
                }
              },
              "route_shapes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "direct_reply",
                    "task_session",
                    "mission",
                    "project_bootstrap",
                    "browser_session",
                    "pipeline",
                    "actuator_action"
                  ]
                }
              },
              "result_shapes": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "surface_contains_any": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "trigger_keywords_any": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          },
          "dispatch": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "decision_style_observed": { "type": "string" },
              "recurring_task_candidate": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "approval_threshold_observed": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "correction_signals": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
