{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "operator-profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "profile_id",
    "scope",
    "subject",
    "communication",
    "decision_style",
    "approval_policy",
    "learning"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["operator-profile"]
    },
    "profile_id": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "string",
      "enum": ["personal", "confidential", "public"]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles", "locale", "timezone"],
      "properties": {
        "display_name": { "type": "string" },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["ceo", "cto", "operator", "founder", "product_owner", "engineer"]
          }
        },
        "locale": { "type": "string", "minLength": 2 },
        "timezone": { "type": "string", "minLength": 1 }
      }
    },
    "communication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preferred_language", "response_style", "preferred_detail_level"],
      "properties": {
        "preferred_language": { "type": "string", "minLength": 2 },
        "response_style": {
          "type": "string",
          "enum": ["brief_direct", "structured", "detailed", "executive"]
        },
        "preferred_detail_level": {
          "type": "string",
          "enum": ["compact", "standard", "deep"]
        },
        "question_budget_default": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "default_structure": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decision_style": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ambiguity_tolerance", "default_assumption_policy", "ask_before_action_if"],
      "properties": {
        "ambiguity_tolerance": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "prefers_options_over_open_ended": { "type": "boolean" },
        "default_assumption_policy": {
          "type": "string",
          "enum": ["ask_first", "reasonable_and_explicit", "proceed_when_low_risk"]
        },
        "tie_break_style": {
          "type": "string",
          "enum": ["recommend_then_wait", "ask_for_choice", "choose_and_explain"]
        },
        "ask_before_action_if": {
          "type": "array",
          "items": { "$ref": "#/$defs/approvalTrigger" }
        }
      }
    },
    "terminology": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "canonical_terms": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["term", "aliases"],
            "properties": {
              "term": { "type": "string", "minLength": 1 },
              "aliases": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "preferred_labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "forbidden_terms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "recurring_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["family", "trigger_phrases"],
        "properties": {
          "family": { "type": "string", "minLength": 1 },
          "trigger_phrases": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "default_route": {
            "type": "string",
            "enum": ["direct_reply", "task_session", "mission", "pipeline"]
          },
          "default_outputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "approval_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires_confirmation_if"],
      "properties": {
        "requires_confirmation_if": {
          "type": "array",
          "items": { "$ref": "#/$defs/approvalTrigger" }
        },
        "approval_thresholds": {
          "type": "object",
          "additionalProperties": true
        },
        "delegate_when": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "learning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["update_policy", "min_samples_to_promote", "retain_counterexamples"],
      "properties": {
        "update_policy": {
          "type": "string",
          "enum": ["manual_only", "incremental", "mission_review_only"]
        },
        "min_samples_to_promote": {
          "type": "integer",
          "minimum": 1
        },
        "retain_counterexamples": { "type": "boolean" },
        "drift_detection": { "type": "boolean" }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "do_not_export": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "exportable": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "approvalTrigger": {
      "type": "string",
      "enum": [
        "irreversible_action",
        "high_risk_action",
        "financial_commitment",
        "external_side_effect",
        "authority_unclear",
        "credential_use",
        "customer_facing_commitment",
        "org_policy_change"
      ]
    }
  }
}
