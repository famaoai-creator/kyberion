{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/work-coordination-event.schema.json",
  "title": "Work Coordination Event",
  "type": "object",
  "required": ["event_id", "ts", "event_type"],
  "properties": {
    "event_id": { "type": "string" },
    "ts": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": [
        "item_imported",
        "item_created",
        "item_updated",
        "item_claimed",
        "item_released",
        "item_handed_off",
        "item_blocked",
        "item_unblocked",
        "item_attempt_started",
        "item_attempt_released",
        "item_attempt_completed",
        "item_attempt_blocked",
        "item_attempt_failed",
        "review_requested",
        "external_sync_pulled",
        "external_sync_pushed",
        "conflict_detected",
        "board_created",
        "board_updated",
        "lease_expired"
      ]
    },
    "item_id": { "type": "string" },
    "board_id": { "type": "string" },
    "lease_id": { "type": "string" },
    "actor_peer_id": { "type": "string" },
    "actor_user_id": { "type": "string" },
    "command_id": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "expected_version": { "type": "integer" },
    "status": { "type": "string" },
    "note": { "type": "string" },
    "payload": { "type": "object" }
  },
  "additionalProperties": true
}
