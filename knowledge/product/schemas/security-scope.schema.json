{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/security-scope.schema.json",
  "title": "Context Security Scope",
  "type": "object",
  "additionalProperties": false,
  "required": ["tenant_id", "mission_id", "read_tiers", "write_tier", "purpose"],
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1 },
    "organization_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "participant_id": { "type": "string", "minLength": 1 },
    "read_tiers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["personal", "confidential", "public"] }
    },
    "write_tier": {
      "type": "string",
      "enum": ["personal", "confidential", "public"]
    },
    "purpose": { "type": "string", "minLength": 1 },
    "external_egress": { "type": "string", "enum": ["deny", "allow"] },
    "allowed_reasoning_backends": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
