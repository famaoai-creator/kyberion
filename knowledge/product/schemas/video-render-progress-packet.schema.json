{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "video-render-progress-packet.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "job_id", "status", "progress", "updated_at"],
  "properties": {
    "kind": { "type": "string", "const": "video_render_progress_packet" },
    "job_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["queued", "validating_contract", "resolving_templates", "staging_assets", "assembling_bundle", "rendering", "encoding", "completed", "failed", "cancelled"]
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "total", "percent", "unit"],
      "properties": {
        "current": { "type": "number", "minimum": 0 },
        "total": { "type": "number", "minimum": 1 },
        "percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "unit": { "type": "string", "enum": ["steps", "scenes", "artifacts", "percent"] }
      }
    },
    "message": { "type": "string" },
    "artifact_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "queue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["position", "queued_ahead", "queued_total", "running", "concurrency"],
      "properties": {
        "position": { "type": "integer", "minimum": 1 },
        "queued_ahead": { "type": "integer", "minimum": 0 },
        "queued_total": { "type": "integer", "minimum": 1 },
        "running": { "type": "integer", "minimum": 0 },
        "concurrency": { "type": "integer", "minimum": 1 }
      }
    },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
