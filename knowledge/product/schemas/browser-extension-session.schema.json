{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/browser-extension-session.schema.json",
  "title": "Browser Extension Session Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "mission_id",
    "pipeline_id",
    "tab_id",
    "origin",
    "mode",
    "recording_id",
    "requested_operations"
  ],
  "properties": {
    "kind": { "const": "browser-extension-session.v1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "pipeline_id": { "type": "string", "minLength": 1 },
    "tab_id": { "type": "string", "minLength": 1 },
    "origin": { "type": "string", "pattern": "^https?://" },
    "mode": { "enum": ["observe", "record", "execute"] },
    "recording_id": { "type": "string", "minLength": 1 },
    "requested_operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "snapshot",
          "screenshot",
          "extract_text_ref",
          "list_tabs",
          "open_tab",
          "select_tab",
          "navigate",
          "click_ref",
          "click_if_present",
          "fill_ref",
          "select_ref",
          "press_ref",
          "wait_for_ref",
          "submit_form",
          "upload_file",
          "download_file",
          "delete",
          "purchase",
          "credential_submit",
          "settings_change"
        ]
      },
      "uniqueItems": true
    },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_id", "issued_at", "expires_at", "approved_step_hashes"],
      "properties": {
        "lease_id": { "type": "string", "minLength": 1 },
        "issued_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "approved_step_hashes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "uniqueItems": true
        },
        "origin": { "type": "string", "minLength": 1 },
        "segment_index": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
