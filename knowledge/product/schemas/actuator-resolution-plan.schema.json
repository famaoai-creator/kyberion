{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Actuator Resolution Plan",
  "type": "object",
  "required": ["kind", "archetype_id", "phases"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["actuator-resolution-plan"]
    },
    "archetype_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "actuators"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "actuators": {
            "type": "array",
            "items": { "type": "string" }
          },
          "artifacts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "exit_criteria": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
