{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kyberion Music Generation ADF",
  "description": "Engine-neutral contract for lyric-driven or instrumental music generation requests.",
  "type": "object",
  "required": ["kind", "version", "style", "composition", "output"],
  "properties": {
    "kind": {
      "type": "string",
      "const": "music-generation-adf"
    },
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "intent": {
      "type": "string"
    },
    "style": {
      "type": "object",
      "required": ["genre"],
      "properties": {
        "genre": {
          "type": "string"
        },
        "mood": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "vocal": {
          "type": "object",
          "properties": {
            "presence": {
              "type": "boolean",
              "default": false
            },
            "gender": {
              "type": "string",
              "enum": ["female", "male", "duet", "mixed", "unspecified"]
            },
            "language": {
              "type": "string"
            },
            "tone": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "composition": {
      "type": "object",
      "required": ["duration_sec"],
      "properties": {
        "duration_sec": {
          "type": "number",
          "minimum": 1
        },
        "bpm": {
          "type": "integer",
          "minimum": 1
        },
        "time_signature": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "structure": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "lyrics": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["provided", "instrumental", "assisted", "generate"]
        },
        "text": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "arrangement": {
      "type": "object",
      "properties": {
        "instruments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mix_traits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "engine": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "default": "comfyui"
        },
        "model_family": {
          "type": "string",
          "default": "ace_step_1_5"
        },
        "profile": {
          "type": "string",
          "enum": ["turbo", "base", "sft"]
        },
        "cfg_scale": {
          "type": "number"
        },
        "temperature": {
          "type": "number"
        },
        "top_p": {
          "type": "number"
        },
        "top_k": {
          "type": "integer"
        },
        "min_p": {
          "type": "number"
        },
        "seed": {
          "type": "integer"
        },
        "generate_audio_codes": {
          "type": "boolean"
        },
        "models": {
          "type": "object",
          "properties": {
            "unet_name": {
              "type": "string"
            },
            "clip_name1": {
              "type": "string"
            },
            "clip_name2": {
              "type": "string"
            },
            "vae_name": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "required": ["format"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["mp3", "wav", "flac"]
        },
        "filename_prefix": {
          "type": "string"
        },
        "target_path": {
          "type": "string"
        },
        "await_completion": {
          "type": "boolean",
          "default": true
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1000
        },
        "poll_interval_ms": {
          "type": "integer",
          "minimum": 100
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
