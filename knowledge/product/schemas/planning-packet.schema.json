{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kyberion.local/schemas/planning-packet.schema.json",
  "title": "Planning Packet",
  "type": "object",
  "required": ["plan_markdown", "next_tasks"],
  "properties": {
    "mission_id": { "type": "string" },
    "summary": { "type": "string" },
    "plan_markdown": {
      "type": "string",
      "minLength": 1
    },
    "next_tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_id", "team_role", "description"],
        "properties": {
          "task_id": { "type": "string", "minLength": 1 },
          "team_role": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "deliverable": { "type": "string" },
          "target_path": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high", "approval_required", "high_stakes"]
          },
          "expected_output_format": {
            "type": "string",
            "enum": ["text", "files", "structured"]
          },
          "estimated_scope": {
            "type": "string",
            "enum": ["S", "M", "L"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
