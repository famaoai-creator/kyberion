{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harness-capability-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capabilityEntry" }
    }
  },
  "required": ["version", "capabilities"],
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cli_native", "skill", "plugin", "agent_runtime"]
        },
        "provider": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      },
      "required": ["type", "provider", "name", "version"]
    },
    "approvalHooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requires_pre_approval": { "type": "boolean" },
        "approval_scope": {
          "type": "string",
          "enum": ["none", "capability", "action", "high_risk_only"]
        }
      },
      "required": ["requires_pre_approval", "approval_scope"]
    },
    "preferredUsage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflow_shapes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["direct_reply", "task_session", "mission", "project_bootstrap"]
          }
        },
        "intents": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "required": ["workflow_shapes", "intents"]
    },
    "fallbackPath": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["kyberion_local_actuator", "kyberion_local_pipeline", "none"]
        },
        "target": { "type": "string" }
      },
      "required": ["mode", "target"]
    },
    "capabilityEntry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capability_id": { "type": "string", "minLength": 1 },
        "source": { "$ref": "#/$defs/source" },
        "kind": {
          "type": "string",
          "enum": ["reasoning", "interactive_tooling", "delegated_execution", "deterministic_utility"]
        },
        "interaction_mode": {
          "type": "string",
          "enum": ["request_response", "interactive_loop", "delegated_task", "deterministic_task"]
        },
        "risk_class": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "replayability": {
          "type": "string",
          "enum": ["deterministic", "partial", "opaque"]
        },
        "approval_hooks": { "$ref": "#/$defs/approvalHooks" },
        "preferred_usage": { "$ref": "#/$defs/preferredUsage" },
        "fallback_path": { "$ref": "#/$defs/fallbackPath" },
        "status": {
          "type": "string",
          "enum": ["active", "experimental", "deprecated", "blocked"]
        },
        "notes": { "type": "string" }
      },
      "required": [
        "capability_id",
        "source",
        "kind",
        "interaction_mode",
        "risk_class",
        "replayability",
        "approval_hooks",
        "preferred_usage",
        "fallback_path",
        "status"
      ]
    }
  }
}
