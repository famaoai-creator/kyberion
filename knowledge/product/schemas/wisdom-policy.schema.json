{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wisdom-policy.schema.json",
  "title": "Wisdom Distillation Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "llm", "rules", "tier_mapping"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profiles"],
      "properties": {
        "profiles": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "args"],
            "properties": {
              "description": {
                "type": "string"
              },
              "command": {
                "type": "string",
                "minLength": 1
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "timeout_ms": {
                "type": "number",
                "minimum": 1
              },
              "response_format": {
                "type": "string",
                "minLength": 1
              },
              "adapter": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "purpose_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "default_profile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "tier_mapping": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
