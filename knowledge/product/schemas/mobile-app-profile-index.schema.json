{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mobile App Profile Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["profiles"],
  "properties": {
    "version": {
      "type": "string"
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "platform", "title", "path", "description"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "platform": {
            "type": "string",
            "enum": ["android", "ios"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
