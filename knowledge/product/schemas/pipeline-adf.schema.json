{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kyberion Pipeline ADF",
  "type": "object",
  "required": ["steps"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["pipeline"]
    },
    "id": { "type": "string" },
    "pipeline_id": { "type": "string" },
    "name": {
      "type": "string"
    },
    "version": { "type": "string" },
    "description": {
      "type": "string"
    },
    "labels": {},
    "expected_outcome": {},
    "parameters": {},
    "variables": {},
    "inputs": {},
    "fallback_pipeline": { "type": "string" },
    "knowledge_scope": {},
    "env": { "type": "object" },
    "session_id": { "type": "string" },
    "context": {
      "type": "object"
    },
    "options": {
      "type": "object",
      "properties": {
        "max_steps": {
          "type": "number"
        },
        "timeout_ms": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/step" }
    },
    "schedule": {
      "type": "object",
      "required": ["cron"],
      "properties": {
        "id": { "type": "string" },
        "cron": { "type": "string", "minLength": 9 },
        "timezone": { "type": "string" },
        "enabled": { "type": "boolean" },
        "deliver_to": {
          "type": "object",
          "required": ["surface", "channel"],
          "properties": {
            "surface": { "type": "string", "enum": ["slack", "telegram", "discord", "imessage"] },
            "channel": { "type": "string", "minLength": 1, "maxLength": 500 },
            "thread_ts": { "type": "string", "maxLength": 500 },
            "template": { "type": "string", "minLength": 1, "maxLength": 8000 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "step": {
      "type": "object",
      "required": ["op"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "comment": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["capture", "transform", "apply", "control"]
        },
        "role": {
          "type": "string",
          "enum": ["source", "transform", "sink", "gate"]
        },
        "op": { "type": "string", "minLength": 1 },
        "effort": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "budget": {
          "type": "object",
          "properties": {
            "cost_cap_tokens": { "type": "number", "minimum": 1 },
            "max_prompt_chars": { "type": "number", "minimum": 1 },
            "max_response_chars": { "type": "number", "minimum": 1 },
            "max_combined_chars": { "type": "number", "minimum": 1 },
            "approval_required": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "params": { "type": "object" },
        "produces": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "object",
              "required": ["channel"],
              "properties": {
                "channel": { "type": "string", "minLength": 1 },
                "type": { "type": "string" }
              },
              "additionalProperties": false
            }
          ]
        },
        "consumes": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "array", "items": { "type": "string", "minLength": 1 } }
          ]
        },
        "on_error": {
          "type": "object",
          "required": ["strategy"],
          "properties": {
            "strategy": { "type": "string", "enum": ["skip", "abort", "fallback"] },
            "fallback": {
              "type": "array",
              "items": { "$ref": "#/definitions/step" }
            },
            "ref": { "type": "string" },
            "bind": { "type": "object" },
            "remediation": { "type": "string" }
          },
          "additionalProperties": false
        },
        "hooks": {
          "type": "object",
          "properties": {
            "before": { "$ref": "#/definitions/hookList" },
            "after": { "$ref": "#/definitions/hookList" }
          },
          "additionalProperties": false
        }
      },
      "patternProperties": {
        "^_": {}
      },
      "additionalProperties": false
    },
    "hookList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["actuator_op", "http", "command"] },
          "label": { "type": "string" },
          "on_reject": { "type": "string", "enum": ["abort", "skip", "warn"] },
          "op": { "type": "string" },
          "params": { "type": "object" },
          "url": { "type": "string" },
          "method": { "type": "string", "enum": ["GET", "POST"] },
          "body": { "type": "object" },
          "headers": { "type": "object" },
          "cmd": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "patternProperties": {
    "^_": {}
  },
  "additionalProperties": false
}
