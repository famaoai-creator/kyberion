{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "video-composition-template-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "default_template_id", "templates"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "default_template_id": { "type": "string", "minLength": 1 },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["template_id", "display_name", "status", "renderer", "supported_roles", "required_content_fields", "supported_output_formats"],
        "properties": {
          "template_id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["active", "shadow", "disabled"] },
          "renderer": { "type": "string", "enum": ["builtin_html"] },
          "supported_roles": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["hook", "feature", "proof", "cta", "outro", "generic"] }
          },
          "required_content_fields": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "supported_output_formats": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["mp4", "mov", "webm"] }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
