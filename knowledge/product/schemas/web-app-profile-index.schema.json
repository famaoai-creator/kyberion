{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Web App Profile Index",
  "type": "object",
  "required": ["profiles"],
  "properties": {
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "platform", "title", "path", "description"],
        "properties": {
          "id": { "type": "string" },
          "platform": {
            "type": "string",
            "enum": ["browser"]
          },
          "title": { "type": "string" },
          "path": { "type": "string" },
          "description": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
