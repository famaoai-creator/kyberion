{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Document Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "artifact_family", "document_type", "document_profile", "render_target", "payload"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["document-brief"]
    },
    "artifact_family": {
      "type": "string",
      "enum": ["document", "presentation", "spreadsheet", "diagram"]
    },
    "document_type": {
      "type": "string",
      "minLength": 1
    },
    "document_profile": {
      "type": "string",
      "minLength": 1
    },
    "render_target": {
      "type": "string",
      "enum": ["pdf", "pptx", "docx", "xlsx", "svg", "drawio", "mmd", "d2"]
    },
    "locale": {
      "type": "string",
      "default": "en-US"
    },
    "layout_template_id": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  }
}
