{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mission Lease",
  "type": "object",
  "required": ["lease_id", "scope", "mission_id", "holder_agent_id", "holder_role", "status", "granted_at", "expires_at"],
  "properties": {
    "lease_id": { "type": "string" },
    "scope": {
      "type": "string",
      "enum": ["mission", "task", "bridge", "resource"]
    },
    "mission_id": { "type": "string" },
    "task_id": { "type": "string" },
    "holder_agent_id": { "type": "string" },
    "holder_role": {
      "type": "string",
      "enum": ["owner", "worker", "observer"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "released", "expired", "revoked", "denied"]
    },
    "resource_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "granted_at": { "type": "string" },
    "expires_at": { "type": "string" },
    "revoked_at": { "type": "string" },
    "granted_by": { "type": "string" },
    "reason": { "type": "string" },
    "policy_used": { "type": "string" },
    "correlation_id": { "type": "string" }
  },
  "additionalProperties": true
}
