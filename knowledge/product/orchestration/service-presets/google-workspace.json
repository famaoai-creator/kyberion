{
  "service_id": "google-workspace",
  "name": "Google Workspace CLI Presets",
  "auth_strategy": "session",
  "setup_hint": "Install gws, run gws auth setup, then gws auth login.",
  "allow_unsafe_cli": true,
  "operations": {
    "auth_status": {
      "type": "cli",
      "command": "gws",
      "args": ["auth", "status"],
      "health_check": "gws auth status",
      "description": "Check whether Google Workspace CLI authentication is available."
    },
    "schema_method": {
      "type": "cli",
      "command": "gws",
      "args": ["schema", "{{method}}"],
      "description": "Inspect the request/response schema for a Google Workspace discovery method.",
      "parameters": {
        "method": { "required": true, "type": "string" }
      }
    },
    "drive_files_list": {
      "type": "cli",
      "command": "gws",
      "args": ["drive", "files", "list", "--params", "{{params}}", "--page-all"],
      "description": "List Google Drive files using the discovery-backed CLI.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    },
    "gmail_triage": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+triage"],
      "description": "Summarize unread Gmail inbox items."
    },
    "gmail_send": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+send", "--to", "{{to}}", "--subject", "{{subject}}", "--body", "{{body}}"],
      "description": "Send a Gmail message."
    },
    "gmail_send_draft": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+send", "--to", "{{to}}", "--subject", "{{subject}}", "--body", "{{body}}", "--draft"],
      "description": "Create a Gmail draft instead of sending."
    },
    "gmail_reply": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+reply", "--message-id", "{{message_id}}", "--body", "{{body}}"],
      "description": "Reply to a Gmail message."
    },
    "gmail_reply_draft": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+reply", "--message-id", "{{message_id}}", "--body", "{{body}}", "--draft"],
      "description": "Create a Gmail reply draft."
    },
    "gmail_reply_all": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+reply-all", "--message-id", "{{message_id}}", "--body", "{{body}}"],
      "description": "Reply-all to a Gmail message."
    },
    "gmail_reply_all_draft": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+reply-all", "--message-id", "{{message_id}}", "--body", "{{body}}", "--draft"],
      "description": "Create a Gmail reply-all draft."
    },
    "calendar_agenda": {
      "type": "cli",
      "command": "gws",
      "args": ["calendar", "+agenda"],
      "description": "Show the upcoming Google Calendar agenda."
    }
  }
}
