{
  "service_id": "google-workspace",
  "name": "Google Workspace CLI Presets",
  "auth_strategy": "session",
  "setup_hint": "Install gws, run gws auth setup, then gws auth login.",
  "allow_unsafe_cli": true,
  "operations": {
    "auth_status": {
      "type": "cli",
      "command": "gws",
      "args": ["auth", "status"],
      "health_check": "gws auth status",
      "description": "Check whether Google Workspace CLI authentication is available."
    },
    "schema_method": {
      "type": "cli",
      "command": "gws",
      "args": ["schema", "{{method}}"],
      "description": "Inspect the request/response schema for a Google Workspace discovery method.",
      "parameters": {
        "method": { "required": true, "type": "string" }
      }
    },
    "drive_files_list": {
      "type": "cli",
      "command": "gws",
      "args": ["drive", "files", "list", "--params", "{{params}}", "--page-all"],
      "description": "List Google Drive files using the discovery-backed CLI.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    },
    "gmail_triage": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+triage"],
      "description": "Summarize unread Gmail inbox items."
    },
    "gmail_messages_list": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "users", "messages", "list", "--params", "{{params}}"],
      "description": "List Gmail messages with the discovery-backed Gmail API."
    },
    "gmail_message_get": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "users", "messages", "get", "--params", "{{params}}"],
      "description": "Get a Gmail message with metadata headers."
    },
    "gmail_filters_list": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "users", "settings", "filters", "list", "--params", "{{params}}"],
      "description": "List Gmail filters for the authenticated user."
    },
    "gmail_filters_create": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "users", "settings", "filters", "create", "--params", "{{params}}", "--json", "{{body}}"],
      "description": "Create a Gmail filter."
    },
    "gmail_messages_batch_modify": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "users", "messages", "batchModify", "--params", "{{params}}", "--json", "{{body}}"],
      "description": "Batch modify Gmail messages, including archiving by removing the INBOX label."
    },
    "gmail_send": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+send", "--to", "{{to}}", "--subject", "{{subject}}", "--body", "{{body}}"],
      "description": "Send a Gmail message."
    },
    "gmail_send_draft": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+send", "--to", "{{to}}", "--subject", "{{subject}}", "--body", "{{body}}", "--draft"],
      "description": "Create a Gmail draft instead of sending."
    },
    "gmail_reply": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+reply", "--message-id", "{{message_id}}", "--body", "{{body}}"],
      "description": "Reply to a Gmail message."
    },
    "gmail_reply_draft": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+reply", "--message-id", "{{message_id}}", "--body", "{{body}}", "--draft"],
      "description": "Create a Gmail reply draft."
    },
    "gmail_reply_all": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+reply-all", "--message-id", "{{message_id}}", "--body", "{{body}}"],
      "description": "Reply-all to a Gmail message."
    },
    "gmail_reply_all_draft": {
      "type": "cli",
      "command": "gws",
      "args": ["gmail", "+reply-all", "--message-id", "{{message_id}}", "--body", "{{body}}", "--draft"],
      "description": "Create a Gmail reply-all draft."
    },
    "calendar_agenda": {
      "type": "cli",
      "command": "gws",
      "args": ["calendar", "+agenda"],
      "description": "Show the upcoming Google Calendar agenda."
    },
    "calendar_calendarList_list": {
      "type": "cli",
      "command": "gws",
      "args": ["calendar", "calendarList", "list", "--params", "{{params}}"],
      "description": "List the authenticated user's calendars.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    },
    "calendar_events_list": {
      "type": "cli",
      "command": "gws",
      "args": ["calendar", "events", "list", "--params", "{{params}}"],
      "description": "List Google Calendar events for a calendar.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    },
    "calendar_freebusy_query": {
      "type": "cli",
      "command": "gws",
      "args": ["calendar", "freebusy", "query", "--json", "{{body}}"],
      "description": "Query free/busy windows for one or more calendars.",
      "parameters": {
        "body": { "required": true, "type": "object" }
      }
    },
    "calendar_events_insert": {
      "type": "cli",
      "command": "gws",
      "args": ["calendar", "events", "insert", "--params", "{{params}}", "--json", "{{body}}"],
      "description": "Create a Google Calendar event, optionally with Google Meet.",
      "parameters": {
        "params": { "required": true, "type": "object" },
        "body": { "required": true, "type": "object" }
      }
    },
    "meet_spaces_create": {
      "type": "cli",
      "command": "gws",
      "args": ["meet", "spaces", "create", "--json", "{{params}}"],
      "description": "Create a Google Meet space using the authenticated Google account.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    },
    "meet_spaces_get": {
      "type": "cli",
      "command": "gws",
      "args": ["meet", "spaces", "get", "--params", "{{params}}"],
      "description": "Fetch a Google Meet space by name or resource identifier.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    },
    "meet_spaces_patch": {
      "type": "cli",
      "command": "gws",
      "args": ["meet", "spaces", "patch", "--params", "{{params}}", "--json", "{{params}}"],
      "description": "Update a Google Meet space using the authenticated Google account.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    },
    "meet_spaces_end_active_conference": {
      "type": "cli",
      "command": "gws",
      "args": ["meet", "spaces", "endActiveConference", "--params", "{{params}}"],
      "description": "End the active conference attached to a Google Meet space.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    },
    "meet_conference_records_list": {
      "type": "cli",
      "command": "gws",
      "args": ["meet", "conferenceRecords", "list", "--params", "{{params}}"],
      "description": "List Google Meet conference records.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    },
    "meet_conference_records_get": {
      "type": "cli",
      "command": "gws",
      "args": ["meet", "conferenceRecords", "get", "--params", "{{params}}"],
      "description": "Fetch a Google Meet conference record by name.",
      "parameters": {
        "params": { "required": false, "type": "object" }
      }
    }
  }
}
