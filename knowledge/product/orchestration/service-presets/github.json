{
  "service_id": "github",
  "name": "GitHub REST API Presets",
  "base_url": "https://api.github.com",
  "auth_strategy": "Bearer",
  "operations": {
    "create_issue": {
      "type": "api",
      "path": "repos/{{owner}}/{{repo}}/issues",
      "method": "POST",
      "description": "Creates a new issue in a repository.",
      "parameters": {
        "owner": { "required": true, "type": "string" },
        "repo": { "required": true, "type": "string" },
        "title": { "required": true, "type": "string" },
        "body": { "required": false, "type": "string" }
      },
      "output_mapping": { "id": "number", "url": "html_url" }
    },
    "update_issue": {
      "type": "api",
      "path": "repos/{{owner}}/{{repo}}/issues/{{issue_number}}",
      "method": "PATCH",
      "description": "Updates a GitHub issue.",
      "parameters": {
        "owner": { "required": true, "type": "string" },
        "repo": { "required": true, "type": "string" },
        "issue_number": { "required": true, "type": "number" },
        "title": { "required": false, "type": "string" },
        "body": { "required": false, "type": "string" },
        "state": { "required": false, "type": "string" }
      }
    },
    "add_comment": {
      "type": "api",
      "path": "repos/{{owner}}/{{repo}}/issues/{{issue_number}}/comments",
      "method": "POST",
      "description": "Adds a comment to a GitHub issue.",
      "parameters": {
        "owner": { "required": true, "type": "string" },
        "repo": { "required": true, "type": "string" },
        "issue_number": { "required": true, "type": "number" },
        "body": { "required": true, "type": "string" }
      }
    },
    "close_issue": {
      "type": "api",
      "path": "repos/{{owner}}/{{repo}}/issues/{{issue_number}}",
      "method": "PATCH",
      "description": "Closes a GitHub issue.",
      "parameters": {
        "owner": { "required": true, "type": "string" },
        "repo": { "required": true, "type": "string" },
        "issue_number": { "required": true, "type": "number" }
      },
      "payload_template": {
        "state": "closed"
      }
    },
    "list_repos": {
      "type": "api",
      "path": "user/repos",
      "method": "GET",
      "description": "Lists repositories for the authenticated user.",
      "parameters": {
        "sort": { "default": "updated" },
        "per_page": { "default": 30 }
      }
    },
    "actions_list_runs": {
      "type": "api",
      "path": "repos/{{owner}}/{{repo}}/actions/runs",
      "method": "GET",
      "description": "Lists workflow runs for a repository.",
      "parameters": {
        "owner": { "required": true, "type": "string" },
        "repo": { "required": true, "type": "string" },
        "branch": { "required": false, "type": "string" },
        "event": { "required": false, "type": "string" },
        "status": { "required": false, "type": "string" },
        "per_page": { "required": false, "type": "number" }
      }
    },
    "actions_get_run": {
      "type": "api",
      "path": "repos/{{owner}}/{{repo}}/actions/runs/{{run_id}}",
      "method": "GET",
      "description": "Gets a single workflow run and its status metadata.",
      "parameters": {
        "owner": { "required": true, "type": "string" },
        "repo": { "required": true, "type": "string" },
        "run_id": { "required": true, "type": "number" }
      },
      "output_mapping": {
        "run_id": "id",
        "status": "status",
        "conclusion": "conclusion",
        "html_url": "html_url",
        "name": "name",
        "head_branch": "head_branch",
        "head_sha": "head_sha"
      }
    },
    "actions_dispatch_workflow": {
      "type": "api",
      "path": "repos/{{owner}}/{{repo}}/actions/workflows/{{workflow_id}}/dispatches",
      "method": "POST",
      "description": "Dispatches a GitHub Actions workflow run.",
      "parameters": {
        "owner": { "required": true, "type": "string" },
        "repo": { "required": true, "type": "string" },
        "workflow_id": { "required": true, "type": "string" },
        "ref": { "required": true, "type": "string" },
        "inputs": { "required": false, "type": "object" }
      },
      "payload_template": {
        "ref": "{{ref}}",
        "inputs": "{{inputs}}"
      }
    },
    "create_pull_request": {
      "type": "api",
      "path": "repos/{{owner}}/{{repo}}/pulls",
      "method": "POST",
      "description": "Creates a pull request.",
      "parameters": {
        "owner": { "required": true, "type": "string" },
        "repo": { "required": true, "type": "string" },
        "title": { "required": true, "type": "string" },
        "head": { "required": true, "type": "string" },
        "base": { "required": true, "type": "string" }
      },
      "output_mapping": { "number": "number", "url": "html_url" }
    },
    "merge_pull_request": {
      "type": "api",
      "path": "repos/{{owner}}/{{repo}}/pulls/{{pull_number}}/merge",
      "method": "PUT",
      "description": "Merges a pull request.",
      "parameters": {
        "owner": { "required": true, "type": "string" },
        "repo": { "required": true, "type": "string" },
        "pull_number": { "required": true, "type": "number" }
      }
    }
  }
}
