{
  "service_id": "voice",
  "name": "Kyberion Voice Synthesis and Playback Unified Presets",
  "operations": {
    "speak_local": {
      "type": "auto",
      "alternatives": [
        {
          "type": "cli",
          "command": "{{voice_python_bin}}",
          "args": ["libs/actuators/voice-actuator/voice-bridge.py", "{\"action\": \"speak\", \"params\": {{params}} }"],
          "description": "Local Generative TTS via Python Bridge"
        },
        {
          "type": "cli",
          "command": "say",
          "args": ["-v", "{{voice_name}}", "-r", "{{rate}}", "{{text}}"],
          "description": "macOS Native Fallback"
        }
      ]
    },
    "generate_voice": {
      "type": "auto",
      "alternatives": [
        {
          "type": "cli",
          "command": "{{voice_python_bin}}",
          "args": ["libs/actuators/voice-actuator/voice-bridge.py", "{\"action\": \"speak\", \"params\": {{params}} }"],
          "description": "Intent-aligned governed voice generation via Python bridge"
        },
        {
          "type": "cli",
          "command": "say",
          "args": ["-v", "{{voice_name}}", "-r", "{{rate}}", "{{text}}"],
          "description": "Intent-aligned macOS fallback voice generation"
        }
      ]
    }
  }
}
