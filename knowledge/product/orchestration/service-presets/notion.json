{
  "service_id": "notion",
  "name": "Notion API Presets",
  "base_url": "https://api.notion.com/v1",
  "auth_strategy": "Bearer",
  "headers": {
    "Notion-Version": "2022-06-28"
  },
  "oauth": {
    "authorize_url": "https://api.notion.com/v1/oauth/authorize",
    "token_url": "https://api.notion.com/v1/oauth/token",
    "scopes": []
  },
  "operations": {
    "exchange_oauth_code": {
      "type": "api",
      "path": "oauth/token",
      "method": "POST",
      "auth_strategy": "Basic",
      "description": "Exchanges an OAuth authorization code for Notion access tokens.",
      "headers": {
        "Content-Type": "application/json"
      },
      "parameters": {
        "code": { "required": true, "type": "string" },
        "redirect_uri": { "required": false, "type": "string" }
      },
      "payload_template": {
        "grant_type": "authorization_code",
        "code": "{{code}}",
        "redirect_uri": "{{redirect_uri}}"
      }
    },
    "create_page": {
      "path": "pages",
      "method": "POST",
      "description": "Creates a new page in a database.",
      "parameters": {
        "database_id": { "required": true, "type": "string" },
        "title": { "required": true, "type": "string" }
      },
      "payload_template": {
        "parent": { "database_id": "{{database_id}}" },
        "properties": {
          "Name": { "title": [{ "text": { "content": "{{title}}" } }] }
        }
      }
    },
    "query_database": {
      "path": "databases/{{database_id}}/query",
      "method": "POST",
      "description": "Queries a database."
    }
  }
}
