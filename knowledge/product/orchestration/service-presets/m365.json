{
  "service_id": "m365",
  "name": "Microsoft 365 CLI Presets",
  "auth_strategy": "none",
  "allow_unsafe_cli": true,
  "setup_hint": "Install CLI for Microsoft 365, run m365 status, and authenticate in the CLI.",
  "operations": {
    "auth_status": {
      "type": "cli",
      "command": "m365",
      "args": ["status", "--output", "json"],
      "description": "Check whether the Microsoft 365 CLI is authenticated."
    },
    "calendar_list": {
      "type": "cli",
      "command": "m365",
      "args": ["request", "--url", "@graph/me/calendars", "--output", "json"],
      "description": "List the signed-in user's calendars."
    },
    "calendar_events_list": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--url",
        "@graph/{{calendarPath}}/calendarView?startDateTime={{timeMin}}&endDateTime={{timeMax}}",
        "--output",
        "json"
      ],
      "description": "List calendar events for the requested window."
    },
    "calendar_freebusy_query": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "post",
        "--url",
        "@graph/me/calendar/getSchedule",
        "--body",
        "{{body}}",
        "--output",
        "json"
      ],
      "description": "Query free/busy windows for one or more calendars."
    },
    "calendar_events_insert": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "post",
        "--url",
        "@graph/{{calendarPath}}/events",
        "--body",
        "{{body}}",
        "--output",
        "json"
      ],
      "description": "Create a Microsoft 365 calendar event."
    },
    "outlook_messages_list": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--url",
        "@graph/me/mailFolders/inbox/messages?$top={{max_results}}&$select=id,subject,from,receivedDateTime,bodyPreview,isRead",
        "--output",
        "json"
      ],
      "description": "List messages from the signed-in user's Outlook inbox."
    },
    "outlook_message_get": {
      "type": "cli",
      "command": "m365",
      "args": ["request", "--url", "@graph/me/messages/{{message_id}}", "--output", "json"],
      "description": "Get one Outlook message by ID."
    },
    "outlook_send": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "post",
        "--url",
        "@graph/me/sendMail",
        "--body",
        "{{body}}",
        "--output",
        "json"
      ],
      "description": "Send a new Outlook message."
    },
    "outlook_message_draft": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "post",
        "--url",
        "@graph/me/messages",
        "--body",
        "{{body}}",
        "--output",
        "json"
      ],
      "description": "Create an Outlook message draft."
    },
    "outlook_reply": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "post",
        "--url",
        "@graph/me/messages/{{message_id}}/reply",
        "--body",
        "{{body}}",
        "--output",
        "json"
      ],
      "description": "Reply to an Outlook message."
    },
    "outlook_reply_all": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "post",
        "--url",
        "@graph/me/messages/{{message_id}}/replyAll",
        "--body",
        "{{body}}",
        "--output",
        "json"
      ],
      "description": "Reply to all recipients of an Outlook message."
    },
    "outlook_create_reply": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "post",
        "--url",
        "@graph/me/messages/{{message_id}}/createReply",
        "--body",
        "{}",
        "--output",
        "json"
      ],
      "description": "Create an Outlook reply draft."
    },
    "outlook_create_reply_all": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "post",
        "--url",
        "@graph/me/messages/{{message_id}}/createReplyAll",
        "--body",
        "{}",
        "--output",
        "json"
      ],
      "description": "Create an Outlook reply-all draft."
    },
    "outlook_message_update": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "patch",
        "--url",
        "@graph/me/messages/{{message_id}}",
        "--body",
        "{{body}}",
        "--output",
        "json"
      ],
      "description": "Update an Outlook draft message."
    },
    "outlook_message_move": {
      "type": "cli",
      "command": "m365",
      "args": [
        "request",
        "--method",
        "post",
        "--url",
        "@graph/me/messages/{{message_id}}/move",
        "--body",
        "{{body}}",
        "--output",
        "json"
      ],
      "description": "Move an Outlook message to another mail folder."
    }
  }
}
