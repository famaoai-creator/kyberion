{
  "default_pattern": "https://api.{service_id}.com/v1",
  "services": {
    "aws-ce": {
      "base_url": "https://ce.us-east-1.amazonaws.com",
      "preset_path": "knowledge/product/orchestration/service-presets/aws-ce.json"
    },
    "backlog": {
      "base_url": "https://{{space}}.backlog.com/api/v2",
      "preset_path": "knowledge/product/orchestration/service-presets/backlog.json",
      "credential_suffixes": {
        "accessToken": ["API_KEY"]
      }
    },
    "brave-search": {
      "preset_path": "knowledge/product/orchestration/service-presets/brave-search.json"
    },
    "canva": {
      "base_url": "https://api.canva.com/rest/v1",
      "preset_path": "knowledge/product/orchestration/service-presets/canva.json"
    },
    "comfyui": {
      "preset_path": "knowledge/product/orchestration/service-presets/comfyui.json"
    },
    "confluence": {
      "base_url": "https://{{domain}}.atlassian.net/wiki/api/v2",
      "preset_path": "knowledge/product/orchestration/service-presets/confluence.json"
    },
    "discord": {
      "base_url": "https://discord.com/api/v10",
      "preset_path": "knowledge/product/orchestration/service-presets/discord.json"
    },
    "github": {
      "base_url": "https://api.github.com",
      "preset_path": "knowledge/product/orchestration/service-presets/github.json"
    },
    "github-mcp": {
      "preset_path": "knowledge/product/orchestration/service-presets/github-mcp.json"
    },
    "gitlab": {
      "base_url": "https://{{host}}.com/api/v4",
      "preset_path": "knowledge/product/orchestration/service-presets/gitlab.json"
    },
    "google-maps": {
      "preset_path": "knowledge/product/orchestration/service-presets/google-maps.json"
    },
    "google-workspace": {
      "preset_path": "knowledge/product/orchestration/service-presets/google-workspace.json",
      "allow_unsafe_cli": true
    },
    "jira": {
      "base_url": "https://atlassian.net/rest/api/3",
      "preset_path": "knowledge/product/orchestration/service-presets/jira.json"
    },
    "linear": {
      "base_url": "https://api.linear.app/graphql",
      "preset_path": "knowledge/product/orchestration/service-presets/linear.json"
    },
    "m365": {
      "preset_path": "knowledge/product/orchestration/service-presets/m365.json",
      "allow_unsafe_cli": true,
      "intent_aliases": ["outlook_calendar"]
    },
    "media-generation": {
      "preset_path": "knowledge/product/orchestration/service-presets/media-generation.json",
      "intent_aliases": ["generate-video", "generate-image", "generate-music"]
    },
    "meeting": {
      "preset_path": "knowledge/product/orchestration/service-presets/meeting.json",
      "intent_aliases": ["meeting-operations", "live-voice"]
    },
    "moltbook": {
      "base_url": "https://www.moltbook.com/api/v1"
    },
    "notion": {
      "base_url": "https://api.notion.com/v1",
      "preset_path": "knowledge/product/orchestration/service-presets/notion.json"
    },
    "paper2any": {
      "base_url": "{{paper2any_base_url}}",
      "preset_path": "knowledge/product/orchestration/service-presets/paper2any.json",
      "credential_suffixes": {
        "baseUrl": ["PAPER2ANY_BASE_URL"]
      }
    },
    "slack": {
      "base_url": "https://slack.com/api",
      "preset_path": "knowledge/product/orchestration/service-presets/slack.json",
      "allow_stream_ingress": false,
      "credential_suffixes": {
        "accessToken": ["ACCESS_TOKEN", "BOT_TOKEN", "TOKEN"],
        "appToken": ["APP_TOKEN"]
      }
    },
    "smoke-test": {
      "base_url": "https://postman-echo.com",
      "preset_path": "knowledge/product/orchestration/service-presets/smoke-test.json"
    },
    "sqlite": {
      "preset_path": "knowledge/product/orchestration/service-presets/sqlite.json"
    },
    "telegram": {
      "base_url": "https://api.telegram.org",
      "preset_path": "knowledge/product/orchestration/service-presets/telegram.json"
    },
    "vision": {
      "preset_path": "knowledge/product/orchestration/service-presets/media-generation.json",
      "alias_of": "media-generation",
      "intent_aliases": [
        "generate-image",
        "generate-video",
        "generate-music",
        "capture-screen",
        "record-screen"
      ]
    },
    "voice": {
      "preset_path": "knowledge/product/orchestration/service-presets/voice.json",
      "intent_aliases": ["speak-with-my-voice", "live-voice"]
    },
    "whisper": {
      "preset_path": "knowledge/product/orchestration/service-presets/whisper.json",
      "intent_aliases": ["transcribe-audio", "live-voice"]
    },
    "x-docs": {
      "preset_path": "knowledge/product/orchestration/service-presets/x-docs.json",
      "intent_aliases": ["x-documentation", "x-api-docs", "x-mcp-docs"]
    },
    "xapi": {
      "preset_path": "knowledge/product/orchestration/service-presets/xapi.json",
      "allow_unsafe_cli": true,
      "intent_aliases": ["social-post-search", "x-search", "twitter-search"],
      "credential_suffixes": {
        "clientId": ["CLIENT_ID"],
        "clientSecret": ["CLIENT_SECRET"],
        "redirectUri": ["REDIRECT_URI"]
      }
    },
    "youtube": {
      "preset_path": "knowledge/product/orchestration/service-presets/youtube.json"
    },
    "zendesk": {
      "base_url": "https://{{subdomain}}.zendesk.com/api/v2",
      "preset_path": "knowledge/product/orchestration/service-presets/zendesk.json"
    },
    "video-analysis": {
      "preset_path": "knowledge/product/orchestration/service-presets/video-analysis.json",
      "allow_unsafe_cli": true,
      "intent_aliases": ["analyze-video", "extract-keyframes"]
    }
  }
}
