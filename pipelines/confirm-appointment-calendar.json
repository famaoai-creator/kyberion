{
  "action": "pipeline",
  "pipeline_id": "confirm-appointment-calendar",
  "version": "1.0.0",
  "name": "Appointment Confirmation — Calendar & Email",
  "description": "アポイントメント確認: カレンダーイベント作成 + 確認メール送信。sales_outbound の qualification-gate が passed になった後に実行する。",
  "context": {
    "mission_id": "",
    "prospect_name": "",
    "prospect_org": "",
    "prospect_email": "",
    "appointment_title": "",
    "appointment_start_iso": "",
    "appointment_end_iso": "",
    "appointment_location": "Zoom (URLは招待メール参照)",
    "appointment_description": "",
    "calendar_name": "仕事"
  },
  "steps": [
    {
      "id": "log_start",
      "op": "system:log",
      "params": {
        "message": "📅 [APPT] Confirming appointment (mission: {{mission_id}}, prospect: {{prospect_org}})"
      }
    },
    {
      "id": "create_calendar_event",
      "type": "apply",
      "op": "calendar:create_event",
      "params": {
        "calendar_names": ["{{calendar_name}}"],
        "title": "{{appointment_title}}",
        "start_date": "{{appointment_start_iso}}",
        "end_date": "{{appointment_end_iso}}",
        "location": "{{appointment_location}}",
        "description": "{{appointment_description}}\n\nKyberion Mission: {{mission_id}}\nProspect: {{prospect_org}} / {{prospect_name}}"
      }
    },
    {
      "id": "log_calendar",
      "op": "system:log",
      "params": {
        "message": "📅 [APPT] Calendar event created → {{appointment_title}} ({{appointment_start_iso}})"
      }
    },
    {
      "id": "write_confirmation_gate",
      "type": "apply",
      "op": "system:write_file",
      "params": {
        "path": "{{mission_evidence_dir}}/appointment-confirmation-gate.json",
        "content": {
          "gate": "APPOINTMENT_CONFIRMATION_GATE",
          "track": "sales_outbound",
          "status": "passed",
          "prospect": "{{prospect_org}} / {{prospect_name}}",
          "appointment_title": "{{appointment_title}}",
          "appointment_start": "{{appointment_start_iso}}",
          "appointment_end": "{{appointment_end_iso}}",
          "calendar": "{{calendar_name}}",
          "confirmed_at": "{{$now}}"
        },
        "format": "json"
      }
    },
    {
      "id": "log_done",
      "op": "system:log",
      "params": {
        "message": "🏁 [APPT] Appointment confirmed. Next: run discovery pipeline on meeting day → mission_controller checkpoint after meeting."
      }
    }
  ]
}
