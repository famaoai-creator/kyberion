{
  "action": "pipeline",
  "name": "Executive Narrative Bridge",
  "version": "1.0.0",
  "description": "Bridges raw analysis into executive-grade narrative: reasoning synthesis, multi-perspective wisdom, and system logging.",
  "steps": [
    { "role": "sink", "op": "system:log", "params": { "message": "🎙️ Executive Narrative Bridge — starting..." } },
    {
      "role": "source",
      "op": "reasoning:analyze",
      "produces": { "channel": "analysis", "type": "ReasoningResult" },
      "params": { "context": "{{input.context}}", "depth": "executive" }
    },
    {
      "role": "transform",
      "op": "wisdom:a2a_fanout",
      "consumes": "analysis",
      "produces": { "channel": "narrative_views", "type": "FanoutResult" },
      "params": {
        "personas": ["ceo", "ruthless_auditor"],
        "prompt_template": "Reframe for {{persona}}: {{analysis}}"
      }
    },
    {
      "role": "transform",
      "op": "wisdom:cross_critique",
      "consumes": "narrative_views",
      "produces": { "channel": "narrative_synthesis", "type": "CrossCritiqueResult" },
      "params": {}
    },
    {
      "role": "sink",
      "op": "system:checkpoint",
      "consumes": "narrative_synthesis",
      "params": { "label": "executive-narrative" }
    }
  ]
}
