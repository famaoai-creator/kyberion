{
  "action": "pipeline",
  "name": "Executive Narrative Bridge",
  "version": "1.0.0",
  "description": "Bridges raw analysis into executive-grade narrative: reasoning synthesis, multi-perspective wisdom, and system logging.",
  "steps": [
    {
      "role": "sink",
      "op": "system:log",
      "params": { "message": "🎙️ Executive Narrative Bridge — starting..." }
    },
    {
      "role": "source",
      "op": "reasoning:analyze",
      "produces": { "channel": "analysis", "type": "ReasoningResult" },
      "params": { "context": "{{input.context}}", "depth": "executive", "export_as": "analysis" }
    },
    {
      "role": "transform",
      "op": "wisdom:a2a_fanout",
      "consumes": "analysis",
      "produces": { "channel": "narrative_views", "type": "FanoutResult" },
      "params": {
        "personas": ["ceo", "ruthless_auditor"],
        "topic": "Reframe this analysis for executive narrative purposes: {{analysis}}",
        "output_path": "active/shared/tmp/reports/executive-narrative-fanout.json"
      }
    },
    {
      "role": "transform",
      "op": "wisdom:cross_critique",
      "consumes": "narrative_views",
      "produces": { "channel": "narrative_synthesis", "type": "CrossCritiqueResult" },
      "params": {
        "source_path": "active/shared/tmp/reports/executive-narrative-fanout.json",
        "personas": ["ceo", "ruthless_auditor"],
        "output_path": "active/shared/tmp/reports/executive-narrative.json"
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "consumes": "narrative_synthesis",
      "params": {
        "message": "✅ Executive narrative saved to active/shared/tmp/reports/executive-narrative.json"
      }
    }
  ]
}
