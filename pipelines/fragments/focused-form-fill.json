{
  "action": "pipeline",
  "name": "focused-form-fill-fragment",
  "version": "2.0.0",
  "description": "Checks if the currently focused UI element is editable, pastes fill_text into it, and optionally submits. Required context var: fill_text. Optional: auto_submit (boolean string 'true'/'false', default false), application (activates the app before checking focus).",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "steps": [
    {
      "id": "activate_app",
      "role": "gate",
      "op": "core:if",
      "params": {
        "condition": "application",
        "then": [
          {
            "id": "activate",
            "role": "sink",
            "op": "system:activate_application",
            "params": { "application": "{{application}}" }
          }
        ]
      }
    },
    {
      "id": "check_focus",
      "role": "source",
      "op": "system:get_focused_input",
      "produces": { "channel": "focused_input", "type": "FocusedInputResult" },
      "params": {}
    },
    {
      "id": "fill_or_warn",
      "role": "gate",
      "op": "core:if",
      "consumes": "focused_input",
      "params": {
        "condition": { "from": "focused_input.editable", "operator": "equals", "value": true },
        "then": [
          {
            "id": "stage_clipboard",
            "role": "sink",
            "op": "system:clipboard_write",
            "params": { "text": "{{fill_text}}" }
          },
          {
            "id": "paste",
            "role": "sink",
            "op": "system:paste_text",
            "params": { "text": "{{fill_text}}" }
          },
          {
            "id": "maybe_submit",
            "role": "gate",
            "op": "core:if",
            "params": {
              "condition": { "from": "auto_submit", "operator": "equals", "value": "true" },
              "then": [
                {
                  "id": "submit",
                  "role": "sink",
                  "op": "system:press_key",
                  "params": { "key": "enter" }
                }
              ]
            }
          },
          {
            "id": "notify_success",
            "role": "sink",
            "op": "system:system_notify",
            "consumes": "focused_input",
            "params": {
              "title": "Kyberion",
              "message": "入力しました",
              "subtitle": "{{focused_input.application}} — {{focused_input.windowTitle}}"
            }
          }
        ],
        "else": [
          {
            "id": "notify_not_editable",
            "role": "sink",
            "op": "system:system_notify",
            "consumes": "focused_input",
            "params": {
              "title": "Kyberion",
              "message": "入力フォームにフォーカスがありません",
              "subtitle": "role: {{focused_input.role}}"
            }
          }
        ]
      }
    }
  ]
}
