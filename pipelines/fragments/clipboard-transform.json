{
  "action": "pipeline",
  "name": "clipboard-transform-fragment",
  "version": "2.0.0",
  "description": "Reads the clipboard, transforms the content via LLM, writes the result back, and notifies. Required context var: transform_instruction (e.g. 'Translate to English', 'Summarize in 3 bullets', 'Fix grammar').",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "steps": [
    {
      "id": "read_clipboard",
      "role": "source",
      "op": "system:clipboard_read",
      "produces": { "channel": "clipboard_input", "type": "ClipboardContent" },
      "params": {}
    },
    {
      "id": "guard_empty",
      "role": "gate",
      "op": "core:if",
      "consumes": "clipboard_input",
      "params": {
        "condition": "clipboard_input",
        "then": [
          {
            "id": "transform",
            "role": "transform",
            "op": "reasoning:analyze",
            "consumes": "clipboard_input",
            "produces": { "channel": "clipboard_output", "type": "TextResult" },
            "params": {
              "instruction": "{{transform_instruction}}",
              "context": ["{{clipboard_input}}"]
            }
          },
          {
            "id": "write_back",
            "role": "sink",
            "op": "system:clipboard_write",
            "consumes": "clipboard_output",
            "params": { "text": "{{clipboard_output}}" }
          },
          {
            "id": "notify_done",
            "role": "sink",
            "op": "system:system_notify",
            "params": {
              "title": "Kyberion",
              "message": "クリップボードを更新しました",
              "subtitle": "{{transform_instruction}}"
            }
          }
        ],
        "else": [
          {
            "id": "notify_empty",
            "role": "sink",
            "op": "system:system_notify",
            "params": {
              "title": "Kyberion",
              "message": "クリップボードが空です"
            }
          }
        ]
      }
    }
  ]
}
