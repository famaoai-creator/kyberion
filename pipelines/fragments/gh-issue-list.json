{
  "action": "pipeline",
  "name": "gh-issue-list-fragment",
  "version": "2.0.0",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "context": {
    "repo": "cli/cli",
    "limit": 5
  },
  "steps": [
    {
      "role": "source",
      "op": "cli_health_check",
      "produces": { "channel": "gh_health", "type": "HealthResult" },
      "params": {
        "command": "gh"
      }
    },
    {
      "role": "source",
      "op": "exec",
      "produces": { "channel": "issues_raw", "type": "ShellResult" },
      "params": {
        "command": "gh",
        "args": [
          "issue",
          "list",
          "--repo",
          "{{repo}}",
          "--limit",
          "{{limit}}",
          "--json",
          "number,title,state,updatedAt"
        ]
      }
    },
    {
      "role": "sink",
      "op": "log",
      "consumes": "issues_raw",
      "params": {
        "message": "Found {{issues_raw.stdout.length}} characters of issue data."
      }
    }
  ]
}
