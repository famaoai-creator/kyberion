{
  "description": "Maintenance pipeline: Opens browser tabs ONLY for active UI surfaces in a single browser instance.",
  "action": "pipeline",
  "version": "2.0.0",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type without roles.",
  "options": {
    "headless": false,
    "browser_channel": "chrome",
    "keep_alive": true,
    "lease_ms": 300000
  },
  "steps": [
    {
      "id": "get-active-surfaces",
      "role": "source",
      "op": "process:list-surfaces",
      "produces": { "channel": "surfaces", "type": "SurfaceList" },
      "params": {}
    },
    {
      "id": "inspect-each-surface",
      "role": "gate",
      "op": "core:foreach",
      "consumes": "surfaces",
      "params": {
        "items": "{{surfaces}}",
        "as": "surface",
        "do": [
          {
            "role": "gate",
            "op": "core:if",
            "params": {
              "condition": {
                "operator": "and",
                "conditions": [
                  "surface.running",
                  "surface.port",
                  {
                    "operator": "eq",
                    "from": "surface.kind",
                    "value": "ui"
                  }
                ]
              },
              "then": [
                {
                  "role": "sink",
                  "op": "browser:open_tab",
                  "params": {
                    "url": "{{surface.home_url}}",
                    "tab_id": "tab-{{surface.id}}",
                    "waitUntil": "domcontentloaded"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
