{
  "action": "pipeline",
  "name": "policy-compliance-scan-fragment",
  "version": "2.0.0",
  "description": "Scans a directory for security policy violations and sensitive content markers.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "context": {
    "target_dir": "active/shared/tmp",
    "target_tier": "public"
  },
  "steps": [
    {
      "id": "run_scan",
      "role": "source",
      "op": "system:exec",
      "produces": { "channel": "scan_result", "type": "ComplianceResult" },
      "params": {
        "command": "node",
        "args": [
          "dist/scripts/compliance_checker.js",
          "--dir", "{{target_dir}}",
          "--tier", "{{target_tier}}"
        ],
        "env": { "KYBERION_PERSONA": "sovereign" },
        "allow_error": true
      }
    },
    {
      "id": "check_violations",
      "role": "gate",
      "op": "core:if",
      "consumes": "scan_result",
      "params": {
        "condition": { "from": "scan_result.status", "operator": "equals", "value": "passed" },
        "then": [
          { "role": "sink", "op": "system:log", "params": { "message": "Compliance scan passed for {{target_dir}}." } }
        ],
        "else": [
          { "role": "sink", "op": "system:log", "params": { "message": "Compliance scan FAILED for {{target_dir}}. Violations: {{scan_result.violations}}" } }
        ]
      }
    }
  ]
}
