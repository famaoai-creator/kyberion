{
  "action": "pipeline",
  "name": "artifact-preview-fragment",
  "version": "2.0.0",
  "description": "Opens a generated artifact in the OS default handler and sends a desktop notification. Append after any write_artifact step. Required context var: artifact_path (relative to repo root). Optional: notify_title, notify_message.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "steps": [
    {
      "id": "probe_artifact",
      "role": "source",
      "op": "system:probe",
      "produces": { "channel": "artifact_probe", "type": "ProbeResult" },
      "params": {
        "path": "{{artifact_path}}"
      }
    },
    {
      "id": "open_or_warn",
      "role": "gate",
      "op": "core:if",
      "consumes": "artifact_probe",
      "params": {
        "condition": { "from": "artifact_probe.exists", "operator": "equals", "value": true },
        "then": [
          {
            "id": "open_artifact",
            "role": "sink",
            "op": "system:open_file",
            "params": { "path": "{{artifact_path}}" }
          },
          {
            "id": "notify_opened",
            "role": "sink",
            "op": "system:system_notify",
            "params": {
              "title": "{{notify_title|Artifact Ready}}",
              "message": "{{notify_message|成果物が生成されました}}",
              "subtitle": "{{artifact_path}}"
            }
          }
        ],
        "else": [
          {
            "id": "warn_missing",
            "role": "sink",
            "op": "system:log",
            "params": {
              "message": "[ARTIFACT PREVIEW] File not found: {{artifact_path}}"
            }
          }
        ]
      }
    }
  ]
}
