{
  "action": "pipeline",
  "name": "security-incident-containment",
  "version": "2.0.0",
  "description": "Fragment for Scenario 9: Security incident response with audit logging and approval gates.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "context": {
    "threat_type": "unknown",
    "affected_resources": [],
    "mission_id": "MSN-EXAMPLE"
  },
  "steps": [
    {
      "id": "triage_incident",
      "role": "source",
      "op": "wisdom:knowledge_search",
      "produces": { "channel": "triage_plan", "type": "KnowledgeSearchResult" },
      "params": {
        "query": "incident triage procedures for {{threat_type}}"
      }
    },
    {
      "id": "collect_evidence",
      "role": "sink",
      "op": "system:collect_logs",
      "params": {
        "scope": "{{affected_resources}}",
        "export_path": "active/shared/tmp/{{mission_id}}/evidence.log"
      }
    },
    {
      "id": "audit_record_start",
      "role": "sink",
      "op": "blockchain:record_event",
      "params": {
        "event": "INCIDENT_TRIAGE_STARTED",
        "evidence_hash": "sha256:{{evidence_log_hash}}"
      }
    },
    {
      "id": "approval_gate_containment",
      "role": "sink",
      "op": "approval:request",
      "params": {
        "title": "Incident Containment Approval",
        "description": "Approve isolation of {{affected_resources}} based on triage plan.",
        "risk_level": "high"
      }
    },
    {
      "id": "execute_containment",
      "role": "sink",
      "op": "system:execute_procedure",
      "params": {
        "procedure": "isolate_resources",
        "args": { "resources": "{{affected_resources}}" }
      }
    },
    {
      "id": "audit_record_finish",
      "role": "sink",
      "op": "blockchain:record_event",
      "params": {
        "event": "INCIDENT_CONTAINMENT_EXECUTED",
        "outcome": "success"
      }
    }
  ]
}
