{
  "action": "pipeline",
  "name": "memory-distillation-fragment",
  "version": "2.0.0",
  "description": "Analyzes recent mission traces to extract hints and lessons learned, updating the system's operational memory.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "steps": [
    {
      "id": "distill_wisdom",
      "role": "source",
      "op": "wisdom:distill",
      "produces": { "channel": "lessons_learned", "type": "AnalysisResult" },
      "params": {
        "scope": "recent_missions"
      }
    },
    {
      "id": "write_distill_summary",
      "role": "sink",
      "op": "system:write_artifact",
      "consumes": "lessons_learned",
      "params": {
        "path": "active/shared/tmp/memory-distillation-summary.md",
        "content": "{{lessons_learned}}"
      }
    },
    {
      "id": "nominate_promotion",
      "role": "sink",
      "op": "working-memory:nominate-promotion",
      "consumes": "lessons_learned",
      "params": {
        "mdPath": "active/shared/tmp/memory-distillation-summary.md",
        "source_ref": "pipeline:memory-distillation",
        "summary": "Distilled operational lesson from recent missions",
        "source_type": "artifact",
        "evidence_refs": ["active/shared/tmp/memory-distillation-summary.md"],
        "proposed_memory_kind": "heuristic",
        "sensitivity_tier": "confidential"
      }
    }
  ]
}
