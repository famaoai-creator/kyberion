{
  "version": "2.0.0",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "steps": [
    {
      "id": "check-login",
      "role": "source",
      "op": "browser:evaluate",
      "produces": { "channel": "login_status", "type": "EvalResult" },
      "params": {
        "script": "(() => document.querySelector(\"input[name='_account']\") ? 'need_login' : 'already_logged_in')()"
      }
    },
    {
      "id": "login-if-needed",
      "role": "gate",
      "op": "core:if",
      "consumes": "login_status",
      "params": {
        "condition": { "from": "login_status", "operator": "eq", "value": "need_login" },
        "then": [
          {
            "role": "sink",
            "op": "browser:fill",
            "params": { "selector": "input[name='_account']", "text": "{{login_user}}" }
          },
          {
            "role": "sink",
            "op": "browser:fill",
            "params": { "selector": "input[name='_password']", "text": "{{login_password}}" }
          },
          {
            "role": "sink",
            "op": "browser:click",
            "params": { "selector": "input.login-button, input[type='submit']" }
          },
          { "role": "sink", "op": "browser:wait", "params": { "duration": 3000 } }
        ]
      }
    }
  ]
}
