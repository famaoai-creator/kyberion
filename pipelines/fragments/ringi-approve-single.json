{
  "version": "2.0.0",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type without roles.",
  "steps": [
    { "id": "click-first-item", "role": "sink", "op": "click", "params": { "selector": "{{item_selector}}" } },
    { "id": "wait-after-open", "role": "sink", "op": "wait", "params": { "duration": 5000 } },
    { "id": "click-approve", "role": "sink", "op": "click", "params": { "selector": "{{approve_button_selector}}" } },
    { "id": "wait-after-approve", "role": "sink", "op": "wait", "params": { "duration": 5000 } },
    { "id": "click-ok", "role": "sink", "op": "click", "params": { "selector": "{{ok_button_selector}}" } },
    { "id": "wait-after-ok", "role": "sink", "op": "wait", "params": { "duration": 5000 } },
    { "id": "navigate-back", "role": "sink", "op": "navigate", "params": { "url": "{{list_url}}" } },
    { "id": "wait-after-navigate", "role": "sink", "op": "wait", "params": { "duration": 5000 } },
    { "id": "check-remaining", "role": "source", "op": "evaluate", "produces": { "channel": "remaining_items", "type": "EvalResult" }, "params": { "script": "(() => document.querySelectorAll('{{item_selector}}').length)()" } }
  ]
}
