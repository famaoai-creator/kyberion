{
  "action": "pipeline",
  "name": "mission-bootstrap-fragment",
  "version": "2.0.0",
  "description": "Standardizes the creation of a new Kyberion mission, initializing the evidence directory and Git repository.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "context": {
    "tier": "confidential",
    "tenant_id": "default",
    "mission_type": "development",
    "vision_ref": "vision_001",
    "persona": "ecosystem_architect"
  },
  "steps": [
    {
      "id": "create_mission",
      "role": "source",
      "op": "system:exec",
      "produces": { "channel": "bootstrap_raw", "type": "ShellResult" },
      "params": {
        "command": "node",
        "args": [
          "dist/scripts/mission_controller.js",
          "create",
          "{{tier}}",
          "{{tenant_id}}",
          "{{mission_type}}",
          "{{vision_ref}}",
          "{{persona}}"
        ]
      }
    },
    {
      "id": "extract_mission_id",
      "role": "transform",
      "op": "system:regex_extract",
      "consumes": "bootstrap_raw",
      "produces": { "channel": "mission_id", "type": "TextResult" },
      "params": {
        "from": "bootstrap_raw.stdout",
        "pattern": "Created evidence directory for mission ([^\\s\\.]*)"
      }
    },
    {
      "id": "log_mission_id",
      "role": "sink",
      "op": "system:log",
      "consumes": "mission_id",
      "params": {
        "message": "Mission bootstrapped successfully. ID: {{mission_id}}"
      }
    }
  ]
}
