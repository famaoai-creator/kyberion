{
  "action": "pipeline",
  "name": "standard-sdlc-loop",
  "version": "2.0.0",
  "description": "Reusable SDLC skeleton: requirements extraction → design synthesis → test planning → task decomposition → summary.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used type + export_as.",
  "context": {
    "mission_id": "",
    "project_name": "",
    "source_path": "",
    "source_type": "meeting_notes",
    "language": "ja",
    "customer_name": "",
    "customer_org": "",
    "additional_context": "",
    "validation_profile": "default"
  },
  "steps": [
    {
      "id": "extract_requirements",
      "role": "sink",
      "op": "modeling:extract_requirements",
      "produces": { "channel": "requirements", "type": "RequirementsResult" },
      "params": {
        "mission_id": "{{mission_id}}",
        "project_name": "{{project_name}}",
        "source_path": "{{source_path}}",
        "source_type": "{{source_type}}",
        "language": "{{language}}",
        "customer_name": "{{customer_name}}",
        "customer_org": "{{customer_org}}"
      }
    },
    {
      "id": "synthesize_design",
      "role": "sink",
      "op": "modeling:extract_design_spec",
      "produces": { "channel": "design", "type": "DesignSpec" },
      "params": {
        "mission_id": "{{mission_id}}",
        "project_name": "{{project_name}}",
        "additional_context": "{{additional_context}}"
      }
    },
    {
      "id": "derive_test_plan",
      "role": "sink",
      "op": "modeling:extract_test_plan",
      "produces": { "channel": "test_plan", "type": "TestPlan" },
      "params": {
        "mission_id": "{{mission_id}}",
        "project_name": "{{project_name}}"
      }
    },
    {
      "id": "decompose_tasks",
      "role": "sink",
      "op": "orchestrator:decompose_into_tasks",
      "produces": { "channel": "task_plan", "type": "TaskPlan" },
      "params": {
        "mission_id": "{{mission_id}}",
        "project_name": "{{project_name}}"
      }
    },
    {
      "id": "emit_summary",
      "role": "sink",
      "op": "system:log",
      "consumes": ["requirements", "design", "test_plan", "task_plan"],
      "params": {
        "message": "SDLC fragment complete for {{project_name}}: requirements v{{requirements.version}} / design v{{design.version}} / test plan v{{test_plan.version}} / task plan v{{task_plan.version}}."
      }
    }
  ]
}
