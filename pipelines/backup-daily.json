{
  "action": "pipeline",
  "name": "backup-daily",
  "version": "1.0.0",
  "description": "Creates an encrypted daily Kyberion state snapshot. OP-02 requires an external backup destination for real DR; the backup tool warns when the target is on the same device.",
  "_refs": {
    "plan": "docs/improvement-plans-2026-07/OP-02_BACKUP_RECOVERY.ja.md",
    "implementation": "scripts/backup.ts"
  },
  "context": {},
  "schedule": {
    "id": "backup-daily",
    "cron": "15 3 * * *",
    "timezone": "Asia/Tokyo",
    "enabled": true
  },
  "steps": [
    {
      "id": "create_encrypted_backup",
      "role": "source",
      "op": "system:exec",
      "produces": {
        "channel": "backup_result",
        "type": "CommandResult"
      },
      "params": {
        "command": "node",
        "args": [
          "--import",
          "./scripts/ts-loader.mjs",
          "scripts/backup.ts",
          "create",
          "--scope",
          "all",
          "--encrypt",
          "--prune",
          "--retain-daily",
          "7",
          "--retain-weekly",
          "4"
        ],
        "timeout_ms": 120000
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "params": {
        "message": "Daily backup command completed. Confirm archive location and external-copy policy."
      }
    }
  ]
}
