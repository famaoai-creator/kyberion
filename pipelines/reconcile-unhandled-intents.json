{
  "action": "pipeline",
  "pipeline_id": "reconcile-unhandled-intents",
  "version": "1.0.0",
  "name": "Unhandled Intent Reconciler",
  "description": "Reads the unhandled-intent registry (unrouted + unrecognized) and writes proposal stubs. Invokes reasoning:analyze to suggest routing entries (for unrouted) or new intent definitions (for unrecognized).",
  "context": {
    "registry_path": "active/shared/tmp/unhandled-intent-registry.json",
    "proposals_dir": "active/shared/tmp/unhandled-intent-proposals",
    "routing_map": "knowledge/product/governance/intent-routing-map.json",
    "intent_catalog": "knowledge/product/governance/standard-intents.json"
  },
  "steps": [
    {
      "id": "log_start",
      "role": "sink",
      "op": "system:log",
      "params": { "message": "[UNHANDLED-INTENT] Starting reconcile cycle..." }
    },
    {
      "id": "run_reconciler",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "reconcile_result", "type": "ShellResult" },
      "params": {
        "cmd": "node dist/scripts/reconcile_unhandled_intents.js 2>/dev/null || echo '{\"proposals_written\":[],\"skipped\":[],\"total_unreconciled\":0}'"
      }
    },
    {
      "id": "log_result",
      "role": "sink",
      "op": "system:log",
      "consumes": "reconcile_result",
      "params": { "message": "{{reconcile_result.summary_line}}" }
    },
    {
      "id": "write_summary",
      "role": "sink",
      "op": "system:write_file",
      "consumes": "reconcile_result",
      "params": {
        "path": "active/shared/tmp/unhandled-intent-last-run.json",
        "content": {
          "ran_at": "{{_now}}",
          "result": "{{reconcile_result}}"
        },
        "format": "json"
      }
    },
    {
      "id": "log_done",
      "role": "sink",
      "op": "system:log",
      "consumes": "reconcile_result",
      "params": { "message": "{{reconcile_result.summary_line}}" }
    }
  ]
}
