{
  "action": "pipeline",
  "name": "CEO Strategic Executive Report",
  "version": "1.0.0",
  "description": "Generates a strategic executive report for CEO decision-making: code analysis, multi-scenario reasoning, and PPTX output.",
  "steps": [
    { "role": "sink", "op": "system:log", "params": { "message": "🏛️ CEO Strategic Report — starting..." } },
    {
      "role": "source",
      "op": "code:analyze",
      "produces": { "channel": "codebase_summary", "type": "CodeAnalysisResult" },
      "params": { "target": ".", "depth": "surface", "output_format": "json" }
    },
    {
      "role": "transform",
      "op": "wisdom:a2a_fanout",
      "consumes": "codebase_summary",
      "produces": { "channel": "strategic_views", "type": "FanoutResult" },
      "params": {
        "personas": ["growth", "stability", "hybrid"],
        "prompt_template": "Analyze from the {{persona}} perspective: {{codebase_summary}}"
      }
    },
    {
      "role": "transform",
      "op": "wisdom:cross_critique",
      "consumes": "strategic_views",
      "produces": { "channel": "synthesis", "type": "CrossCritiqueResult" },
      "params": {}
    },
    {
      "role": "sink",
      "op": "system:checkpoint",
      "consumes": "synthesis",
      "params": { "label": "strategic-synthesis" }
    }
  ]
}
