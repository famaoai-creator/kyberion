{
  "pipeline_id": "baseline-check",
  "version": "2.0.0",
  "description": "Unified Pre-Flight Check (L0-L5) for system awakening",
  "_migration_note": "v2: Typed Flow format. v1 used type only.",
  "action": "pipeline",
  "schedule": {
    "id": "baseline-check-hourly",
    "cron": "0 * * * *",
    "timezone": "Asia/Tokyo",
    "enabled": true
  },
  "steps": [
    {
      "id": "run-sentinel",
      "role": "sink",
      "op": "system:exec",
      "params": {
        "command": "node",
        "args": ["dist/scripts/run_baseline_check.js"]
      }
    }
  ]
}
