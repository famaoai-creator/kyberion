{
  "action": "pipeline",
  "name": "weekly-review",
  "version": "2.0.0",
  "description": "Volatile Knowledge Layer — weekly review: opens the current week's face, then nominates it as a memory-promotion-queue candidate for distillation into knowledge/.",
  "_refs": {
    "schema": "schemas/volatile-knowledge.schema.json",
    "actuator": "working-memory-actuator",
    "plan": "docs/VOLATILE_KNOWLEDGE_PLAN.ja.md § Phase 2b"
  },
  "schedule": {
    "id": "weekly-review",
    "cron": "0 7 * * 1",
    "timezone": "Asia/Tokyo",
    "enabled": true
  },
  "steps": [
    {
      "id": "open_weekly",
      "role": "source",
      "op": "working-memory:weekly-open",
      "produces": { "channel": "weekly_face", "type": "WeeklyOpenResult" },
      "params": {
        "export_as": "weekly_face"
      }
    },
    {
      "id": "reconcile_unhandled_intents",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "reconcile_result", "type": "ShellResult" },
      "params": {
        "cmd": "node dist/scripts/reconcile_unhandled_intents.js",
        "export_as": "reconcile_result"
      }
    },
    {
      "id": "log_unhandled_intents",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "reconcile_summary", "type": "ShellResult" },
      "params": {
        "cmd": "cat active/shared/tmp/unhandled-intent-last-run.summary.txt",
        "export_as": "reconcile_summary"
      }
    },
    {
      "id": "emit_unhandled_intents_summary",
      "role": "sink",
      "op": "system:log",
      "consumes": "reconcile_summary",
      "params": {
        "message": "{{reconcile_summary}}"
      }
    },
    {
      "id": "nominate_promotion",
      "role": "sink",
      "op": "working-memory:nominate-promotion",
      "consumes": "weekly_face",
      "params": {
        "export_as": "nomination_result",
        "mdPath": "{{weekly_face.weeklyPath}}",
        "summary": "Weekly review face — candidate for knowledge distillation",
        "source_type": "task_session",
        "proposed_memory_kind": "heuristic",
        "sensitivity_tier": "personal"
      }
    },
    {
      "id": "summarize_task_model_routing",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "task_model_routing_summary", "type": "ShellResult" },
      "params": {
        "cmd": "node dist/scripts/summarize_task_model_routing.js --json > active/shared/tmp/task-model-routing-summary.json || printf '{\"samples\":[],\"rows\":[]}' > active/shared/tmp/task-model-routing-summary.json"
      }
    },
    {
      "id": "log_task_model_routing_summary",
      "role": "sink",
      "op": "system:log",
      "consumes": "task_model_routing_summary",
      "params": {
        "message": "[WEEKLY-REVIEW] Task model routing summary written to active/shared/tmp/task-model-routing-summary.json."
      }
    },
    {
      "id": "summarize_memory_queue",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "memory_queue_summary", "type": "ShellResult" },
      "params": {
        "cmd": "node dist/scripts/summarize_memory_promotion_queue.js --status queued --output active/shared/tmp/memory-promotion-queue-summary.md"
      }
    },
    {
      "id": "log_memory_queue_summary",
      "role": "sink",
      "op": "system:log",
      "consumes": "memory_queue_summary",
      "params": {
        "message": "[WEEKLY-REVIEW] Memory promotion queue summary written to active/shared/tmp/memory-promotion-queue-summary.md."
      }
    }
  ]
}
