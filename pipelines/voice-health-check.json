{
  "action": "pipeline",
  "name": "Voice Health Check",
  "version": "1.0.0",
  "description": "Verifies the voice pipeline toolchain: mlx_audio_tts_bridge.py, native TTS, and STT bridge availability.",
  "steps": [
    { "role": "sink", "op": "system:log", "params": { "message": "🎙️ Voice Health Check — starting..." } },
    {
      "id": "check_tts_bridge",
      "role": "source",
      "op": "system:probe",
      "produces": { "channel": "tts_bridge", "type": "ProbeResult" },
      "params": { "path": "libs/actuators/voice-actuator/scripts/mlx_audio_tts_bridge.py" }
    },
    {
      "id": "check_native_tts",
      "role": "source",
      "op": "system:check_native_tts",
      "produces": { "channel": "native_tts", "type": "ProbeResult" },
      "params": {}
    },
    {
      "id": "notify",
      "role": "sink",
      "op": "system:system_notify",
      "consumes": ["tts_bridge", "native_tts"],
      "params": {
        "message": "Voice Health Check: TTS bridge={{tts_bridge.exists}} native={{native_tts.ready}}"
      }
    }
  ]
}
