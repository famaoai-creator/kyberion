{
  "action": "pipeline",
  "name": "Voice Health Check",
  "version": "1.0.0",
  "description": "Verifies the governed voice toolchain: tool runtime inventory, mlx_audio_tts_bridge.py, native TTS, STT bridge availability, and the realtime-loop surfaces (silero VAD bridge script).",
  "steps": [
    {
      "role": "sink",
      "op": "system:log",
      "params": {
        "message": "🎙️ Voice Health Check — starting..."
      }
    },
    {
      "id": "list_tool_runtimes",
      "role": "source",
      "op": "system:list_tool_runtimes",
      "produces": {
        "channel": "tool_runtimes",
        "type": "ToolRuntimeInventory"
      },
      "params": {
        "requested_mode": "trial"
      }
    },
    {
      "id": "check_tts_bridge",
      "role": "source",
      "op": "system:probe",
      "produces": {
        "channel": "tts_bridge",
        "type": "ProbeResult"
      },
      "params": {
        "path": "libs/actuators/voice-actuator/scripts/mlx_audio_tts_bridge.py"
      }
    },
    {
      "id": "check_native_tts",
      "role": "sink",
      "op": "system:check_native_tts",
      "produces": {
        "channel": "native_tts",
        "type": "ProbeResult"
      },
      "params": {}
    },
    {
      "id": "check_silero_vad_bridge",
      "role": "source",
      "op": "system:probe",
      "produces": {
        "channel": "silero_vad_bridge",
        "type": "ProbeResult"
      },
      "params": {
        "capability": "silero_vad"
      }
    },
    {
      "id": "notify",
      "role": "sink",
      "op": "system:system_notify",
      "consumes": ["tool_runtimes", "tts_bridge", "native_tts", "silero_vad_bridge"],
      "params": {
        "message": "Voice Health Check: runtimes={{tool_runtimes.default_tool_id}}/{{tool_runtimes.tools.length}} | TTS bridge={{tts_bridge.exists}} native={{native_tts.ready}} sileroVAD={{silero_vad_bridge.available}} reason={{silero_vad_bridge.reason}}"
      }
    }
  ]
}
