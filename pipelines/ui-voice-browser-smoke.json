{
  "action": "pipeline",
  "name": "UI Voice Browser Smoke",
  "version": "1.0.0",
  "description": "End-to-end smoke test: launches presence-studio, runs voice-hello pipeline, verifies browser session, and checks meeting consent gate.",
  "steps": [
    { "role": "sink", "op": "system:log", "params": { "message": "🔬 UI Voice Browser Smoke — starting..." } },
    {
      "id": "start_presence_studio",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "studio_pid", "type": "ShellResult" },
      "params": { "cmd": "node presence/displays/presence-studio/server.ts &" }
    },
    {
      "id": "run_voice_hello",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "voice_result", "type": "ShellResult" },
      "params": { "cmd": "node dist/scripts/run_pipeline.js --input pipelines/voice-hello.json" }
    },
    {
      "id": "verify_session",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "session_result", "type": "ShellResult" },
      "params": { "cmd": "node dist/scripts/run_pipeline.js --input pipelines/verify-session.json" }
    },
    {
      "id": "check_meeting_consent",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "consent_result", "type": "ShellResult" },
      "params": {
        "cmd": "node dist/libs/actuators/meeting-actuator/src/index.ts --check-consent",
        "gate": "meeting consent gate"
      }
    },
    {
      "id": "final_log",
      "role": "sink",
      "op": "system:log",
      "consumes": ["voice_result", "session_result", "consent_result"],
      "params": {
        "message": "✅ Smoke complete. Voice={{voice_result.status}} Session={{session_result.status}} Consent={{consent_result.status}}"
      }
    }
  ]
}
