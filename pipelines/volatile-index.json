{
  "action": "pipeline",
  "name": "volatile-index",
  "version": "2.0.0",
  "description": "Volatile Knowledge Layer — regenerates active/INDEX.volatile.{md,json} by scanning all *.volatile.json sidecars. Uses working-memory:build-index (no external scripts). Safe to run at any time.",
  "_refs": {
    "schema": "schemas/volatile-knowledge.schema.json",
    "actuator": "working-memory-actuator",
    "plan": "docs/VOLATILE_KNOWLEDGE_PLAN.ja.md § Phase 5"
  },
  "schedule": {
    "id": "volatile-index-daily",
    "cron": "0 5 * * *",
    "timezone": "Asia/Tokyo",
    "enabled": true
  },
  "steps": [
    {
      "id": "build_index",
      "role": "sink",
      "op": "working-memory:build-index",
      "params": {
        "export_as": "index_result"
      }
    }
  ]
}
