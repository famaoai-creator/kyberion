{
  "action": "pipeline",
  "name": "Automated License Header Injection",
  "version": "2.0.0",
  "description": "Injects a license header into a target file if it's missing.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used export_as without roles.",
  "context": {
    "target_file": "active/shared/tmp/license-test.ts",
    "header": "// (c) 2026 Kyberion Sovereign Ecosystem. All rights reserved.\n"
  },
  "steps": [
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "init_status", "type": "ShellResult" },
      "params": {
        "cmd": "echo 'console.log(\"Hello world\");' > active/shared/tmp/license-test.ts"
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "params": { "message": "📄 Processing {{target_file}}..." }
    },
    {
      "role": "gate",
      "op": "core:include",
      "params": {
        "fragment": "license-injection-inner.json"
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "params": { "message": "✅ License injection attempted." }
    },
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "file_content", "type": "ShellResult" },
      "params": {
        "cmd": "cat active/shared/tmp/license-test.ts"
      }
    },
    {
      "role": "sink",
      "op": "system:log",
      "consumes": "file_content",
      "params": { "message": "📝 Resulting content:\n{{file_content}}" }
    }
  ]
}
