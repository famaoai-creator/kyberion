{
  "action": "pipeline",
  "name": "Sovereign System Upgrade Execution",
  "version": "2.0.0",
  "description": "Performs the actual upgrade: pull, build, test, and merge.",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used export_as without roles.",
  "steps": [
    { "role": "sink", "op": "system:log", "params": { "message": "🛠️ Step 2: Executing System Upgrade..." } },
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "pull_result", "type": "ShellResult" },
      "params": {
        "cmd": "git checkout main && git pull origin main",
        "retry": { "maxRetries": 2 }
      }
    },
    { "role": "sink", "op": "system:log", "params": { "message": "📦 Step 3: Rebuilding physical foundation..." } },
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "build_result", "type": "ShellResult" },
      "params": { "cmd": "pnpm install && npm run build" }
    },
    { "role": "sink", "op": "system:log", "params": { "message": "🧪 Step 4: Running comprehensive validation..." } },
    {
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "test_result", "type": "ShellResult" },
      "params": { "cmd": "pnpm test" }
    },
    {
      "role": "gate",
      "op": "core:if",
      "consumes": "test_result",
      "params": {
        "condition": {
          "from": "test_result",
          "operator": "not_empty"
        },
        "then": [
          { "role": "sink", "op": "system:log", "params": { "message": "✅ Validation passed. Finalizing upgrade..." } },
          {
            "role": "source",
            "op": "system:shell",
            "produces": { "channel": "final_vital", "type": "ShellResult" },
            "params": { "cmd": "pnpm vital" }
          },
          { "role": "sink", "op": "system:log", "params": { "message": "🚀 System successfully upgraded to the latest version." } }
        ],
        "else": [
          { "role": "sink", "op": "system:log", "params": { "message": "❌ Validation failed! Human intervention required for rollback." } }
        ]
      }
    }
  ]
}
