{
  "action": "pipeline",
  "pipeline_id": "voice-hello",
  "name": "Voice Hello (First-Win)",
  "version": "1.0.0",
  "description": "Minimal voice first-win pipeline: check TTS, wait for user input, speak a greeting.",
  "steps": [
    {
      "id": "check_tts",
      "role": "source",
      "op": "system:check_native_tts",
      "produces": { "channel": "tts_ready", "type": "ProbeResult" },
      "params": {}
    },
    {
      "id": "wait_for_user",
      "role": "source",
      "op": "system:wait_for",
      "consumes": "tts_ready",
      "produces": { "channel": "user_input", "type": "EventResult" },
      "params": {
        "event": "voice-hello.user-spoke",
        "endpoint": "http://127.0.0.1:3031/voice-hello",
        "timeout_ms": 30000
      }
    },
    {
      "id": "speak",
      "role": "sink",
      "op": "system:native_tts_speak",
      "consumes": "user_input",
      "params": {
        "text": "こんにちは。Kyberion が聴いています。",
        "language": "ja"
      }
    }
  ]
}
