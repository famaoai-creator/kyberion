{
  "action": "pipeline",
  "name": "dependency-vuln-scan",
  "version": "1.0.0",
  "description": "Daily dependency vulnerability scan and ledger append for AO-02.",
  "_refs": {
    "plan": "docs/developer/improvement-plans-2026-07/AO-02_DEPENDENCY_VULN_PATCH.ja.md",
    "implementation": "scripts/scan_dependency_vulns.ts"
  },
  "schedule": {
    "id": "dependency-vuln-scan-daily",
    "cron": "0 5 * * *",
    "timezone": "Asia/Tokyo",
    "enabled": true
  },
  "steps": [
    {
      "id": "scan_dependency_vulns",
      "role": "source",
      "op": "system:exec",
      "produces": {
        "channel": "dependency_vuln_scan_result",
        "type": "CommandResult"
      },
      "params": {
        "command": "node",
        "args": ["--import", "./scripts/ts-loader.mjs", "scripts/scan_dependency_vulns.ts"],
        "timeout_ms": 120000
      }
    }
  ]
}
