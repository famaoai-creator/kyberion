{
  "action": "pipeline",
  "name": "System Tool Diagnostics",
  "description": "Checks for external binary dependencies using system:cli_health_check.",
  "steps": [
    { "op": "system:log", "params": { "message": "🔍 Diagnosing External Tool Dependencies..." } },
    { "op": "system:cli_health_check", "params": { "command": "node", "export_as": "h_node" } },
    { "op": "system:cli_health_check", "params": { "command": "npm", "export_as": "h_npm" } },
    { "op": "system:cli_health_check", "params": { "command": "git", "export_as": "h_git" } },
    { "op": "system:cli_health_check", "params": { "command": "gh", "export_as": "h_gh" } },
    { "op": "system:cli_health_check", "params": { "command": "python3", "export_as": "h_python" } },
    
    { "op": "system:log", "params": { "message": "✅ [FOUND] node: {{h_node.stdout}}" } },
    { "op": "system:log", "params": { "message": "✅ [FOUND] npm:  {{h_npm.stdout}}" } },
    { "op": "system:log", "params": { "message": "✅ [FOUND] git:  {{h_git.stdout}}" } },
    { "op": "system:log", "params": { "message": "✅ [FOUND] gh:   {{h_gh.stdout}}" } },
    { "op": "system:log", "params": { "message": "✅ [FOUND] python: {{h_python.stdout}}" } }
  ]
}
