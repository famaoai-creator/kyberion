{
  "action": "pipeline",
  "name": "System Tool Diagnostics",
  "description": "Checks for external binary dependencies required by various skills.",
  "steps": [
    { "op": "system:log", "params": { "message": "🔍 Diagnosing External Tool Dependencies..." } },
    { "op": "system:shell", "params": { "cmd": "node --version 2>/dev/null || echo 'MISSING: node'", "export_as": "v_node" } },
    { "op": "system:shell", "params": { "cmd": "npm --version 2>/dev/null || echo 'MISSING: npm'", "export_as": "v_npm" } },
    { "op": "system:shell", "params": { "cmd": "git --version 2>/dev/null || echo 'MISSING: git'", "export_as": "v_git" } },
    { "op": "system:shell", "params": { "cmd": "gh --version 2>/dev/null || echo 'MISSING: gh'", "export_as": "v_gh" } },
    { "op": "system:shell", "params": { "cmd": "python3 --version 2>/dev/null || echo 'MISSING: python3'", "export_as": "v_python" } },
    { "op": "system:shell", "params": { "cmd": "git rev-parse --is-inside-work-tree > /dev/null 2>&1 && echo 'OK' || echo 'FAIL'", "export_as": "status_git" } },
    { "op": "system:shell", "params": { "cmd": "echo 'SKIPPED (network probe optional in sandbox)'", "export_as": "status_network" } },
    { "op": "system:log", "params": { "message": "✅ [FOUND] node: {{v_node}}" } },
    { "op": "system:log", "params": { "message": "✅ [FOUND] npm: {{v_npm}}" } },
    { "op": "system:log", "params": { "message": "✅ [FOUND] git: {{v_git}}" } },
    { "op": "system:log", "params": { "message": "✅ [FOUND] gh: {{v_gh}}" } },
    { "op": "system:log", "params": { "message": "✅ [FOUND] python3: {{v_python}}" } },
    { "op": "system:log", "params": { "message": "✅ Git Repository: {{status_git}}" } },
    { "op": "system:log", "params": { "message": "✅ Network Connectivity: {{status_network}}" } }
  ]
}
