{
  "action": "pipeline",
  "name": "Contract Review",
  "version": "1.0.0",
  "description": "Multi-perspective contract review: digest extraction, multi-agent critique, dissent logging, and written output.",
  "steps": [
    {
      "role": "sink",
      "op": "system:log",
      "params": { "message": "📄 Contract Review Pipeline — starting..." }
    },
    {
      "role": "source",
      "op": "media:document_digest",
      "produces": { "channel": "contract_digest", "type": "DocumentDigest" },
      "params": { "path": "{{input.contract_path}}", "export_as": "contract_digest" }
    },
    {
      "role": "transform",
      "op": "wisdom:a2a_fanout",
      "consumes": "contract_digest",
      "produces": { "channel": "review_perspectives", "type": "FanoutResult" },
      "params": {
        "personas": ["legal_strategist", "finance_controller", "cyber_security"],
        "topic": "Review this contract from multiple professional perspectives: {{contract_digest}}",
        "output_path": "active/shared/tmp/reports/contract-review-fanout.json"
      }
    },
    {
      "role": "transform",
      "op": "wisdom:cross_critique",
      "consumes": "review_perspectives",
      "produces": { "channel": "critique_result", "type": "CrossCritiqueResult" },
      "params": {
        "source_path": "active/shared/tmp/reports/contract-review-fanout.json",
        "personas": ["legal_strategist", "finance_controller", "cyber_security"],
        "output_path": "active/shared/tmp/reports/contract-review-critique.json"
      }
    },
    {
      "role": "sink",
      "op": "wisdom:emit_dissent_log",
      "consumes": "critique_result",
      "params": {
        "source_path": "active/shared/tmp/reports/contract-review-critique.json",
        "output_path": "active/audit/contract-review-dissent.jsonl"
      }
    },
    {
      "role": "sink",
      "op": "wisdom:render_hypothesis_report",
      "consumes": "critique_result",
      "params": {
        "source_path": "active/shared/tmp/reports/contract-review-critique.json",
        "output_path": "active/shared/tmp/reports/contract-review.md",
        "title": "Contract Review"
      }
    }
  ]
}
