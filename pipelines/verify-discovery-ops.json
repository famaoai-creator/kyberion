{
  "action": "pipeline",
  "name": "Ecosystem Discovery Verification",
  "version": "2.0.0",
  "_migration_note": "v2: Typed Flow format (role/produces/consumes). v1 used export_as without roles.",
  "steps": [
    { "role": "sink", "op": "system:log", "params": { "message": "🔍 Verifying Global Discovery Operations..." } },

    { "role": "source", "op": "agent:list-manifests", "produces": { "channel": "agents", "type": "AgentList" }, "params": {} },
    { "role": "sink", "op": "system:log", "consumes": "agents", "params": { "message": "✅ Agents: {{agents.count}} manifests found." } },

    { "role": "source", "op": "agent:list-runtimes", "produces": { "channel": "runtimes", "type": "RuntimeList" }, "params": {} },
    { "role": "sink", "op": "system:log", "consumes": "runtimes", "params": { "message": "✅ Runtimes: {{runtimes.count}} active instances." } },

    { "role": "source", "op": "project:list", "produces": { "channel": "projects", "type": "ProjectList" }, "params": {} },
    { "role": "sink", "op": "system:log", "consumes": "projects", "params": { "message": "✅ Projects: {{projects.count}} project records found." } },

    { "role": "source", "op": "capability:list", "produces": { "channel": "caps", "type": "CapabilityList" }, "params": {} },
    { "role": "sink", "op": "system:log", "consumes": "caps", "params": { "message": "✅ Capabilities: {{caps.count}} actuators installed." } },

    { "role": "source", "op": "knowledge:list", "produces": { "channel": "know", "type": "KnowledgeList" }, "params": {} },
    { "role": "sink", "op": "system:log", "consumes": "know", "params": { "message": "✅ Knowledge: {{know.count}} incidents recorded." } },

    { "role": "sink", "op": "system:log", "params": { "message": "\n🚀 Discovery Verification Complete." } }
  ]
}
