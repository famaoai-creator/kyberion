{
  "action": "pipeline",
  "name": "Marketing Content Generation",
  "version": "1.0.0",
  "description": "Generates brand-aligned marketing materials: diagrams, themed PPTX slides, and merged content output.",
  "steps": [
    {
      "role": "sink",
      "op": "system:log",
      "params": { "message": "📣 Marketing Content Pipeline — starting..." }
    },
    {
      "role": "transform",
      "op": "media:document_diagram_asset_from_brief",
      "produces": { "channel": "diagram_asset", "type": "DiagramAsset" },
      "params": {
        "brief": "{{input.brief}}",
        "diagram_type": "flow"
      }
    },
    {
      "role": "transform",
      "op": "media:apply_theme",
      "consumes": "diagram_asset",
      "produces": { "channel": "themed_asset", "type": "ThemedAsset" },
      "params": { "theme": "{{input.theme | default: 'auto'}}" }
    },
    {
      "role": "transform",
      "op": "media:apply_pattern",
      "consumes": "themed_asset",
      "produces": { "channel": "patterned_asset", "type": "PatternedAsset" },
      "params": { "pattern": "{{input.pattern | default: 'corporate-grid'}}" }
    },
    {
      "role": "transform",
      "op": "media:merge_content",
      "consumes": "patterned_asset",
      "produces": { "channel": "merged_deck", "type": "MergedDeck" },
      "params": { "slides": "{{input.slides}}" }
    },
    {
      "role": "sink",
      "op": "media:pptx_render",
      "consumes": "merged_deck",
      "params": {
        "output_path": "{{input.output_path | default: 'active/shared/tmp/marketing-output.pptx'}}"
      }
    }
  ]
}
