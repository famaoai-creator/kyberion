{
  "action": "pipeline",
  "name": "Trial Narrated Report",
  "version": "1.0.0",
  "description": "End-to-end narrated executive report: voice narration + video composition with strict ADF preflight.",
  "steps": [
    {
      "id": "check_voice_actuator_build",
      "role": "source",
      "op": "system:probe",
      "produces": { "channel": "voice_build", "type": "ProbeResult" },
      "params": { "dir": "dist/libs/actuators/voice-actuator/src", "kind": "dir" }
    },
    {
      "id": "check_video_actuator_build",
      "role": "source",
      "op": "system:probe",
      "produces": { "channel": "video_build", "type": "ProbeResult" },
      "params": { "dir": "dist/libs/actuators/video-composition-actuator/src", "kind": "dir" }
    },
    {
      "id": "preflight_tools",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "tool_check", "type": "ShellResult" },
      "params": {
        "cmd": "which say && which espeak || true && which ffmpeg && which ffprobe",
        "preflight_artifacts": ["say", "espeak", "ffmpeg", "ffprobe"]
      }
    },
    {
      "id": "write_voice_action",
      "role": "source",
      "op": "system:write_file",
      "produces": { "channel": "voice_action_path", "type": "PathResult" },
      "params": {
        "path": "active/shared/tmp/voice-action.json",
        "content": "{\"action\":\"generate_voice\",\"engine\":{\"engine_id\":\"local_say\"},\"delivery\":{\"mode\":\"artifact\",\"format\":\"aiff\"},\"rendering\":{\"language\":\"ja\",\"speed\":1.0},\"text\":\"{{input.narration_text}}\"}"
      }
    },
    {
      "id": "write_video_render_policy",
      "role": "source",
      "op": "system:write_file",
      "produces": { "channel": "video_render_policy_json", "type": "PathResult" },
      "params": {
        "path": "active/shared/tmp/video-composition/render-policy.json",
        "content": "{\"enable_backend_rendering\":true,\"backend\":\"hyperframes_cli\",\"output_format\":\"mp4\",\"resolution\":\"1920x1080\"}"
      }
    },
    {
      "id": "generate_audio",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "audio_gen_result", "type": "ShellResult" },
      "params": {
        "cmd": "node dist/libs/actuators/voice-actuator/src/index.js --input {{voice_action_path}} --output {{audio_path}}",
        "audio_path": "active/shared/tmp/narration.aiff"
      }
    },
    {
      "id": "validate_audio_output",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "audio_check", "type": "ShellResult" },
      "params": {
        "cmd": "test -f {{audio_path}} && ffprobe -v error -select_streams a:0 -show_entries stream=codec_type -of csv=p=0 {{audio_path}}"
      }
    },
    {
      "id": "generate_video",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "video_gen_result", "type": "ShellResult" },
      "params": {
        "cmd": "KYBERION_VIDEO_RENDER_RUNTIME_POLICY_PATH={{video_render_policy_json}} node dist/libs/actuators/video-composition-actuator/src/index.js --audio {{audio_path}} --output {{video_output_path}}",
        "video_output_path": "active/shared/tmp/narrated-report.mp4"
      }
    },
    {
      "id": "validate_video_output",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "video_check", "type": "ShellResult" },
      "params": {
        "cmd": "test -f {{video_output_path}} && test -f active/shared/tmp/video-composition/executive-summary/index.html && test -f active/shared/tmp/video-composition/executive-summary/render-plan.json"
      }
    },
    {
      "id": "final_log",
      "role": "sink",
      "op": "system:log",
      "consumes": ["audio_gen_result", "video_gen_result", "video_check"],
      "params": {
        "message": "✅ Trial Narrated Report complete. Audio: {{audio_gen_result}} Video: {{video_gen_result}}"
      }
    }
  ]
}
