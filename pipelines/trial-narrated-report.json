{
  "action": "pipeline",
  "name": "Trial Narrated Executive Report",
  "description": "Enterprise-grade narrated report pipeline using pre-built JS actuators, runtime preflight checks, and final audio-muxed MP4 rendering.",
  "context": {
    "mission_id": "trial-voice-video-1",
    "report_summary": "Kyberion Ecosystem Vitals are all green. Development productivity has increased by 15 percent this month.",
    "audio_path": "active/shared/tmp/trial-narration.aiff",
    "video_output_path": "active/shared/tmp/executive-summary.mp4",
    "voice_action_json": "active/shared/tmp/voice-action.json",
    "video_action_json": "active/shared/tmp/video-action.json",
    "video_render_policy_json": "active/shared/tmp/video-render-runtime-policy.full-render.json",
    "profile_id": "operator-ja-default"
  },
  "steps": [
    {
      "id": "check_voice_actuator_build",
      "type": "capture",
      "op": "system:glob_files",
      "params": {
        "dir": "dist/libs/actuators/voice-actuator/src",
        "ext": ".js",
        "export_as": "voice_actuator_build_files"
      }
    },
    {
      "id": "check_video_actuator_build",
      "type": "capture",
      "op": "system:glob_files",
      "params": {
        "dir": "dist/libs/actuators/video-composition-actuator/src",
        "ext": ".js",
        "export_as": "video_actuator_build_files"
      }
    },
    {
      "id": "preflight_artifacts",
      "type": "control",
      "op": "core:if",
      "params": {
        "condition": {
          "from": "voice_actuator_build_files",
          "operator": "not_empty"
        },
        "then": [
          {
            "id": "preflight_video_artifacts",
            "type": "control",
            "op": "core:if",
            "params": {
              "condition": {
                "from": "video_actuator_build_files",
                "operator": "not_empty"
              },
              "then": [
                {
                  "id": "preflight_runtime_tools",
                  "op": "system:shell",
                  "params": {
                    "cmd": "if [ \"$(uname -s)\" = \"Darwin\" ]; then command -v say >/dev/null; else command -v espeak >/dev/null; fi && command -v ffmpeg >/dev/null && command -v ffprobe >/dev/null && echo ok",
                    "export_as": "preflight_result"
                  }
                }
              ],
              "else": [
                {
                  "id": "missing_video_build",
                  "op": "system:log",
                  "params": {
                    "message": "missing build artifact(s) for video-composition-actuator"
                  }
                },
                {
                  "id": "fail_missing_video_build",
                  "op": "system:shell",
                  "params": {
                    "cmd": "exit 1"
                  }
                }
              ]
            }
          }
        ],
        "else": [
          {
            "id": "missing_voice_build",
            "op": "system:log",
            "params": {
              "message": "missing build artifact(s) for voice-actuator"
            }
          },
          {
            "id": "fail_missing_voice_build",
            "op": "system:shell",
            "params": {
              "cmd": "exit 1"
            }
          }
        ]
      }
    },
    {
      "id": "write_voice_action",
      "op": "code:write_artifact",
      "params": {
        "path": "{{voice_action_json}}",
        "content": "{\"action\":\"generate_voice\",\"request_id\":\"trial-narrated-report-audio\",\"text\":\"{{report_summary}}\",\"profile_ref\":{\"profile_id\":\"{{profile_id}}\"},\"engine\":{\"engine_id\":\"local_say\"},\"rendering\":{\"language\":\"ja\",\"chunking\":{\"max_chunk_chars\":4000,\"crossfade_ms\":50,\"preserve_paralinguistic_tags\":true}},\"delivery\":{\"mode\":\"artifact\",\"format\":\"aiff\",\"artifact_path\":\"{{audio_path}}\",\"emit_progress_packets\":true},\"routing\":{\"personal_voice_mode\":\"allow_fallback\"}}"
      }
    },
    {
      "id": "write_video_action",
      "op": "code:write_artifact",
      "params": {
        "path": "{{video_action_json}}",
        "content": "{\"action\":\"create_narrated_intro_movie\",\"params\":{\"narrated_video_brief\":{\"kind\":\"narrated-video-brief\",\"version\":\"1.0.0\",\"intent\":\"executive-summary\",\"title\":\"Kyberion Monthly Strategic Update\",\"script\":{\"hook\":\"Greetings.\",\"feature\":\"{{report_summary}}\",\"cta\":\"Details in full report.\"},\"narration\":{\"artifact_ref\":\"{{audio_path}}\"},\"design_system\":{\"brand_name\":\"Kyberion Sovereign\",\"theme_tokens\":{\"background_color\":\"#000000\"}},\"output\":{\"format\":\"mp4\",\"target_path\":\"{{video_output_path}}\",\"await_completion\":true}}}}"
      }
    },
    {
      "id": "write_video_render_policy",
      "op": "code:write_artifact",
      "params": {
        "path": "{{video_render_policy_json}}",
        "content": "{\"version\":\"1.0.0\",\"queue\":{\"concurrency\":1,\"cancellation\":\"queued_or_running\"},\"progress\":{\"throttle_ms\":250,\"min_percent_delta\":2,\"emit_heartbeat\":true},\"bundle\":{\"default_bundle_root\":\"active/shared/tmp/video-composition\",\"copy_declared_assets\":false},\"render\":{\"allowed_output_formats\":[\"mp4\",\"mov\",\"webm\"],\"enable_backend_rendering\":true,\"backend\":\"hyperframes_cli\",\"quality\":\"standard\",\"command_timeout_ms\":300000}}"
      }
    },
    {
      "id": "generate_audio",
      "op": "system:shell",
      "params": {
        "cmd": "node dist/libs/actuators/voice-actuator/src/index.js --input {{voice_action_json}}",
        "export_as": "audio_gen_result"
      }
    },
    {
      "id": "generate_video",
      "op": "system:shell",
      "params": {
        "cmd": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--require=$(pwd)/scripts/hyperframes-localhost-preload.cjs\" KYBERION_VIDEO_RENDER_RUNTIME_POLICY_PATH={{video_render_policy_json}} node dist/libs/actuators/video-composition-actuator/src/index.js --input {{video_action_json}}",
        "export_as": "video_gen_result"
      }
    },
    {
      "id": "validate_video_output",
      "type": "control",
      "op": "core:if",
      "params": {
        "condition": {
          "from": "video_output_path",
          "operator": "exists"
        },
        "then": [
          {
            "id": "validate_outputs",
            "op": "system:shell",
            "params": {
              "cmd": "test -f {{audio_path}} || { echo 'missing audio artifact: {{audio_path}}'; exit 1; } && test -f {{video_output_path}} || { echo 'missing rendered video artifact: {{video_output_path}}'; exit 1; } && test -f active/shared/tmp/video-composition/executive-summary/index.html || { echo 'missing video bundle index'; exit 1; } && test -f active/shared/tmp/video-composition/executive-summary/render-plan.json || { echo 'missing video bundle render plan'; exit 1; } && test -n \"$(ffprobe -v error -select_streams a:0 -show_entries stream=index -of csv=p=0 {{video_output_path}})\" || { echo 'missing audio stream in rendered video'; exit 1; } && echo 'outputs verified with audio-muxed mp4'",
              "export_as": "verify_result"
            }
          }
        ],
        "else": [
          {
            "id": "validate_bundle_only",
            "op": "system:shell",
            "params": {
              "cmd": "test -f {{audio_path}} || { echo 'missing audio artifact: {{audio_path}}'; exit 1; } && test -f active/shared/tmp/video-composition/executive-summary/index.html || { echo 'missing video bundle index'; exit 1; } && test -f active/shared/tmp/video-composition/executive-summary/render-plan.json || { echo 'missing video bundle render plan'; exit 1; } && echo 'outputs verified with bundle-only fallback'",
              "export_as": "verify_result"
            }
          }
        ]
      }
    },
    {
      "id": "final_log",
      "op": "system:log",
      "params": {
        "message": "✅ Narrated report generation attempted. Preflight: {{preflight_result}} Audio: {{audio_gen_result}} Video: {{video_gen_result}} Verify: {{verify_result}}"
      }
    }
  ]
}
