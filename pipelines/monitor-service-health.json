{
  "pipeline_id": "monitor-service-health",
  "version": "3.0.0",
  "description": "Dynamically verify the response health of all active ecosystem services.",
  "_migration_note": "v3: Typed Flow format (role/produces/consumes). v2 used type + export_as.",
  "action": "pipeline",
  "steps": [
    {
      "id": "get-surfaces",
      "role": "source",
      "op": "process:list-surfaces",
      "produces": { "channel": "ecosystem_surfaces", "type": "SurfaceList" },
      "params": {}
    },
    {
      "id": "log-summary",
      "role": "sink",
      "op": "system:log",
      "consumes": "ecosystem_surfaces",
      "params": {
        "message": "📡 [MONITOR] Auditing {{ecosystem_surfaces.length}} registered surfaces..."
      }
    },
    {
      "id": "audit-loop",
      "role": "gate",
      "op": "core:foreach",
      "consumes": "ecosystem_surfaces",
      "params": {
        "items": "{{ecosystem_surfaces}}",
        "as": "surface",
        "do": [
          {
            "role": "gate",
            "op": "core:if",
            "params": {
              "condition": "surface.running",
              "then": [
                {
                  "role": "sink",
                  "op": "system:log",
                  "params": {
                    "message": "  - [OK] {{surface.id}} ({{surface.kind}}) is running on port {{surface.port}}"
                  }
                }
              ],
              "else": [
                {
                  "role": "gate",
                  "op": "core:if",
                  "params": {
                    "condition": "surface.enabled",
                    "then": [
                      {
                        "role": "sink",
                        "op": "system:log",
                        "params": {
                          "message": "  - [ALERT] {{surface.id}} is ENABLED but NOT RUNNING!"
                        }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "check-recent-errors",
      "role": "source",
      "op": "system:shell",
      "produces": { "channel": "recent_service_errors", "type": "LogText" },
      "params": {
        "cmd": "grep -r 'ERROR' active/shared/logs/surfaces 2>/dev/null | tail -n 15 || echo 'No recent surface errors'"
      }
    },
    {
      "id": "analyze-reliability",
      "role": "transform",
      "op": "reasoning:analyze",
      "consumes": ["ecosystem_surfaces", "recent_service_errors"],
      "produces": { "channel": "reliability_report", "type": "ReliabilityReport" },
      "params": {
        "instruction": "Based on the dynamically discovered surface status list and recent log errors, evaluate the overall reliability of the ecosystem. Identify 'zombie' services (enabled but not running) or 'flapping' services with frequent errors. Propose specific recovery actions for the operator.",
        "context": ["{{ecosystem_surfaces}}", "{{recent_service_errors}}"]
      }
    },
    {
      "id": "log-reliability-report",
      "role": "sink",
      "op": "system:log",
      "consumes": "reliability_report",
      "params": {
        "message": "📊 [RELIABILITY_REPORT]\n{{reliability_report}}"
      }
    }
  ]
}
