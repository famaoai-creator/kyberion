{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "useUnknownInCatchVariables": true,
    "noEmit": true,
    "paths": {
      "@agent/core": ["../../libs/core/dist/index.d.ts"],
      "@agent/core/*": ["../../libs/core/dist/*"]
    }
  },
  "include": [
    "mission-types.ts",
    "mission-dispatch-io.ts",
